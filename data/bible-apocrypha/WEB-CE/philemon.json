      "1": "Paul|strong=\"G3972\", a|strong=\"G2532\"prisoner|strong=\"G1198\"of|strong=\"G2532\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", and|strong=\"G2532\"Timothy|strong=\"G5095\"our|strong=\"G2424\"brother, to|strong=\"G2532\"Philemon|strong=\"G5371\", our|strong=\"G2424\"beloved fellow|strong=\"G4904\"worker|strong=\"G4904\",",
