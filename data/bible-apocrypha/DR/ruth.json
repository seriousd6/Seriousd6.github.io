      "1": "In|strong=\"H0776\"the|strong=\"H3117\"days|strong=\"H3117\"of|strong=\"H1121\"one|strong=\"H0376\"of|strong=\"H1121\"the|strong=\"H3117\"judges|strong=\"H8199\", when|strong=\"H1961\"the|strong=\"H3117\"judges|strong=\"H8199\"ruled|strong=\"H8199\", there|strong=\"H1961\"came|strong=\"H1961\"a|strong=\"H1961\"famine|strong=\"H7458\"in|strong=\"H0776\"the|strong=\"H3117\"land|strong=\"H0776\". And|strong=\"H1121\"a|strong=\"H1961\"certain|strong=\"H0376\"man|strong=\"H0376\"of|strong=\"H1121\"Bethlehem|strong=\"H1035\"Juda, went|strong=\"H0376\"to|strong=\"H1961\"sojourn in|strong=\"H0776\"the|strong=\"H3117\"land|strong=\"H0776\"of|strong=\"H1121\"Moab|strong=\"H4124\"with|strong=\"H0376\"his|strong=\"H1961\"wife|strong=\"H0802\"and|strong=\"H1121\"his|strong=\"H1961\"two|strong=\"H8147\"sons|strong=\"H1121\".",
      "2": "He|strong=\"H8033\"was|strong=\"H8034\"named|strong=\"H8034\"Elimelech|strong=\"H0458\", and|strong=\"H1121\"his|strong=\"H1961\"wife|strong=\"H0802\", Noemi: and|strong=\"H1121\"his|strong=\"H1961\"two|strong=\"H8147\"sons|strong=\"H1121\", the|strong=\"H0935\"one|strong=\"H0376\"Mahalon, and|strong=\"H1121\"the|strong=\"H0935\"other|strong=\"H8147\"Chelion, Ephrathites|strong=\"H0673\"of|strong=\"H1121\"Bethlehem|strong=\"H1035\"Juda. And|strong=\"H1121\"entering|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H0935\"country|strong=\"H7704\"of|strong=\"H1121\"Moab|strong=\"H4124\", they|strong=\"H8033\"abode there|strong=\"H8033\".",
      "3": "And|strong=\"H1121\"Elimelech|strong=\"H0458\"the|strong=\"H4191\"husband|strong=\"H0376\"of|strong=\"H1121\"Noemi died|strong=\"H4191\": and|strong=\"H1121\"she|strong=\"H1931\"remained|strong=\"H7604\"with|strong=\"H0376\"her|strong=\"H5281\"sons|strong=\"H1121\".",
      "4": "And|strong=\"H0802\"they|strong=\"H8033\"took|strong=\"H5375\"wives|strong=\"H0802\"of|strong=\"H8141\"the|strong=\"H5375\"women|strong=\"H0802\"of|strong=\"H8141\"Moab|strong=\"H4125\", of|strong=\"H8141\"which|strong=\"H8033\"one|strong=\"H0259\"was|strong=\"H8034\"called|strong=\"H8034\"Orpha, and|strong=\"H0802\"the|strong=\"H5375\"other|strong=\"H0259\"Ruth|strong=\"H7327\". And|strong=\"H0802\"they|strong=\"H8033\"dwelt|strong=\"H3427\"there|strong=\"H8033\"ten|strong=\"H6235\"years|strong=\"H8141\".",
      "5": "And|strong=\"H0376\"they|strong=\"H0376\"both|strong=\"H8147\"died|strong=\"H4191\", to|strong=\"H4191\"wit, Mahalon and|strong=\"H0376\"Chelion: and|strong=\"H0376\"the|strong=\"H1571\"woman|strong=\"H0802\"was|strong=\"H0376\"left|strong=\"H7604\"alone, having lost both|strong=\"H8147\"her|strong=\"H0802\"sons|strong=\"H3206\"and|strong=\"H0376\"her|strong=\"H0802\"husband|strong=\"H0376\".",
      "6": "And|strong=\"H6965\"she|strong=\"H1931\"arose|strong=\"H6965\"to|strong=\"H7725\"go|strong=\"H7725\"from|strong=\"H7725\"the|strong=\"H0853\"land|strong=\"H7704\"of|strong=\"H3068\"Moab|strong=\"H4124\"to|strong=\"H7725\"her|strong=\"H5414\"own country|strong=\"H7704\"with|strong=\"H3068\"both her|strong=\"H5414\"daughters in|strong=\"H3068\"law: for|strong=\"H3588\"she|strong=\"H1931\"had|strong=\"H3068\"heard|strong=\"H8085\"that|strong=\"H3588\"the|strong=\"H0853\"Lord|strong=\"H3068\"had|strong=\"H3068\"looked upon his|strong=\"H5414\"people|strong=\"H5971\", and|strong=\"H6965\"had|strong=\"H3068\"given|strong=\"H5414\"them|strong=\"H5414\"food|strong=\"H3899\".",
      "7": "Wherefore she|strong=\"H0834\"went|strong=\"H3318\"forth|strong=\"H3318\"out|strong=\"H3318\"of|strong=\"H0776\"the|strong=\"H0834\"place|strong=\"H4725\"of|strong=\"H0776\"her|strong=\"H0413\"sojournment, with|strong=\"H5973\"both|strong=\"H8147\"her|strong=\"H0413\"daughters in|strong=\"H0413\"law: and|strong=\"H3063\"being|strong=\"H1961\"now|strong=\"H1961\"in|strong=\"H0413\"the|strong=\"H0834\"way|strong=\"H1870\"to|strong=\"H0413\"return|strong=\"H7725\"into|strong=\"H0413\"the|strong=\"H0834\"land|strong=\"H0776\"of|strong=\"H0776\"Juda,",
      "8": "She|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0559\"them|strong=\"H7725\": Go|strong=\"H7725\"ye home|strong=\"H1004\"to|strong=\"H0559\"your|strong=\"H3068\"mothers|strong=\"H0517\": the|strong=\"H0559\"Lord|strong=\"H3068\"deal|strong=\"H6213\"mercifully with|strong=\"H5973\"you|strong=\"H0834\", as|strong=\"H0834\"you|strong=\"H0834\"have|strong=\"H0834\"dealt with|strong=\"H5973\"the|strong=\"H0559\"dead|strong=\"H4191\"and|strong=\"H3068\"with|strong=\"H5973\"me|strong=\"H7725\".",
      "9": "May|strong=\"H0376\"he|strong=\"H3068\"grant|strong=\"H5414\"you|strong=\"H5414\"to|strong=\"H3068\"find|strong=\"H4672\"rest|strong=\"H4496\"in|strong=\"H3068\"the|strong=\"H5414\"houses|strong=\"H1004\"of|strong=\"H1004\"the|strong=\"H5414\"husbands|strong=\"H0376\"which|strong=\"H0802\"you|strong=\"H5414\"shall|strong=\"H3068\"take|strong=\"H5375\". And|strong=\"H3068\"she kissed|strong=\"H5401\"them|strong=\"H5414\". And|strong=\"H3068\"they|strong=\"H0376\"lifted|strong=\"H5375\"up|strong=\"H5375\"their|strong=\"H3068\"voice|strong=\"H6963\"and|strong=\"H3068\"began to|strong=\"H3068\"weep|strong=\"H1058\",",
      "10": "And|strong=\"H7725\"to|strong=\"H0559\"say|strong=\"H0559\": We|strong=\"H3588\"will|strong=\"H7725\"go|strong=\"H7725\"on|strong=\"H7725\"with|strong=\"H0854\"thee to|strong=\"H0559\"thy people|strong=\"H5971\".",
      "11": "But|strong=\"H1961\"she|strong=\"H5973\"answered|strong=\"H0559\"them|strong=\"H7725\": Return|strong=\"H7725\", my|strong=\"H1961\"daughters|strong=\"H1323\": why|strong=\"H4100\"come|strong=\"H1961\"ye with|strong=\"H5973\"me|strong=\"H7725\"? have|strong=\"H1961\"I|strong=\"H0559\"any|strong=\"H0376\"more|strong=\"H5750\"sons|strong=\"H1121\"in|strong=\"H0376\"my|strong=\"H1961\"womb|strong=\"H4578\", that|strong=\"H0559\"you|strong=\"H7725\"may|strong=\"H1961\"hope for|strong=\"H0376\"husbands|strong=\"H0376\"of|strong=\"H1121\"me|strong=\"H7725\"?",
      "12": "Return|strong=\"H7725\"again|strong=\"H7725\", my|strong=\"H1961\"daughters|strong=\"H1323\", and|strong=\"H1121\"go|strong=\"H7725\"your|strong=\"H7725\"ways: for|strong=\"H3588\"I|strong=\"H3588\"am|strong=\"H1961\"now|strong=\"H1961\"spent|strong=\"H7725\"with|strong=\"H0376\"age|strong=\"H1121\", and|strong=\"H1121\"not|strong=\"H1961\"fit for|strong=\"H3588\"wedlock. Although|strong=\"H3588\"I|strong=\"H3588\"might|strong=\"H1323\"conceive this|strong=\"H3588\"night|strong=\"H3915\", and|strong=\"H1121\"bear|strong=\"H3205\"children|strong=\"H1121\",",
      "13": "If|strong=\"H3588\"you|strong=\"H0834\"would|strong=\"H3068\"wait till|strong=\"H5704\"they|strong=\"H0834\"were|strong=\"H0834\"grown|strong=\"H1431\"up|strong=\"H5704\", and|strong=\"H3068\"come|strong=\"H1961\"to|strong=\"H5704\"man’s|strong=\"H0376\"estate, you|strong=\"H0834\"would|strong=\"H3068\"be|strong=\"H1961\"old|strong=\"H1323\"women|strong=\"H1323\"before|strong=\"H5704\"you|strong=\"H0834\"marry. Do|strong=\"H0408\"not|strong=\"H0408\"so|strong=\"H4480\", my|strong=\"H3068\"daughters|strong=\"H1323\", I|strong=\"H0834\"beseech you|strong=\"H0834\": for|strong=\"H3588\"I|strong=\"H0834\"am|strong=\"H1961\"grieved the|strong=\"H0834\"more|strong=\"H4480\"for|strong=\"H3588\"your|strong=\"H3068\"distress|strong=\"H3027\", and|strong=\"H3068\"the|strong=\"H0834\"hand|strong=\"H3027\"of|strong=\"H0376\"the|strong=\"H0834\"Lord|strong=\"H3068\"is|strong=\"H0834\"gone|strong=\"H3318\"out|strong=\"H3318\"against|strong=\"H4480\"me|strong=\"H4480\".",
      "14": "And|strong=\"H6963\"they|strong=\"H5375\"lifted|strong=\"H5375\"up|strong=\"H5375\"their|strong=\"H5375\"voice|strong=\"H6963\", and|strong=\"H6963\"began to|strong=\"H5750\"weep|strong=\"H1058\"again|strong=\"H5750\": Orpha kissed|strong=\"H5401\"her|strong=\"H5375\"mother in|strong=\"H6963\"law and|strong=\"H6963\"returned: Ruth|strong=\"H7327\"stuck|strong=\"H1692\"close|strong=\"H1692\"to|strong=\"H5750\"her|strong=\"H5375\"mother in|strong=\"H6963\"law.",
      "15": "And|strong=\"H0430\"Noemi said|strong=\"H0559\"to|strong=\"H0413\"her|strong=\"H0413\": Behold|strong=\"H2009\"thy kinswoman is|strong=\"H0430\"returned|strong=\"H7725\"to|strong=\"H0413\"her|strong=\"H0413\"people|strong=\"H5971\", and|strong=\"H0430\"to|strong=\"H0413\"her|strong=\"H0413\"gods|strong=\"H0430\", go|strong=\"H7725\"thou with|strong=\"H0413\"her|strong=\"H0413\".",
      "16": "She|strong=\"H0834\"answered|strong=\"H0559\": Be|strong=\"H0408\"not|strong=\"H0408\"against|strong=\"H0413\"me|strong=\"H0413\", to|strong=\"H0413\"desire that|strong=\"H0834\"I|strong=\"H0834\"should|strong=\"H3588\"leave|strong=\"H5800\"thee and|strong=\"H0430\"depart: for|strong=\"H3588\"whithersoever thou shalt go|strong=\"H7725\", I|strong=\"H0834\"will|strong=\"H0430\"go|strong=\"H7725\": and|strong=\"H0430\"where|strong=\"H0834\"thou shalt dwell, I|strong=\"H0834\"also|strong=\"H0430\"will|strong=\"H0430\"dwell. Thy people|strong=\"H5971\"shall|strong=\"H0834\"be|strong=\"H0408\"my|strong=\"H7725\"people|strong=\"H5971\", and|strong=\"H0430\"thy God|strong=\"H0430\"my|strong=\"H7725\"God|strong=\"H0430\".",
      "17": "The|strong=\"H0834\"land that|strong=\"H0834\"shall|strong=\"H3068\"receive thee dying|strong=\"H4191\", in|strong=\"H3068\"the|strong=\"H0834\"same|strong=\"H3541\"will|strong=\"H3068\"I|strong=\"H0834\"die|strong=\"H4191\": and|strong=\"H3068\"there|strong=\"H8033\"will|strong=\"H3068\"I|strong=\"H0834\"be|strong=\"H4191\"buried|strong=\"H6912\". The|strong=\"H0834\"Lord|strong=\"H3068\"do|strong=\"H6213\"so|strong=\"H6213\"and|strong=\"H3068\"so|strong=\"H6213\"to|strong=\"H4191\"me|strong=\"H3254\", and|strong=\"H3068\"add|strong=\"H3254\"more|strong=\"H3254\"also|strong=\"H3068\", if|strong=\"H3588\"aught but|strong=\"H3588\"death|strong=\"H4191\"part me|strong=\"H3254\"and|strong=\"H3068\"thee.",
      "18": "Then|strong=\"H1696\"Noemi, seeing|strong=\"H7200\"that|strong=\"H3588\"Ruth|strong=\"H0553\"was|strong=\"H1931\"steadfastly determined|strong=\"H0553\"to|strong=\"H0413\"go with|strong=\"H0854\"her|strong=\"H0413\", would not|strong=\"H2308\"be|strong=\"H1931\"against|strong=\"H0413\"it|strong=\"H1931\", nor|strong=\"H0413\"persuade her|strong=\"H0413\"any|strong=\"H3588\"more|strong=\"H3588\"to|strong=\"H0413\"return to|strong=\"H0413\"her|strong=\"H0413\"friends:",
      "19": "So|strong=\"H1961\"they|strong=\"H5921\"went|strong=\"H0935\"together|strong=\"H5921\"and|strong=\"H0935\"came|strong=\"H0935\"to|strong=\"H0559\"Bethlehem|strong=\"H1035\". And|strong=\"H0935\"when|strong=\"H1961\"they|strong=\"H5921\"were|strong=\"H1961\"come|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H3605\"city|strong=\"H5892\", the|strong=\"H3605\"report|strong=\"H0559\"was|strong=\"H1961\"quickly spread among|strong=\"H5921\"all|strong=\"H3605\": and|strong=\"H0935\"the|strong=\"H3605\"women said|strong=\"H0559\": This|strong=\"H2063\"is|strong=\"H3605\"that|strong=\"H3605\"Noemi.",
      "20": "But|strong=\"H3588\"she|strong=\"H3588\"said|strong=\"H0559\"to|strong=\"H0413\"them|strong=\"H0413\": Call|strong=\"H7121\"me|strong=\"H0413\"not|strong=\"H0408\"Noemi, (that|strong=\"H3588\"is|strong=\"H3588\", beautiful,) but|strong=\"H3588\"call|strong=\"H7121\"me|strong=\"H0413\"Mara|strong=\"H4755\", (that|strong=\"H3588\"is|strong=\"H3588\", bitter|strong=\"H4843\",) for|strong=\"H3588\"the|strong=\"H0559\"Almighty|strong=\"H7706\"hath quite filled me|strong=\"H0413\"with|strong=\"H0413\"bitterness.",
      "21": "I|strong=\"H0589\"went|strong=\"H1980\"out|strong=\"H4100\"full|strong=\"H4392\", and|strong=\"H1980\"the|strong=\"H0589\"Lord|strong=\"H3068\"hath brought|strong=\"H7725\"me|strong=\"H7725\"back|strong=\"H7725\"empty|strong=\"H7387\". Why|strong=\"H4100\"then|strong=\"H6030\"do|strong=\"H4100\"you|strong=\"H7725\"call|strong=\"H7121\"me|strong=\"H7725\"Noemi, whom|strong=\"H7121\"the|strong=\"H0589\"Lord|strong=\"H3068\"hath humbled and|strong=\"H1980\"the|strong=\"H0589\"Almighty|strong=\"H7706\"hath afflicted?",
      "22": "So|strong=\"H0935\"Noemi came|strong=\"H0935\"with|strong=\"H5973\"Ruth|strong=\"H7327\"the|strong=\"H0935\"Moabitess|strong=\"H4125\"her|strong=\"H0935\"daughter in|strong=\"H0935\"law, from|strong=\"H7725\"the|strong=\"H0935\"land|strong=\"H7704\"of|strong=\"H7704\"her|strong=\"H0935\"sojournment: and|strong=\"H0935\"returned|strong=\"H7725\"into|strong=\"H0935\"Bethlehem|strong=\"H1035\", in|strong=\"H0935\"the|strong=\"H0935\"beginning|strong=\"H8462\"of|strong=\"H7704\"the|strong=\"H0935\"barley|strong=\"H8184\"harvest|strong=\"H7105\"."
