    "2": {
      "1": "Now her|strong=\"H5281\"husband|strong=\"H0376\"Elimelech|strong=\"H0458\"had|strong=\"H3045\"a|strong=\"H0376\"kinsman, a|strong=\"H0376\"powerful|strong=\"H1368\"man|strong=\"H0376\", and|strong=\"H0376\"very|strong=\"H2428\"rich, whose|strong=\"H0376\"name|strong=\"H8034\"was|strong=\"H8034\"Booz.",
      "2": "And|strong=\"H5869\"Ruth|strong=\"H7327\"the|strong=\"H0559\"Moabitess|strong=\"H4125\"said|strong=\"H0559\"to|strong=\"H0413\"her|strong=\"H0413\"mother in|strong=\"H0413\"law: If|strong=\"H0834\"thou wilt, I|strong=\"H0834\"will|strong=\"H0834\"go|strong=\"H4994\"into|strong=\"H0413\"the|strong=\"H0559\"field|strong=\"H7704\", and|strong=\"H5869\"glean|strong=\"H3950\"the|strong=\"H0559\"ears|strong=\"H7641\"of|strong=\"H1323\"corn that|strong=\"H0834\"escape the|strong=\"H0559\"hands of|strong=\"H1323\"the|strong=\"H0559\"reapers, wheresoever I|strong=\"H0834\"shall|strong=\"H0834\"find|strong=\"H4672\"grace|strong=\"H2580\"with|strong=\"H0413\"a|strong=\"H4672\"householder that|strong=\"H0834\"will|strong=\"H0834\"be|strong=\"H4994\"favourable to|strong=\"H0413\"me|strong=\"H0413\". And|strong=\"H5869\"she|strong=\"H0834\"answered|strong=\"H0559\"her|strong=\"H0413\": Go|strong=\"H4994\", my|strong=\"H0834\"daughter|strong=\"H1323\".",
      "3": "She|strong=\"H0834\"went|strong=\"H0935\"therefore|strong=\"H0834\"and|strong=\"H0935\"gleaned|strong=\"H3950\"the|strong=\"H0834\"ears of|strong=\"H7704\"corn after|strong=\"H0310\"the|strong=\"H0834\"reapers. And|strong=\"H0935\"it|strong=\"H0834\"happened|strong=\"H7136\"that|strong=\"H0834\"the|strong=\"H0834\"owner of|strong=\"H7704\"that|strong=\"H0834\"field|strong=\"H7704\"was|strong=\"H0834\"Booz, who|strong=\"H0834\"was|strong=\"H0834\"of|strong=\"H7704\"the|strong=\"H0834\"kindred of|strong=\"H7704\"Elimelech|strong=\"H0458\".",
      "4": "And|strong=\"H0935\"behold|strong=\"H2009\", he|strong=\"H3068\"came|strong=\"H0935\"out|strong=\"H0935\"of|strong=\"H3068\"Bethlehem|strong=\"H1035\", and|strong=\"H0935\"said|strong=\"H0559\"to|strong=\"H0559\"the|strong=\"H0559\"reapers: The|strong=\"H0559\"Lord|strong=\"H3068\"be|strong=\"H1288\"with|strong=\"H5973\"you|strong=\"H5973\". And|strong=\"H0935\"they|strong=\"H3068\"answered|strong=\"H0559\"him|strong=\"H0935\": The|strong=\"H0559\"Lord|strong=\"H3068\"bless|strong=\"H1288\"thee.",
      "5": "And|strong=\"H5288\"Booz said|strong=\"H0559\"to|strong=\"H0559\"the|strong=\"H0559\"young|strong=\"H5288\"man|strong=\"H5288\"that|strong=\"H0559\"was|strong=\"H5288\"set|strong=\"H5324\"over|strong=\"H5921\"the|strong=\"H0559\"reapers: Whose|strong=\"H4310\"maid is|strong=\"H4310\"this|strong=\"H2063\"?",
      "6": "And|strong=\"H7725\"he|strong=\"H1931\"answered|strong=\"H0559\"him|strong=\"H5921\": This|strong=\"H1931\"is|strong=\"H1931\"the|strong=\"H0559\"Moabitess|strong=\"H4125\"who|strong=\"H1931\"came|strong=\"H7725\"with|strong=\"H5973\"Noemi, from|strong=\"H7725\"the|strong=\"H0559\"land|strong=\"H7704\"of|strong=\"H5921\"Moab|strong=\"H4124\",",
      "7": "And|strong=\"H0935\"she|strong=\"H0310\"desired|strong=\"H0559\"leave to|strong=\"H0559\"glean|strong=\"H3950\"the|strong=\"H0559\"ears of|strong=\"H1004\"corn that|strong=\"H2088\"remain|strong=\"H3427\", following|strong=\"H0310\"the|strong=\"H0559\"steps of|strong=\"H1004\"the|strong=\"H0559\"reapers: and|strong=\"H0935\"she|strong=\"H0310\"hath been|strong=\"H6258\"in|strong=\"H3427\"the|strong=\"H0559\"field from|strong=\"H0935\"morning|strong=\"H1242\"till|strong=\"H5704\"now|strong=\"H6258\", and|strong=\"H0935\"hath not|strong=\"H2088\"gone|strong=\"H0935\"home|strong=\"H1004\"for|strong=\"H1004\"one|strong=\"H2088\"moment.",
      "8": "And|strong=\"H8085\"Booz said|strong=\"H0559\"to|strong=\"H0413\"Ruth|strong=\"H7327\": Hear|strong=\"H8085\"me|strong=\"H0413\", daughter|strong=\"H1323\", do|strong=\"H0408\"not|strong=\"H3808\"go|strong=\"H5674\"to|strong=\"H0413\"glean|strong=\"H3950\"in|strong=\"H0413\"any|strong=\"H1571\"other|strong=\"H0312\"field|strong=\"H7704\", and|strong=\"H8085\"do|strong=\"H0408\"not|strong=\"H3808\"depart from|strong=\"H8085\"this|strong=\"H2088\"place|strong=\"H2088\": but|strong=\"H3808\"keep|strong=\"H8085\"with|strong=\"H5973\"my|strong=\"H8085\"maids|strong=\"H5291\",",
      "9": "And|strong=\"H1980\"follow|strong=\"H0310\"where|strong=\"H0834\"they|strong=\"H0834\"reap|strong=\"H7114\". For|strong=\"H0413\"I|strong=\"H0834\"have|strong=\"H0834\"charged|strong=\"H6680\"my|strong=\"H0834\"young|strong=\"H5288\"men|strong=\"H5288\", not|strong=\"H3808\"to|strong=\"H0413\"molest thee: and|strong=\"H1980\"if|strong=\"H0834\"thou art thirsty|strong=\"H6770\", go|strong=\"H1980\"to|strong=\"H0413\"the|strong=\"H0853\"vessels|strong=\"H3627\", and|strong=\"H1980\"drink|strong=\"H8354\"of|strong=\"H3627\"the|strong=\"H0853\"waters whereof the|strong=\"H0853\"servants|strong=\"H5288\"drink|strong=\"H8354\".",
      "10": "She|strong=\"H6440\"fell|strong=\"H5307\"on|strong=\"H5921\"her|strong=\"H0413\"face|strong=\"H6440\"and|strong=\"H0776\"worshipping upon|strong=\"H5921\"the|strong=\"H0559\"ground|strong=\"H0776\", said|strong=\"H0559\"to|strong=\"H0413\"him|strong=\"H0413\": Whence cometh this to|strong=\"H0413\"me|strong=\"H0413\", that|strong=\"H0559\"I|strong=\"H0595\"should|strong=\"H0559\"find|strong=\"H4672\"grace|strong=\"H2580\"before|strong=\"H6440\"thy eyes|strong=\"H5869\", and|strong=\"H0776\"that|strong=\"H0559\"thou shouldst vouchsafe to|strong=\"H0413\"take|strong=\"H5234\"notice|strong=\"H5869\"of|strong=\"H0776\"me|strong=\"H0413\"a|strong=\"H4672\"woman|strong=\"H5237\"of|strong=\"H0776\"another country|strong=\"H0776\"?",
      "11": "And|strong=\"H0776\"he|strong=\"H0834\"answered|strong=\"H0559\"her|strong=\"H3605\": All|strong=\"H3605\"hath been|strong=\"H0834\"told|strong=\"H5046\"me|strong=\"H0413\", that|strong=\"H0834\"thou hast done|strong=\"H6213\"to|strong=\"H0413\"thy mother|strong=\"H0517\"in|strong=\"H0413\"law after|strong=\"H0310\"the|strong=\"H3605\"death|strong=\"H4194\"of|strong=\"H0776\"thy husband|strong=\"H0376\": and|strong=\"H0776\"how|strong=\"H0834\"thou hast left|strong=\"H5800\"thy parents|strong=\"H0001\", and|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\"wherein|strong=\"H0834\"thou wast born|strong=\"H4138\", and|strong=\"H0776\"art come to|strong=\"H0413\"a|strong=\"H0834\"people|strong=\"H5971\"which|strong=\"H0834\"thou knewest not|strong=\"H3808\"heretofore.",
      "12": "The|strong=\"H0834\"Lord|strong=\"H3068\"render unto thee for|strong=\"H8478\"thy work|strong=\"H6467\", and|strong=\"H0935\"mayest thou receive|strong=\"H1961\"a|strong=\"H1961\"full|strong=\"H8003\"reward|strong=\"H7999\"of|strong=\"H0430\"the|strong=\"H0834\"Lord|strong=\"H3068\"the|strong=\"H0834\"God|strong=\"H0430\"of|strong=\"H0430\"Israel|strong=\"H3478\", to|strong=\"H0935\"whom|strong=\"H0834\"thou art come|strong=\"H0935\", and|strong=\"H0935\"under|strong=\"H8478\"whose|strong=\"H0834\"wings|strong=\"H3671\"thou art fled.",
      "13": "And|strong=\"H5869\"she|strong=\"H3588\"said|strong=\"H0559\": I|strong=\"H0595\"have|strong=\"H1961\"found|strong=\"H4672\"grace|strong=\"H2580\"in|strong=\"H5921\"thy eyes|strong=\"H5869\", my|strong=\"H5921\"lord|strong=\"H0113\", who|strong=\"H0259\"hast comforted|strong=\"H5162\"me|strong=\"H5921\"and|strong=\"H5869\"hast spoken|strong=\"H1696\"to|strong=\"H0559\"the|strong=\"H0559\"heart|strong=\"H3820\"of|strong=\"H5869\"thy handmaid, who|strong=\"H0259\"am|strong=\"H0595\"not|strong=\"H3808\"like|strong=\"H1961\"to|strong=\"H0559\"one|strong=\"H0259\"of|strong=\"H5869\"thy maids|strong=\"H8198\".",
      "14": "And|strong=\"H0398\"Booz said|strong=\"H0559\"to|strong=\"H0559\"her|strong=\"H0398\": At|strong=\"H3427\"mealtime come|strong=\"H5066\"thou hither, and|strong=\"H0398\"eat|strong=\"H0398\"of|strong=\"H3427\"the|strong=\"H0559\"bread|strong=\"H3899\", and|strong=\"H0398\"dip|strong=\"H2881\"thy morsel|strong=\"H6595\"in|strong=\"H3427\"the|strong=\"H0559\"vinegar|strong=\"H2558\". So|strong=\"H4480\"she|strong=\"H6256\"sat|strong=\"H3427\"at|strong=\"H3427\"the|strong=\"H0559\"side|strong=\"H6654\"of|strong=\"H3427\"the|strong=\"H0559\"reapers, and|strong=\"H0398\"she|strong=\"H6256\"heaped to|strong=\"H0559\"herself frumenty, and|strong=\"H0398\"ate|strong=\"H0398\"and|strong=\"H0398\"was|strong=\"H3427\"filled|strong=\"H7646\", and|strong=\"H0398\"took|strong=\"H0398\"the|strong=\"H0559\"leavings.",
      "15": "And|strong=\"H6965\"she|strong=\"H3808\"arose|strong=\"H6965\"from|strong=\"H6965\"thence, to|strong=\"H0559\"glean|strong=\"H3950\"the|strong=\"H0853\"ears of|strong=\"H0559\"corn as|strong=\"H1571\"before|strong=\"H3808\". And|strong=\"H6965\"Booz commanded|strong=\"H6680\"his|strong=\"H6680\"servants|strong=\"H5288\", saying|strong=\"H0559\": If she|strong=\"H3808\"would|strong=\"H0559\"even|strong=\"H1571\"reap with|strong=\"H6965\"you|strong=\"H6680\", hinder her|strong=\"H0996\"not|strong=\"H3808\":",
      "16": "And|strong=\"H1571\"let|strong=\"H3808\"fall some|strong=\"H4480\"of|strong=\"H4480\"your|strong=\"H4480\"handfuls of|strong=\"H4480\"purpose, and|strong=\"H1571\"leave|strong=\"H5800\"them|strong=\"H4480\", that|strong=\"H4480\"she|strong=\"H3808\"may|strong=\"H1571\"gather|strong=\"H3950\"them|strong=\"H4480\"without|strong=\"H3808\"shame, and|strong=\"H1571\"let|strong=\"H3808\"no|strong=\"H3808\"man rebuke|strong=\"H1605\"her|strong=\"H1571\"when|strong=\"H4480\"she|strong=\"H3808\"gathereth them|strong=\"H4480\".",
      "17": "She|strong=\"H0834\"gleaned|strong=\"H3950\"therefore|strong=\"H1961\"in|strong=\"H1961\"the|strong=\"H0853\"field|strong=\"H7704\"till|strong=\"H5704\"evening|strong=\"H6153\": and|strong=\"H7704\"beating|strong=\"H2251\"out|strong=\"H2251\"with|strong=\"H1961\"a|strong=\"H1961\"rod and|strong=\"H7704\"threshing|strong=\"H2251\"what|strong=\"H0834\"she|strong=\"H0834\"had|strong=\"H0834\"gleaned|strong=\"H3950\", she|strong=\"H0834\"found about|strong=\"H1961\"the|strong=\"H0853\"measure|strong=\"H0374\"of|strong=\"H7704\"an|strong=\"H1961\"ephi of|strong=\"H7704\"barley|strong=\"H8184\", that|strong=\"H0834\"is|strong=\"H0834\", three bushels:",
      "18": "Which|strong=\"H0834\"she|strong=\"H0834\"took|strong=\"H5375\"up|strong=\"H5375\"and|strong=\"H0935\"returned|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H0853\"city|strong=\"H5892\", and|strong=\"H0935\"shewed it|strong=\"H5414\"to|strong=\"H0935\"her|strong=\"H5414\"mother in|strong=\"H0935\"law: moreover she|strong=\"H0834\"brought|strong=\"H0935\"out|strong=\"H3318\", and|strong=\"H0935\"gave|strong=\"H5414\"her|strong=\"H5414\"of|strong=\"H0935\"the|strong=\"H0853\"remains|strong=\"H3498\"of|strong=\"H0935\"her|strong=\"H5414\"meat, wherewith she|strong=\"H0834\"had|strong=\"H0834\"been|strong=\"H0834\"filled.",
      "19": "And|strong=\"H3117\"her|strong=\"H5046\"mother in|strong=\"H3117\"law said|strong=\"H0559\"to|strong=\"H0559\"her|strong=\"H5046\": Where|strong=\"H0834\"hast thou gleaned|strong=\"H3950\"today|strong=\"H3117\", and|strong=\"H3117\"where|strong=\"H0834\"hast thou wrought? blessed|strong=\"H1288\"be|strong=\"H1961\"he|strong=\"H0834\"that|strong=\"H0834\"hath had|strong=\"H0834\"pity on|strong=\"H3117\"thee. And|strong=\"H3117\"she|strong=\"H0834\"told|strong=\"H5046\"her|strong=\"H5046\"with|strong=\"H5973\"whom|strong=\"H0834\"she|strong=\"H0834\"had|strong=\"H0834\"wrought: and|strong=\"H3117\"she|strong=\"H0834\"told|strong=\"H5046\"the|strong=\"H0853\"man’s|strong=\"H0376\"name|strong=\"H8034\", that|strong=\"H0834\"he|strong=\"H0834\"was|strong=\"H8034\"called|strong=\"H0559\"Booz.",
      "20": "And|strong=\"H3068\"Noemi answered|strong=\"H0559\"her|strong=\"H0559\": Blessed|strong=\"H1288\"be|strong=\"H4191\"he|strong=\"H0834\"of|strong=\"H0376\"the|strong=\"H0559\"Lord|strong=\"H3068\": because|strong=\"H0834\"the|strong=\"H0559\"same|strong=\"H1931\"kindness|strong=\"H2617\"which|strong=\"H0834\"he|strong=\"H0834\"shewed to|strong=\"H0559\"the|strong=\"H0559\"living|strong=\"H2416\", he|strong=\"H0834\"hath kept also|strong=\"H3068\"to|strong=\"H0559\"the|strong=\"H0559\"dead|strong=\"H4191\". And|strong=\"H3068\"again she|strong=\"H1931\"said|strong=\"H0559\": The|strong=\"H0559\"man|strong=\"H0376\"is|strong=\"H0834\"our|strong=\"H3068\"kinsman|strong=\"H1350\".",
      "21": "And|strong=\"H5288\"Ruth|strong=\"H7327\"said|strong=\"H0559\", He|strong=\"H0834\"also|strong=\"H1571\"charged me|strong=\"H0413\", that|strong=\"H0834\"I|strong=\"H0834\"should|strong=\"H0518\"keep close|strong=\"H1692\"to|strong=\"H0413\"his|strong=\"H3605\"reapers, till|strong=\"H5704\"all|strong=\"H3605\"the|strong=\"H3605\"corn should|strong=\"H0518\"be|strong=\"H1571\"reaped.",
      "22": "And|strong=\"H7704\"her|strong=\"H0413\"mother in|strong=\"H0413\"law said|strong=\"H0559\"to|strong=\"H0413\"her|strong=\"H0413\": It|strong=\"H3588\"is|strong=\"H2896\"better|strong=\"H2896\"for|strong=\"H3588\"thee, my|strong=\"H3318\"daughter|strong=\"H1323\", to|strong=\"H0413\"go|strong=\"H3318\"out|strong=\"H3318\"to|strong=\"H0413\"reap with|strong=\"H5973\"his|strong=\"H3588\"maids|strong=\"H5291\", lest in|strong=\"H0413\"another|strong=\"H0312\"man’s|strong=\"H0312\"field|strong=\"H7704\"some one|strong=\"H3808\"may|strong=\"H7704\"resist thee.",
      "23": "So|strong=\"H3427\"she|strong=\"H5704\"kept close|strong=\"H1692\"to|strong=\"H5704\"the|strong=\"H5704\"maids|strong=\"H5291\"of|strong=\"H3427\"Booz: and|strong=\"H3427\"continued to|strong=\"H5704\"glean|strong=\"H3950\"with|strong=\"H0854\"them|strong=\"H3615\", till|strong=\"H5704\"all|strong=\"H5704\"the|strong=\"H5704\"barley|strong=\"H8184\"and|strong=\"H3427\"the|strong=\"H5704\"wheat|strong=\"H2406\"were|strong=\"H3427\"laid up|strong=\"H5704\"in|strong=\"H3427\"the|strong=\"H5704\"barns."
    },
    "3": {
      "1": "After she|strong=\"H0834\"was|strong=\"H0834\"returned to|strong=\"H0559\"her|strong=\"H0559\"mother in|strong=\"H3808\"law, Noemi said|strong=\"H0559\"to|strong=\"H0559\"her|strong=\"H0559\": My|strong=\"H1245\"daughter|strong=\"H1323\", I|strong=\"H0834\"will|strong=\"H0834\"seek|strong=\"H1245\"rest|strong=\"H4494\"for|strong=\"H1245\"thee, and|strong=\"H1323\"will|strong=\"H0834\"provide that|strong=\"H0834\"it|strong=\"H0834\"may|strong=\"H0834\"be|strong=\"H3808\"well|strong=\"H3190\"with|strong=\"H2545\"thee.",
      "2": "This|strong=\"H1931\"Booz, with|strong=\"H0854\"whose|strong=\"H0834\"maids|strong=\"H5291\"thou wast joined|strong=\"H0854\"in|strong=\"H1961\"the|strong=\"H0853\"field, is|strong=\"H0834\"our|strong=\"H1961\"near|strong=\"H0854\"kinsman|strong=\"H4130\", and|strong=\"H3915\"behold|strong=\"H2009\"this|strong=\"H1931\"night|strong=\"H3915\"he|strong=\"H0834\"winnoweth barley|strong=\"H8184\"in|strong=\"H1961\"the|strong=\"H0853\"threshingfloor.",
      "3": "Wash|strong=\"H7364\"thyself therefore|strong=\"H3045\"and|strong=\"H0398\"anoint|strong=\"H5480\"thee, and|strong=\"H0398\"put|strong=\"H7760\"on|strong=\"H5921\"thy best garments|strong=\"H8071\", and|strong=\"H0398\"go|strong=\"H3381\"down|strong=\"H3381\"to|strong=\"H5704\"the|strong=\"H5921\"barnfloor: but|strong=\"H0376\"let|strong=\"H0408\"not|strong=\"H0408\"the|strong=\"H5921\"man|strong=\"H0376\"see|strong=\"H3045\"thee, till|strong=\"H5704\"he|strong=\"H5704\"shall|strong=\"H0376\"have|strong=\"H3045\"done eating|strong=\"H0398\"and|strong=\"H0398\"drinking|strong=\"H8354\".",
      "4": "And|strong=\"H0935\"when|strong=\"H1961\"he|strong=\"H0834\"shall|strong=\"H0834\"go|strong=\"H0935\"to|strong=\"H0935\"sleep|strong=\"H7901\", mark the|strong=\"H0853\"place|strong=\"H4725\"wherein|strong=\"H0834\"he|strong=\"H0834\"sleepeth: and|strong=\"H0935\"thou shalt go|strong=\"H0935\"in|strong=\"H0935\", and|strong=\"H0935\"lift|strong=\"H1540\"up|strong=\"H0935\"the|strong=\"H0853\"clothes wherewith he|strong=\"H0834\"is|strong=\"H0834\"covered towards his|strong=\"H0834\"feet|strong=\"H4772\", and|strong=\"H0935\"shalt lay|strong=\"H7901\"thyself down|strong=\"H7901\"there|strong=\"H8033\": and|strong=\"H0935\"he|strong=\"H0834\"will|strong=\"H1961\"tell|strong=\"H5046\"thee what|strong=\"H0834\"thou must|strong=\"H0853\"do|strong=\"H6213\".",
      "5": "She|strong=\"H0834\"answered|strong=\"H0559\": Whatsoever|strong=\"H3605\"thou shalt command|strong=\"H0559\", I|strong=\"H0834\"will|strong=\"H0834\"do|strong=\"H6213\".",
      "6": "And|strong=\"H3381\"she|strong=\"H0834\"went|strong=\"H3381\"down|strong=\"H3381\"to|strong=\"H3381\"the|strong=\"H3605\"barnfloor, and|strong=\"H3381\"did|strong=\"H6213\"all|strong=\"H3605\"that|strong=\"H0834\"her|strong=\"H3605\"mother in|strong=\"H3605\"law had|strong=\"H0834\"bid her|strong=\"H3605\".",
      "7": "And|strong=\"H0935\"when|strong=\"H0935\"Booz had|strong=\"H0935\"eaten|strong=\"H0398\", and|strong=\"H0935\"drunk|strong=\"H8354\", and|strong=\"H0935\"was|strong=\"H3820\"merry|strong=\"H3190\", he|strong=\"H0935\"went|strong=\"H0935\"to|strong=\"H0935\"sleep|strong=\"H7901\"by|strong=\"H0935\"the|strong=\"H0935\"heap|strong=\"H6194\"of|strong=\"H3820\"sheaves, and|strong=\"H0935\"she|strong=\"H3820\"came|strong=\"H0935\"softly and|strong=\"H0935\"uncovering his|strong=\"H0935\"feet|strong=\"H4772\", laid|strong=\"H7901\"herself down|strong=\"H7901\".",
      "8": "And|strong=\"H0376\"behold|strong=\"H2009\", when|strong=\"H1961\"it|strong=\"H1961\"was|strong=\"H1961\"now|strong=\"H1961\"midnight the|strong=\"H1961\"man|strong=\"H0376\"was|strong=\"H1961\"afraid|strong=\"H2729\", and|strong=\"H0376\"troubled: and|strong=\"H0376\"he|strong=\"H0376\"saw|strong=\"H2009\"a|strong=\"H1961\"woman|strong=\"H0802\"lying|strong=\"H7901\"at|strong=\"H1961\"his|strong=\"H1961\"feet|strong=\"H4772\",",
      "9": "And|strong=\"H3671\"he|strong=\"H3588\"said|strong=\"H0559\"to|strong=\"H0559\"her|strong=\"H5921\": Who|strong=\"H4310\"art thou? And|strong=\"H3671\"she|strong=\"H3588\"answered|strong=\"H0559\": I|strong=\"H0595\"am|strong=\"H0595\"Ruth|strong=\"H7327\"thy handmaid|strong=\"H0519\": spread|strong=\"H6566\"thy coverlet over|strong=\"H5921\"thy servant|strong=\"H0519\", for|strong=\"H3588\"thou art a|strong=\"H3588\"near|strong=\"H5921\"kinsman|strong=\"H1350\".",
      "10": "And|strong=\"H3068\"he|strong=\"H0518\"said|strong=\"H0559\": Blessed|strong=\"H1288\"art thou of|strong=\"H3068\"the|strong=\"H0559\"Lord|strong=\"H3068\", my|strong=\"H3068\"daughter|strong=\"H1323\", and|strong=\"H3068\"thy latter|strong=\"H0314\"kindness|strong=\"H2617\"has|strong=\"H3068\"surpassed the|strong=\"H0559\"former|strong=\"H7223\": because|strong=\"H4480\"thou hast not|strong=\"H1115\"followed|strong=\"H0310\"young|strong=\"H0970\"men|strong=\"H0970\"either|strong=\"H0518\"poor|strong=\"H1800\"or|strong=\"H0518\"rich|strong=\"H6223\".",
      "11": "Fear|strong=\"H3372\"not|strong=\"H0408\"therefore|strong=\"H6258\", but|strong=\"H3588\"whatsoever|strong=\"H3605\"thou shalt say|strong=\"H0559\"to|strong=\"H0559\"me|strong=\"H0834\"I|strong=\"H0834\"will|strong=\"H0834\"do|strong=\"H6213\"to|strong=\"H0559\"thee. For|strong=\"H3588\"all|strong=\"H3605\"the|strong=\"H3605\"people|strong=\"H5971\"that|strong=\"H0834\"dwell within the|strong=\"H3605\"gates|strong=\"H8179\"of|strong=\"H1323\"my|strong=\"H3605\"city|strong=\"H8179\", know|strong=\"H3045\"that|strong=\"H0834\"thou art a|strong=\"H3588\"virtuous woman|strong=\"H0802\".",
      "12": "Neither|strong=\"H1571\"do|strong=\"H0518\"I|strong=\"H0595\"deny myself|strong=\"H0595\"to|strong=\"H4480\"be|strong=\"H1571\"near|strong=\"H7138\"of|strong=\"H4480\"kin, but|strong=\"H3588\"there|strong=\"H3426\"is|strong=\"H3426\"another|strong=\"H1571\"nearer than|strong=\"H4480\"I|strong=\"H0595\".",
      "13": "Rest|strong=\"H7901\"thou this|strong=\"H3068\"night|strong=\"H3915\": and|strong=\"H3068\"when|strong=\"H1961\"morning|strong=\"H1242\"is|strong=\"H3068\"come|strong=\"H1961\", if|strong=\"H0518\"he|strong=\"H0518\"will|strong=\"H3068\"take|strong=\"H1961\"thee by|strong=\"H3068\"the|strong=\"H3068\"right|strong=\"H2896\"of|strong=\"H3068\"kindred, all|strong=\"H5704\"is|strong=\"H3068\"well|strong=\"H2896\": but|strong=\"H0518\"if|strong=\"H0518\"he|strong=\"H0518\"will|strong=\"H3068\"not|strong=\"H3808\", I|strong=\"H0595\"will|strong=\"H3068\"undoubtedly take|strong=\"H1961\"thee, as|strong=\"H5704\"the|strong=\"H3068\"Lord|strong=\"H3068\"liveth: sleep|strong=\"H7901\"till|strong=\"H5704\"the|strong=\"H3068\"morning|strong=\"H1242\".",
      "14": "So|strong=\"H6965\"she|strong=\"H3588\"slept|strong=\"H7901\"at|strong=\"H0935\"his|strong=\"H0376\"feet|strong=\"H4772\"till|strong=\"H5704\"the|strong=\"H0853\"night was|strong=\"H0376\"going|strong=\"H0935\"off|strong=\"H0853\". And|strong=\"H0935\"she|strong=\"H3588\"arose|strong=\"H6965\"before|strong=\"H5704\"men|strong=\"H0376\"could|strong=\"H0376\"know|strong=\"H3045\"one|strong=\"H0376\"another|strong=\"H7453\", and|strong=\"H0935\"Booz said|strong=\"H0559\": Beware lest any|strong=\"H0376\"man|strong=\"H0376\"know|strong=\"H3045\"that|strong=\"H3588\"thou camest hither.",
      "15": "And|strong=\"H0935\"again he|strong=\"H0834\"said|strong=\"H0559\": Spread thy mantle, wherewith thou art covered, and|strong=\"H0935\"hold|strong=\"H0270\"it|strong=\"H5921\"with|strong=\"H5921\"both|strong=\"H5921\"hands. And|strong=\"H0935\"when|strong=\"H0834\"she|strong=\"H0834\"spread it|strong=\"H5921\"and|strong=\"H0935\"held|strong=\"H0270\"it|strong=\"H5921\", he|strong=\"H0834\"measured|strong=\"H4058\"six|strong=\"H8337\"measures of|strong=\"H5921\"barley|strong=\"H8184\", and|strong=\"H0935\"laid|strong=\"H7896\"it|strong=\"H5921\"upon|strong=\"H5921\"her|strong=\"H5921\". And|strong=\"H0935\"she|strong=\"H0834\"carried|strong=\"H0935\"it|strong=\"H5921\"and|strong=\"H0935\"went|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H0559\"city|strong=\"H5892\",",
      "16": "And|strong=\"H0935\"came|strong=\"H0935\"to|strong=\"H0413\"her|strong=\"H3605\"mother in|strong=\"H0935\"law; who|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0413\"her|strong=\"H3605\": What|strong=\"H0834\"hast thou done|strong=\"H6213\", daughter|strong=\"H1323\"? And|strong=\"H0935\"she|strong=\"H0834\"told|strong=\"H5046\"her|strong=\"H3605\"all|strong=\"H3605\"that|strong=\"H0834\"the|strong=\"H3605\"man|strong=\"H0376\"had|strong=\"H0834\"done|strong=\"H6213\"to|strong=\"H0413\"her|strong=\"H3605\".",
      "17": "And|strong=\"H0935\"she|strong=\"H3588\"said|strong=\"H0559\": Behold he|strong=\"H3588\"hath given|strong=\"H5414\"me|strong=\"H0413\"six|strong=\"H8337\"measures of|strong=\"H0935\"barley|strong=\"H8184\": for|strong=\"H3588\"he|strong=\"H3588\"said|strong=\"H0559\": I|strong=\"H3588\"will|strong=\"H5414\"not|strong=\"H0408\"have|strong=\"H5414\"thee return|strong=\"H0935\"empty|strong=\"H7387\"to|strong=\"H0413\"thy mother in|strong=\"H0935\"law.",
      "18": "And|strong=\"H3117\"Noemi said|strong=\"H0559\": Wait|strong=\"H3427\"my|strong=\"H3045\"daughter|strong=\"H1323\", till|strong=\"H5704\"we|strong=\"H3588\"see|strong=\"H3045\"what|strong=\"H0834\"end|strong=\"H3615\"the|strong=\"H0559\"thing|strong=\"H1697\"will|strong=\"H0834\"have|strong=\"H0834\". For|strong=\"H3588\"the|strong=\"H0559\"man|strong=\"H0376\"will|strong=\"H0834\"not|strong=\"H3808\"rest|strong=\"H8252\"until|strong=\"H5704\"he|strong=\"H0834\"have|strong=\"H0834\"accomplished|strong=\"H3615\"what|strong=\"H0834\"he|strong=\"H0834\"hath said|strong=\"H0559\"."
    },
    "4": {
      "1": "Then|strong=\"H1696\"Booz went|strong=\"H5927\"up|strong=\"H5927\"to|strong=\"H0559\"the|strong=\"H0559\"gate|strong=\"H8179\", and|strong=\"H8033\"sat|strong=\"H3427\"there|strong=\"H8033\". And|strong=\"H8033\"when|strong=\"H0834\"he|strong=\"H0834\"had|strong=\"H0834\"seen the|strong=\"H0559\"kinsman|strong=\"H1350\"going|strong=\"H5927\"by|strong=\"H3427\", of|strong=\"H3427\"whom|strong=\"H0834\"he|strong=\"H0834\"had|strong=\"H0834\"spoken|strong=\"H1696\"before, he|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0559\"him|strong=\"H0559\", calling him|strong=\"H0559\"by|strong=\"H3427\"his|strong=\"H0834\"name|strong=\"H0559\": Turn|strong=\"H5493\"aside|strong=\"H5493\"for|strong=\"H8033\"a|strong=\"H1696\"little while|strong=\"H2009\", and|strong=\"H8033\"sit|strong=\"H3427\"down|strong=\"H3427\"here|strong=\"H6311\". He|strong=\"H0834\"turned|strong=\"H5493\"aside|strong=\"H5493\", and|strong=\"H8033\"sat|strong=\"H3427\"down|strong=\"H3427\".",
      "2": "And|strong=\"H0376\"Booz taking|strong=\"H3947\"ten|strong=\"H6235\"men|strong=\"H0376\"of|strong=\"H0376\"the|strong=\"H0559\"ancients of|strong=\"H0376\"the|strong=\"H0559\"city|strong=\"H5892\", said|strong=\"H0559\"to|strong=\"H0559\"them|strong=\"H3947\": Sit|strong=\"H3427\"ye down|strong=\"H3427\"here|strong=\"H6311\".",
      "3": "They|strong=\"H0834\"sat down, and|strong=\"H7725\"he|strong=\"H0834\"spoke|strong=\"H0559\"to|strong=\"H0559\"the|strong=\"H0559\"kinsman|strong=\"H0251\": Noemi, who|strong=\"H0834\"is|strong=\"H0834\"returned|strong=\"H7725\"from|strong=\"H7725\"the|strong=\"H0559\"country|strong=\"H7704\"of|strong=\"H7704\"Moab|strong=\"H4124\", will|strong=\"H0834\"sell|strong=\"H4376\"a|strong=\"H0834\"parcel of|strong=\"H7704\"land|strong=\"H7704\"that|strong=\"H0834\"belonged to|strong=\"H0559\"our|strong=\"H0834\"brother|strong=\"H0251\"Elimelech|strong=\"H0458\".",
      "4": "I|strong=\"H0589\"would|strong=\"H0559\"have|strong=\"H0369\"thee to|strong=\"H0559\"understand|strong=\"H3045\"this|strong=\"H3588\", and|strong=\"H3045\"would|strong=\"H0559\"tell|strong=\"H5046\"thee before|strong=\"H5048\"all|strong=\"H3045\"that|strong=\"H3588\"sit|strong=\"H3427\"here|strong=\"H1350\", and|strong=\"H3045\"before|strong=\"H5048\"the|strong=\"H0559\"ancients of|strong=\"H3427\"my|strong=\"H3045\"people|strong=\"H5971\". If|strong=\"H0518\"thou wilt take|strong=\"H3045\"possession of|strong=\"H3427\"it|strong=\"H0518\"by|strong=\"H3427\"the|strong=\"H0559\"right of|strong=\"H3427\"kindred: buy|strong=\"H7069\"it|strong=\"H0518\"and|strong=\"H3045\"possess it|strong=\"H0518\": but|strong=\"H3588\"if|strong=\"H0518\"it|strong=\"H0518\"please|strong=\"H0595\"thee not|strong=\"H3808\", tell|strong=\"H5046\"me|strong=\"H5046\"so|strong=\"H3808\", that|strong=\"H3588\"I|strong=\"H0589\"may|strong=\"H3808\"know|strong=\"H3045\"what|strong=\"H3045\"I|strong=\"H0589\"have|strong=\"H0369\"to|strong=\"H0559\"do|strong=\"H0518\". For|strong=\"H3588\"there|strong=\"H0369\"is|strong=\"H0369\"no|strong=\"H3808\"near|strong=\"H5048\"kinsman|strong=\"H1350\"besides|strong=\"H2108\"thee, who|strong=\"H0369\"art first, and|strong=\"H3045\"me|strong=\"H5046\", who|strong=\"H0369\"am|strong=\"H0589\"second. But|strong=\"H3588\"he|strong=\"H3588\"answered|strong=\"H0559\": I|strong=\"H0589\"will|strong=\"H0369\"buy|strong=\"H7069\"the|strong=\"H0559\"field.",
      "5": "And|strong=\"H6965\"Booz said|strong=\"H0559\"to|strong=\"H0559\"him|strong=\"H5921\": When|strong=\"H3117\"thou shalt buy|strong=\"H7069\"the|strong=\"H0559\"field|strong=\"H7704\"at|strong=\"H5921\"the|strong=\"H0559\"woman’s|strong=\"H0802\"hand|strong=\"H3027\", thou must|strong=\"H4191\"take|strong=\"H6965\"also|strong=\"H3117\"Ruth|strong=\"H7327\"the|strong=\"H0559\"Moabitess|strong=\"H4125\", who|strong=\"H0802\"was|strong=\"H8034\"the|strong=\"H0559\"wife|strong=\"H0802\"of|strong=\"H3117\"the|strong=\"H0559\"deceased|strong=\"H4191\": to|strong=\"H0559\"raise|strong=\"H6965\"up|strong=\"H6965\"the|strong=\"H0559\"name|strong=\"H8034\"of|strong=\"H3117\"thy kinsman in|strong=\"H5921\"his|strong=\"H5921\"inheritance|strong=\"H5159\".",
      "6": "He|strong=\"H3588\"answered|strong=\"H0559\": I|strong=\"H3588\"yield up|strong=\"H0853\"my|strong=\"H3588\"right|strong=\"H1353\"of|strong=\"H0559\"next|strong=\"H1350\"akin: for|strong=\"H3588\"I|strong=\"H3588\"must|strong=\"H0853\"not|strong=\"H3808\"cut off|strong=\"H0853\"the|strong=\"H0853\"posterity of|strong=\"H0559\"my|strong=\"H3588\"own family. Do|strong=\"H3201\"thou make|strong=\"H3588\"use of|strong=\"H0559\"my|strong=\"H3588\"privilege, which I|strong=\"H3588\"profess I|strong=\"H3588\"do|strong=\"H3201\"willingly forego.",
      "7": "Now|strong=\"H5414\"this|strong=\"H2063\"in|strong=\"H5921\"former|strong=\"H6440\"times|strong=\"H6440\"was|strong=\"H3478\"the|strong=\"H3605\"manner|strong=\"H1697\"in|strong=\"H5921\"Israel|strong=\"H3478\"between|strong=\"H5921\"kinsmen, that|strong=\"H3605\"if|strong=\"H0376\"at|strong=\"H5921\"any|strong=\"H3605\"time|strong=\"H3478\"one|strong=\"H0376\"yielded|strong=\"H5414\"his|strong=\"H3605\"right|strong=\"H1353\"to|strong=\"H5921\"another|strong=\"H7453\": that|strong=\"H3605\"the|strong=\"H3605\"grant|strong=\"H5414\"might|strong=\"H3478\"be|strong=\"H0376\"sure, the|strong=\"H3605\"man|strong=\"H0376\"put|strong=\"H5414\"off|strong=\"H5921\"his|strong=\"H3605\"shoe|strong=\"H5275\", and|strong=\"H6965\"gave|strong=\"H5414\"it|strong=\"H5414\"to|strong=\"H5921\"his|strong=\"H3605\"neighhour; this|strong=\"H2063\"was|strong=\"H3478\"a|strong=\"H5414\"testimony|strong=\"H8584\"of|strong=\"H0376\"cession of|strong=\"H0376\"right|strong=\"H1353\"in|strong=\"H5921\"Israel|strong=\"H3478\".",
      "8": "So|strong=\"H1350\"Booz said|strong=\"H0559\"to|strong=\"H0559\"his|strong=\"H8025\"kinsman|strong=\"H1350\": Put off thy shoe|strong=\"H5275\". And|strong=\"H0559\"immediately he|strong=\"H0559\"took it|strong=\"H1350\"off from his|strong=\"H8025\"foot.",
      "9": "And|strong=\"H3027\"he|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0559\"the|strong=\"H3605\"ancients and|strong=\"H3027\"to|strong=\"H0559\"all|strong=\"H3605\"the|strong=\"H3605\"people|strong=\"H5971\": You|strong=\"H0859\"are|strong=\"H0834\"witnesses|strong=\"H5707\"this|strong=\"H3588\"day|strong=\"H3117\", that|strong=\"H0834\"I|strong=\"H0834\"have|strong=\"H0834\"bought|strong=\"H7069\"all|strong=\"H3605\"that|strong=\"H0834\"was|strong=\"H0834\"Elimelech’s, and|strong=\"H3027\"Chelion’s, and|strong=\"H3027\"Mahalon’s, of|strong=\"H3117\"the|strong=\"H3605\"hand|strong=\"H3027\"of|strong=\"H3117\"Noemi:",
      "10": "And|strong=\"H6965\"have|strong=\"H1571\"taken|strong=\"H6965\"to|strong=\"H4191\"wife|strong=\"H0802\"Ruth|strong=\"H7327\"the|strong=\"H0853\"Moabitess|strong=\"H4125\", the|strong=\"H0853\"wife|strong=\"H0802\"of|strong=\"H3117\"Mahalon, to|strong=\"H4191\"raise|strong=\"H6965\"up|strong=\"H6965\"the|strong=\"H0853\"name|strong=\"H8034\"of|strong=\"H3117\"the|strong=\"H0853\"deceased|strong=\"H4191\"in|strong=\"H5921\"his|strong=\"H5921\"inheritance|strong=\"H5159\"lest his|strong=\"H5921\"name|strong=\"H8034\"be|strong=\"H4191\"cut|strong=\"H3772\"off|strong=\"H3772\", from|strong=\"H5921\"among|strong=\"H5973\"his|strong=\"H5921\"family|strong=\"H4191\"and|strong=\"H6965\"his|strong=\"H5921\"brethren|strong=\"H0251\"and|strong=\"H6965\"his|strong=\"H5921\"people|strong=\"H3808\". You|strong=\"H0859\", I|strong=\"H3117\"say, are|strong=\"H3117\"witnesses|strong=\"H5707\"of|strong=\"H3117\"this|strong=\"H3117\"thing.",
      "11": "Then|strong=\"H0853\"all|strong=\"H3605\"the|strong=\"H3605\"people|strong=\"H5971\"that|strong=\"H0834\"were|strong=\"H0834\"in|strong=\"H0935\"the|strong=\"H3605\"gate|strong=\"H8179\", and|strong=\"H0935\"the|strong=\"H3605\"ancients answered|strong=\"H0559\": We|strong=\"H0834\"are|strong=\"H0834\"witnesses|strong=\"H5707\": The|strong=\"H3605\"Lord|strong=\"H3068\"make|strong=\"H5414\"this|strong=\"H0834\"woman|strong=\"H0802\"who|strong=\"H0834\"cometh into|strong=\"H0413\"thy house|strong=\"H1004\", like|strong=\"H0834\"Rachel|strong=\"H7354\", and|strong=\"H0935\"Lia, who|strong=\"H0834\"built|strong=\"H1129\"up|strong=\"H5414\"the|strong=\"H3605\"house|strong=\"H1004\"of|strong=\"H1004\"Israel|strong=\"H3478\": that|strong=\"H0834\"she|strong=\"H0834\"may|strong=\"H3068\"be|strong=\"H8034\"an|strong=\"H1129\"example of|strong=\"H1004\"virtue in|strong=\"H0935\"Ephrata, and|strong=\"H0935\"may|strong=\"H3068\"have|strong=\"H0834\"a|strong=\"H5414\"famous|strong=\"H8034\"name|strong=\"H8034\"in|strong=\"H0935\"Bethlehem|strong=\"H1035\":",
      "12": "And|strong=\"H3068\"that|strong=\"H0834\"the|strong=\"H0834\"house|strong=\"H1004\"may|strong=\"H1961\"be|strong=\"H1961\", as|strong=\"H0834\"the|strong=\"H0834\"house|strong=\"H1004\"of|strong=\"H1004\"Phares, whom|strong=\"H0834\"Thamar bore|strong=\"H3205\"unto Juda, of|strong=\"H1004\"the|strong=\"H0834\"seed|strong=\"H2233\"which|strong=\"H0834\"the|strong=\"H0834\"Lord|strong=\"H3068\"shall|strong=\"H3068\"give|strong=\"H5414\"thee of|strong=\"H1004\"this|strong=\"H2063\"young|strong=\"H5291\"woman|strong=\"H5291\".",
      "13": "Booz therefore|strong=\"H3068\"took|strong=\"H3947\"Ruth|strong=\"H7327\", and|strong=\"H1121\"married|strong=\"H3947\"her|strong=\"H0413\": and|strong=\"H1121\"went|strong=\"H0935\"in|strong=\"H0935\"unto her|strong=\"H0413\", and|strong=\"H1121\"the|strong=\"H0853\"Lord|strong=\"H3068\"gave|strong=\"H5414\"her|strong=\"H0413\"to|strong=\"H0413\"conceive|strong=\"H2032\"and|strong=\"H1121\"to|strong=\"H0413\"bear|strong=\"H3205\"a|strong=\"H1961\"son|strong=\"H1121\".",
      "14": "And|strong=\"H3068\"the|strong=\"H0559\"women|strong=\"H0802\"said|strong=\"H0559\"to|strong=\"H0413\"Noemi: Blessed|strong=\"H1288\"be|strong=\"H3808\"the|strong=\"H0559\"Lord|strong=\"H3068\", who|strong=\"H0834\"hath not|strong=\"H3808\"suffered thy family to|strong=\"H0413\"want a|strong=\"H7121\"successor, that|strong=\"H0834\"his|strong=\"H3068\"name|strong=\"H8034\"should|strong=\"H3068\"be|strong=\"H3808\"preserved in|strong=\"H0413\"Israel|strong=\"H3478\".",
      "15": "And|strong=\"H1121\"thou shouldst have|strong=\"H1961\"one|strong=\"H1931\"to|strong=\"H7725\"comfort thy soul|strong=\"H5315\", and|strong=\"H1121\"cherish thy old|strong=\"H1121\"age|strong=\"H1121\". For|strong=\"H3588\"he|strong=\"H0834\"is|strong=\"H0834\"born|strong=\"H3205\"of|strong=\"H1121\"thy daughter in|strong=\"H5315\"law: who|strong=\"H0834\"loveth thee: and|strong=\"H1121\"is|strong=\"H0834\"much|strong=\"H0834\"better|strong=\"H2896\"to|strong=\"H7725\"thee, than|strong=\"H2896\"if|strong=\"H3588\"thou hadst seven|strong=\"H7651\"sons|strong=\"H1121\".",
      "16": "And|strong=\"H0853\"Noemi taking|strong=\"H3947\"the|strong=\"H0853\"child|strong=\"H3206\"laid|strong=\"H7896\"it|strong=\"H1961\"in|strong=\"H0539\"her|strong=\"H3947\"bosom|strong=\"H2436\", and|strong=\"H0853\"she carried|strong=\"H3947\"it|strong=\"H1961\", and|strong=\"H0853\"was|strong=\"H1961\"a|strong=\"H1961\"nurse|strong=\"H0539\"unto it|strong=\"H1961\".",
      "17": "And|strong=\"H1121\"the|strong=\"H0559\"women|strong=\"H7934\"her|strong=\"H7121\"neighbours, congratulating with|strong=\"H1732\"her|strong=\"H7121\"and|strong=\"H1121\"saying|strong=\"H0559\": There is|strong=\"H1931\"a|strong=\"H3205\"son|strong=\"H1121\"born|strong=\"H3205\"to|strong=\"H0559\"Noemi: called|strong=\"H7121\"his|strong=\"H1732\"name|strong=\"H8034\"Obed|strong=\"H5744\": he|strong=\"H1931\"is|strong=\"H1931\"the|strong=\"H0559\"father|strong=\"H0001\"of|strong=\"H1121\"Isai, the|strong=\"H0559\"father|strong=\"H0001\"of|strong=\"H1121\"David|strong=\"H1732\".",
      "18": "These|strong=\"H0428\"are|strong=\"H0428\"the|strong=\"H0853\"generations|strong=\"H8435\"of|strong=\"H3205\"Phares: Phares begot|strong=\"H3205\"Esron,",
      "19": "Esron begot|strong=\"H3205\"Aram, Aram begot|strong=\"H3205\"Aminadab,",
      "20": "Aminadab begot|strong=\"H3205\"Nahasson, Nahasson begot|strong=\"H3205\"Salmon|strong=\"H8009\",",
      "21": "Salmon|strong=\"H8012\"begot|strong=\"H3205\"Booz, Booz begot|strong=\"H3205\"Obed|strong=\"H5744\",",
      "22": "Obed|strong=\"H5744\"begot|strong=\"H3205\"Isai, Isai begot|strong=\"H3205\"David|strong=\"H1732\"."
    }
