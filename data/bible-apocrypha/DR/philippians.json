    "2": {
      "1": "If|strong=\"G1487\"there|strong=\"G1722\"be|strong=\"G2532\"therefore|strong=\"G3767\"any|strong=\"G5100\"consolation|strong=\"G3874\"in|strong=\"G1722\"Christ|strong=\"G5547\", if|strong=\"G1487\"any|strong=\"G5100\"comfort|strong=\"G3874\"of|strong=\"G4151\"charity, if|strong=\"G1487\"any|strong=\"G5100\"society of|strong=\"G4151\"the|strong=\"G2532\"spirit|strong=\"G4151\", if|strong=\"G1487\"any|strong=\"G5100\"bowels of|strong=\"G4151\"commiseration:",
      "2": "Fulfill|strong=\"G4137\"ye my|strong=\"G2192\"joy|strong=\"G5479\", that|strong=\"G2443\"you|strong=\"G1520\"may|strong=\"G2443\"be|strong=\"G2192\"of|strong=\"G1520\"one|strong=\"G1520\"mind|strong=\"G5426\", having|strong=\"G2192\"the|strong=\"G3588\"same|strong=\"G0846\"charity, being|strong=\"G2192\"of|strong=\"G1520\"one|strong=\"G1520\"accord, agreeing in|strong=\"G2192\"sentiment.",
      "3": "Let nothing|strong=\"G3367\"be|strong=\"G3366\"done through|strong=\"G2596\"contention, neither|strong=\"G3366\"by|strong=\"G2596\"vain glory: but|strong=\"G0235\"in|strong=\"G2596\"humility|strong=\"G5012\", let each|strong=\"G2596\"esteem|strong=\"G2233\"others|strong=\"G3588\"better than|strong=\"G5242\"themselves|strong=\"G1438\":",
      "4": "Each|strong=\"G1538\"one|strong=\"G1538\"not|strong=\"G3361\"considering the|strong=\"G3588\"things|strong=\"G3588\"that|strong=\"G1438\"are|strong=\"G3588\"his|strong=\"G1438\"own|strong=\"G1438\", but|strong=\"G0235\"those|strong=\"G3588\"that|strong=\"G1438\"are|strong=\"G3588\"other|strong=\"G2087\"men’s.",
      "5": "For|strong=\"G1722\"let this|strong=\"G3778\"mind|strong=\"G5426\"be|strong=\"G2532\"in|strong=\"G1722\"you|strong=\"G5210\", which|strong=\"G3739\"was|strong=\"G2424\"also|strong=\"G2532\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\":",
      "6": "Who|strong=\"G3739\"being|strong=\"G1510\"in|strong=\"G1722\"the|strong=\"G3588\"form|strong=\"G3444\"of|strong=\"G2316\"God|strong=\"G2316\", thought|strong=\"G2233\"it|strong=\"G2233\"not|strong=\"G3756\"robbery to|strong=\"G1722\"be|strong=\"G1510\"equal|strong=\"G2470\"with|strong=\"G1722\"God|strong=\"G2316\":",
      "7": "But|strong=\"G0235\"emptied|strong=\"G2758\"himself|strong=\"G1438\", taking|strong=\"G2983\"the|strong=\"G2532\"form|strong=\"G3444\"of|strong=\"G1401\"a|strong=\"G5613\"servant|strong=\"G1401\", being|strong=\"G1096\"made|strong=\"G1096\"in|strong=\"G1722\"the|strong=\"G2532\"likeness|strong=\"G3667\"of|strong=\"G1401\"men|strong=\"G0444\", and|strong=\"G2532\"in|strong=\"G1722\"habit found|strong=\"G2147\"as|strong=\"G5613\"a|strong=\"G5613\"man|strong=\"G0444\".",
      "8": "He|strong=\"G1161\"humbled|strong=\"G5013\"himself|strong=\"G1438\", becoming|strong=\"G1096\"obedient|strong=\"G5255\"unto death|strong=\"G2288\", even|strong=\"G1161\"to|strong=\"G1096\"the|strong=\"G1161\"death|strong=\"G2288\"of|strong=\"G4716\"the|strong=\"G1161\"cross|strong=\"G4716\".",
      "9": "For|strong=\"G5228\"which|strong=\"G3588\"cause God|strong=\"G2316\"also|strong=\"G2532\"hath exalted|strong=\"G5251\"him|strong=\"G0846\", and|strong=\"G2532\"hath given|strong=\"G5483\"him|strong=\"G0846\"a|strong=\"G2532\"name|strong=\"G3686\"which|strong=\"G3588\"is|strong=\"G2316\"above|strong=\"G5228\"all|strong=\"G3956\"names|strong=\"G3686\":",
      "10": "That|strong=\"G2443\"in|strong=\"G1722\"the|strong=\"G3956\"name|strong=\"G3686\"of|strong=\"G3686\"Jesus|strong=\"G2424\"every|strong=\"G3956\"knee|strong=\"G1119\"should|strong=\"G2443\"bow|strong=\"G2578\", of|strong=\"G3686\"those|strong=\"G3588\"that|strong=\"G2443\"are|strong=\"G3956\"in|strong=\"G1722\"heaven|strong=\"G2032\", on|strong=\"G1722\"earth|strong=\"G1919\", and|strong=\"G2532\"under|strong=\"G1722\"the|strong=\"G3956\"earth|strong=\"G1919\":",
      "11": "And|strong=\"G2532\"that|strong=\"G3754\"every|strong=\"G3956\"tongue|strong=\"G1100\"should|strong=\"G2316\"confess|strong=\"G1843\"that|strong=\"G3754\"the|strong=\"G3956\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"is|strong=\"G2316\"in|strong=\"G1519\"the|strong=\"G3956\"glory|strong=\"G1391\"of|strong=\"G2316\"God|strong=\"G2316\"the|strong=\"G3956\"Father|strong=\"G3962\".",
      "12": "Wherefore, my|strong=\"G1722\"dearly beloved|strong=\"G0027\", (as|strong=\"G5613\"you|strong=\"G1722\"have|strong=\"G2532\"always|strong=\"G3842\"obeyed|strong=\"G5219\", not|strong=\"G3361\"as|strong=\"G5613\"in|strong=\"G1722\"my|strong=\"G1722\"presence|strong=\"G3952\"only|strong=\"G3440\", but|strong=\"G0235\"much|strong=\"G4183\"more|strong=\"G3123\"now|strong=\"G3568\"in|strong=\"G1722\"my|strong=\"G1722\"absence|strong=\"G0666\",) with|strong=\"G3326\"fear|strong=\"G5401\"and|strong=\"G2532\"trembling|strong=\"G5156\"work|strong=\"G2716\"out|strong=\"G1438\"your|strong=\"G2532\"salvation|strong=\"G4991\".",
      "13": "For|strong=\"G1063\"it|strong=\"G1510\"is|strong=\"G1510\"God|strong=\"G2316\"who|strong=\"G3588\"worketh in|strong=\"G1722\"you|strong=\"G5210\", both|strong=\"G2532\"to|strong=\"G2309\"will|strong=\"G2316\"and|strong=\"G2532\"to|strong=\"G2309\"accomplish|strong=\"G1754\", according to|strong=\"G2309\"his|strong=\"G2532\"good|strong=\"G2107\"will|strong=\"G2316\".",
      "14": "And|strong=\"G2532\"do|strong=\"G4160\"ye all|strong=\"G3956\"things|strong=\"G3956\"without|strong=\"G5565\"murmurings and|strong=\"G2532\"hesitations;",
      "15": "That|strong=\"G3739\"you|strong=\"G3739\"may|strong=\"G2532\"be|strong=\"G1096\"blameless|strong=\"G0273\", and|strong=\"G2532\"sincere children|strong=\"G5043\"of|strong=\"G2316\"God|strong=\"G2316\", without|strong=\"G0273\"reproof, in|strong=\"G1722\"the|strong=\"G2532\"midst|strong=\"G3319\"of|strong=\"G2316\"a|strong=\"G5613\"crooked|strong=\"G4646\"and|strong=\"G2532\"perverse|strong=\"G1294\"generation|strong=\"G1074\"; among|strong=\"G1722\"whom|strong=\"G3739\"you|strong=\"G3739\"shine|strong=\"G5316\"as|strong=\"G5613\"lights|strong=\"G5458\"in|strong=\"G1722\"the|strong=\"G2532\"world|strong=\"G2889\".",
      "16": "Holding|strong=\"G1907\"forth the|strong=\"G1519\"word|strong=\"G3056\"of|strong=\"G3056\"life|strong=\"G2222\"to|strong=\"G1519\"my|strong=\"G3754\"glory|strong=\"G2745\"in|strong=\"G1519\"the|strong=\"G1519\"day|strong=\"G2250\"of|strong=\"G3056\"Christ|strong=\"G5547\", because|strong=\"G3754\"I|strong=\"G1473\"have|strong=\"G3748\"not|strong=\"G3756\"run|strong=\"G5143\"in|strong=\"G1519\"vain|strong=\"G2756\", nor|strong=\"G3761\"laboured in|strong=\"G1519\"vain|strong=\"G2756\".",
      "17": "Yea, and|strong=\"G2532\"if|strong=\"G1487\"I|strong=\"G2532\"be|strong=\"G2532\"made a|strong=\"G1487\"victim upon|strong=\"G1909\"the|strong=\"G3956\"sacrifice|strong=\"G2378\"and|strong=\"G2532\"service|strong=\"G3009\"of|strong=\"G1909\"your|strong=\"G1487\"faith|strong=\"G4102\", I|strong=\"G2532\"rejoice|strong=\"G5463\", and|strong=\"G2532\"congratulate with|strong=\"G1909\"you|strong=\"G5210\"all|strong=\"G3956\".",
