    "1": {
      "1": "Paul|strong=\"G3972\"and|strong=\"G2532\"Timothy|strong=\"G5095\", the|strong=\"G3956\"servants|strong=\"G1249\"of|strong=\"G1401\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"; to|strong=\"G2532\"all|strong=\"G3956\"the|strong=\"G3956\"saints|strong=\"G0040\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", who|strong=\"G3588\"are|strong=\"G1510\"at|strong=\"G1722\"Philippi|strong=\"G5375\", with|strong=\"G1722\"the|strong=\"G3956\"bishops and|strong=\"G2532\"deacons|strong=\"G1249\".",
      "2": "Grace|strong=\"G5485\"be|strong=\"G2532\"unto you|strong=\"G5210\", and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G0575\"God|strong=\"G2316\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"the|strong=\"G2532\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "3": "I|strong=\"G1473\"give|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G1909\"my|strong=\"G3956\"God|strong=\"G2316\"in|strong=\"G1909\"every|strong=\"G3956\"remembrance|strong=\"G3417\"of|strong=\"G2316\"you|strong=\"G5210\",",
      "4": "Always|strong=\"G3842\"in|strong=\"G1722\"all|strong=\"G3956\"my|strong=\"G3956\"prayers|strong=\"G1162\"making|strong=\"G4160\"supplication|strong=\"G1162\"for|strong=\"G5228\"you|strong=\"G5210\"all|strong=\"G3956\", with|strong=\"G3326\"joy|strong=\"G5479\";",
      "5": "For|strong=\"G1519\"your|strong=\"G3588\"communication in|strong=\"G1519\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2250\"Christ from|strong=\"G0575\"the|strong=\"G3588\"first|strong=\"G4413\"day|strong=\"G2250\"until|strong=\"G0891\"now|strong=\"G3568\".",
      "6": "Being|strong=\"G2250\"confident|strong=\"G3982\"of|strong=\"G2250\"this|strong=\"G3778\"very|strong=\"G0846\"thing|strong=\"G0018\", that|strong=\"G3754\"he|strong=\"G0846\", who|strong=\"G3588\"hath begun|strong=\"G1728\"a|strong=\"G2250\"good|strong=\"G0018\"work|strong=\"G2041\"in|strong=\"G1722\"you|strong=\"G5210\", will|strong=\"G2250\"perfect|strong=\"G2005\"it|strong=\"G0846\"unto the|strong=\"G3588\"day|strong=\"G2250\"of|strong=\"G2250\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "7": "As|strong=\"G2531\"it|strong=\"G1223\"is|strong=\"G1510\"meet for|strong=\"G5228\"me|strong=\"G1473\"to|strong=\"G2532\"think|strong=\"G5426\"this|strong=\"G3778\"for|strong=\"G5228\"you|strong=\"G5210\"all|strong=\"G3956\", for|strong=\"G5228\"that|strong=\"G3778\"I|strong=\"G1473\"have|strong=\"G2192\"you|strong=\"G5210\"in|strong=\"G1722\"my|strong=\"G3956\"heart|strong=\"G2588\"; and|strong=\"G2532\"that|strong=\"G3778\"in|strong=\"G1722\"my|strong=\"G3956\"bands, and|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G3956\"defence and|strong=\"G2532\"confirmation|strong=\"G0951\"of|strong=\"G1223\"the|strong=\"G3956\"gospel|strong=\"G2098\", you|strong=\"G5210\"all|strong=\"G3956\"are|strong=\"G1510\"partakers|strong=\"G4791\"of|strong=\"G1223\"my|strong=\"G3956\"joy|strong=\"G5485\".",
      "8": "For|strong=\"G1063\"God|strong=\"G2316\"is|strong=\"G2316\"my|strong=\"G3956\"witness|strong=\"G3144\", how|strong=\"G5613\"I|strong=\"G1473\"long|strong=\"G1971\"after|strong=\"G5613\"you|strong=\"G5210\"all|strong=\"G3956\"in|strong=\"G1722\"the|strong=\"G3956\"bowels of|strong=\"G2316\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "9": "And|strong=\"G2532\"this|strong=\"G3778\"I|strong=\"G2532\"pray|strong=\"G4336\", that|strong=\"G2443\"your|strong=\"G2532\"charity may|strong=\"G2532\"more|strong=\"G3123\"and|strong=\"G2532\"more|strong=\"G3123\"abound|strong=\"G4052\"in|strong=\"G1722\"knowledge|strong=\"G1922\", and|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\"understanding:",
      "10": "That|strong=\"G2443\"you|strong=\"G5210\"may|strong=\"G2532\"approve|strong=\"G1381\"the|strong=\"G3588\"better things|strong=\"G3588\", that|strong=\"G2443\"you|strong=\"G5210\"may|strong=\"G2532\"be|strong=\"G1510\"sincere|strong=\"G1506\"and|strong=\"G2532\"without|strong=\"G2532\"offence unto the|strong=\"G3588\"day|strong=\"G2250\"of|strong=\"G2250\"Christ|strong=\"G5547\",",
      "11": "Filled|strong=\"G4137\"with|strong=\"G1223\"the|strong=\"G3588\"fruit|strong=\"G2590\"of|strong=\"G1223\"justice|strong=\"G1343\", through|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", unto the|strong=\"G3588\"glory|strong=\"G1391\"and|strong=\"G2532\"praise|strong=\"G1868\"of|strong=\"G1223\"God|strong=\"G2316\".",
      "12": "Now|strong=\"G1161\", brethren|strong=\"G0080\", I|strong=\"G1473\"desire|strong=\"G1014\"you|strong=\"G5210\"should|strong=\"G0080\"know|strong=\"G1097\", that|strong=\"G3754\"the|strong=\"G3588\"things|strong=\"G3588\"which|strong=\"G3748\"have|strong=\"G3748\"happened|strong=\"G3588\"to|strong=\"G1519\"me|strong=\"G1473\", have|strong=\"G3748\"fallen out rather|strong=\"G3123\"to|strong=\"G1519\"the|strong=\"G3588\"furtherance of|strong=\"G2098\"the|strong=\"G3588\"gospel|strong=\"G2098\":",
      "13": "So|strong=\"G2532\"that|strong=\"G5620\"my|strong=\"G3956\"bands are|strong=\"G3956\"made|strong=\"G1096\"manifest in|strong=\"G1722\"Christ|strong=\"G5547\", in|strong=\"G1722\"all|strong=\"G3956\"the|strong=\"G3956\"court, and|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\"other|strong=\"G3062\"places;",
      "14": "And|strong=\"G2532\"many|strong=\"G4183\"of|strong=\"G3056\"the|strong=\"G3588\"brethren|strong=\"G0080\"in|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\", growing|strong=\"G1722\"confident|strong=\"G3982\"by|strong=\"G1722\"my|strong=\"G1722\"bands, are|strong=\"G3588\"much|strong=\"G4183\"more|strong=\"G4183\"bold|strong=\"G5111\"to|strong=\"G2532\"speak|strong=\"G2980\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G2316\"without|strong=\"G0870\"fear|strong=\"G0870\".",
      "15": "Some|strong=\"G5100\"indeed|strong=\"G2532\", even|strong=\"G2532\"out of|strong=\"G1223\"envy|strong=\"G5355\"and|strong=\"G2532\"contention; but|strong=\"G1161\"some|strong=\"G5100\"also|strong=\"G2532\"for|strong=\"G1223\"good|strong=\"G2107\"will|strong=\"G5100\"preach|strong=\"G2784\"Christ|strong=\"G5547\".",
      "16": "Some|strong=\"G1537\"out|strong=\"G1537\"of|strong=\"G1537\"charity, knowing|strong=\"G1492\"that|strong=\"G3754\"I|strong=\"G3754\"am set|strong=\"G2749\"for|strong=\"G1519\"the|strong=\"G3588\"defence of|strong=\"G1537\"the|strong=\"G3588\"gospel|strong=\"G2098\".",
      "17": "And|strong=\"G1161\"some|strong=\"G1537\"out|strong=\"G1537\"of|strong=\"G1537\"contention preach Christ|strong=\"G5547\"not|strong=\"G3756\"sincerely|strong=\"G0055\": supposing that|strong=\"G1161\"they|strong=\"G1161\"raise|strong=\"G1453\"affliction|strong=\"G2347\"to|strong=\"G5547\"my bands.",
      "18": "But|strong=\"G0235\"what|strong=\"G5101\"then|strong=\"G2532\"? So|strong=\"G2532\"that|strong=\"G3754\"by|strong=\"G1722\"all|strong=\"G3956\"means|strong=\"G1722\", whether|strong=\"G1535\"by|strong=\"G1722\"occasion, or|strong=\"G2532\"by|strong=\"G1722\"truth|strong=\"G0225\", Christ|strong=\"G5547\"be|strong=\"G2532\"preached: in|strong=\"G1722\"this|strong=\"G3778\"also|strong=\"G2532\"I|strong=\"G2532\"rejoice|strong=\"G5463\", yea, and|strong=\"G2532\"will|strong=\"G5101\"rejoice|strong=\"G5463\".",
      "19": "For|strong=\"G1063\"I|strong=\"G1473\"know|strong=\"G1492\"that|strong=\"G3754\"this|strong=\"G3778\"shall|strong=\"G3778\"fall out to|strong=\"G1519\"me|strong=\"G1473\"unto salvation|strong=\"G4991\", through|strong=\"G1223\"your|strong=\"G2532\"prayer|strong=\"G1162\", and|strong=\"G2532\"the|strong=\"G3588\"supply of|strong=\"G4151\"the|strong=\"G3588\"Spirit|strong=\"G4151\"of|strong=\"G4151\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\",",
      "20": "According|strong=\"G2596\"to|strong=\"G2596\"my|strong=\"G3956\"expectation|strong=\"G0603\"and|strong=\"G2532\"hope|strong=\"G1680\"; that|strong=\"G3754\"in|strong=\"G1722\"nothing|strong=\"G3762\"I|strong=\"G1473\"shall|strong=\"G2532\"be|strong=\"G2532\"confounded, but|strong=\"G0235\"with|strong=\"G1722\"all|strong=\"G3956\"confidence|strong=\"G3954\", as|strong=\"G5613\"always|strong=\"G3842\", so|strong=\"G2532\"now|strong=\"G3568\"also|strong=\"G2532\"shall|strong=\"G2532\"Christ|strong=\"G5547\"be|strong=\"G2532\"magnified|strong=\"G3170\"in|strong=\"G1722\"my|strong=\"G3956\"body|strong=\"G4983\", wither it|strong=\"G1223\"be|strong=\"G2532\"by|strong=\"G1722\"life|strong=\"G2222\", or|strong=\"G2532\"by|strong=\"G1722\"death|strong=\"G2288\".",
      "21": "For|strong=\"G1063\"to|strong=\"G2532\"me|strong=\"G1473\", to|strong=\"G2532\"live|strong=\"G2198\"is|strong=\"G3588\"Christ|strong=\"G5547\"; and|strong=\"G2532\"to|strong=\"G2532\"die|strong=\"G0599\"is|strong=\"G3588\"gain|strong=\"G2771\".",
      "22": "And|strong=\"G2532\"if|strong=\"G1487\"to|strong=\"G2532\"live|strong=\"G2198\"in|strong=\"G1722\"the|strong=\"G3588\"flesh|strong=\"G4561\", this|strong=\"G3778\"is|strong=\"G5101\"to|strong=\"G2532\"me|strong=\"G1473\"the|strong=\"G3588\"fruit|strong=\"G2590\"of|strong=\"G2041\"labour, and|strong=\"G2532\"what|strong=\"G5101\"I|strong=\"G1473\"shall|strong=\"G3778\"choose|strong=\"G0138\"I|strong=\"G1473\"know|strong=\"G1107\"not|strong=\"G3756\".",
      "23": "But|strong=\"G1161\"I|strong=\"G2532\"am|strong=\"G1510\"straitened between|strong=\"G1537\"two|strong=\"G1417\": having|strong=\"G2192\"a|strong=\"G2192\"desire|strong=\"G1939\"to|strong=\"G1519\"be|strong=\"G1510\"dissolved and|strong=\"G2532\"to|strong=\"G1519\"be|strong=\"G1510\"with|strong=\"G4862\"Christ|strong=\"G5547\", a|strong=\"G2192\"thing by|strong=\"G1537\"far|strong=\"G3588\"the|strong=\"G3588\"better|strong=\"G2909\".",
      "24": "But|strong=\"G1161\"to|strong=\"G1722\"abide still in|strong=\"G1722\"the|strong=\"G3588\"flesh|strong=\"G4561\", is|strong=\"G3588\"needful for|strong=\"G1223\"you|strong=\"G5210\".",
      "25": "And|strong=\"G2532\"having|strong=\"G3982\"this|strong=\"G3778\"confidence|strong=\"G3982\", I|strong=\"G2532\"know|strong=\"G1492\"that|strong=\"G3754\"I|strong=\"G2532\"shall|strong=\"G3778\"abide|strong=\"G3306\", and|strong=\"G2532\"continue|strong=\"G3306\"with|strong=\"G2532\"you|strong=\"G5210\"all|strong=\"G3956\", for|strong=\"G1519\"your|strong=\"G2532\"furtherance and|strong=\"G2532\"joy|strong=\"G5479\"of|strong=\"G3956\"faith|strong=\"G4102\":",
      "26": "That|strong=\"G2443\"your|strong=\"G1223\"rejoicing may|strong=\"G2443\"abound|strong=\"G4052\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"for|strong=\"G1223\"me|strong=\"G1473\", by|strong=\"G1722\"my|strong=\"G1699\"coming|strong=\"G3952\"to|strong=\"G4314\"you|strong=\"G5210\"again|strong=\"G3825\".",
      "27": "Only|strong=\"G3440\"let|strong=\"G2443\"your|strong=\"G3708\"conversation be|strong=\"G2532\"worthy|strong=\"G0516\"of|strong=\"G4151\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G4151\"Christ|strong=\"G5547\": that|strong=\"G3754\", whether|strong=\"G1535\"I|strong=\"G2532\"come|strong=\"G2064\"and|strong=\"G2532\"see|strong=\"G3708\"you|strong=\"G5210\", or|strong=\"G2532\", being|strong=\"G4771\"absent|strong=\"G0548\", may|strong=\"G2532\"hear|strong=\"G0191\"of|strong=\"G4151\"you|strong=\"G5210\", that|strong=\"G3754\"you|strong=\"G5210\"stand|strong=\"G4739\"fast in|strong=\"G1722\"one|strong=\"G1520\"spirit|strong=\"G4151\", with|strong=\"G1722\"one|strong=\"G1520\"mind|strong=\"G5590\"labouring together|strong=\"G4866\"for|strong=\"G3754\"the|strong=\"G3588\"faith|strong=\"G4102\"of|strong=\"G4151\"the|strong=\"G3588\"gospel|strong=\"G2098\".",
      "28": "And|strong=\"G2532\"in|strong=\"G1722\"nothing|strong=\"G3367\"be|strong=\"G1510\"ye terrified by|strong=\"G1722\"the|strong=\"G3588\"adversaries|strong=\"G0480\": which|strong=\"G3748\"to|strong=\"G2532\"them|strong=\"G0846\"is|strong=\"G1510\"a|strong=\"G1510\"cause of|strong=\"G0575\"perdition|strong=\"G0684\", but|strong=\"G1161\"to|strong=\"G2532\"you|strong=\"G5210\"of|strong=\"G0575\"salvation|strong=\"G4991\", and|strong=\"G2532\"this|strong=\"G3778\"from|strong=\"G0575\"God|strong=\"G2316\":",
      "29": "For|strong=\"G1519\"unto you|strong=\"G5210\"it|strong=\"G0846\"is|strong=\"G3588\"given|strong=\"G5483\"for|strong=\"G1519\"Christ|strong=\"G5547\", not|strong=\"G3756\"only|strong=\"G3440\"to|strong=\"G1519\"believe|strong=\"G4100\"in|strong=\"G1519\"him|strong=\"G0846\", but|strong=\"G0235\"also|strong=\"G2532\"to|strong=\"G1519\"suffer|strong=\"G3958\"for|strong=\"G1519\"him|strong=\"G0846\".",
      "30": "Having|strong=\"G2192\"the|strong=\"G3588\"same|strong=\"G0846\"conflict|strong=\"G0073\"as|strong=\"G1722\"that|strong=\"G0191\"which|strong=\"G3588\"you|strong=\"G1722\"have|strong=\"G2192\"seen|strong=\"G3708\"in|strong=\"G1722\"me|strong=\"G1473\", and|strong=\"G2532\"now|strong=\"G3568\"have|strong=\"G2192\"heard|strong=\"G0191\"of|strong=\"G1722\"me|strong=\"G1473\"."
