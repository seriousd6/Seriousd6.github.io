      "4": "By|strong=\"G1722\"whom|strong=\"G3739\"he|strong=\"G2532\"hath given us|strong=\"G1722\"most great|strong=\"G3173\"and|strong=\"G2532\"precious|strong=\"G5093\"promises|strong=\"G1862\": that|strong=\"G3739\"by|strong=\"G1722\"these|strong=\"G3778\"you|strong=\"G3739\"may|strong=\"G2532\"be|strong=\"G1096\"made|strong=\"G1096\"partakers|strong=\"G2844\"of|strong=\"G1223\"the|strong=\"G3588\"divine|strong=\"G2304\"nature|strong=\"G5449\": flying the|strong=\"G3588\"corruption|strong=\"G5356\"of|strong=\"G1223\"that|strong=\"G3739\"concupiscence which|strong=\"G3739\"is|strong=\"G3778\"in|strong=\"G1722\"the|strong=\"G3588\"world|strong=\"G2889\".",
      "5": "And|strong=\"G2532\"you|strong=\"G5210\", employing all|strong=\"G3956\"care, minister in|strong=\"G1722\"your|strong=\"G2532\"faith|strong=\"G4102\", virtue; and|strong=\"G2532\"in|strong=\"G1722\"virtue, knowledge|strong=\"G1108\";",
      "6": "And|strong=\"G1161\"in|strong=\"G1722\"knowledge|strong=\"G1108\", abstinence; and|strong=\"G1161\"in|strong=\"G1722\"abstinence, patience|strong=\"G5281\"; and|strong=\"G1161\"in|strong=\"G1722\"patience|strong=\"G5281\", godliness|strong=\"G2150\";",
      "7": "And|strong=\"G1161\"in|strong=\"G1722\"godliness|strong=\"G2150\", love|strong=\"G0026\"of|strong=\"G0026\"brotherhood; and|strong=\"G1161\"in|strong=\"G1722\"love|strong=\"G0026\"of|strong=\"G0026\"brotherhood, charity.",
      "8": "For|strong=\"G1063\"if|strong=\"G2532\"these|strong=\"G3778\"things|strong=\"G3778\"be|strong=\"G2532\"with|strong=\"G2532\"you|strong=\"G5210\"and|strong=\"G2532\"abound, they|strong=\"G2532\"will|strong=\"G2962\"make|strong=\"G3756\"you|strong=\"G5210\"to|strong=\"G1519\"be|strong=\"G2532\"neither|strong=\"G3756\"empty nor|strong=\"G3761\"unfruitful|strong=\"G0175\"in|strong=\"G1519\"the|strong=\"G3588\"knowledge|strong=\"G1922\"of|strong=\"G2962\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "9": "For|strong=\"G1063\"he|strong=\"G0846\"that|strong=\"G3739\"hath not|strong=\"G3361\"these|strong=\"G3778\"things|strong=\"G3778\"with|strong=\"G0846\"him|strong=\"G0846\", is|strong=\"G1510\"blind|strong=\"G5185\", and|strong=\"G0846\"groping, having forgotten that|strong=\"G3739\"he|strong=\"G0846\"was|strong=\"G1510\"purged from|strong=\"G3361\"his|strong=\"G0846\"old sins|strong=\"G0265\".",
      "10": "Wherefore|strong=\"G1352\", brethren|strong=\"G0080\", labour the|strong=\"G3588\"more|strong=\"G3123\", that|strong=\"G3778\"by|strong=\"G2532\"good works you|strong=\"G5210\"may|strong=\"G2532\"make|strong=\"G4160\"sure|strong=\"G0949\"your|strong=\"G4160\"calling|strong=\"G2821\"and|strong=\"G2532\"election|strong=\"G1589\". For|strong=\"G1063\"doing|strong=\"G4160\"these|strong=\"G3778\"things|strong=\"G3778\", you|strong=\"G5210\"shall|strong=\"G3778\"not|strong=\"G3756\"sin at|strong=\"G3588\"any|strong=\"G3756\"time|strong=\"G4218\".",
      "11": "For|strong=\"G1063\"so|strong=\"G2532\"an|strong=\"G2532\"entrance|strong=\"G1529\"shall|strong=\"G2532\"be|strong=\"G2532\"ministered to|strong=\"G1519\"you|strong=\"G5210\"abundantly|strong=\"G4146\"into|strong=\"G1519\"the|strong=\"G3588\"everlasting kingdom|strong=\"G0932\"of|strong=\"G0932\"our|strong=\"G2424\"Lord|strong=\"G2962\"and|strong=\"G2532\"Saviour Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "12": "For|strong=\"G4012\"which|strong=\"G3588\"cause I|strong=\"G2532\"will|strong=\"G3195\"begin to|strong=\"G3195\"put you|strong=\"G5210\"always|strong=\"G0104\"in|strong=\"G1722\"remembrance|strong=\"G5279\"of|strong=\"G4012\"these|strong=\"G3778\"things|strong=\"G3778\": though|strong=\"G2532\"indeed|strong=\"G2532\"you|strong=\"G5210\"know|strong=\"G1492\"them|strong=\"G1722\", and|strong=\"G2532\"are|strong=\"G3778\"confirmed in|strong=\"G1722\"the|strong=\"G3588\"present|strong=\"G3778\"truth|strong=\"G0225\".",
      "13": "But|strong=\"G1161\"I|strong=\"G3778\"think it|strong=\"G2233\"meet as|strong=\"G1722\"long|strong=\"G3745\"as|strong=\"G1722\"I|strong=\"G3778\"am|strong=\"G1510\"in|strong=\"G1722\"this|strong=\"G3778\"tabernacle|strong=\"G4638\", to|strong=\"G1909\"stir|strong=\"G1326\"you|strong=\"G5210\"up by|strong=\"G1722\"putting you|strong=\"G5210\"in|strong=\"G1722\"remembrance.",
