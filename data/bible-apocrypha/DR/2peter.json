      "15": "And|strong=\"G2532\"I|strong=\"G2532\"will|strong=\"G3778\"endeavour, that|strong=\"G3778\"you|strong=\"G5210\"frequently have|strong=\"G2192\"after|strong=\"G3326\"my|strong=\"G1699\"decease, whereby you|strong=\"G5210\"may|strong=\"G2532\"keep|strong=\"G4160\"a|strong=\"G2192\"memory of|strong=\"G2192\"these|strong=\"G3778\"things|strong=\"G3778\".",
      "16": "For|strong=\"G1063\"we|strong=\"G2249\"have|strong=\"G2532\"not|strong=\"G3756\"by|strong=\"G2532\"following artificial fables|strong=\"G3454\", made|strong=\"G1096\"known|strong=\"G1107\"to|strong=\"G2532\"you|strong=\"G5210\"the|strong=\"G3588\"power|strong=\"G1411\", and|strong=\"G2532\"presence|strong=\"G3952\"of|strong=\"G1411\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"; but|strong=\"G0235\"we|strong=\"G2249\"were|strong=\"G1096\"eyewitnesses|strong=\"G2030\"of|strong=\"G1411\"his|strong=\"G2532\"greatness|strong=\"G3168\".",
      "17": "For|strong=\"G1063\"he|strong=\"G2532\"received|strong=\"G2983\"from|strong=\"G3844\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", honour and|strong=\"G2532\"glory|strong=\"G1391\": this|strong=\"G3778\"voice|strong=\"G5456\"coming down to|strong=\"G1519\"him|strong=\"G0846\"from|strong=\"G3844\"the|strong=\"G3588\"excellent glory|strong=\"G1391\": This|strong=\"G3778\"is|strong=\"G1510\"my|strong=\"G5259\"beloved|strong=\"G0027\"Son|strong=\"G5207\", in|strong=\"G1519\"whom|strong=\"G3739\"I|strong=\"G1473\"am|strong=\"G1510\"well|strong=\"G2532\"pleased|strong=\"G2106\"; hear ye him|strong=\"G0846\".",
      "18": "And|strong=\"G2532\"this|strong=\"G3778\"voice|strong=\"G5456\"we|strong=\"G2249\"heard|strong=\"G0191\"brought|strong=\"G5342\"from|strong=\"G1537\"heaven|strong=\"G3772\", when|strong=\"G2532\"we|strong=\"G2249\"were|strong=\"G1510\"with|strong=\"G1722\"him|strong=\"G0846\"in|strong=\"G1722\"the|strong=\"G3588\"holy|strong=\"G0040\"mount|strong=\"G3735\".",
      "19": "And|strong=\"G2532\"we|strong=\"G3739\"have|strong=\"G2192\"the|strong=\"G3588\"more|strong=\"G0949\"firm|strong=\"G0949\"prophetical word|strong=\"G3056\": whereunto you|strong=\"G5210\"do|strong=\"G4160\"well|strong=\"G2573\"to|strong=\"G2193\"attend, as|strong=\"G5613\"to|strong=\"G2193\"a|strong=\"G2192\"light|strong=\"G5316\"that|strong=\"G3739\"shineth in|strong=\"G1722\"a|strong=\"G2192\"dark place|strong=\"G5117\", until|strong=\"G2193\"the|strong=\"G3588\"day|strong=\"G2250\"dawn, and|strong=\"G2532\"the|strong=\"G3588\"day|strong=\"G2250\"star|strong=\"G5459\"arise in|strong=\"G1722\"your|strong=\"G2192\"hearts|strong=\"G2588\":",
      "20": "Understanding this|strong=\"G3778\"first|strong=\"G4413\", that|strong=\"G3754\"no|strong=\"G3756\"prophecy|strong=\"G4394\"of|strong=\"G3956\"scripture|strong=\"G1124\"is|strong=\"G3778\"made|strong=\"G1096\"by|strong=\"G1097\"private interpretation|strong=\"G1955\".",
