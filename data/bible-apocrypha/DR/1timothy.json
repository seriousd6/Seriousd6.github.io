      "15": "Which|strong=\"G3739\"in|strong=\"G2532\"his|strong=\"G3739\"times|strong=\"G2540\"he|strong=\"G2532\"shall|strong=\"G2532\"shew who|strong=\"G3739\"is|strong=\"G3739\"the|strong=\"G3588\"Blessed|strong=\"G3107\"and|strong=\"G2532\"only|strong=\"G3441\"Mighty, the|strong=\"G3588\"King|strong=\"G0935\"of|strong=\"G2962\"kings|strong=\"G0935\", and|strong=\"G2532\"Lord|strong=\"G2962\"of|strong=\"G2962\"lords|strong=\"G2962\";",
      "16": "Who|strong=\"G3739\"only|strong=\"G3441\"hath immortality|strong=\"G0110\", and|strong=\"G2532\"inhabiteth light|strong=\"G5457\"inaccessible, whom|strong=\"G3739\"no|strong=\"G3762\"man|strong=\"G0444\"hath seen|strong=\"G3708\", nor|strong=\"G3761\"can|strong=\"G1410\"see|strong=\"G3708\": to|strong=\"G1410\"whom|strong=\"G3739\"be|strong=\"G2532\"honour and|strong=\"G2532\"empire everlasting. Amen|strong=\"G0281\".",
      "17": "Charge|strong=\"G3853\"the|strong=\"G3956\"rich|strong=\"G4145\"of|strong=\"G2316\"this|strong=\"G3588\"world|strong=\"G0165\"not|strong=\"G3361\"to|strong=\"G1519\"be|strong=\"G3956\"highminded, nor|strong=\"G3366\"to|strong=\"G1519\"trust|strong=\"G1679\"in|strong=\"G1722\"the|strong=\"G3956\"uncertainty|strong=\"G0083\"of|strong=\"G2316\"riches|strong=\"G4149\", but|strong=\"G0235\"in|strong=\"G1722\"the|strong=\"G3956\"living God|strong=\"G2316\", (who|strong=\"G3588\"giveth us|strong=\"G1519\"abundantly|strong=\"G4146\"all|strong=\"G3956\"things|strong=\"G3956\"to|strong=\"G1519\"enjoy|strong=\"G0619\",)",
      "18": "To|strong=\"G1722\"do|strong=\"G1510\"good|strong=\"G2570\", to|strong=\"G1722\"be|strong=\"G1510\"rich|strong=\"G4147\"in|strong=\"G1722\"good|strong=\"G2570\"works|strong=\"G2041\", to|strong=\"G1722\"give easily, to|strong=\"G1722\"communicate to|strong=\"G1722\"others,",
      "19": "To|strong=\"G1519\"lay up|strong=\"G1519\"in|strong=\"G1519\"store for|strong=\"G1519\"themselves|strong=\"G1438\"a|strong=\"G1438\"good|strong=\"G2570\"foundation|strong=\"G2310\"against|strong=\"G1519\"the|strong=\"G3588\"time to|strong=\"G1519\"come|strong=\"G3195\", that|strong=\"G2443\"they may|strong=\"G2443\"lay hold|strong=\"G1949\"on|strong=\"G1519\"the|strong=\"G3588\"true life|strong=\"G2222\".",
      "20": "O|strong=\"G5599\"Timothy|strong=\"G5095\", keep|strong=\"G5442\"that which|strong=\"G3588\"is|strong=\"G3588\"committed to|strong=\"G2532\"thy trust, avoiding|strong=\"G1624\"the|strong=\"G3588\"profane|strong=\"G0952\"novelties of|strong=\"G3588\"words|strong=\"G2532\", and|strong=\"G2532\"oppositions of|strong=\"G3588\"knowledge|strong=\"G1108\"falsely|strong=\"G5581\"so|strong=\"G2532\"called|strong=\"G5581\".",
      "21": "Which|strong=\"G3739\"some|strong=\"G5100\"promising|strong=\"G1861\", have|strong=\"G5100\"erred concerning|strong=\"G4012\"the|strong=\"G3588\"faith|strong=\"G4102\". Grace|strong=\"G5485\"be|strong=\"G3326\"with|strong=\"G3326\"thee. Amen."
