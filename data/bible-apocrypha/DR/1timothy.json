    "1": {
      "1": "Paul|strong=\"G3972\", an|strong=\"G2532\"apostle|strong=\"G0652\"of|strong=\"G2316\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"commandment|strong=\"G2003\"of|strong=\"G2316\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour, and|strong=\"G2532\"of|strong=\"G2316\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"our|strong=\"G2316\"hope|strong=\"G1680\":",
      "2": "To|strong=\"G2532\"Timothy|strong=\"G5095\", his|strong=\"G2532\"beloved son|strong=\"G5043\"in|strong=\"G1722\"faith|strong=\"G4102\". Grace|strong=\"G5485\", mercy|strong=\"G1656\", and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G0575\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"our|strong=\"G2316\"Lord|strong=\"G2962\".",
      "3": "As|strong=\"G2531\"I|strong=\"G1722\"desired thee to|strong=\"G1519\"remain|strong=\"G4357\"at|strong=\"G1722\"Ephesus|strong=\"G2181\"when|strong=\"G1722\"I|strong=\"G1722\"went|strong=\"G4198\"into|strong=\"G1519\"Macedonia|strong=\"G3109\", that|strong=\"G2443\"thou mightest charge|strong=\"G3853\"some|strong=\"G5100\"not|strong=\"G3361\"to|strong=\"G1519\"teach|strong=\"G2085\"otherwise|strong=\"G2443\",",
      "4": "Not|strong=\"G3366\"to|strong=\"G2532\"give|strong=\"G3930\"heed to|strong=\"G2532\"fables|strong=\"G3454\"and|strong=\"G2532\"endless|strong=\"G0562\"genealogies|strong=\"G1076\": which|strong=\"G3748\"furnish questions|strong=\"G2214\"rather|strong=\"G3123\"than|strong=\"G2228\"the|strong=\"G3588\"edification of|strong=\"G2316\"God|strong=\"G2316\", which|strong=\"G3748\"is|strong=\"G2316\"in|strong=\"G1722\"faith|strong=\"G4102\".",
      "5": "Now|strong=\"G1161\"the|strong=\"G3588\"end|strong=\"G5056\"of|strong=\"G1537\"the|strong=\"G3588\"commandment is|strong=\"G1510\"charity, from|strong=\"G1537\"a|strong=\"G1510\"pure|strong=\"G2513\"heart|strong=\"G2588\", and|strong=\"G2532\"a|strong=\"G1510\"good|strong=\"G0018\"conscience|strong=\"G4893\", and|strong=\"G2532\"an|strong=\"G1510\"unfeigned faith|strong=\"G4102\".",
      "6": "From|strong=\"G5100\"which|strong=\"G3739\"things|strong=\"G3739\"some|strong=\"G5100\"going astray|strong=\"G0795\", are|strong=\"G3739\"turned|strong=\"G1624\"aside|strong=\"G1624\"unto vain babbling:",
      "7": "Desiring|strong=\"G2309\"to|strong=\"G3004\"be|strong=\"G1510\"teachers|strong=\"G3547\"of|strong=\"G4012\"the|strong=\"G3739\"law|strong=\"G3547\", understanding neither|strong=\"G3383\"the|strong=\"G3739\"things|strong=\"G3739\"they|strong=\"G3739\"say|strong=\"G3004\", nor|strong=\"G3383\"whereof they|strong=\"G3739\"affirm.",
      "8": "But|strong=\"G1161\"we|strong=\"G1437\"know|strong=\"G1492\"that|strong=\"G3754\"the|strong=\"G3588\"law|strong=\"G3551\"is|strong=\"G5100\"good|strong=\"G2570\", if|strong=\"G1437\"a|strong=\"G1437\"man|strong=\"G5100\"use|strong=\"G5530\"it|strong=\"G0846\"lawfully|strong=\"G3545\":",
      "9": "Knowing|strong=\"G1492\"this|strong=\"G3778\", that|strong=\"G3754\"the|strong=\"G2532\"law|strong=\"G3551\"is|strong=\"G3778\"not|strong=\"G3756\"made|strong=\"G2749\"for|strong=\"G3754\"the|strong=\"G2532\"just|strong=\"G1342\"man|strong=\"G3778\", but|strong=\"G1161\"for|strong=\"G3754\"the|strong=\"G2532\"unjust and|strong=\"G2532\"disobedient, for|strong=\"G3754\"the|strong=\"G2532\"ungodly|strong=\"G0765\", and|strong=\"G2532\"for|strong=\"G3754\"sinners|strong=\"G0268\", for|strong=\"G3754\"the|strong=\"G2532\"wicked and|strong=\"G2532\"defiled, for|strong=\"G3754\"murderers|strong=\"G0409\"of|strong=\"G3551\"fathers, and|strong=\"G2532\"murderers|strong=\"G0409\"of|strong=\"G3551\"mothers|strong=\"G3389\", for|strong=\"G3754\"manslayers,",
      "10": "For|strong=\"G2532\"fornicators|strong=\"G4205\", for|strong=\"G2532\"them who|strong=\"G3588\"defile themselves with|strong=\"G2532\"mankind, for|strong=\"G2532\"menstealers, for|strong=\"G2532\"liars|strong=\"G5583\", for|strong=\"G2532\"perjured persons|strong=\"G4205\", and|strong=\"G2532\"whatever|strong=\"G5100\"other|strong=\"G2087\"thing is|strong=\"G5100\"contrary|strong=\"G0480\"to|strong=\"G2532\"sound|strong=\"G5198\"doctrine|strong=\"G1319\",",
      "11": "Which|strong=\"G3739\"is|strong=\"G2316\"according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2316\"the|strong=\"G3588\"glory|strong=\"G1391\"of|strong=\"G2316\"the|strong=\"G3588\"blessed|strong=\"G3107\"God|strong=\"G2316\", which|strong=\"G3739\"hath been committed to|strong=\"G2596\"my|strong=\"G3739\"trust.",
      "12": "I|strong=\"G1473\"give thanks|strong=\"G5485\"who|strong=\"G3588\"hath strengthened|strong=\"G1743\"me|strong=\"G1473\", even|strong=\"G1519\"to|strong=\"G1519\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"our|strong=\"G2424\"Lord|strong=\"G2962\", for|strong=\"G1519\"that|strong=\"G3754\"he|strong=\"G3754\"hath counted|strong=\"G2233\"me|strong=\"G1473\"faithful|strong=\"G4103\", putting|strong=\"G5087\"me|strong=\"G1473\"in|strong=\"G1519\"the|strong=\"G3588\"ministry|strong=\"G1248\";",
      "13": "Who|strong=\"G3588\"before|strong=\"G1722\"was|strong=\"G1510\"a|strong=\"G1510\"blasphemer|strong=\"G0989\", and|strong=\"G2532\"a|strong=\"G1510\"persecutor|strong=\"G1376\", and|strong=\"G2532\"contumelious. But|strong=\"G0235\"I|strong=\"G2532\"obtained the|strong=\"G3588\"mercy|strong=\"G1653\"of|strong=\"G1722\"God|strong=\"G1653\", because|strong=\"G3754\"I|strong=\"G2532\"did|strong=\"G4160\"it|strong=\"G4160\"ignorantly|strong=\"G0050\"in|strong=\"G1722\"unbelief|strong=\"G0570\".",
      "14": "Now|strong=\"G1161\"the|strong=\"G3588\"grace|strong=\"G5485\"of|strong=\"G5485\"our|strong=\"G2424\"Lord|strong=\"G2962\"hath abounded exceedingly with|strong=\"G3326\"faith|strong=\"G4102\"and|strong=\"G2532\"love|strong=\"G0026\", which|strong=\"G3588\"is|strong=\"G2962\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "15": "A|strong=\"G1510\"faithful|strong=\"G4103\"saying|strong=\"G3056\", and|strong=\"G2532\"worthy|strong=\"G0514\"of|strong=\"G3056\"all|strong=\"G3956\"acceptation, that|strong=\"G3754\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"came|strong=\"G2064\"into|strong=\"G1519\"this|strong=\"G3588\"world|strong=\"G2889\"to|strong=\"G1519\"save|strong=\"G4982\"sinners|strong=\"G0268\", of|strong=\"G3056\"whom|strong=\"G3739\"I|strong=\"G1473\"am|strong=\"G1510\"the|strong=\"G3956\"chief.",
      "16": "But|strong=\"G0235\"for|strong=\"G1519\"this|strong=\"G3778\"cause have|strong=\"G1653\"I|strong=\"G1473\"obtained mercy|strong=\"G1653\": that|strong=\"G2443\"in|strong=\"G1722\"me|strong=\"G1473\"first|strong=\"G4413\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"might|strong=\"G5547\"shew forth all|strong=\"G0537\"patience|strong=\"G3115\", for|strong=\"G1519\"the|strong=\"G3588\"information of|strong=\"G1223\"them|strong=\"G0846\"that|strong=\"G2443\"shall|strong=\"G3778\"believe|strong=\"G4100\"in|strong=\"G1722\"him|strong=\"G0846\"unto life|strong=\"G2222\"everlasting.",
      "17": "Now|strong=\"G1161\"to|strong=\"G1519\"the|strong=\"G3588\"king|strong=\"G0935\"of|strong=\"G2316\"ages|strong=\"G0165\", immortal|strong=\"G0862\", invisible|strong=\"G0517\", the|strong=\"G3588\"only|strong=\"G3441\"God|strong=\"G2316\", be|strong=\"G2532\"honour and|strong=\"G2532\"glory|strong=\"G1391\"for|strong=\"G1519\"ever|strong=\"G0165\"and|strong=\"G2532\"ever|strong=\"G0165\". Amen|strong=\"G0281\".",
      "18": "This|strong=\"G3778\"precept I|strong=\"G3778\"commend|strong=\"G3908\"to|strong=\"G2443\"thee, O son|strong=\"G5043\"Timothy|strong=\"G5095\"; according|strong=\"G2596\"to|strong=\"G2443\"the|strong=\"G3588\"prophecies|strong=\"G4394\"going|strong=\"G4254\"before|strong=\"G1909\"on|strong=\"G1909\"thee, that|strong=\"G2443\"thou war|strong=\"G4754\"in|strong=\"G1722\"them|strong=\"G0846\"a|strong=\"G1909\"good|strong=\"G2570\"warfare|strong=\"G4752\",",
      "19": "Having|strong=\"G2192\"faith|strong=\"G4102\"and|strong=\"G2532\"a|strong=\"G2192\"good|strong=\"G0018\"conscience|strong=\"G4893\", which|strong=\"G3739\"some|strong=\"G5100\"rejecting have|strong=\"G2192\"made shipwreck|strong=\"G3489\"concerning|strong=\"G4012\"the|strong=\"G3588\"faith|strong=\"G4102\".",
      "20": "Of|strong=\"G3588\"whom|strong=\"G3739\"is|strong=\"G1510\"Hymeneus and|strong=\"G2532\"Alexander|strong=\"G0223\", whom|strong=\"G3739\"I|strong=\"G3739\"have|strong=\"G1510\"delivered|strong=\"G3860\"up|strong=\"G3860\"to|strong=\"G2443\"Satan|strong=\"G4567\", that|strong=\"G3739\"they|strong=\"G3739\"may|strong=\"G2532\"learn not|strong=\"G3361\"to|strong=\"G2443\"blaspheme|strong=\"G0987\"."
    },
    "2": {
      "1": "I|strong=\"G3767\"desire therefore|strong=\"G3767\", first|strong=\"G4413\"of|strong=\"G3956\"all|strong=\"G3956\", that|strong=\"G3956\"supplications, prayers|strong=\"G4335\", intercessions|strong=\"G1783\", and|strong=\"G4160\"thanksgivings|strong=\"G2169\"be|strong=\"G3956\"made|strong=\"G4160\"for|strong=\"G5228\"all|strong=\"G3956\"men|strong=\"G0444\":",
      "2": "For|strong=\"G5228\"kings|strong=\"G0935\", and|strong=\"G2532\"for|strong=\"G5228\"all|strong=\"G3956\"that|strong=\"G2443\"are|strong=\"G1510\"in|strong=\"G1722\"high station: that|strong=\"G2443\"we|strong=\"G2532\"may|strong=\"G2532\"lead|strong=\"G1236\"a|strong=\"G1510\"quiet|strong=\"G2272\"and|strong=\"G2532\"a|strong=\"G1510\"peaceable life|strong=\"G0979\"in|strong=\"G1722\"all|strong=\"G3956\"piety|strong=\"G2150\"and|strong=\"G2532\"chastity.",
      "3": "For|strong=\"G2316\"this|strong=\"G3778\"is|strong=\"G2316\"good|strong=\"G2570\"and|strong=\"G2532\"acceptable|strong=\"G0587\"in|strong=\"G2316\"the|strong=\"G3588\"sight|strong=\"G1799\"of|strong=\"G2316\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour,",
      "4": "Who|strong=\"G3739\"will|strong=\"G3739\"have|strong=\"G2532\"all|strong=\"G3956\"men|strong=\"G0444\"to|strong=\"G1519\"be|strong=\"G2532\"saved|strong=\"G4982\", and|strong=\"G2532\"to|strong=\"G1519\"come|strong=\"G2064\"to|strong=\"G1519\"the|strong=\"G3956\"knowledge|strong=\"G1922\"of|strong=\"G3956\"the|strong=\"G3956\"truth|strong=\"G0225\".",
      "5": "For|strong=\"G1063\"there|strong=\"G0444\"is|strong=\"G2316\"one|strong=\"G1520\"God|strong=\"G2316\", and|strong=\"G2532\"one|strong=\"G1520\"mediator|strong=\"G3316\"of|strong=\"G2316\"God|strong=\"G2316\"and|strong=\"G2532\"men|strong=\"G0444\", the|strong=\"G2532\"man|strong=\"G0444\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\":",
      "6": "Who|strong=\"G3588\"gave|strong=\"G1325\"himself|strong=\"G1438\"a|strong=\"G1325\"redemption for|strong=\"G5228\"all|strong=\"G3956\", a|strong=\"G1325\"testimony|strong=\"G3142\"in|strong=\"G3956\"due|strong=\"G2398\"times|strong=\"G2540\".",
      "7": "Whereunto I|strong=\"G1473\"am|strong=\"G1473\"appointed|strong=\"G5087\"a|strong=\"G5087\"preacher|strong=\"G2783\"and|strong=\"G2532\"an|strong=\"G2532\"apostle|strong=\"G0652\", (I|strong=\"G1473\"say|strong=\"G3004\"the|strong=\"G2532\"truth|strong=\"G0225\", I|strong=\"G1473\"lie|strong=\"G5574\"not|strong=\"G3756\",) a|strong=\"G5087\"doctor of|strong=\"G0652\"the|strong=\"G2532\"Gentiles|strong=\"G1484\"in|strong=\"G1722\"faith|strong=\"G4102\"and|strong=\"G2532\"truth|strong=\"G0225\".",
      "8": "I|strong=\"G2532\"will|strong=\"G3956\"therefore|strong=\"G3767\"that|strong=\"G3956\"men|strong=\"G0435\"pray|strong=\"G4336\"in|strong=\"G1722\"every|strong=\"G3956\"place|strong=\"G5117\", lifting|strong=\"G1869\"up|strong=\"G1869\"pure hands|strong=\"G5495\", without|strong=\"G5565\"anger|strong=\"G3709\"and|strong=\"G2532\"contention.",
      "9": "In|strong=\"G1722\"like manner|strong=\"G5615\"women|strong=\"G1135\"also|strong=\"G2532\"in|strong=\"G1722\"decent apparel|strong=\"G2887\": adorning themselves|strong=\"G1438\"with|strong=\"G3326\"modesty|strong=\"G0127\"and|strong=\"G2532\"sobriety, not|strong=\"G3361\"with|strong=\"G3326\"plaited hair|strong=\"G4117\", or|strong=\"G2228\"gold|strong=\"G5553\", or|strong=\"G2228\"pearls|strong=\"G3135\", or|strong=\"G2228\"costly|strong=\"G4185\"attire,",
      "10": "But|strong=\"G0235\"as|strong=\"G3739\"it|strong=\"G1223\"becometh women|strong=\"G1135\"professing godliness|strong=\"G2317\", with|strong=\"G1223\"good|strong=\"G0018\"works|strong=\"G2041\".",
      "11": "Let the|strong=\"G3956\"woman|strong=\"G1135\"learn|strong=\"G3129\"in|strong=\"G1722\"silence, with|strong=\"G1722\"all|strong=\"G3956\"subjection|strong=\"G5292\".",
      "12": "But|strong=\"G1161\"I|strong=\"G1161\"suffer not|strong=\"G3756\"a|strong=\"G1510\"woman|strong=\"G1135\"to|strong=\"G1722\"teach|strong=\"G1321\", nor|strong=\"G3761\"to|strong=\"G1722\"use authority|strong=\"G0831\"over|strong=\"G0831\"the|strong=\"G1722\"man|strong=\"G0435\": but|strong=\"G1161\"to|strong=\"G1722\"be|strong=\"G1510\"in|strong=\"G1722\"silence.",
      "13": "For|strong=\"G1063\"Adam|strong=\"G0076\"was first|strong=\"G4413\"formed; then|strong=\"G1534\"Eve|strong=\"G2096\".",
      "14": "And|strong=\"G2532\"Adam|strong=\"G0076\"was|strong=\"G3588\"not|strong=\"G3756\"seduced; but|strong=\"G1161\"the|strong=\"G3588\"woman|strong=\"G1135\"being|strong=\"G1096\"seduced, was|strong=\"G3588\"in|strong=\"G1722\"the|strong=\"G3588\"transgression|strong=\"G3847\".",
      "15": "Yet|strong=\"G2532\"she|strong=\"G1437\"shall|strong=\"G2532\"be|strong=\"G2532\"saved|strong=\"G4982\"through|strong=\"G1223\"childbearing|strong=\"G5042\"; if|strong=\"G1437\"she|strong=\"G1437\"continue|strong=\"G3306\"in|strong=\"G1722\"faith|strong=\"G4102\", and|strong=\"G2532\"love|strong=\"G0026\", and|strong=\"G2532\"sanctification|strong=\"G0038\", with|strong=\"G3326\"sobriety."
    },
    "3": {
      "1": "A|strong=\"G1487\"faithful|strong=\"G4103\"saying|strong=\"G3056\": if|strong=\"G1487\"a|strong=\"G1487\"man|strong=\"G5100\"desire|strong=\"G1937\"the|strong=\"G3588\"office|strong=\"G1984\"of|strong=\"G3056\"a|strong=\"G1487\"bishop, he|strong=\"G1487\"desireth a|strong=\"G1487\"good|strong=\"G2570\"work|strong=\"G2041\".",
      "2": "It|strong=\"G1510\"behoveth therefore|strong=\"G3767\"a|strong=\"G1510\"bishop to|strong=\"G1163\"be|strong=\"G1510\"blameless, the|strong=\"G3588\"husband|strong=\"G0435\"of|strong=\"G0435\"one|strong=\"G1520\"wife|strong=\"G1135\", sober, prudent|strong=\"G4998\", of|strong=\"G0435\"good|strong=\"G1510\"behaviour, chaste, given to|strong=\"G1163\"hospitality, a|strong=\"G1510\"teacher,",
      "3": "Not|strong=\"G3361\"given to|strong=\"G3943\"wine|strong=\"G3943\", no|strong=\"G3361\"striker, but|strong=\"G0235\"modest, not|strong=\"G3361\"quarrelsome, not|strong=\"G3361\"covetous, but|strong=\"G0235\"",
      "4": "One|strong=\"G3588\"that|strong=\"G3956\"ruleth well|strong=\"G2573\"his|strong=\"G3956\"own|strong=\"G2398\"house|strong=\"G3624\", having|strong=\"G2192\"his|strong=\"G3956\"children|strong=\"G5043\"in|strong=\"G1722\"subjection|strong=\"G5292\"with|strong=\"G3326\"all|strong=\"G3956\"chastity.",
      "5": "But|strong=\"G1161\"if|strong=\"G1487\"a|strong=\"G1487\"man|strong=\"G5100\"know|strong=\"G1492\"not|strong=\"G3756\"how|strong=\"G4459\"to|strong=\"G5100\"rule his|strong=\"G2398\"own|strong=\"G2398\"house|strong=\"G3624\", how|strong=\"G4459\"shall|strong=\"G2316\"he|strong=\"G1161\"take|strong=\"G1959\"care|strong=\"G1959\"of|strong=\"G2316\"the|strong=\"G3588\"church|strong=\"G1577\"of|strong=\"G2316\"God|strong=\"G2316\"?",
      "6": "Not|strong=\"G3361\"a|strong=\"G3361\"neophyte: lest|strong=\"G3361\"being puffed up|strong=\"G1519\"with|strong=\"G1519\"pride, he fall|strong=\"G1706\"into|strong=\"G1519\"the|strong=\"G3588\"judgment|strong=\"G2917\"of|strong=\"G3588\"the|strong=\"G3588\"devil|strong=\"G1228\".",
      "7": "Moreover|strong=\"G1161\"he|strong=\"G2532\"must|strong=\"G1163\"have|strong=\"G2192\"a|strong=\"G2192\"good|strong=\"G2570\"testimony|strong=\"G3141\"of|strong=\"G0575\"them|strong=\"G2443\"who|strong=\"G3588\"are|strong=\"G3588\"without|strong=\"G3361\": lest|strong=\"G3361\"he|strong=\"G2532\"fall|strong=\"G1706\"into|strong=\"G1519\"reproach|strong=\"G3680\"and|strong=\"G2532\"the|strong=\"G3588\"snare|strong=\"G3803\"of|strong=\"G0575\"the|strong=\"G3588\"devil|strong=\"G1228\".",
      "8": "Deacons|strong=\"G1249\"in|strong=\"G4183\"like manner|strong=\"G5615\"chaste, not|strong=\"G3361\"double tongued, not|strong=\"G3361\"given to|strong=\"G4183\"much|strong=\"G4183\"wine|strong=\"G3631\", not|strong=\"G3361\"greedy of|strong=\"G1249\"filthy lucre:",
      "9": "Holding|strong=\"G2192\"the|strong=\"G3588\"mystery|strong=\"G3466\"of|strong=\"G1722\"faith|strong=\"G4102\"in|strong=\"G1722\"a|strong=\"G2192\"pure|strong=\"G2513\"conscience|strong=\"G4893\".",
      "10": "And|strong=\"G2532\"let|strong=\"G1510\"these|strong=\"G3778\"also|strong=\"G2532\"first|strong=\"G4413\"be|strong=\"G1510\"proved: and|strong=\"G2532\"so|strong=\"G2532\"let|strong=\"G1510\"them|strong=\"G3778\"minister|strong=\"G1247\", having no crime.",
      "11": "The|strong=\"G3956\"women|strong=\"G1135\"in|strong=\"G1722\"like manner|strong=\"G5615\"chaste, not|strong=\"G3361\"slanderers|strong=\"G1228\", but|strong=\"G3361\"sober, faithful|strong=\"G4103\"in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\".",
      "12": "Let|strong=\"G1510\"deacons|strong=\"G1249\"be|strong=\"G1510\"the|strong=\"G3588\"husbands|strong=\"G0435\"of|strong=\"G3624\"one|strong=\"G1520\"wife|strong=\"G1135\": who|strong=\"G3588\"rule well|strong=\"G2573\"their|strong=\"G2532\"children|strong=\"G5043\", and|strong=\"G2532\"their|strong=\"G2532\"own|strong=\"G2398\"houses.",
      "13": "For|strong=\"G1063\"they|strong=\"G2532\"that|strong=\"G1438\"have|strong=\"G2532\"ministered|strong=\"G1247\"well|strong=\"G2573\", shall|strong=\"G2532\"purchase to|strong=\"G2532\"themselves|strong=\"G1438\"a|strong=\"G2532\"good|strong=\"G2570\"degree, and|strong=\"G2532\"much|strong=\"G4183\"confidence|strong=\"G3954\"in|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\"which|strong=\"G3588\"is|strong=\"G3588\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "14": "These|strong=\"G3778\"things|strong=\"G3778\"I|strong=\"G3778\"write|strong=\"G1125\"to|strong=\"G4314\"thee, hoping|strong=\"G1679\"that|strong=\"G3778\"I|strong=\"G3778\"shall|strong=\"G3778\"come|strong=\"G2064\"to|strong=\"G4314\"thee shortly|strong=\"G5034\".",
      "15": "But|strong=\"G1161\"if|strong=\"G1437\"I|strong=\"G1437\"tarry long, that|strong=\"G2443\"thou mayest know|strong=\"G1492\"how|strong=\"G4459\"thou oughtest to|strong=\"G2443\"behave thyself in|strong=\"G1722\"the|strong=\"G3588\"house|strong=\"G3624\"of|strong=\"G2316\"God|strong=\"G2316\", which|strong=\"G3748\"is|strong=\"G1510\"the|strong=\"G3588\"church|strong=\"G1577\"of|strong=\"G2316\"the|strong=\"G3588\"living|strong=\"G2198\"God|strong=\"G2316\", the|strong=\"G3588\"pillar|strong=\"G4769\"and|strong=\"G2532\"ground of|strong=\"G2316\"the|strong=\"G3588\"truth|strong=\"G0225\".",
      "16": "And|strong=\"G2532\"evidently great|strong=\"G3173\"is|strong=\"G1510\"the|strong=\"G3588\"mystery|strong=\"G3466\"of|strong=\"G4151\"godliness|strong=\"G2150\", which|strong=\"G3739\"was|strong=\"G1510\"manifested|strong=\"G5319\"in|strong=\"G1722\"the|strong=\"G3588\"flesh|strong=\"G4561\", was|strong=\"G1510\"justified|strong=\"G1344\"in|strong=\"G1722\"the|strong=\"G3588\"spirit|strong=\"G4151\", appeared|strong=\"G3708\"unto angels|strong=\"G0032\", hath been|strong=\"G1510\"preached|strong=\"G2784\"unto the|strong=\"G3588\"Gentiles|strong=\"G1484\", is|strong=\"G1510\"believed|strong=\"G4100\"in|strong=\"G1722\"the|strong=\"G3588\"world|strong=\"G2889\", is|strong=\"G1510\"taken|strong=\"G0353\"up|strong=\"G0353\"in|strong=\"G1722\"glory|strong=\"G1391\"."
    },
    "4": {
      "1": "Now|strong=\"G1161\"the|strong=\"G3588\"Spirit|strong=\"G4151\"manifestly saith, that|strong=\"G3754\"in|strong=\"G1722\"the|strong=\"G3588\"last times|strong=\"G2540\"some|strong=\"G5100\"shall|strong=\"G2532\"depart|strong=\"G0868\"from|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\", giving|strong=\"G4337\"heed to|strong=\"G3004\"spirits|strong=\"G4151\"of|strong=\"G4151\"error, and|strong=\"G2532\"doctrines|strong=\"G1319\"of|strong=\"G4151\"devils,",
