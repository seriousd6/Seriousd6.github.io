      "3": "Grace|strong=\"G5485\"be|strong=\"G1510\"with|strong=\"G3326\"you|strong=\"G1722\", mercy|strong=\"G1656\", and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G3844\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G3844\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"the|strong=\"G3588\"Son|strong=\"G5207\"of|strong=\"G5207\"the|strong=\"G3588\"Father|strong=\"G3962\"; in|strong=\"G1722\"truth|strong=\"G0225\"and|strong=\"G2532\"charity.",
      "4": "I|strong=\"G3754\"was|strong=\"G3588\"exceeding glad|strong=\"G5463\", that|strong=\"G3754\"I|strong=\"G3754\"found|strong=\"G2147\"of|strong=\"G1537\"thy children|strong=\"G5043\"walking|strong=\"G4043\"in|strong=\"G1722\"truth|strong=\"G0225\", as|strong=\"G2531\"we|strong=\"G3754\"have|strong=\"G3748\"received|strong=\"G2983\"a|strong=\"G2983\"commandment|strong=\"G1785\"from|strong=\"G1537\"the|strong=\"G3588\"Father|strong=\"G3962\".",
      "5": "And|strong=\"G2532\"now|strong=\"G3568\"I|strong=\"G3739\"beseech thee, lady|strong=\"G2959\", not|strong=\"G3756\"as|strong=\"G5613\"writing|strong=\"G1125\"a|strong=\"G5613\"new|strong=\"G2537\"commandment|strong=\"G1785\"to|strong=\"G2443\"thee, but|strong=\"G0235\"that|strong=\"G3739\"which|strong=\"G3739\"we|strong=\"G3739\"have|strong=\"G2532\"had|strong=\"G3739\"from|strong=\"G0575\"the|strong=\"G2532\"beginning|strong=\"G0746\", that|strong=\"G3739\"we|strong=\"G3739\"love|strong=\"G0025\"one|strong=\"G0240\"another|strong=\"G0240\".",
      "6": "And|strong=\"G2532\"this|strong=\"G3778\"is|strong=\"G1510\"charity, that|strong=\"G2443\"we|strong=\"G3778\"walk|strong=\"G4043\"according|strong=\"G2596\"to|strong=\"G2443\"his|strong=\"G0846\"commandments|strong=\"G1785\". For|strong=\"G1722\"this|strong=\"G3778\"is|strong=\"G1510\"the|strong=\"G3588\"commandment|strong=\"G1785\", that|strong=\"G2443\", as|strong=\"G2531\"you|strong=\"G1722\"have|strong=\"G1510\"heard|strong=\"G0191\"from|strong=\"G0575\"the|strong=\"G3588\"beginning|strong=\"G0746\", you|strong=\"G1722\"should|strong=\"G2443\"walk|strong=\"G4043\"in|strong=\"G1722\"the|strong=\"G3588\"same|strong=\"G0846\":",
      "7": "For|strong=\"G1519\"many|strong=\"G4183\"seducers are|strong=\"G1510\"gone|strong=\"G1831\"out|strong=\"G1831\"into|strong=\"G1519\"the|strong=\"G3588\"world|strong=\"G2889\", who|strong=\"G3588\"confess|strong=\"G3670\"not|strong=\"G3361\"that|strong=\"G3754\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"is|strong=\"G1510\"come|strong=\"G2064\"in|strong=\"G1722\"the|strong=\"G3588\"flesh|strong=\"G4561\": this|strong=\"G3778\"is|strong=\"G1510\"a|strong=\"G1510\"seducer and|strong=\"G2532\"an|strong=\"G1510\"antichrist|strong=\"G0500\".",
      "8": "Look|strong=\"G0991\"to|strong=\"G2443\"yourselves|strong=\"G1438\", that|strong=\"G3739\"you|strong=\"G3739\"lose|strong=\"G0622\"not|strong=\"G3361\"the|strong=\"G3739\"things|strong=\"G3739\"which|strong=\"G3739\"you|strong=\"G3739\"have|strong=\"G0622\"wrought: but|strong=\"G0235\"that|strong=\"G3739\"you|strong=\"G3739\"may|strong=\"G2443\"receive|strong=\"G0618\"a|strong=\"G3739\"full|strong=\"G4134\"reward|strong=\"G3408\".",
      "9": "Whosoever revolteth, and|strong=\"G2532\"continueth not|strong=\"G3756\"in|strong=\"G1722\"the|strong=\"G3956\"doctrine of|strong=\"G5207\"Christ|strong=\"G5547\", hath not|strong=\"G3756\"God|strong=\"G2316\". He|strong=\"G2532\"that|strong=\"G3778\"continueth in|strong=\"G1722\"the|strong=\"G3956\"doctrine, the|strong=\"G3956\"same|strong=\"G3778\"hath both|strong=\"G2532\"the|strong=\"G3956\"Father|strong=\"G3962\"and|strong=\"G2532\"the|strong=\"G3956\"Son|strong=\"G5207\".",
      "10": "If|strong=\"G1487\"any|strong=\"G5100\"man|strong=\"G3778\"come|strong=\"G2064\"to|strong=\"G1519\"you|strong=\"G5210\", and|strong=\"G2532\"bring|strong=\"G5342\"not|strong=\"G3756\"this|strong=\"G3778\"doctrine, receive|strong=\"G2983\"him|strong=\"G0846\"not|strong=\"G3756\"into|strong=\"G1519\"the|strong=\"G3588\"house|strong=\"G3614\"nor|strong=\"G2532\"say|strong=\"G3004\"to|strong=\"G1519\"him|strong=\"G0846\", God|strong=\"G0846\"speed you|strong=\"G5210\".",
      "11": "For|strong=\"G1063\"he|strong=\"G0846\"that|strong=\"G3004\"saith unto him|strong=\"G0846\", God|strong=\"G0846\"speed you|strong=\"G3004\", communicateth with|strong=\"G0846\"his|strong=\"G0846\"wicked|strong=\"G4190\"works|strong=\"G2041\".",
      "12": "Having|strong=\"G2192\"more|strong=\"G4183\"things|strong=\"G4183\"to|strong=\"G4314\"write|strong=\"G1125\"unto you|strong=\"G5210\", I|strong=\"G2532\"would|strong=\"G1096\"not|strong=\"G3756\"by|strong=\"G1223\"paper|strong=\"G5489\"and|strong=\"G2532\"ink|strong=\"G3188\": for|strong=\"G1223\"I|strong=\"G2532\"hope|strong=\"G1679\"that|strong=\"G2443\"I|strong=\"G2532\"shall|strong=\"G2532\"be|strong=\"G1510\"with|strong=\"G4314\"you|strong=\"G5210\", and|strong=\"G2532\"speak|strong=\"G2980\"face|strong=\"G4750\"to|strong=\"G4314\"face|strong=\"G4750\": that|strong=\"G2443\"your|strong=\"G2192\"joy|strong=\"G5479\"may|strong=\"G2532\"be|strong=\"G1510\"full|strong=\"G4137\".",
