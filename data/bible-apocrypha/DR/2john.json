      "1": "The|strong=\"G3956\"ancient to|strong=\"G2532\"the|strong=\"G3956\"lady|strong=\"G2959\"Elect|strong=\"G1588\", and|strong=\"G2532\"her|strong=\"G0846\"children|strong=\"G5043\", whom|strong=\"G3739\"I|strong=\"G1473\"love|strong=\"G0025\"in|strong=\"G1722\"the|strong=\"G3956\"truth|strong=\"G0225\", and|strong=\"G2532\"not|strong=\"G3756\"I|strong=\"G1473\"only|strong=\"G3441\", but|strong=\"G0235\"also|strong=\"G2532\"all|strong=\"G3956\"they|strong=\"G0846\"that|strong=\"G3739\"have|strong=\"G2532\"known|strong=\"G1097\"the|strong=\"G3956\"truth|strong=\"G0225\",",
