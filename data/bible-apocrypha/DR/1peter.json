      "15": "But|strong=\"G0235\"according|strong=\"G2596\"to|strong=\"G2596\"him|strong=\"G0846\"that|strong=\"G3956\"hath called|strong=\"G2564\"you|strong=\"G5210\", who|strong=\"G3588\"is|strong=\"G3588\"holy|strong=\"G0040\", be|strong=\"G1096\"you|strong=\"G5210\"also|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\"manner|strong=\"G0391\"of|strong=\"G3956\"conversation holy|strong=\"G0040\":",
      "16": "Because|strong=\"G1360\"it|strong=\"G1510\"is|strong=\"G1510\"written|strong=\"G1125\": You|strong=\"G1510\"shall be|strong=\"G1510\"holy|strong=\"G0040\", for|strong=\"G1360\"I|strong=\"G1473\"am|strong=\"G1510\"holy|strong=\"G0040\".",
      "17": "And|strong=\"G2532\"if|strong=\"G1487\"you|strong=\"G5210\"invoke as|strong=\"G1722\"Father|strong=\"G3962\"him|strong=\"G2532\"who|strong=\"G3588\", without|strong=\"G2532\"respect|strong=\"G5401\"of|strong=\"G2041\"persons, judgeth according|strong=\"G2596\"to|strong=\"G2596\"every|strong=\"G2596\"one’s|strong=\"G1538\"work|strong=\"G2041\": converse in|strong=\"G1722\"fear|strong=\"G5401\"during|strong=\"G1722\"the|strong=\"G3588\"time|strong=\"G5550\"of|strong=\"G2041\"your|strong=\"G1487\"sojourning here|strong=\"G1722\".",
      "18": "Knowing|strong=\"G1492\"that|strong=\"G3754\"you|strong=\"G5210\"were|strong=\"G3588\"not|strong=\"G3756\"redeemed|strong=\"G3084\"with|strong=\"G1537\"corruptible|strong=\"G5349\"things|strong=\"G3152\"as|strong=\"G3754\"gold|strong=\"G5553\"or|strong=\"G2228\"silver|strong=\"G0694\", from|strong=\"G1537\"your|strong=\"G3588\"vain|strong=\"G3152\"conversation of|strong=\"G1537\"the|strong=\"G3588\"tradition of|strong=\"G1537\"your|strong=\"G3588\"fathers:",
      "19": "But|strong=\"G0235\"with|strong=\"G2532\"the|strong=\"G2532\"precious|strong=\"G5093\"blood|strong=\"G0129\"of|strong=\"G0129\"Christ|strong=\"G5547\", as|strong=\"G5613\"of|strong=\"G0129\"a|strong=\"G5613\"lamb|strong=\"G0286\"unspotted and|strong=\"G2532\"undefiled,",
      "20": "Foreknown|strong=\"G4267\"indeed|strong=\"G3303\"before|strong=\"G4253\"the|strong=\"G3588\"foundation|strong=\"G2602\"of|strong=\"G1223\"the|strong=\"G3588\"world|strong=\"G2889\", but|strong=\"G1161\"manifested|strong=\"G5319\"in|strong=\"G1909\"the|strong=\"G3588\"last|strong=\"G2078\"times|strong=\"G5550\"for|strong=\"G1223\"you|strong=\"G5210\",",
      "21": "Who|strong=\"G3588\"through|strong=\"G1223\"him|strong=\"G0846\"are|strong=\"G1510\"faithful|strong=\"G4103\"in|strong=\"G1519\"God|strong=\"G2316\", who|strong=\"G3588\"raised|strong=\"G1453\"him|strong=\"G0846\"up|strong=\"G1453\"from|strong=\"G1537\"the|strong=\"G3588\"dead|strong=\"G3498\", and|strong=\"G2532\"hath given|strong=\"G1325\"him|strong=\"G0846\"glory|strong=\"G1391\", that|strong=\"G5620\"your|strong=\"G2532\"faith|strong=\"G4102\"and|strong=\"G2532\"hope|strong=\"G1680\"might|strong=\"G2532\"be|strong=\"G1510\"in|strong=\"G1519\"God|strong=\"G2316\".",
      "22": "Purifying|strong=\"G0048\"your|strong=\"G0025\"souls|strong=\"G5590\"in|strong=\"G1722\"the|strong=\"G3588\"obedience|strong=\"G5218\"of|strong=\"G1537\"charity, with|strong=\"G1722\"a|strong=\"G5590\"brotherly|strong=\"G5360\"love|strong=\"G0025\", from|strong=\"G1537\"a|strong=\"G5590\"sincere|strong=\"G0505\"heart|strong=\"G2588\"love|strong=\"G0025\"one|strong=\"G0240\"another|strong=\"G0240\"earnestly|strong=\"G1619\":",
      "23": "Being born|strong=\"G0313\"again|strong=\"G0313\"not|strong=\"G3756\"of|strong=\"G1537\"corruptible|strong=\"G5349\"seed|strong=\"G4701\", but|strong=\"G0235\"incorruptible, by|strong=\"G1223\"the|strong=\"G1223\"word|strong=\"G3056\"of|strong=\"G1537\"God|strong=\"G2316\"who|strong=\"G2316\"liveth and|strong=\"G2532\"remaineth for|strong=\"G1223\"ever.",
      "24": "For|strong=\"G1360\"all|strong=\"G3956\"flesh|strong=\"G4561\"is|strong=\"G3588\"as|strong=\"G5613\"grass|strong=\"G5528\"; and|strong=\"G2532\"all|strong=\"G3956\"the|strong=\"G3956\"glory|strong=\"G1391\"thereof as|strong=\"G5613\"the|strong=\"G3956\"flower|strong=\"G0438\"of|strong=\"G1391\"grass|strong=\"G5528\". The|strong=\"G3956\"grass|strong=\"G5528\"is|strong=\"G3588\"withered|strong=\"G3583\", and|strong=\"G2532\"the|strong=\"G3956\"flower|strong=\"G0438\"thereof is|strong=\"G3588\"fallen away|strong=\"G3583\".",
