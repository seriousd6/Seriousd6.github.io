      "9": "But|strong=\"G1161\"you|strong=\"G5210\"are|strong=\"G3588\"a|strong=\"G2564\"chosen|strong=\"G1588\"generation, a|strong=\"G2564\"kingly priesthood|strong=\"G2406\", a|strong=\"G2564\"holy|strong=\"G0040\"nation|strong=\"G1484\", a|strong=\"G2564\"purchased people|strong=\"G2992\": that|strong=\"G3704\"you|strong=\"G5210\"may|strong=\"G1484\"declare his|strong=\"G0846\"virtues, who|strong=\"G3588\"hath called|strong=\"G2564\"you|strong=\"G5210\"out|strong=\"G1537\"of|strong=\"G1537\"darkness|strong=\"G4655\"into|strong=\"G1519\"his|strong=\"G0846\"marvellous light|strong=\"G5457\":",
