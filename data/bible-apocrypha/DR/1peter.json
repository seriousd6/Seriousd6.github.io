      "12": "Having|strong=\"G2192\"your|strong=\"G2192\"conversation good|strong=\"G2570\"among|strong=\"G1722\"the|strong=\"G3588\"Gentiles|strong=\"G1484\": that|strong=\"G3739\"whereas they|strong=\"G3739\"speak|strong=\"G2635\"against|strong=\"G1722\"you|strong=\"G5210\"as|strong=\"G5613\"evildoers|strong=\"G2555\", they|strong=\"G3739\"may|strong=\"G2443\", by|strong=\"G1722\"the|strong=\"G3588\"good|strong=\"G2570\"works|strong=\"G2041\", which|strong=\"G3739\"they|strong=\"G3739\"shall|strong=\"G2316\"behold in|strong=\"G1722\"you|strong=\"G5210\", glorify|strong=\"G1392\"God|strong=\"G2316\"in|strong=\"G1722\"the|strong=\"G3588\"day|strong=\"G2250\"of|strong=\"G1537\"visitation|strong=\"G1984\".",
      "13": "Be|strong=\"G3956\"ye subject|strong=\"G5293\"therefore|strong=\"G1223\"to|strong=\"G5293\"every|strong=\"G3956\"human|strong=\"G0442\"creature|strong=\"G2937\"for|strong=\"G1223\"God’s sake|strong=\"G1223\": whether|strong=\"G1535\"it|strong=\"G1223\"be|strong=\"G3956\"to|strong=\"G5293\"the|strong=\"G3956\"king|strong=\"G0935\"as|strong=\"G5613\"excelling;",
