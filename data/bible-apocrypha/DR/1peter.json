      "15": "For|strong=\"G3754\"so|strong=\"G3779\"is|strong=\"G1510\"the|strong=\"G3588\"will|strong=\"G2307\"of|strong=\"G2316\"God|strong=\"G2316\", that|strong=\"G3754\"by|strong=\"G0444\"doing|strong=\"G0015\"well you|strong=\"G3754\"may|strong=\"G2316\"put to|strong=\"G0444\"silence|strong=\"G5392\"the|strong=\"G3588\"ignorance|strong=\"G0056\"of|strong=\"G2316\"foolish|strong=\"G0878\"men|strong=\"G0444\":",
