      "7": "To|strong=\"G1519\"you|strong=\"G5210\"therefore|strong=\"G3767\"that|strong=\"G3739\"believe|strong=\"G4100\", he|strong=\"G2532\"is|strong=\"G3778\"honour: but|strong=\"G1161\"to|strong=\"G1519\"them|strong=\"G3739\"that|strong=\"G3739\"believe|strong=\"G4100\"not|strong=\"G3739\", the|strong=\"G3588\"stone|strong=\"G3037\"which|strong=\"G3739\"the|strong=\"G3588\"builders|strong=\"G3618\"rejected|strong=\"G0593\", the|strong=\"G3588\"same|strong=\"G3739\"is|strong=\"G3778\"made|strong=\"G1096\"the|strong=\"G3588\"head|strong=\"G2776\"of|strong=\"G2776\"the|strong=\"G3588\"corner|strong=\"G1137\":",
