      "6": "Let your|strong=\"G1722\"speech|strong=\"G3056\"be|strong=\"G1163\"always|strong=\"G3842\"in|strong=\"G1722\"grace|strong=\"G5485\"seasoned|strong=\"G0741\"with|strong=\"G1722\"salt|strong=\"G0217\": that|strong=\"G1722\"you|strong=\"G5210\"may|strong=\"G5485\"know|strong=\"G1492\"how|strong=\"G4459\"you|strong=\"G5210\"ought|strong=\"G1163\"to|strong=\"G1722\"answer|strong=\"G0611\"every|strong=\"G1538\"man|strong=\"G1538\".",
      "7": "All|strong=\"G3956\"the|strong=\"G3956\"things|strong=\"G3956\"that|strong=\"G3956\"concern me|strong=\"G1473\", Tychicus|strong=\"G5190\", our|strong=\"G2532\"dearest brother|strong=\"G0080\", and|strong=\"G2532\"faithful|strong=\"G4103\"minister|strong=\"G1249\"and|strong=\"G2532\"fellow|strong=\"G4889\"servant|strong=\"G1249\"in|strong=\"G1722\"the|strong=\"G3956\"Lord|strong=\"G2962\", will|strong=\"G2962\"make|strong=\"G1107\"known|strong=\"G1107\"to|strong=\"G2596\"you|strong=\"G5210\",",
      "8": "Whom|strong=\"G3739\"I|strong=\"G1473\"have|strong=\"G2532\"sent|strong=\"G3992\"to|strong=\"G1519\"you|strong=\"G5210\"for|strong=\"G1519\"this|strong=\"G3778\"same|strong=\"G0846\"purpose|strong=\"G3739\", that|strong=\"G3739\"he|strong=\"G2532\"may|strong=\"G2532\"know|strong=\"G1097\"the|strong=\"G3588\"things|strong=\"G3778\"that|strong=\"G3739\"concern you|strong=\"G5210\", and|strong=\"G2532\"comfort|strong=\"G3870\"your|strong=\"G2532\"hearts|strong=\"G2588\",",
      "9": "With|strong=\"G4862\"Onesimus|strong=\"G3682\", a|strong=\"G1510\"most beloved|strong=\"G0027\"and|strong=\"G2532\"faithful|strong=\"G4103\"brother|strong=\"G0080\", who|strong=\"G3739\"is|strong=\"G1510\"one|strong=\"G3739\"of|strong=\"G1537\"you|strong=\"G5210\". All|strong=\"G3956\"things|strong=\"G3956\"that|strong=\"G3739\"are|strong=\"G1510\"done here|strong=\"G5602\", they|strong=\"G3739\"shall|strong=\"G2532\"make|strong=\"G1107\"known|strong=\"G1107\"to|strong=\"G2532\"you|strong=\"G5210\".",
      "10": "Aristarchus|strong=\"G0708\", my|strong=\"G3739\"fellow|strong=\"G4869\"prisoner|strong=\"G4869\", saluteth you|strong=\"G5210\", and|strong=\"G2532\"Mark|strong=\"G3138\", the|strong=\"G3588\"cousin|strong=\"G0431\"german of|strong=\"G4012\"Barnabus, touching whom|strong=\"G3739\"you|strong=\"G5210\"have|strong=\"G2532\"received|strong=\"G2983\"commandments|strong=\"G1785\"; if|strong=\"G1437\"he|strong=\"G2532\"come|strong=\"G2064\"unto you|strong=\"G5210\", receive|strong=\"G2983\"him|strong=\"G0846\":",
