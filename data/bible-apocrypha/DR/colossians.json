      "6": "For|strong=\"G1223\"which|strong=\"G3739\"things|strong=\"G3739\"the|strong=\"G3588\"wrath|strong=\"G3709\"of|strong=\"G5207\"God|strong=\"G2316\"cometh upon|strong=\"G1909\"the|strong=\"G3588\"children of|strong=\"G5207\"unbelief,",
      "7": "In|strong=\"G1722\"which|strong=\"G3739\"you|strong=\"G5210\"also|strong=\"G2532\"walked|strong=\"G4043\"some|strong=\"G3739\"time|strong=\"G4218\", when|strong=\"G3753\"you|strong=\"G5210\"lived|strong=\"G2198\"in|strong=\"G1722\"them|strong=\"G1722\".",
      "8": "But|strong=\"G1161\"now|strong=\"G1161\"put|strong=\"G0659\"you|strong=\"G5210\"also|strong=\"G2532\"all|strong=\"G3956\"away: anger|strong=\"G3709\", indignation|strong=\"G2372\", malice|strong=\"G2549\", blasphemy|strong=\"G0988\", filthy speech|strong=\"G0148\"out|strong=\"G1537\"of|strong=\"G1537\"your|strong=\"G2532\"mouth|strong=\"G4750\".",
      "9": "Lie|strong=\"G5574\"not|strong=\"G3361\"one|strong=\"G0240\"to|strong=\"G1519\"another|strong=\"G0240\": stripping yourselves|strong=\"G0846\"of|strong=\"G0444\"the|strong=\"G3588\"old|strong=\"G3820\"man|strong=\"G0444\"with|strong=\"G4862\"his|strong=\"G0846\"deeds|strong=\"G4234\",",
      "10": "And|strong=\"G2532\"putting on|strong=\"G1519\"the|strong=\"G3588\"new|strong=\"G3501\", him|strong=\"G0846\"who|strong=\"G3588\"is|strong=\"G3588\"renewed|strong=\"G0341\"unto knowledge|strong=\"G1922\", according|strong=\"G2596\"to|strong=\"G1519\"the|strong=\"G3588\"image|strong=\"G1504\"of|strong=\"G2596\"him|strong=\"G0846\"that|strong=\"G0846\"created|strong=\"G2936\"him|strong=\"G0846\".",
      "11": "Where|strong=\"G3699\"there|strong=\"G1762\"is|strong=\"G3588\"neither|strong=\"G3756\"Gentile nor|strong=\"G2532\"Jew|strong=\"G2453\", circumcision|strong=\"G4061\"nor|strong=\"G2532\"uncircumcision|strong=\"G0203\", Barbarian|strong=\"G0915\"nor|strong=\"G2532\"Scythian|strong=\"G4658\", bond nor|strong=\"G2532\"free|strong=\"G1658\". But|strong=\"G0235\"Christ|strong=\"G5547\"is|strong=\"G3588\"all|strong=\"G3956\", and|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\".",
      "12": "Put|strong=\"G1746\"ye on|strong=\"G3767\"therefore|strong=\"G3767\", as|strong=\"G5613\"the|strong=\"G3588\"elect|strong=\"G1588\"of|strong=\"G2316\"God|strong=\"G2316\", holy|strong=\"G0040\", and|strong=\"G2532\"beloved|strong=\"G0025\", the|strong=\"G3588\"bowels of|strong=\"G2316\"mercy|strong=\"G3628\", benignity, humility|strong=\"G5012\", modesty, patience|strong=\"G3115\":",
      "13": "Bearing|strong=\"G0430\"with|strong=\"G4314\"one|strong=\"G0240\"another|strong=\"G0240\", and|strong=\"G2532\"forgiving|strong=\"G5483\"one|strong=\"G0240\"another|strong=\"G0240\", if|strong=\"G1437\"any|strong=\"G5100\"have|strong=\"G2192\"a|strong=\"G2192\"complaint|strong=\"G3437\"against|strong=\"G4314\"another|strong=\"G0240\": even|strong=\"G2532\"as|strong=\"G2531\"the|strong=\"G3588\"Lord|strong=\"G2962\"hath forgiven|strong=\"G5483\"you|strong=\"G5210\", so|strong=\"G2532\"do|strong=\"G2192\"you|strong=\"G5210\"also|strong=\"G2532\".",
      "14": "But|strong=\"G1161\"above|strong=\"G1909\"all|strong=\"G3956\"these|strong=\"G3778\"things|strong=\"G3778\"have|strong=\"G1510\"charity, which|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3956\"bond|strong=\"G4886\"of|strong=\"G1909\"perfection:",
      "15": "And|strong=\"G2532\"let|strong=\"G1096\"the|strong=\"G3588\"peace|strong=\"G1515\"of|strong=\"G1520\"Christ|strong=\"G5547\"rejoice in|strong=\"G1722\"your|strong=\"G2532\"hearts|strong=\"G2588\", wherein also|strong=\"G2532\"you|strong=\"G5210\"are|strong=\"G3739\"called|strong=\"G2564\"in|strong=\"G1722\"one|strong=\"G1520\"body|strong=\"G4983\": and|strong=\"G2532\"be|strong=\"G1096\"ye thankful|strong=\"G2170\".",
      "16": "Let|strong=\"G1774\"the|strong=\"G3956\"word|strong=\"G3056\"of|strong=\"G3056\"Christ|strong=\"G5547\"dwell|strong=\"G1774\"in|strong=\"G1722\"you|strong=\"G5210\"abundantly|strong=\"G4146\", in|strong=\"G1722\"all|strong=\"G3956\"wisdom|strong=\"G4678\": teaching|strong=\"G1321\"and|strong=\"G2532\"admonishing|strong=\"G3560\"one|strong=\"G1438\"another|strong=\"G1438\"in|strong=\"G1722\"psalms|strong=\"G5568\", hymns|strong=\"G5215\", and|strong=\"G2532\"spiritual|strong=\"G4152\"canticles, singing|strong=\"G0103\"in|strong=\"G1722\"grace|strong=\"G5485\"in|strong=\"G1722\"your|strong=\"G2532\"hearts|strong=\"G2588\"to|strong=\"G2532\"God|strong=\"G2316\".",
      "17": "All|strong=\"G3956\"whatsoever you|strong=\"G3739\"do|strong=\"G4160\"in|strong=\"G1722\"word|strong=\"G3056\"or|strong=\"G2228\"in|strong=\"G1722\"work|strong=\"G2041\", do|strong=\"G4160\"all|strong=\"G3956\"in|strong=\"G1722\"the|strong=\"G3956\"name|strong=\"G3686\"of|strong=\"G3056\"the|strong=\"G3956\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G0846\", giving|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G2532\"God|strong=\"G2316\"and|strong=\"G2532\"the|strong=\"G3956\"Father|strong=\"G3962\"by|strong=\"G1722\"him|strong=\"G0846\".",
      "18": "Wives|strong=\"G1135\", be|strong=\"G2962\"subject|strong=\"G5293\"to|strong=\"G1722\"your|strong=\"G2962\"husbands|strong=\"G0435\", as|strong=\"G5613\"it behoveth in|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\".",
      "19": "Husbands|strong=\"G0435\", love|strong=\"G0025\"your|strong=\"G0025\"wives|strong=\"G1135\", and|strong=\"G2532\"be|strong=\"G2532\"not|strong=\"G3361\"bitter|strong=\"G4087\"towards them|strong=\"G0846\".",
      "20": "Children|strong=\"G5043\", obey|strong=\"G5219\"your|strong=\"G2962\"parents|strong=\"G1118\"in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3778\": for|strong=\"G1063\"this|strong=\"G3778\"is|strong=\"G1510\"well|strong=\"G1063\"pleasing|strong=\"G2101\"to|strong=\"G2596\"the|strong=\"G3956\"Lord|strong=\"G2962\".",
