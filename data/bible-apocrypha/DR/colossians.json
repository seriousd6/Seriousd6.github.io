  "chapters": {
    "1": {
      "1": "Paul|strong=\"G3972\", an|strong=\"G2532\"apostle|strong=\"G0652\"of|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", by|strong=\"G1223\"the|strong=\"G3588\"will|strong=\"G2307\"of|strong=\"G1223\"God|strong=\"G2316\", and|strong=\"G2532\"Timothy|strong=\"G5095\", a|strong=\"G2532\"brother|strong=\"G0080\",",
      "2": "To|strong=\"G2532\"the|strong=\"G3588\"saints|strong=\"G0040\"and|strong=\"G2532\"faithful|strong=\"G4103\"brethren|strong=\"G0080\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2532\", who|strong=\"G3588\"are|strong=\"G3588\"at|strong=\"G1722\"Colossa.",
      "3": "Grace be|strong=\"G2532\"to|strong=\"G2532\"you|strong=\"G5210\"and|strong=\"G2532\"peace from|strong=\"G2424\"God|strong=\"G2316\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G2424\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\". We|strong=\"G2249\"give|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G2532\"God|strong=\"G2316\", and|strong=\"G2532\"the|strong=\"G3588\"Father|strong=\"G3962\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", praying|strong=\"G4336\"always|strong=\"G3842\"for|strong=\"G4012\"you|strong=\"G5210\".",
      "4": "Hearing|strong=\"G0191\"your|strong=\"G2192\"faith|strong=\"G4102\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", and|strong=\"G2532\"the|strong=\"G3956\"love|strong=\"G0026\"which|strong=\"G3739\"you|strong=\"G5210\"have|strong=\"G2192\"towards all|strong=\"G3956\"the|strong=\"G3956\"saints|strong=\"G0040\".",
      "5": "For|strong=\"G1223\"the|strong=\"G3588\"hope|strong=\"G1680\"that|strong=\"G3739\"is|strong=\"G3739\"laid|strong=\"G0606\"up for|strong=\"G1223\"you|strong=\"G5210\"in|strong=\"G1722\"heaven|strong=\"G3772\", which|strong=\"G3739\"you|strong=\"G5210\"have|strong=\"G3588\"heard|strong=\"G4257\"in|strong=\"G1722\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"the|strong=\"G3588\"truth|strong=\"G0225\"of|strong=\"G3056\"the|strong=\"G3588\"gospel|strong=\"G2098\",",
      "6": "Which|strong=\"G3739\"is|strong=\"G1510\"come|strong=\"G1510\"unto you|strong=\"G5210\", as|strong=\"G2531\"also|strong=\"G2532\"it|strong=\"G0191\"is|strong=\"G1510\"in|strong=\"G1722\"the|strong=\"G3956\"whole|strong=\"G3956\"world|strong=\"G2889\", and|strong=\"G2532\"bringeth forth fruit|strong=\"G2592\"and|strong=\"G2532\"groweth, even|strong=\"G2532\"as|strong=\"G2531\"it|strong=\"G0191\"doth in|strong=\"G1722\"you|strong=\"G5210\", since|strong=\"G0575\"the|strong=\"G3956\"day|strong=\"G2250\"you|strong=\"G5210\"heard|strong=\"G0191\"and|strong=\"G2532\"knew|strong=\"G1921\"the|strong=\"G3956\"grace|strong=\"G5485\"of|strong=\"G2250\"God|strong=\"G2316\"in|strong=\"G1722\"truth|strong=\"G0225\".",
      "7": "As|strong=\"G2531\"you|strong=\"G5210\"learned|strong=\"G3129\"of|strong=\"G0575\"Epaphras|strong=\"G1889\", our|strong=\"G5547\"most|strong=\"G5228\"beloved|strong=\"G0027\"fellow|strong=\"G4889\"servant|strong=\"G1249\", who|strong=\"G3739\"is|strong=\"G1510\"for|strong=\"G5228\"you|strong=\"G5210\"a|strong=\"G1510\"faithful|strong=\"G4103\"minister|strong=\"G1249\"of|strong=\"G0575\"Christ|strong=\"G5547\"Jesus|strong=\"G1510\";",
      "8": "Who|strong=\"G3588\"also|strong=\"G2532\"hath manifested to|strong=\"G2532\"us|strong=\"G1722\"your|strong=\"G2532\"love|strong=\"G0026\"in|strong=\"G1722\"the|strong=\"G3588\"spirit|strong=\"G4151\".",
      "9": "Therefore|strong=\"G1223\"we|strong=\"G2249\"also|strong=\"G2532\", from|strong=\"G0575\"the|strong=\"G3956\"day|strong=\"G2250\"that|strong=\"G3739\"we|strong=\"G2249\"heard|strong=\"G0191\"it|strong=\"G0846\", cease|strong=\"G3973\"not|strong=\"G3756\"to|strong=\"G2443\"pray|strong=\"G4336\"for|strong=\"G5228\"you|strong=\"G5210\", and|strong=\"G2532\"to|strong=\"G2443\"beg|strong=\"G0154\"that|strong=\"G3739\"you|strong=\"G5210\"may|strong=\"G2532\"be|strong=\"G2532\"filled|strong=\"G4137\"with|strong=\"G1722\"the|strong=\"G3956\"knowledge|strong=\"G1922\"of|strong=\"G2250\"his|strong=\"G0846\"will|strong=\"G2307\", in|strong=\"G1722\"all|strong=\"G3956\"wisdom|strong=\"G4678\", and|strong=\"G2532\"spiritual|strong=\"G4152\"understanding|strong=\"G4907\":",
      "10": "That|strong=\"G3956\"you|strong=\"G1722\"may|strong=\"G2532\"walk|strong=\"G4043\"worthy|strong=\"G0516\"of|strong=\"G2316\"God|strong=\"G2316\", in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"pleasing; being fruitful in|strong=\"G1722\"every|strong=\"G3956\"good|strong=\"G0018\"work|strong=\"G2041\", and|strong=\"G2532\"increasing|strong=\"G0837\"in|strong=\"G1722\"the|strong=\"G3956\"knowledge|strong=\"G1922\"of|strong=\"G2316\"God|strong=\"G2316\":",
      "11": "Strengthened|strong=\"G1412\"with|strong=\"G3326\"all|strong=\"G3956\"might|strong=\"G2532\", according|strong=\"G2596\"to|strong=\"G1519\"the|strong=\"G3956\"power|strong=\"G1411\"of|strong=\"G1411\"his|strong=\"G0846\"glory|strong=\"G1391\", in|strong=\"G1722\"all|strong=\"G3956\"patience|strong=\"G3115\"and|strong=\"G2532\"longsuffering with|strong=\"G3326\"joy|strong=\"G5479\",",
      "12": "Giving|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G1519\"God|strong=\"G3962\"the|strong=\"G3588\"Father|strong=\"G3962\", who|strong=\"G3588\"hath made|strong=\"G2427\"us|strong=\"G2427\"worthy to|strong=\"G1519\"be|strong=\"G1722\"partakers of|strong=\"G3962\"the|strong=\"G3588\"lot|strong=\"G2819\"of|strong=\"G3962\"the|strong=\"G3588\"saints|strong=\"G0040\"in|strong=\"G1722\"light|strong=\"G5457\":",
      "13": "Who|strong=\"G3739\"hath delivered|strong=\"G4506\"us|strong=\"G1519\"from|strong=\"G1537\"the|strong=\"G3588\"power|strong=\"G1849\"of|strong=\"G5207\"darkness|strong=\"G4655\", and|strong=\"G2532\"hath translated us|strong=\"G1519\"into|strong=\"G1519\"the|strong=\"G3588\"kingdom|strong=\"G0932\"of|strong=\"G5207\"the|strong=\"G3588\"Son|strong=\"G5207\"of|strong=\"G5207\"his|strong=\"G0846\"love|strong=\"G0026\",",
      "14": "In|strong=\"G1722\"whom|strong=\"G3739\"we|strong=\"G3739\"have|strong=\"G2192\"redemption|strong=\"G0629\"through|strong=\"G1722\"his|strong=\"G2192\"blood, the|strong=\"G3588\"remission of|strong=\"G1722\"sins|strong=\"G0266\";",
      "15": "Who|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3956\"image|strong=\"G1504\"of|strong=\"G2316\"the|strong=\"G3956\"invisible|strong=\"G0517\"God|strong=\"G2316\", the|strong=\"G3956\"firstborn|strong=\"G4416\"of|strong=\"G2316\"every|strong=\"G3956\"creature|strong=\"G2937\":",
      "16": "For|strong=\"G1519\"in|strong=\"G1722\"him|strong=\"G0846\"were|strong=\"G3956\"all|strong=\"G3956\"things|strong=\"G3956\"created|strong=\"G2936\"in|strong=\"G1722\"heaven|strong=\"G3772\"and|strong=\"G2532\"on|strong=\"G1909\"earth|strong=\"G1093\", visible|strong=\"G3707\"and|strong=\"G2532\"invisible|strong=\"G0517\", whether|strong=\"G1535\"thrones|strong=\"G2362\", or|strong=\"G2532\"dominations, or|strong=\"G2532\"principalities|strong=\"G0746\", or|strong=\"G2532\"powers|strong=\"G1849\": all|strong=\"G3956\"things|strong=\"G3956\"were|strong=\"G3956\"created|strong=\"G2936\"by|strong=\"G1722\"him|strong=\"G0846\"and|strong=\"G2532\"in|strong=\"G1722\"him|strong=\"G0846\".",
      "17": "And|strong=\"G2532\"he|strong=\"G2532\"is|strong=\"G1510\"before|strong=\"G4253\"all|strong=\"G3956\", and|strong=\"G2532\"by|strong=\"G1722\"him|strong=\"G0846\"all|strong=\"G3956\"things|strong=\"G3956\"consist|strong=\"G1510\".",
      "18": "And|strong=\"G2532\"he|strong=\"G2532\"is|strong=\"G1510\"the|strong=\"G3956\"head|strong=\"G2776\"of|strong=\"G1537\"the|strong=\"G3956\"body|strong=\"G4983\", the|strong=\"G3956\"church|strong=\"G1577\", who|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3956\"beginning|strong=\"G0746\", the|strong=\"G3956\"firstborn|strong=\"G4416\"from|strong=\"G1537\"the|strong=\"G3956\"dead|strong=\"G3498\"; that|strong=\"G3739\"in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"he|strong=\"G2532\"may|strong=\"G2532\"hold the|strong=\"G3956\"primacy:",
      "19": "Because|strong=\"G3754\"in|strong=\"G1722\"him|strong=\"G0846\", it|strong=\"G0846\"hath well|strong=\"G2106\"pleased|strong=\"G2106\"the|strong=\"G3956\"Father, that|strong=\"G3754\"all|strong=\"G3956\"fullness|strong=\"G4138\"should dwell|strong=\"G2730\";",
      "20": "And|strong=\"G2532\"through|strong=\"G1223\"him|strong=\"G0846\"to|strong=\"G1519\"reconcile|strong=\"G0604\"all|strong=\"G3956\"things|strong=\"G3956\"unto himself|strong=\"G0846\", making peace|strong=\"G1517\"through|strong=\"G1223\"the|strong=\"G3956\"blood|strong=\"G0129\"of|strong=\"G1223\"his|strong=\"G0846\"cross|strong=\"G4716\", both|strong=\"G2532\"as|strong=\"G1519\"to|strong=\"G1519\"the|strong=\"G3956\"things|strong=\"G3956\"that|strong=\"G3956\"are|strong=\"G3956\"on|strong=\"G1909\"earth|strong=\"G1093\", and|strong=\"G2532\"the|strong=\"G3956\"things|strong=\"G3956\"that|strong=\"G3956\"are|strong=\"G3956\"in|strong=\"G1722\"heaven|strong=\"G3772\".",
      "21": "And|strong=\"G2532\"you|strong=\"G5210\", whereas|strong=\"G1161\"you|strong=\"G5210\"were|strong=\"G1510\"some|strong=\"G3588\"time|strong=\"G4218\"alienated|strong=\"G0526\"and|strong=\"G2532\"enemies|strong=\"G2190\"in|strong=\"G1722\"mind|strong=\"G1271\"in|strong=\"G1722\"evil|strong=\"G4190\"works|strong=\"G2041\":",
      "22": "Yet|strong=\"G2532\"now|strong=\"G1161\"he|strong=\"G2532\"hath reconciled|strong=\"G0604\"in|strong=\"G1722\"the|strong=\"G3588\"body|strong=\"G4983\"of|strong=\"G1223\"his|strong=\"G0846\"flesh|strong=\"G4561\"through|strong=\"G1223\"death|strong=\"G2288\", to|strong=\"G2532\"present|strong=\"G3936\"you|strong=\"G5210\"holy|strong=\"G0040\"and|strong=\"G2532\"unspotted, and|strong=\"G2532\"blameless|strong=\"G0410\"before|strong=\"G2714\"him|strong=\"G0846\":",
      "23": "If|strong=\"G1487\"so|strong=\"G2532\"ye continue|strong=\"G1961\"in|strong=\"G1722\"the|strong=\"G3956\"faith|strong=\"G4102\", grounded|strong=\"G2311\"and|strong=\"G2532\"settled, and|strong=\"G2532\"immoveable from|strong=\"G0575\"the|strong=\"G3956\"hope|strong=\"G1680\"of|strong=\"G0575\"the|strong=\"G3956\"gospel|strong=\"G2098\"which|strong=\"G3739\"you|strong=\"G3739\"have|strong=\"G2532\"heard|strong=\"G0191\", which|strong=\"G3739\"is|strong=\"G3739\"preached|strong=\"G2784\"in|strong=\"G1722\"all|strong=\"G3956\"the|strong=\"G3956\"creation|strong=\"G2937\"that|strong=\"G3739\"is|strong=\"G3739\"under|strong=\"G5259\"heaven|strong=\"G3772\", whereof I|strong=\"G1473\"Paul|strong=\"G3972\"am|strong=\"G1096\"made|strong=\"G1096\"a|strong=\"G1096\"minister|strong=\"G1249\".",
      "24": "Who|strong=\"G3739\"now|strong=\"G3568\"rejoice|strong=\"G5463\"in|strong=\"G1722\"my|strong=\"G1722\"sufferings|strong=\"G3804\"for|strong=\"G5228\"you|strong=\"G5210\", and|strong=\"G2532\"fill up|strong=\"G0466\"those|strong=\"G3588\"things|strong=\"G3739\"that|strong=\"G3739\"are|strong=\"G1510\"wanting of|strong=\"G1577\"the|strong=\"G3588\"sufferings|strong=\"G3804\"of|strong=\"G1577\"Christ|strong=\"G5547\", in|strong=\"G1722\"my|strong=\"G1722\"flesh|strong=\"G4561\", for|strong=\"G5228\"his|strong=\"G0846\"body|strong=\"G4983\", which|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3588\"church|strong=\"G1577\":",
      "25": "Whereof I|strong=\"G1473\"am|strong=\"G1096\"made|strong=\"G1096\"a|strong=\"G1096\"minister|strong=\"G1249\"according|strong=\"G2596\"to|strong=\"G1519\"the|strong=\"G3588\"dispensation of|strong=\"G3056\"God|strong=\"G2316\", which|strong=\"G3739\"is|strong=\"G2316\"given|strong=\"G1325\"me|strong=\"G1325\"towards you|strong=\"G5210\", that|strong=\"G3739\"I|strong=\"G1473\"may|strong=\"G2316\"fulfill|strong=\"G4137\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G2316\":",
      "26": "The|strong=\"G3588\"mystery|strong=\"G3466\"which|strong=\"G3588\"hath been|strong=\"G2532\"hidden|strong=\"G0613\"from|strong=\"G0575\"ages|strong=\"G0165\"and|strong=\"G2532\"generations|strong=\"G1074\", but|strong=\"G1161\"now|strong=\"G1161\"is|strong=\"G3588\"manifested|strong=\"G5319\"to|strong=\"G2532\"his|strong=\"G0846\"saints|strong=\"G0040\",",
      "27": "To|strong=\"G2309\"whom|strong=\"G3739\"God|strong=\"G2316\"would|strong=\"G5547\"make|strong=\"G1107\"known|strong=\"G1107\"the|strong=\"G3588\"riches|strong=\"G4149\"of|strong=\"G2316\"the|strong=\"G3588\"glory|strong=\"G1391\"of|strong=\"G2316\"this|strong=\"G3778\"mystery|strong=\"G3466\"among|strong=\"G1722\"the|strong=\"G3588\"Gentiles|strong=\"G1484\", which|strong=\"G3739\"is|strong=\"G1510\"Christ|strong=\"G5547\", in|strong=\"G1722\"you|strong=\"G5210\"the|strong=\"G3588\"hope|strong=\"G1680\"of|strong=\"G2316\"glory|strong=\"G1391\".",
      "28": "Whom|strong=\"G3739\"we|strong=\"G2249\"preach, admonishing|strong=\"G3560\"every|strong=\"G3956\"man|strong=\"G0444\", and|strong=\"G2532\"teaching|strong=\"G1321\"every|strong=\"G3956\"man|strong=\"G0444\"in|strong=\"G1722\"all|strong=\"G3956\"wisdom|strong=\"G4678\", that|strong=\"G3739\"we|strong=\"G2249\"may|strong=\"G2532\"present|strong=\"G3936\"every|strong=\"G3956\"man|strong=\"G0444\"perfect|strong=\"G5046\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2532\".",
      "29": "Wherein also|strong=\"G2532\"I|strong=\"G1473\"labour, striving|strong=\"G0075\"according|strong=\"G2596\"to|strong=\"G1519\"his|strong=\"G0846\"working|strong=\"G1754\"which|strong=\"G3739\"he|strong=\"G2532\"worketh in|strong=\"G1722\"me|strong=\"G1473\"in|strong=\"G1722\"power|strong=\"G1411\"."
    },
    "2": {
      "1": "For|strong=\"G1063\"I|strong=\"G1473\"would|strong=\"G2309\"have|strong=\"G2192\"you|strong=\"G5210\"know|strong=\"G1492\", what|strong=\"G3588\"manner of|strong=\"G1722\"care I|strong=\"G1473\"have|strong=\"G2192\"for|strong=\"G1063\"you|strong=\"G5210\"and|strong=\"G2532\"for|strong=\"G1063\"them|strong=\"G1722\"that|strong=\"G3708\"are|strong=\"G3588\"at|strong=\"G1722\"Laodicea|strong=\"G2993\", and|strong=\"G2532\"whosoever have|strong=\"G2192\"not|strong=\"G3756\"seen|strong=\"G3708\"my|strong=\"G3708\"face|strong=\"G4383\"in|strong=\"G1722\"the|strong=\"G3588\"flesh|strong=\"G4561\":",
      "2": "That|strong=\"G2443\"their|strong=\"G0846\"hearts|strong=\"G2588\"may|strong=\"G2532\"be|strong=\"G2532\"comforted|strong=\"G3870\", being instructed in|strong=\"G1722\"charity, and|strong=\"G2532\"unto all|strong=\"G3956\"riches|strong=\"G4149\"of|strong=\"G2316\"fulness of|strong=\"G2316\"understanding|strong=\"G4907\", unto the|strong=\"G3956\"knowledge|strong=\"G1922\"of|strong=\"G2316\"the|strong=\"G3956\"mystery|strong=\"G3466\"of|strong=\"G2316\"God|strong=\"G2316\"the|strong=\"G3956\"Father and|strong=\"G2532\"of|strong=\"G2316\"Christ|strong=\"G5547\"Jesus|strong=\"G0846\":",
      "3": "In|strong=\"G1722\"whom|strong=\"G3739\"are|strong=\"G1510\"hid all|strong=\"G3956\"the|strong=\"G3956\"treasures|strong=\"G2344\"of|strong=\"G3956\"wisdom|strong=\"G4678\"and|strong=\"G2532\"knowledge|strong=\"G1108\".",
      "4": "Now|strong=\"G1722\"this|strong=\"G3778\"I|strong=\"G3778\"say|strong=\"G3004\", that|strong=\"G2443\"no|strong=\"G3367\"man|strong=\"G3778\"may|strong=\"G2443\"deceive you|strong=\"G5210\"by|strong=\"G1722\"loftiness of|strong=\"G1722\"words.",
      "5": "For|strong=\"G1063\"though|strong=\"G1487\"I|strong=\"G2532\"be|strong=\"G1510\"absent|strong=\"G0548\"in|strong=\"G1519\"body|strong=\"G4561\", yet|strong=\"G2532\"in|strong=\"G1519\"spirit|strong=\"G4151\"I|strong=\"G2532\"am|strong=\"G1510\"with|strong=\"G4862\"you|strong=\"G5210\"; rejoicing|strong=\"G5463\", and|strong=\"G2532\"beholding your|strong=\"G1487\"order|strong=\"G5010\", and|strong=\"G2532\"the|strong=\"G3588\"steadfastness of|strong=\"G4151\"your|strong=\"G1487\"faith|strong=\"G4102\"which|strong=\"G3588\"is|strong=\"G1510\"in|strong=\"G1519\"Christ|strong=\"G5547\".",
      "6": "As|strong=\"G5613\"therefore|strong=\"G3767\"you|strong=\"G1722\"have|strong=\"G5547\"received|strong=\"G3880\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"the|strong=\"G3588\"Lord|strong=\"G2962\", walk|strong=\"G4043\"ye in|strong=\"G1722\"him|strong=\"G0846\";",
      "7": "Rooted|strong=\"G4492\"and|strong=\"G2532\"built|strong=\"G2026\"up|strong=\"G2026\"in|strong=\"G1722\"him|strong=\"G0846\", and|strong=\"G2532\"confirmed|strong=\"G0950\"in|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\", as|strong=\"G2531\"also|strong=\"G2532\"you|strong=\"G1722\"have|strong=\"G4052\"learned, abounding|strong=\"G4052\"in|strong=\"G1722\"him|strong=\"G0846\"in|strong=\"G1722\"thanksgiving|strong=\"G2169\".",
      "8": "Beware|strong=\"G0991\"lest|strong=\"G3361\"any|strong=\"G5100\"man|strong=\"G0444\"cheat you|strong=\"G5210\"by|strong=\"G1223\"philosophy|strong=\"G5385\", and|strong=\"G2532\"vain|strong=\"G2756\"deceit|strong=\"G0539\"; according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"tradition|strong=\"G3862\"of|strong=\"G1223\"men|strong=\"G0444\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"elements|strong=\"G4747\"of|strong=\"G1223\"the|strong=\"G3588\"world|strong=\"G2889\", and|strong=\"G2532\"not|strong=\"G3756\"according|strong=\"G2596\"to|strong=\"G2596\"Christ|strong=\"G5547\":",
      "9": "For|strong=\"G3754\"in|strong=\"G1722\"him|strong=\"G0846\"dwelleth all|strong=\"G3956\"the|strong=\"G3956\"fulness of|strong=\"G3956\"the|strong=\"G3956\"Godhead corporeally;",
      "10": "And|strong=\"G2532\"you|strong=\"G3739\"are|strong=\"G1510\"filled|strong=\"G4137\"in|strong=\"G1722\"him|strong=\"G0846\", who|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3956\"head|strong=\"G2776\"of|strong=\"G3956\"all|strong=\"G3956\"principality and|strong=\"G2532\"power|strong=\"G1849\":",
      "11": "In|strong=\"G1722\"whom|strong=\"G3739\"also|strong=\"G2532\"you|strong=\"G3739\"are|strong=\"G3739\"circumcised|strong=\"G4061\"with|strong=\"G1722\"circumcision|strong=\"G4061\"not|strong=\"G3739\"made|strong=\"G0886\"by|strong=\"G1722\"hand, in|strong=\"G1722\"despoiling of|strong=\"G4983\"the|strong=\"G3588\"body|strong=\"G4983\"of|strong=\"G4983\"the|strong=\"G3588\"flesh|strong=\"G4561\", but|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G3588\"circumcision|strong=\"G4061\"of|strong=\"G4983\"Christ|strong=\"G5547\":",
      "12": "Buried|strong=\"G4916\"with|strong=\"G1722\"him|strong=\"G0846\"in|strong=\"G1722\"baptism|strong=\"G0908\", in|strong=\"G1722\"whom|strong=\"G3739\"also|strong=\"G2532\"you|strong=\"G3739\"are|strong=\"G3739\"risen|strong=\"G1453\"again|strong=\"G1453\"by|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\"of|strong=\"G1537\"the|strong=\"G3588\"operation of|strong=\"G1537\"God|strong=\"G2316\", who|strong=\"G3739\"hath raised|strong=\"G1453\"him|strong=\"G0846\"up|strong=\"G1453\"from|strong=\"G1537\"the|strong=\"G3588\"dead|strong=\"G3498\".",
      "13": "And|strong=\"G2532\"you|strong=\"G5210\", when|strong=\"G2532\"you|strong=\"G5210\"were|strong=\"G1510\"dead|strong=\"G3498\"in|strong=\"G1722\"your|strong=\"G2532\"sins|strong=\"G3900\", and|strong=\"G2532\"the|strong=\"G3956\"uncircumcision|strong=\"G0203\"of|strong=\"G3956\"your|strong=\"G2532\"flesh|strong=\"G4561\"; he|strong=\"G2532\"hath quickened together|strong=\"G4806\"with|strong=\"G1722\"him|strong=\"G0846\", forgiving|strong=\"G5483\"you|strong=\"G5210\"all|strong=\"G3956\"offences:",
      "14": "Blotting out|strong=\"G1537\"the|strong=\"G3588\"handwriting of|strong=\"G1537\"the|strong=\"G3588\"decree|strong=\"G1378\"that|strong=\"G3739\"was|strong=\"G1510\"against|strong=\"G2596\"us|strong=\"G1537\", which|strong=\"G3739\"was|strong=\"G1510\"contrary|strong=\"G2596\"to|strong=\"G2596\"us|strong=\"G1537\". And|strong=\"G2532\"he|strong=\"G2532\"hath taken|strong=\"G0142\"the|strong=\"G3588\"same|strong=\"G0846\"out|strong=\"G1537\"of|strong=\"G1537\"the|strong=\"G3588\"way|strong=\"G2596\", fastening it|strong=\"G0846\"to|strong=\"G2596\"the|strong=\"G3588\"cross|strong=\"G4716\":",
      "15": "And|strong=\"G2532\"despoiling the|strong=\"G3588\"principalities|strong=\"G0746\"and|strong=\"G2532\"powers|strong=\"G1849\", he|strong=\"G2532\"hath exposed them|strong=\"G0846\"confidently|strong=\"G3954\"in|strong=\"G1722\"open shew, triumphing over|strong=\"G1849\"them|strong=\"G0846\"in|strong=\"G1722\"himself|strong=\"G1438\".",
      "16": "Let|strong=\"G2919\"no|strong=\"G3361\"man|strong=\"G5100\"therefore|strong=\"G3767\"judge|strong=\"G2919\"you|strong=\"G5210\"in|strong=\"G1722\"meat or|strong=\"G2228\"in|strong=\"G1722\"drink|strong=\"G4213\", or|strong=\"G2228\"in|strong=\"G1722\"respect|strong=\"G3313\"of|strong=\"G5100\"a|strong=\"G2228\"festival|strong=\"G1859\"day|strong=\"G4521\", or|strong=\"G2228\"of|strong=\"G5100\"the|strong=\"G1722\"new moon, or|strong=\"G2228\"of|strong=\"G5100\"the|strong=\"G1722\"sabbaths|strong=\"G4521\",",
      "17": "Which|strong=\"G3739\"are|strong=\"G1510\"a|strong=\"G1510\"shadow|strong=\"G4639\"of|strong=\"G4983\"things|strong=\"G3739\"to|strong=\"G3195\"come|strong=\"G3195\", but|strong=\"G1161\"the|strong=\"G3588\"body|strong=\"G4983\"is|strong=\"G1510\"of|strong=\"G4983\"Christ|strong=\"G5547\".",
      "18": "Let no|strong=\"G3367\"man|strong=\"G4561\"seduce you|strong=\"G5210\", willing|strong=\"G2309\"in|strong=\"G1722\"humility|strong=\"G5012\", and|strong=\"G2532\"religion|strong=\"G2356\"of|strong=\"G1722\"angels|strong=\"G0032\", walking in|strong=\"G1722\"the|strong=\"G3588\"things|strong=\"G3739\"which|strong=\"G3739\"he|strong=\"G2532\"hath not|strong=\"G3367\"seen|strong=\"G3708\", in|strong=\"G1722\"vain|strong=\"G1500\"puffed up by|strong=\"G1722\"the|strong=\"G3588\"sense of|strong=\"G1722\"his|strong=\"G0846\"flesh|strong=\"G4561\",",
      "19": "And|strong=\"G2532\"not|strong=\"G3756\"holding|strong=\"G2902\"the|strong=\"G3956\"head|strong=\"G2776\", from|strong=\"G1537\"which|strong=\"G3739\"the|strong=\"G3956\"whole|strong=\"G3956\"body|strong=\"G4983\", by|strong=\"G1223\"joints|strong=\"G0860\"and|strong=\"G2532\"bands, being supplied|strong=\"G2023\"with|strong=\"G1537\"nourishment and|strong=\"G2532\"compacted, groweth unto the|strong=\"G3956\"increase|strong=\"G0837\"of|strong=\"G1537\"God|strong=\"G2316\".",
      "20": "If|strong=\"G1487\"then|strong=\"G1722\"you|strong=\"G1487\"be|strong=\"G5547\"dead|strong=\"G0599\"with|strong=\"G1722\"Christ|strong=\"G5547\"from|strong=\"G0575\"the|strong=\"G3588\"elements|strong=\"G4747\"of|strong=\"G0575\"this|strong=\"G3588\"world|strong=\"G2889\", why|strong=\"G5101\"do|strong=\"G5101\"you|strong=\"G1487\"yet decree as|strong=\"G5613\"though|strong=\"G5613\"living|strong=\"G2198\"in|strong=\"G1722\"the|strong=\"G3588\"world|strong=\"G2889\"?",
