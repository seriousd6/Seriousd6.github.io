      "22": "Servants|strong=\"G1401\", obey|strong=\"G5219\"in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"your|strong=\"G2962\"masters|strong=\"G2962\"according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3956\"flesh|strong=\"G4561\", not|strong=\"G3361\"serving to|strong=\"G2596\"the|strong=\"G3956\"eye, as|strong=\"G5613\"pleasing men|strong=\"G3956\", but|strong=\"G0235\"in|strong=\"G1722\"simplicity|strong=\"G0572\"of|strong=\"G2962\"heart|strong=\"G2588\", fearing|strong=\"G5399\"God.",
      "23": "Whatsoever you|strong=\"G3739\"do|strong=\"G4160\", do|strong=\"G4160\"it|strong=\"G4160\"from|strong=\"G1537\"the|strong=\"G3588\"heart|strong=\"G5590\", as|strong=\"G5613\"to|strong=\"G2532\"the|strong=\"G3588\"Lord|strong=\"G2962\", and|strong=\"G2532\"not|strong=\"G3756\"to|strong=\"G2532\"men|strong=\"G0444\":",
