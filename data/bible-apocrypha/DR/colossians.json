    "3": {
      "1": "Therefore|strong=\"G3767\", if|strong=\"G1487\"you|strong=\"G1487\"be|strong=\"G1510\"risen with|strong=\"G1722\"Christ|strong=\"G5547\", seek|strong=\"G2212\"the|strong=\"G3588\"things|strong=\"G3588\"that|strong=\"G2316\"are|strong=\"G1510\"above|strong=\"G0507\"; where|strong=\"G3757\"Christ|strong=\"G5547\"is|strong=\"G1510\"sitting|strong=\"G2521\"at|strong=\"G1722\"the|strong=\"G3588\"right|strong=\"G1188\"hand|strong=\"G1188\"of|strong=\"G2316\"God|strong=\"G2316\":",
