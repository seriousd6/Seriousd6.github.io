  "chapters": {
    "1": {
      "1": "Paul|strong=\"G3972\", an|strong=\"G2596\"apostle|strong=\"G0652\"of|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", by|strong=\"G1722\"the|strong=\"G3588\"will|strong=\"G2307\"of|strong=\"G1223\"God|strong=\"G2316\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"promise|strong=\"G1860\"of|strong=\"G1223\"life|strong=\"G2222\", which|strong=\"G3588\"is|strong=\"G2316\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "2": "To|strong=\"G2532\"Timothy|strong=\"G5095\"my|strong=\"G2316\"dearly beloved|strong=\"G0027\"son|strong=\"G5043\", grace|strong=\"G5485\", mercy|strong=\"G1656\", and|strong=\"G2532\"peace|strong=\"G1515\", from|strong=\"G0575\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"our|strong=\"G2316\"Lord|strong=\"G2962\".",
      "3": "I|strong=\"G1473\"give thanks|strong=\"G5485\"to|strong=\"G2532\"God|strong=\"G2316\", whom|strong=\"G3739\"I|strong=\"G1473\"serve|strong=\"G3000\"from|strong=\"G0575\"my|strong=\"G1722\"forefathers|strong=\"G4269\"with|strong=\"G1722\"a|strong=\"G2192\"pure|strong=\"G2513\"conscience|strong=\"G4893\", that|strong=\"G3739\"without|strong=\"G2532\"ceasing, I|strong=\"G1473\"have|strong=\"G2192\"a|strong=\"G2192\"remembrance|strong=\"G3417\"of|strong=\"G2250\"thee in|strong=\"G1722\"my|strong=\"G1722\"prayers|strong=\"G1162\", night|strong=\"G3571\"and|strong=\"G2532\"day|strong=\"G2250\".",
      "4": "Desiring to|strong=\"G2443\"see|strong=\"G3708\"thee, being|strong=\"G4771\"mindful of|strong=\"G3588\"thy tears|strong=\"G1144\", that|strong=\"G2443\"I|strong=\"G2443\"may|strong=\"G2443\"be filled|strong=\"G4137\"with|strong=\"G4137\"joy|strong=\"G5479\",",
      "5": "Calling to|strong=\"G2532\"mind|strong=\"G2532\"that|strong=\"G3754\"faith|strong=\"G4102\"which|strong=\"G3748\"is|strong=\"G3588\"in|strong=\"G1722\"thee unfeigned, which|strong=\"G3748\"also|strong=\"G2532\"dwelt|strong=\"G1774\"first|strong=\"G4413\"in|strong=\"G1722\"thy grandmother|strong=\"G3125\"Lois|strong=\"G3090\", and|strong=\"G2532\"in|strong=\"G1722\"thy mother|strong=\"G3384\"Eunice|strong=\"G2131\", and|strong=\"G2532\"I|strong=\"G2532\"am|strong=\"G2532\"certain that|strong=\"G3754\"in|strong=\"G1722\"thee also|strong=\"G2532\".",
      "6": "For|strong=\"G1223\"which|strong=\"G3739\"cause|strong=\"G0156\"I|strong=\"G1473\"admonish thee, that|strong=\"G3739\"thou stir up the|strong=\"G3588\"grace of|strong=\"G1223\"God|strong=\"G2316\"which|strong=\"G3739\"is|strong=\"G1510\"in|strong=\"G1722\"thee, by|strong=\"G1722\"the|strong=\"G3588\"imposition of|strong=\"G1223\"my|strong=\"G1722\"hands|strong=\"G5495\".",
      "7": "For|strong=\"G1063\"God|strong=\"G2316\"hath not|strong=\"G3756\"given|strong=\"G1325\"us|strong=\"G1325\"the|strong=\"G3588\"spirit|strong=\"G4151\"of|strong=\"G4151\"fear: but|strong=\"G0235\"of|strong=\"G4151\"power|strong=\"G1411\", and|strong=\"G2532\"of|strong=\"G4151\"love|strong=\"G0026\", and|strong=\"G2532\"of|strong=\"G4151\"sobriety.",
      "8": "Be|strong=\"G2316\"not|strong=\"G3361\"thou therefore|strong=\"G3767\"ashamed|strong=\"G1870\"of|strong=\"G2316\"the|strong=\"G3588\"testimony|strong=\"G3142\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\", nor|strong=\"G3366\"of|strong=\"G2316\"me|strong=\"G1473\"his|strong=\"G0846\"prisoner|strong=\"G1198\": but|strong=\"G0235\"labour with|strong=\"G2316\"the|strong=\"G3588\"gospel|strong=\"G2098\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"power|strong=\"G1411\"of|strong=\"G2316\"God|strong=\"G2316\",",
      "9": "Who|strong=\"G3588\"hath delivered us|strong=\"G1325\"and|strong=\"G2532\"called|strong=\"G2564\"us|strong=\"G1325\"by|strong=\"G1722\"his|strong=\"G1325\"holy|strong=\"G0040\"calling|strong=\"G2821\", not|strong=\"G3756\"according|strong=\"G2596\"to|strong=\"G2596\"our|strong=\"G2424\"works|strong=\"G2041\", but|strong=\"G0235\"according|strong=\"G2596\"to|strong=\"G2596\"his|strong=\"G1325\"own|strong=\"G2398\"purpose|strong=\"G4286\"and|strong=\"G2532\"grace|strong=\"G5485\", which|strong=\"G3588\"was|strong=\"G2424\"given|strong=\"G1325\"us|strong=\"G1325\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"before|strong=\"G4253\"the|strong=\"G3588\"times|strong=\"G5550\"of|strong=\"G5485\"the|strong=\"G3588\"world.",
      "10": "But|strong=\"G1161\"is|strong=\"G3588\"now|strong=\"G1161\"made|strong=\"G5319\"manifest|strong=\"G5319\"by|strong=\"G1223\"the|strong=\"G3588\"illumination of|strong=\"G1223\"our|strong=\"G2424\"Saviour Jesus|strong=\"G2424\"Christ|strong=\"G5547\", who|strong=\"G3588\"hath destroyed death|strong=\"G2288\", and|strong=\"G2532\"hath brought|strong=\"G5461\"to|strong=\"G2532\"light|strong=\"G5461\"life|strong=\"G2222\"and|strong=\"G2532\"incorruption by|strong=\"G1223\"the|strong=\"G3588\"gospel|strong=\"G2098\":",
      "11": "Wherein I|strong=\"G1473\"am|strong=\"G1473\"appointed|strong=\"G5087\"a|strong=\"G5087\"preacher|strong=\"G2783\", and|strong=\"G2532\"an|strong=\"G2532\"apostle|strong=\"G0652\", and|strong=\"G2532\"teacher|strong=\"G1320\"of|strong=\"G0652\"the|strong=\"G2532\"Gentiles.",
      "12": "For|strong=\"G1063\"which|strong=\"G3739\"cause|strong=\"G0156\"I|strong=\"G1473\"also|strong=\"G2532\"suffer|strong=\"G3958\"these|strong=\"G3778\"things|strong=\"G3778\": but|strong=\"G0235\"I|strong=\"G1473\"am|strong=\"G1510\"not|strong=\"G3756\"ashamed|strong=\"G1870\". For|strong=\"G1063\"I|strong=\"G1473\"know|strong=\"G1492\"whom|strong=\"G3739\"I|strong=\"G1473\"have|strong=\"G1510\"believed|strong=\"G4100\", and|strong=\"G2532\"I|strong=\"G1473\"am|strong=\"G1510\"certain that|strong=\"G3754\"he|strong=\"G2532\"is|strong=\"G1510\"able|strong=\"G1415\"to|strong=\"G1519\"keep|strong=\"G5442\"that|strong=\"G3754\"which|strong=\"G3739\"I|strong=\"G1473\"have|strong=\"G1510\"committed unto him|strong=\"G3739\", against|strong=\"G1519\"that|strong=\"G3754\"day|strong=\"G2250\".",
      "13": "Hold|strong=\"G2192\"the|strong=\"G3588\"form of|strong=\"G3056\"sound|strong=\"G5198\"words|strong=\"G3056\", which|strong=\"G3739\"thou hast heard|strong=\"G0191\"of|strong=\"G3056\"me|strong=\"G1473\"in|strong=\"G1722\"faith|strong=\"G4102\", and|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G3588\"love|strong=\"G0026\"which|strong=\"G3739\"is|strong=\"G3739\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "14": "Keep|strong=\"G5442\"the|strong=\"G3588\"good|strong=\"G2570\"thing|strong=\"G2570\"committed to|strong=\"G1722\"thy trust by|strong=\"G1722\"the|strong=\"G3588\"Holy|strong=\"G0040\"Ghost, who|strong=\"G3588\"dwelleth in|strong=\"G1722\"us|strong=\"G1722\".",
      "15": "Thou knowest this|strong=\"G3778\", that|strong=\"G3754\"all|strong=\"G3956\"they|strong=\"G3739\"who|strong=\"G3739\"are|strong=\"G1510\"in|strong=\"G1722\"Asia|strong=\"G0773\", are|strong=\"G1510\"turned|strong=\"G0654\"away|strong=\"G0654\"from|strong=\"G1722\"me|strong=\"G1473\": of|strong=\"G3956\"whom|strong=\"G3739\"are|strong=\"G1510\"Phigellus and|strong=\"G2532\"Hermogenes|strong=\"G2061\".",
      "16": "The|strong=\"G3588\"Lord|strong=\"G2962\"give|strong=\"G1325\"mercy|strong=\"G1656\"to|strong=\"G2532\"the|strong=\"G3588\"house|strong=\"G3624\"of|strong=\"G3624\"Onesiphorus|strong=\"G3683\": because|strong=\"G3754\"he|strong=\"G2532\"hath often|strong=\"G4178\"refreshed|strong=\"G0404\"me|strong=\"G1325\", and|strong=\"G2532\"hath not|strong=\"G3756\"been|strong=\"G2532\"ashamed|strong=\"G1870\"of|strong=\"G3624\"my|strong=\"G1325\"chain|strong=\"G0254\":",
      "17": "But|strong=\"G0235\"when|strong=\"G2532\"he|strong=\"G2532\"was|strong=\"G1096\"come|strong=\"G1096\"to|strong=\"G2212\"Rome|strong=\"G4516\", he|strong=\"G2532\"carefully sought|strong=\"G2212\"me|strong=\"G1473\", and|strong=\"G2532\"found|strong=\"G2147\"me|strong=\"G1473\".",
      "18": "The|strong=\"G3588\"Lord|strong=\"G2962\"grant|strong=\"G1325\"unto him|strong=\"G0846\"to|strong=\"G2532\"find|strong=\"G2147\"mercy|strong=\"G1656\"of|strong=\"G2250\"the|strong=\"G3588\"Lord|strong=\"G2962\"in|strong=\"G1722\"that|strong=\"G1565\"day|strong=\"G2250\": and|strong=\"G2532\"in|strong=\"G1722\"how|strong=\"G3745\"many|strong=\"G3745\"things|strong=\"G0846\"he|strong=\"G2532\"ministered|strong=\"G1247\"unto me|strong=\"G1325\"at|strong=\"G1722\"Ephesus|strong=\"G2181\", thou very|strong=\"G0846\"well|strong=\"G2532\"knowest."
    },
    "2": {
      "1": "Thou therefore|strong=\"G3767\", my|strong=\"G1722\"son|strong=\"G5043\", be|strong=\"G3767\"strong|strong=\"G1743\"in|strong=\"G1722\"the|strong=\"G3588\"grace|strong=\"G5485\"which|strong=\"G3588\"is|strong=\"G3588\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\":",
      "2": "And|strong=\"G2532\"the|strong=\"G1223\"things|strong=\"G3778\"which|strong=\"G3739\"thou hast heard|strong=\"G0191\"of|strong=\"G1223\"me|strong=\"G1473\"by|strong=\"G1223\"many|strong=\"G4183\"witnesses|strong=\"G3144\", the|strong=\"G1223\"same|strong=\"G3739\"commend|strong=\"G3908\"to|strong=\"G2532\"faithful|strong=\"G4103\"men|strong=\"G0444\", who|strong=\"G3739\"shall|strong=\"G0444\"be|strong=\"G1510\"fit|strong=\"G2425\"to|strong=\"G2532\"teach|strong=\"G1321\"others|strong=\"G2087\"also|strong=\"G2532\".",
      "3": "Labour as|strong=\"G5613\"a|strong=\"G5613\"good|strong=\"G2570\"soldier|strong=\"G4757\"of|strong=\"G2424\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "4": "No|strong=\"G3762\"man|strong=\"G3762\", being a soldier|strong=\"G4754\"to|strong=\"G2443\"God, entangleth himself with|strong=\"G0979\"secular businesses; that|strong=\"G2443\"he may|strong=\"G2443\"please|strong=\"G0700\"him|strong=\"G2443\"to|strong=\"G2443\"whom|strong=\"G3588\"he hath engaged himself.",
      "5": "For|strong=\"G2532\"he|strong=\"G2532\"also|strong=\"G2532\"that|strong=\"G1437\"striveth for|strong=\"G2532\"the|strong=\"G2532\"mastery, is|strong=\"G5100\"not|strong=\"G3756\"crowned|strong=\"G4737\", except|strong=\"G3361\"he|strong=\"G2532\"strive lawfully|strong=\"G3545\".",
      "6": "The|strong=\"G3588\"husbandman, that laboureth, must|strong=\"G1163\"first|strong=\"G4413\"partake of|strong=\"G4413\"the|strong=\"G3588\"fruits|strong=\"G2590\".",
      "7": "Understand|strong=\"G3539\"what|strong=\"G3739\"I|strong=\"G3739\"say|strong=\"G3004\": for|strong=\"G1063\"the|strong=\"G3956\"Lord|strong=\"G2962\"will|strong=\"G3739\"give|strong=\"G1325\"thee in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"understanding|strong=\"G4907\".",
      "8": "Be|strong=\"G5547\"mindful that|strong=\"G3421\"the|strong=\"G3588\"Lord Jesus|strong=\"G2424\"Christ|strong=\"G5547\"is|strong=\"G3588\"risen|strong=\"G1453\"again|strong=\"G1453\"from|strong=\"G1537\"the|strong=\"G3588\"dead|strong=\"G3498\", of|strong=\"G1537\"the|strong=\"G3588\"seed|strong=\"G4690\"of|strong=\"G1537\"David|strong=\"G1138\", according|strong=\"G2596\"to|strong=\"G2596\"my|strong=\"G2596\"gospel|strong=\"G2098\".",
      "9": "Wherein I|strong=\"G3739\"labour even|strong=\"G3360\"unto bands, as|strong=\"G5613\"an|strong=\"G5613\"evildoer; but|strong=\"G0235\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G2316\"is|strong=\"G2316\"not|strong=\"G3756\"bound|strong=\"G1210\".",
      "10": "Therefore|strong=\"G1223\"I|strong=\"G2532\"endure|strong=\"G5278\"all|strong=\"G3956\"things|strong=\"G3778\"for|strong=\"G1223\"the|strong=\"G3956\"sake|strong=\"G1223\"of|strong=\"G1223\"the|strong=\"G3956\"elect|strong=\"G1588\", that|strong=\"G2443\"they|strong=\"G0846\"also|strong=\"G2532\"may|strong=\"G2532\"obtain|strong=\"G5177\"the|strong=\"G3956\"salvation|strong=\"G4991\", which|strong=\"G3588\"is|strong=\"G3778\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", with|strong=\"G3326\"heavenly glory|strong=\"G1391\".",
      "11": "A|strong=\"G1487\"faithful|strong=\"G4103\"saying|strong=\"G3056\": for|strong=\"G1063\"if|strong=\"G1487\"we|strong=\"G1487\"be|strong=\"G2532\"dead with|strong=\"G2532\"him|strong=\"G2532\", we|strong=\"G1487\"shall|strong=\"G2532\"live|strong=\"G4800\"also|strong=\"G2532\"with|strong=\"G2532\"him|strong=\"G2532\".",
      "12": "If|strong=\"G1487\"we|strong=\"G2249\"suffer, we|strong=\"G2249\"shall|strong=\"G2532\"also|strong=\"G2532\"reign|strong=\"G4821\"with|strong=\"G2532\"him|strong=\"G2532\". If|strong=\"G1487\"we|strong=\"G2249\"deny|strong=\"G0720\"him|strong=\"G2532\", he|strong=\"G2532\"will|strong=\"G2532\"also|strong=\"G2532\"deny|strong=\"G0720\"us.",
      "13": "If|strong=\"G1487\"we|strong=\"G1487\"believe|strong=\"G0569\"not|strong=\"G3756\", he|strong=\"G1565\"continueth faithful|strong=\"G4103\", he|strong=\"G1565\"can|strong=\"G1410\"not|strong=\"G3756\"deny|strong=\"G0720\"himself|strong=\"G1438\".",
      "14": "Of|strong=\"G2316\"these|strong=\"G3778\"things|strong=\"G3778\"put them|strong=\"G0191\"in|strong=\"G1909\"mind, charging them|strong=\"G0191\"before|strong=\"G1799\"the|strong=\"G3588\"Lord|strong=\"G2962\". Contend not|strong=\"G3361\"in|strong=\"G1909\"words|strong=\"G3054\", for|strong=\"G1909\"it|strong=\"G0191\"is|strong=\"G2316\"to|strong=\"G1909\"no|strong=\"G3762\"profit, but|strong=\"G2316\"to|strong=\"G1909\"the|strong=\"G3588\"subverting of|strong=\"G2316\"the|strong=\"G3588\"hearers|strong=\"G0191\".",
      "15": "Carefully study to|strong=\"G2316\"present|strong=\"G3936\"thyself approved|strong=\"G1384\"unto God|strong=\"G2316\", a|strong=\"G2316\"workman|strong=\"G2040\"that|strong=\"G2316\"needeth not to|strong=\"G2316\"be|strong=\"G2316\"ashamed|strong=\"G0422\", rightly handling|strong=\"G3718\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"truth|strong=\"G0225\".",
      "16": "But|strong=\"G1161\"shun profane|strong=\"G0952\"and|strong=\"G1161\"vain babblings: for|strong=\"G1063\"they|strong=\"G1161\"grow much|strong=\"G4183\"towards ungodliness|strong=\"G0763\".",
      "17": "And|strong=\"G2532\"their|strong=\"G0846\"speech|strong=\"G3056\"spreadeth like|strong=\"G5613\"a|strong=\"G2192\"canker: of|strong=\"G3056\"whom|strong=\"G3739\"are|strong=\"G1510\"Hymeneus and|strong=\"G2532\"Philetus|strong=\"G5372\":",
      "18": "Who|strong=\"G3588\"have|strong=\"G2532\"erred from|strong=\"G2532\"the|strong=\"G3588\"truth|strong=\"G0225\", saying|strong=\"G3004\", that|strong=\"G3004\"the|strong=\"G3588\"resurrection|strong=\"G0386\"is|strong=\"G5100\"past already|strong=\"G2235\", and|strong=\"G2532\"have|strong=\"G2532\"subverted the|strong=\"G3588\"faith|strong=\"G4102\"of|strong=\"G5100\"some|strong=\"G5100\".",
      "19": "But|strong=\"G2532\"the|strong=\"G3956\"sure|strong=\"G1097\"foundation|strong=\"G2310\"of|strong=\"G0575\"God|strong=\"G2316\"standeth firm|strong=\"G2476\", having|strong=\"G2192\"this|strong=\"G3778\"seal|strong=\"G4973\": the|strong=\"G3956\"Lord|strong=\"G2962\"knoweth who|strong=\"G3588\"are|strong=\"G1510\"his|strong=\"G0846\"; and|strong=\"G2532\"let|strong=\"G1510\"every|strong=\"G3956\"one|strong=\"G3778\"depart|strong=\"G0868\"from|strong=\"G0575\"iniquity|strong=\"G0093\"who|strong=\"G3588\"nameth the|strong=\"G3956\"name|strong=\"G3686\"of|strong=\"G0575\"the|strong=\"G3956\"Lord|strong=\"G2962\".",
      "20": "But|strong=\"G1161\"in|strong=\"G1722\"a|strong=\"G1510\"great|strong=\"G3173\"house|strong=\"G3614\"there|strong=\"G1510\"are|strong=\"G1510\"not|strong=\"G3756\"only|strong=\"G3440\"vessels|strong=\"G4632\"of|strong=\"G1722\"gold|strong=\"G5552\"and|strong=\"G2532\"silver|strong=\"G0693\", but|strong=\"G1161\"also|strong=\"G2532\"of|strong=\"G1722\"wood|strong=\"G3585\"and|strong=\"G2532\"earth: and|strong=\"G2532\"some|strong=\"G3739\"indeed|strong=\"G2532\"unto honour, but|strong=\"G1161\"some|strong=\"G3739\"unto dishonour.",
      "21": "If|strong=\"G1437\"any|strong=\"G5100\"man|strong=\"G3778\"therefore|strong=\"G3767\"shall|strong=\"G3778\"cleanse himself|strong=\"G1438\"from|strong=\"G0575\"these|strong=\"G3778\", he|strong=\"G3778\"shall|strong=\"G3778\"be|strong=\"G1510\"a|strong=\"G1510\"vessel|strong=\"G4632\"unto honour, sanctified|strong=\"G0037\"and|strong=\"G5092\"profitable to|strong=\"G1519\"the|strong=\"G3956\"Lord|strong=\"G1203\", prepared|strong=\"G2090\"unto every|strong=\"G3956\"good|strong=\"G0018\"work|strong=\"G2041\".",
      "22": "But|strong=\"G1161\"flee|strong=\"G5343\"thou youthful|strong=\"G3512\"desires|strong=\"G1939\", and|strong=\"G1161\"pursue|strong=\"G1377\"justice|strong=\"G1343\", faith|strong=\"G4102\", charity, and|strong=\"G1161\"peace|strong=\"G1515\", with|strong=\"G3326\"them|strong=\"G1377\"that|strong=\"G1161\"call|strong=\"G1941\"on|strong=\"G1537\"the|strong=\"G3588\"Lord|strong=\"G2962\"out|strong=\"G1537\"of|strong=\"G1537\"a|strong=\"G3326\"pure|strong=\"G2513\"heart|strong=\"G2588\".",
      "23": "And|strong=\"G2532\"avoid foolish|strong=\"G3474\"and|strong=\"G2532\"unlearned questions|strong=\"G2214\", knowing|strong=\"G1492\"that|strong=\"G3754\"they|strong=\"G2532\"beget strifes.",
      "24": "But|strong=\"G1161\"the|strong=\"G3956\"servant|strong=\"G1401\"of|strong=\"G2962\"the|strong=\"G3956\"Lord|strong=\"G2962\"must|strong=\"G1163\"not|strong=\"G3756\"wrangle: but|strong=\"G1161\"be|strong=\"G1510\"mild towards all|strong=\"G3956\"men|strong=\"G3956\", apt to|strong=\"G4314\"teach|strong=\"G1317\", patient|strong=\"G0420\",",
      "25": "With|strong=\"G1722\"modesty admonishing them|strong=\"G0846\"that|strong=\"G0846\"resist the|strong=\"G3588\"truth|strong=\"G0225\": if|strong=\"G3379\"peradventure God|strong=\"G2316\"may|strong=\"G2316\"give|strong=\"G1325\"them|strong=\"G0846\"repentance|strong=\"G3341\"to|strong=\"G1519\"know the|strong=\"G3588\"truth|strong=\"G0225\",",
      "26": "And|strong=\"G2532\"they|strong=\"G0846\"may|strong=\"G2532\"recover themselves|strong=\"G0846\"from|strong=\"G1537\"the|strong=\"G3588\"snares of|strong=\"G1537\"the|strong=\"G3588\"devil|strong=\"G1228\", by|strong=\"G5259\"whom|strong=\"G3588\"they|strong=\"G0846\"are|strong=\"G3588\"held|strong=\"G2221\"captive|strong=\"G2221\"at|strong=\"G1519\"his|strong=\"G0846\"will|strong=\"G2307\"."
    },
    "3": {
      "1": "Know|strong=\"G1097\"also|strong=\"G1161\"this|strong=\"G3778\", that|strong=\"G3754\", in|strong=\"G1722\"the|strong=\"G1722\"last|strong=\"G2078\"days|strong=\"G2250\", shall|strong=\"G3778\"come|strong=\"G1764\"dangerous times|strong=\"G2540\".",
      "2": "Men|strong=\"G0444\"shall|strong=\"G0444\"be|strong=\"G1510\"lovers|strong=\"G5366\"of|strong=\"G0444\"themselves|strong=\"G1510\", covetous, haughty, proud, blasphemers|strong=\"G0989\", disobedient|strong=\"G0545\"to|strong=\"G0444\"parents|strong=\"G1118\", ungrateful|strong=\"G0884\", wicked,",
      "3": "Without|strong=\"G0193\"affection, without|strong=\"G0193\"peace, slanderers|strong=\"G1228\", incontinent, unmerciful, without|strong=\"G0193\"kindness,",
      "4": "Traitors, stubborn, puffed up, and|strong=\"G4273\"lovers|strong=\"G5369\"of|strong=\"G2228\"pleasures more|strong=\"G3123\"than|strong=\"G2228\"of|strong=\"G2228\"God|strong=\"G5377\":",
      "5": "Having|strong=\"G2192\"an|strong=\"G2192\"appearance indeed|strong=\"G2532\"of|strong=\"G1411\"godliness|strong=\"G2150\", but|strong=\"G1161\"denying|strong=\"G0720\"the|strong=\"G3588\"power|strong=\"G1411\"thereof. Now|strong=\"G1161\"these|strong=\"G3778\"avoid|strong=\"G0665\".",
      "6": "For|strong=\"G1063\"of|strong=\"G1537\"these|strong=\"G3778\"sort are|strong=\"G1510\"they|strong=\"G2532\"who|strong=\"G3588\"creep into|strong=\"G1519\"houses|strong=\"G3614\", and|strong=\"G2532\"lead|strong=\"G0071\"captive|strong=\"G0163\"silly women|strong=\"G1133\"laden with|strong=\"G1537\"sins|strong=\"G0266\", who|strong=\"G3588\"are|strong=\"G1510\"led|strong=\"G0071\"away|strong=\"G0071\"with|strong=\"G1537\"divers desires|strong=\"G1939\":",
      "7": "Ever learning|strong=\"G3129\", and|strong=\"G2532\"never|strong=\"G3368\"attaining to|strong=\"G1519\"the|strong=\"G2532\"knowledge|strong=\"G1922\"of|strong=\"G0225\"the|strong=\"G2532\"truth|strong=\"G0225\".",
      "8": "Now|strong=\"G1161\"as|strong=\"G2532\"Jannes|strong=\"G2389\"and|strong=\"G2532\"Mambres resisted Moses|strong=\"G3475\", so|strong=\"G2532\"these|strong=\"G3778\"also|strong=\"G2532\"resist|strong=\"G0436\"the|strong=\"G3588\"truth|strong=\"G0225\", men|strong=\"G0444\"corrupted in|strong=\"G2532\"mind|strong=\"G3563\", reprobate concerning|strong=\"G4012\"the|strong=\"G3588\"faith|strong=\"G4102\".",
      "9": "But|strong=\"G0235\"they|strong=\"G0846\"shall|strong=\"G2532\"proceed|strong=\"G4298\"no|strong=\"G3756\"farther; for|strong=\"G1063\"their|strong=\"G0846\"folly|strong=\"G0454\"shall|strong=\"G2532\"be|strong=\"G1510\"manifest to|strong=\"G1909\"all|strong=\"G3956\"men|strong=\"G3956\", as|strong=\"G5613\"theirs|strong=\"G0846\"also|strong=\"G2532\"was|strong=\"G1510\".",
      "10": "But|strong=\"G1161\"thou hast fully known my|strong=\"G3877\"doctrine|strong=\"G1319\", manner of|strong=\"G0026\"life, purpose|strong=\"G4286\", faith|strong=\"G4102\", longsuffering, love|strong=\"G0026\", patience|strong=\"G3115\",",
      "11": "Persecutions|strong=\"G1375\", afflictions: such|strong=\"G3634\"as|strong=\"G1722\"came|strong=\"G1096\"upon|strong=\"G1096\"me|strong=\"G1473\"at|strong=\"G1722\"Antioch|strong=\"G0490\", at|strong=\"G1722\"Iconium|strong=\"G2430\", and|strong=\"G2532\"at|strong=\"G1722\"Lystra|strong=\"G3082\": what|strong=\"G3588\"persecutions|strong=\"G1375\"I|strong=\"G1473\"endured|strong=\"G5297\", and|strong=\"G2532\"out|strong=\"G1537\"of|strong=\"G1537\"them|strong=\"G1722\"all|strong=\"G3956\"the|strong=\"G3956\"Lord|strong=\"G2962\"delivered|strong=\"G4506\"me|strong=\"G1473\".",
      "12": "And|strong=\"G2532\"all|strong=\"G3956\"that|strong=\"G3956\"will|strong=\"G2309\"live|strong=\"G2198\"godly|strong=\"G2153\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", shall|strong=\"G2532\"suffer persecution.",
      "13": "But|strong=\"G1161\"evil|strong=\"G4190\"men|strong=\"G0444\"and|strong=\"G2532\"seducers shall|strong=\"G0444\"grow worse|strong=\"G5501\"and|strong=\"G2532\"worse|strong=\"G5501\": erring|strong=\"G4105\", and|strong=\"G2532\"driving into|strong=\"G1909\"error.",
      "14": "But|strong=\"G1161\"continue|strong=\"G3306\"thou in|strong=\"G1722\"those|strong=\"G1161\"things|strong=\"G3739\"which|strong=\"G3739\"thou hast learned|strong=\"G3129\", and|strong=\"G2532\"which|strong=\"G3739\"have|strong=\"G2532\"been|strong=\"G2532\"committed to|strong=\"G2532\"thee: knowing|strong=\"G1492\"of|strong=\"G1722\"whom|strong=\"G3739\"thou hast learned|strong=\"G3129\"them|strong=\"G1722\";",
      "15": "And|strong=\"G2532\"because|strong=\"G3754\"from|strong=\"G0575\"thy infancy|strong=\"G1025\"thou hast known the|strong=\"G3588\"holy scriptures, which|strong=\"G3748\"can|strong=\"G1410\"instruct thee to|strong=\"G1519\"salvation|strong=\"G4991\", by|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\"which|strong=\"G3748\"is|strong=\"G3588\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\".",
      "16": "All|strong=\"G3956\"scripture|strong=\"G1124\", inspired|strong=\"G2315\"of|strong=\"G3956\"God|strong=\"G4314\", is|strong=\"G3588\"profitable|strong=\"G5624\"to|strong=\"G4314\"teach, to|strong=\"G4314\"reprove, to|strong=\"G4314\"correct, to|strong=\"G4314\"instruct in|strong=\"G1722\"justice|strong=\"G1343\",",
      "17": "That|strong=\"G2443\"the|strong=\"G3956\"man|strong=\"G0444\"of|strong=\"G2316\"God|strong=\"G2316\"may|strong=\"G2443\"be|strong=\"G1510\"perfect, furnished to|strong=\"G4314\"every|strong=\"G3956\"good|strong=\"G0018\"work|strong=\"G2041\"."
    },
    "4": {
      "1": "I|strong=\"G2532\"charge|strong=\"G1263\"thee, before|strong=\"G1799\"God|strong=\"G2316\"and|strong=\"G2532\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", who|strong=\"G3588\"shall|strong=\"G2532\"judge|strong=\"G2919\"the|strong=\"G3588\"living|strong=\"G2198\"and|strong=\"G2532\"the|strong=\"G3588\"dead|strong=\"G3498\", by|strong=\"G2198\"his|strong=\"G0846\"coming, and|strong=\"G2532\"his|strong=\"G0846\"kingdom|strong=\"G0932\":",
      "2": "Preach|strong=\"G2784\"the|strong=\"G3956\"word|strong=\"G3056\": be|strong=\"G2532\"instant in|strong=\"G1722\"season|strong=\"G2122\", out of|strong=\"G3056\"season|strong=\"G2122\": reprove|strong=\"G1651\", entreat|strong=\"G3870\", rebuke|strong=\"G2008\"in|strong=\"G1722\"all|strong=\"G3956\"patience|strong=\"G3115\"and|strong=\"G2532\"doctrine.",
      "3": "For|strong=\"G1063\"there|strong=\"G1510\"shall be|strong=\"G1510\"a|strong=\"G1510\"time|strong=\"G2540\", when|strong=\"G3753\"they|strong=\"G1510\"will|strong=\"G1510\"not|strong=\"G3756\"endure|strong=\"G0430\"sound|strong=\"G5198\"doctrine|strong=\"G1319\"; but|strong=\"G0235\", according|strong=\"G2596\"to|strong=\"G2596\"their|strong=\"G1438\"own|strong=\"G2398\"desires|strong=\"G1939\", they|strong=\"G1510\"will|strong=\"G1510\"heap to|strong=\"G2596\"themselves|strong=\"G1438\"teachers|strong=\"G1320\", having itching ears|strong=\"G0189\":",
      "4": "And|strong=\"G2532\"will|strong=\"G2532\"indeed|strong=\"G2532\"turn|strong=\"G0654\"away|strong=\"G0654\"their|strong=\"G2532\"hearing|strong=\"G0189\"from|strong=\"G0575\"the|strong=\"G3588\"truth|strong=\"G0225\", but|strong=\"G1161\"will|strong=\"G2532\"be|strong=\"G2532\"turned|strong=\"G1624\"unto fables|strong=\"G3454\".",
      "5": "But|strong=\"G1161\"be|strong=\"G3956\"thou vigilant, labour in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\", do|strong=\"G4160\"the|strong=\"G3956\"work|strong=\"G2041\"of|strong=\"G2041\"an|strong=\"G4160\"evangelist|strong=\"G2099\", fulfill|strong=\"G4135\"thy ministry|strong=\"G1248\". Be|strong=\"G3956\"sober|strong=\"G3525\".",
      "6": "For|strong=\"G1063\"I|strong=\"G1473\"am|strong=\"G1473\"even|strong=\"G2532\"now|strong=\"G2532\"ready|strong=\"G2186\"to|strong=\"G2532\"be|strong=\"G2532\"sacrificed: and|strong=\"G2532\"the|strong=\"G3588\"time|strong=\"G2540\"of|strong=\"G2540\"my|strong=\"G2532\"dissolution is|strong=\"G3588\"at|strong=\"G2235\"hand.",
      "7": "I|strong=\"G0073\"have|strong=\"G3588\"fought|strong=\"G0075\"a good|strong=\"G2570\"fight|strong=\"G0073\", I|strong=\"G0073\"have|strong=\"G3588\"finished|strong=\"G5055\"my|strong=\"G5083\"course|strong=\"G1408\", I|strong=\"G0073\"have|strong=\"G3588\"kept|strong=\"G5083\"the|strong=\"G3588\"faith|strong=\"G4102\".",
      "8": "As|strong=\"G1722\"to|strong=\"G2532\"the|strong=\"G3956\"rest, there|strong=\"G1722\"is|strong=\"G3739\"laid|strong=\"G0606\"up for|strong=\"G1722\"me|strong=\"G1473\"a|strong=\"G3739\"crown|strong=\"G4735\"of|strong=\"G2250\"justice|strong=\"G1343\", which|strong=\"G3739\"the|strong=\"G3956\"Lord|strong=\"G2962\"the|strong=\"G3956\"just|strong=\"G1342\"judge|strong=\"G2923\"will|strong=\"G3739\"render|strong=\"G0591\"to|strong=\"G2532\"me|strong=\"G1473\"in|strong=\"G1722\"that|strong=\"G3739\"day|strong=\"G2250\": and|strong=\"G2532\"not|strong=\"G3756\"only|strong=\"G3440\"to|strong=\"G2532\"me|strong=\"G1473\", but|strong=\"G1161\"to|strong=\"G2532\"them|strong=\"G0846\"also|strong=\"G2532\"that|strong=\"G3739\"love|strong=\"G0025\"his|strong=\"G0846\"coming. Make|strong=\"G0591\"haste to|strong=\"G2532\"come to|strong=\"G2532\"me|strong=\"G1473\"quickly|strong=\"G1722\".",
      "9": "For|strong=\"G4314\"Demas hath left me|strong=\"G1473\", loving this world, and|strong=\"G2064\"is|strong=\"G2064\"gone to|strong=\"G4314\"Thessalonica:",
      "10": "Crescens|strong=\"G2913\"into|strong=\"G1519\"Galatia|strong=\"G1053\", Titus|strong=\"G5103\"into|strong=\"G1519\"Dalmatia|strong=\"G1149\".",
      "11": "Only|strong=\"G3441\"Luke|strong=\"G3065\"is|strong=\"G1510\"with|strong=\"G3326\"me|strong=\"G1473\". Take|strong=\"G0353\"Mark|strong=\"G3138\", and|strong=\"G1510\"bring|strong=\"G0071\"him|strong=\"G0071\"with|strong=\"G3326\"thee: for|strong=\"G1063\"he|strong=\"G1510\"is|strong=\"G1510\"profitable to|strong=\"G1519\"me|strong=\"G1473\"for|strong=\"G1063\"the|strong=\"G1519\"ministry|strong=\"G1248\".",
      "12": "But|strong=\"G1161\"Tychicus|strong=\"G5190\"I|strong=\"G1161\"have sent|strong=\"G0649\"to|strong=\"G1519\"Ephesus|strong=\"G2181\".",
      "13": "The|strong=\"G3588\"cloak that|strong=\"G3739\"I|strong=\"G3739\"left|strong=\"G0620\"at|strong=\"G1722\"Troas|strong=\"G5174\", with|strong=\"G1722\"Carpus|strong=\"G2591\", when|strong=\"G2532\"thou comest, bring|strong=\"G5342\"with|strong=\"G1722\"thee, and|strong=\"G2532\"the|strong=\"G3588\"books|strong=\"G0975\", especially|strong=\"G3122\"the|strong=\"G3588\"parchments|strong=\"G3200\".",
      "14": "Alexander|strong=\"G0223\"the|strong=\"G3588\"coppersmith|strong=\"G5471\"hath done|strong=\"G2041\"me|strong=\"G1473\"much|strong=\"G4183\"evil|strong=\"G2556\": the|strong=\"G3588\"Lord|strong=\"G2962\"will|strong=\"G2962\"reward|strong=\"G0591\"him|strong=\"G0846\"according|strong=\"G2596\"to|strong=\"G2596\"his|strong=\"G0846\"works|strong=\"G2041\":",
      "15": "Whom|strong=\"G3739\"do|strong=\"G2532\"thou also|strong=\"G2532\"avoid, for|strong=\"G1063\"he|strong=\"G2532\"hath greatly|strong=\"G3029\"withstood our|strong=\"G2532\"words|strong=\"G3056\".",
      "16": "At|strong=\"G1722\"my|strong=\"G3956\"first|strong=\"G4413\"answer no|strong=\"G3762\"man|strong=\"G3762\"stood with|strong=\"G1722\"me|strong=\"G1473\", but|strong=\"G0235\"all|strong=\"G3956\"forsook me|strong=\"G1473\": may|strong=\"G3956\"it|strong=\"G0846\"not|strong=\"G3361\"be|strong=\"G3956\"laid to|strong=\"G1722\"their|strong=\"G0846\"charge.",
      "17": "But|strong=\"G1161\"the|strong=\"G3956\"Lord|strong=\"G2962\"stood|strong=\"G3936\"by|strong=\"G1223\"me|strong=\"G1473\", and|strong=\"G2532\"strengthened|strong=\"G1743\"me|strong=\"G1473\", that|strong=\"G2443\"by|strong=\"G1223\"me|strong=\"G1473\"the|strong=\"G3956\"preaching|strong=\"G2782\"may|strong=\"G2532\"be|strong=\"G2532\"accomplished|strong=\"G4135\", and|strong=\"G2532\"that|strong=\"G2443\"all|strong=\"G3956\"the|strong=\"G3956\"Gentiles|strong=\"G1484\"may|strong=\"G2532\"hear|strong=\"G0191\": and|strong=\"G2532\"I|strong=\"G1473\"was|strong=\"G3588\"delivered|strong=\"G4506\"out|strong=\"G1537\"of|strong=\"G1537\"the|strong=\"G3956\"mouth|strong=\"G4750\"of|strong=\"G1537\"the|strong=\"G3956\"lion|strong=\"G3023\".",
      "18": "The|strong=\"G3956\"Lord|strong=\"G2962\"hath delivered|strong=\"G4506\"me|strong=\"G1473\"from|strong=\"G0575\"every|strong=\"G3956\"evil|strong=\"G4190\"work|strong=\"G2041\": and|strong=\"G2532\"will|strong=\"G3739\"preserve me|strong=\"G1473\"unto his|strong=\"G0846\"heavenly|strong=\"G2032\"kingdom|strong=\"G0932\", to|strong=\"G1519\"whom|strong=\"G3739\"be|strong=\"G2532\"glory|strong=\"G1391\"for|strong=\"G1519\"ever|strong=\"G0165\"and|strong=\"G2532\"ever|strong=\"G0165\". Amen|strong=\"G0281\".",
      "19": "Salute Prisca|strong=\"G4251\"and|strong=\"G2532\"Aquila|strong=\"G0207\", and|strong=\"G2532\"the|strong=\"G3588\"household|strong=\"G3624\"of|strong=\"G3624\"Onesiphorus|strong=\"G3683\".",
      "20": "Erastus|strong=\"G2037\"remained|strong=\"G3306\"at|strong=\"G1722\"Corinth|strong=\"G2882\". And|strong=\"G1161\"Trophimus|strong=\"G5161\"I|strong=\"G1161\"left|strong=\"G0620\"sick|strong=\"G0770\"at|strong=\"G1722\"Miletus|strong=\"G3399\".",
      "21": "Make|strong=\"G4704\"haste to|strong=\"G2064\"come|strong=\"G2064\"before|strong=\"G4253\"winter|strong=\"G5494\"Eubulus|strong=\"G2103\"and|strong=\"G2532\"Pudens|strong=\"G4227\", and|strong=\"G2532\"Linus|strong=\"G3044\"and|strong=\"G2532\"Claudia|strong=\"G2803\", and|strong=\"G2532\"all|strong=\"G3956\"the|strong=\"G3956\"brethren|strong=\"G0080\", salute thee.",
      "22": "The|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2962\"Christ|strong=\"G2962\"be|strong=\"G3326\"with|strong=\"G3326\"thy spirit|strong=\"G4151\". Grace|strong=\"G5485\"be|strong=\"G3326\"with|strong=\"G3326\"you|strong=\"G5210\". Amen."
    }
