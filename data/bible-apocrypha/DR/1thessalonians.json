    "1": {
      "1": "Paul|strong=\"G3972\"and|strong=\"G2532\"Sylvanus and|strong=\"G2532\"Timothy|strong=\"G5095\": to|strong=\"G2532\"the|strong=\"G3588\"church|strong=\"G1577\"of|strong=\"G2316\"the|strong=\"G3588\"Thessalonians|strong=\"G2331\", in|strong=\"G1722\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "2": "Grace be|strong=\"G3956\"to|strong=\"G1909\"you|strong=\"G5210\"and|strong=\"G2316\"peace. We|strong=\"G2249\"give|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G1909\"God|strong=\"G2316\"always|strong=\"G3842\"for|strong=\"G4012\"you|strong=\"G5210\"all|strong=\"G3956\"; making|strong=\"G4160\"a|strong=\"G4160\"remembrance|strong=\"G3417\"of|strong=\"G2316\"you|strong=\"G5210\"in|strong=\"G1909\"our|strong=\"G2316\"prayers|strong=\"G4335\"without|strong=\"G0089\"ceasing|strong=\"G0089\",",
      "3": "Being|strong=\"G4771\"mindful of|strong=\"G2316\"the|strong=\"G3588\"work|strong=\"G2041\"of|strong=\"G2316\"your|strong=\"G2962\"faith|strong=\"G4102\", and|strong=\"G2532\"labour, and|strong=\"G2532\"charity, and|strong=\"G2532\"of|strong=\"G2316\"the|strong=\"G3588\"enduring|strong=\"G5281\"of|strong=\"G2316\"the|strong=\"G3588\"hope|strong=\"G1680\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"before|strong=\"G1715\"God|strong=\"G2316\"and|strong=\"G2532\"our|strong=\"G2316\"Father|strong=\"G3962\":",
      "4": "Knowing|strong=\"G1492\", brethren|strong=\"G0080\"beloved|strong=\"G0025\"of|strong=\"G2316\"God|strong=\"G2316\", your|strong=\"G0025\"election|strong=\"G1589\":",
      "5": "For|strong=\"G1519\"our|strong=\"G2532\"gospel|strong=\"G2098\"hath not|strong=\"G3756\"been|strong=\"G1096\"unto you|strong=\"G5210\"in|strong=\"G1722\"word|strong=\"G3056\"only|strong=\"G3440\", but|strong=\"G0235\"in|strong=\"G1722\"power|strong=\"G1411\"also|strong=\"G2532\", and|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G3588\"Holy|strong=\"G0040\"Ghost, and|strong=\"G2532\"in|strong=\"G1722\"much|strong=\"G4183\"fulness, as|strong=\"G2531\"you|strong=\"G5210\"know|strong=\"G1492\"what|strong=\"G3588\"manner of|strong=\"G3056\"men|strong=\"G3634\"we|strong=\"G2249\"have|strong=\"G2532\"been|strong=\"G1096\"among|strong=\"G1722\"you|strong=\"G5210\"for|strong=\"G1519\"your|strong=\"G2532\"sakes|strong=\"G1223\".",
      "6": "And|strong=\"G2532\"you|strong=\"G5210\"became|strong=\"G1096\"followers of|strong=\"G3056\"us|strong=\"G1722\", and|strong=\"G2532\"of|strong=\"G3056\"the|strong=\"G3588\"Lord|strong=\"G2962\"; receiving the|strong=\"G3588\"word|strong=\"G3056\"in|strong=\"G1722\"much|strong=\"G4183\"tribulation|strong=\"G2347\", with|strong=\"G3326\"joy|strong=\"G5479\"of|strong=\"G3056\"the|strong=\"G3588\"Holy|strong=\"G0040\"Ghost:",
      "7": "So|strong=\"G2532\"that|strong=\"G4100\"you|strong=\"G5210\"were|strong=\"G3956\"made|strong=\"G1096\"a|strong=\"G1096\"pattern|strong=\"G5179\"to|strong=\"G2532\"all|strong=\"G3956\"that|strong=\"G4100\"believe|strong=\"G4100\"in|strong=\"G1722\"Macedonia|strong=\"G3109\"and|strong=\"G2532\"in|strong=\"G1722\"Achaia|strong=\"G0882\".",
      "8": "For|strong=\"G1063\"from|strong=\"G0575\"you|strong=\"G5210\"was|strong=\"G3588\"spread|strong=\"G1831\"abroad the|strong=\"G3956\"word|strong=\"G3056\"of|strong=\"G3056\"the|strong=\"G3956\"Lord|strong=\"G2962\", not|strong=\"G3756\"only|strong=\"G3440\"in|strong=\"G1722\"Macedonia|strong=\"G3109\", and|strong=\"G2532\"in|strong=\"G1722\"Achaia|strong=\"G0882\", but|strong=\"G0235\"also|strong=\"G2532\"in|strong=\"G1722\"every|strong=\"G3956\"place|strong=\"G5117\", your|strong=\"G2962\"faith|strong=\"G4102\"which|strong=\"G3588\"is|strong=\"G2316\"towards God|strong=\"G2316\", is|strong=\"G2316\"gone|strong=\"G1831\"forth|strong=\"G1831\", so|strong=\"G2532\"that|strong=\"G5620\"we|strong=\"G2249\"need|strong=\"G5532\"not|strong=\"G3756\"to|strong=\"G4314\"speak|strong=\"G2980\"any|strong=\"G5100\"thing|strong=\"G3056\".",
      "9": "For|strong=\"G1063\"they|strong=\"G0846\"themselves|strong=\"G0846\"relate of|strong=\"G0575\"us|strong=\"G4012\", what|strong=\"G3588\"manner of|strong=\"G0575\"entering in|strong=\"G2316\"we|strong=\"G2249\"had|strong=\"G2192\"unto you|strong=\"G5210\"; and|strong=\"G2532\"how|strong=\"G4459\"you|strong=\"G5210\"turned|strong=\"G1994\"to|strong=\"G4314\"God|strong=\"G2316\"from|strong=\"G0575\"idols|strong=\"G1497\", to|strong=\"G4314\"serve|strong=\"G1398\"the|strong=\"G3588\"living|strong=\"G2198\"and|strong=\"G2532\"true|strong=\"G0228\"God|strong=\"G2316\".",
      "10": "And|strong=\"G2532\"to|strong=\"G2064\"wait|strong=\"G0362\"for|strong=\"G1537\"his|strong=\"G0846\"Son|strong=\"G5207\"from|strong=\"G1537\"heaven|strong=\"G3772\"(whom|strong=\"G3739\"he|strong=\"G2532\"raised|strong=\"G1453\"up|strong=\"G1453\"from|strong=\"G1537\"the|strong=\"G3588\"dead|strong=\"G3498\",) Jesus|strong=\"G2424\", who|strong=\"G3739\"hath delivered|strong=\"G4506\"us|strong=\"G1537\"from|strong=\"G1537\"the|strong=\"G3588\"wrath|strong=\"G3709\"to|strong=\"G2064\"come|strong=\"G2064\"."
    },
    "2": {
      "1": "For|strong=\"G1063\"yourselves|strong=\"G0846\"know|strong=\"G1492\", brethren|strong=\"G0080\", our|strong=\"G0080\"entrance|strong=\"G1529\"in|strong=\"G1096\"unto you|strong=\"G5210\", that|strong=\"G3754\"it|strong=\"G0846\"was|strong=\"G3588\"not|strong=\"G3756\"in|strong=\"G1096\"vain|strong=\"G2756\":",
      "2": "But|strong=\"G0235\"having suffered many|strong=\"G4183\"things|strong=\"G4183\"before|strong=\"G4314\", and|strong=\"G2532\"been|strong=\"G2532\"shamefully treated (as|strong=\"G2531\"you|strong=\"G5210\"know|strong=\"G1492\") at|strong=\"G1722\"Philippi|strong=\"G5375\", we|strong=\"G2249\"had|strong=\"G2316\"confidence|strong=\"G3955\"in|strong=\"G1722\"our|strong=\"G2316\"God|strong=\"G2316\", to|strong=\"G4314\"speak|strong=\"G2980\"unto you|strong=\"G5210\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2316\"God|strong=\"G2316\"in|strong=\"G1722\"much|strong=\"G4183\"carefulness.",
      "3": "For|strong=\"G1063\"our|strong=\"G1722\"exhortation|strong=\"G3874\"was|strong=\"G3588\"not|strong=\"G3756\"of|strong=\"G1537\"error|strong=\"G4106\", nor|strong=\"G3761\"of|strong=\"G1537\"uncleanness|strong=\"G0167\", nor|strong=\"G3761\"in|strong=\"G1722\"deceit|strong=\"G1388\":",
      "4": "But|strong=\"G0235\"as|strong=\"G5613\"we|strong=\"G2249\"were|strong=\"G3588\"approved by|strong=\"G5259\"God|strong=\"G2316\"that|strong=\"G4100\"the|strong=\"G3588\"gospel|strong=\"G2098\"should|strong=\"G2316\"be|strong=\"G2316\"committed to|strong=\"G2980\"us: even so|strong=\"G3779\"we|strong=\"G2249\"speak|strong=\"G2980\", not|strong=\"G3756\"as|strong=\"G5613\"pleasing|strong=\"G0700\"men|strong=\"G0444\", but|strong=\"G0235\"God|strong=\"G2316\", who|strong=\"G3588\"proveth our|strong=\"G2316\"hearts|strong=\"G2588\".",
      "5": "For|strong=\"G1063\"neither|strong=\"G3777\"have|strong=\"G1096\"we|strong=\"G1492\"used, at|strong=\"G1722\"any|strong=\"G4218\"time|strong=\"G4218\", the|strong=\"G1722\"speech|strong=\"G3056\"of|strong=\"G3056\"flattery, as|strong=\"G2531\"you|strong=\"G1722\"know|strong=\"G1492\"; nor|strong=\"G3777\"taken|strong=\"G1096\"an|strong=\"G1096\"occasion of|strong=\"G3056\"covetousness|strong=\"G4124\", God|strong=\"G2316\"is|strong=\"G2316\"witness|strong=\"G3144\":",
      "6": "Nor|strong=\"G3777\"sought|strong=\"G2212\"we|strong=\"G1510\"glory|strong=\"G1391\"of|strong=\"G1537\"men|strong=\"G0444\", neither|strong=\"G3777\"of|strong=\"G1537\"you|strong=\"G5210\", nor|strong=\"G3777\"of|strong=\"G1537\"others|strong=\"G0243\".",
      "7": "Whereas we|strong=\"G1437\"might|strong=\"G1410\"have|strong=\"G1510\"been|strong=\"G1510\"burdensome to|strong=\"G1410\"you|strong=\"G5210\", as|strong=\"G5613\"the|strong=\"G3588\"apostles|strong=\"G0652\"of|strong=\"G5043\"Christ|strong=\"G5547\": but|strong=\"G0235\"we|strong=\"G1437\"became|strong=\"G1096\"little ones in|strong=\"G1722\"the|strong=\"G3588\"midst|strong=\"G3319\"of|strong=\"G5043\"you|strong=\"G5210\", as|strong=\"G5613\"if|strong=\"G1437\"a|strong=\"G5613\"nurse should cherish her|strong=\"G1437\"children|strong=\"G5043\":",
      "8": "So|strong=\"G2532\"desirous of|strong=\"G2316\"you|strong=\"G5210\", we|strong=\"G2249\"would|strong=\"G1096\"gladly|strong=\"G2106\"impart|strong=\"G3330\"unto you|strong=\"G5210\"not|strong=\"G3756\"only|strong=\"G3440\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2316\"God|strong=\"G2316\", but|strong=\"G0235\"also|strong=\"G2532\"our|strong=\"G2316\"own|strong=\"G1438\"souls|strong=\"G5590\": because|strong=\"G1360\"you|strong=\"G5210\"were|strong=\"G1096\"become|strong=\"G1096\"most dear|strong=\"G0027\"unto us.",
      "9": "For|strong=\"G1063\"you|strong=\"G5210\"remember|strong=\"G3421\", brethren|strong=\"G0080\", our|strong=\"G2316\"labour and|strong=\"G2532\"toil|strong=\"G2873\": working night|strong=\"G3571\"and|strong=\"G2532\"day|strong=\"G2250\", lest|strong=\"G3361\"we|strong=\"G2249\"should|strong=\"G5100\"be|strong=\"G2532\"chargeable to|strong=\"G1519\"any|strong=\"G5100\"of|strong=\"G2250\"you|strong=\"G5210\", we|strong=\"G2249\"preached|strong=\"G2784\"among|strong=\"G1519\"you|strong=\"G5210\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2250\"God|strong=\"G2316\".",
      "10": "You|strong=\"G5210\"are|strong=\"G3588\"witnesses|strong=\"G3144\", and|strong=\"G2532\"God|strong=\"G2316\"also|strong=\"G2532\", how|strong=\"G5613\"holily, and|strong=\"G2532\"justly|strong=\"G1346\", and|strong=\"G2532\"without|strong=\"G0274\"blame|strong=\"G0274\", we|strong=\"G2532\"have|strong=\"G2532\"been|strong=\"G1096\"to|strong=\"G2532\"you|strong=\"G5210\"that|strong=\"G4100\"have|strong=\"G2532\"believed|strong=\"G4100\":",
      "11": "As|strong=\"G5613\"you|strong=\"G5210\"know|strong=\"G1492\"in|strong=\"G2532\"what|strong=\"G5613\"manner, entreating and|strong=\"G2532\"comforting you|strong=\"G5210\", (as|strong=\"G5613\"a|strong=\"G5613\"father|strong=\"G3962\"doth his|strong=\"G1438\"children|strong=\"G5043\",)",
      "12": "We|strong=\"G2532\"testified to|strong=\"G1519\"every one|strong=\"G1438\"of|strong=\"G0932\"you|strong=\"G5210\", that|strong=\"G2316\"you|strong=\"G5210\"would|strong=\"G2532\"walk|strong=\"G4043\"worthy|strong=\"G0516\"of|strong=\"G0932\"God|strong=\"G2316\", who|strong=\"G3588\"hath called|strong=\"G2564\"you|strong=\"G5210\"unto his|strong=\"G1438\"kingdom|strong=\"G0932\"and|strong=\"G2532\"glory|strong=\"G1391\".",
      "13": "Therefore|strong=\"G1223\", we|strong=\"G2249\"also|strong=\"G2532\"give|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G2532\"God|strong=\"G2316\"without|strong=\"G3756\"ceasing|strong=\"G0089\": because|strong=\"G3754\", that|strong=\"G3754\"when|strong=\"G2532\"you|strong=\"G5210\"had|strong=\"G1510\"received|strong=\"G3880\"of|strong=\"G3056\"us|strong=\"G1722\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"the|strong=\"G3588\"hearing|strong=\"G0189\"of|strong=\"G3056\"God|strong=\"G2316\", you|strong=\"G5210\"received|strong=\"G3880\"it|strong=\"G1223\"not|strong=\"G3756\"as|strong=\"G2531\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"men|strong=\"G0444\", but|strong=\"G0235\"(as|strong=\"G2531\"it|strong=\"G1223\"is|strong=\"G1510\"indeed|strong=\"G2532\") the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G2316\", who|strong=\"G3739\"worketh in|strong=\"G1722\"you|strong=\"G5210\"that|strong=\"G3754\"have|strong=\"G1510\"believed|strong=\"G4100\".",
      "14": "For|strong=\"G1063\"you|strong=\"G5210\", brethren|strong=\"G0080\", are|strong=\"G1510\"become|strong=\"G1096\"followers of|strong=\"G2316\"the|strong=\"G3588\"churches|strong=\"G1577\"of|strong=\"G2316\"God|strong=\"G2316\"which|strong=\"G3748\"are|strong=\"G1510\"in|strong=\"G1722\"Judea|strong=\"G2453\", in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\": for|strong=\"G1063\"you|strong=\"G5210\"also|strong=\"G2532\"have|strong=\"G1510\"suffered|strong=\"G3958\"the|strong=\"G3588\"same|strong=\"G0846\"things|strong=\"G0846\"from|strong=\"G5259\"your|strong=\"G2532\"own|strong=\"G2398\"coutrymen, even|strong=\"G2532\"as|strong=\"G2531\"they|strong=\"G0846\"have|strong=\"G1510\"from|strong=\"G5259\"the|strong=\"G3588\"Jews|strong=\"G2453\",",
      "15": "Who|strong=\"G3588\"both|strong=\"G2532\"killed|strong=\"G0615\"the|strong=\"G3956\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\", and|strong=\"G2532\"the|strong=\"G3956\"prophets|strong=\"G4396\", and|strong=\"G2532\"have|strong=\"G2532\"persecuted|strong=\"G1559\"us, and|strong=\"G2532\"please|strong=\"G0700\"not|strong=\"G3361\"God|strong=\"G2316\", and|strong=\"G2532\"are|strong=\"G3956\"adversaries to|strong=\"G2532\"all|strong=\"G3956\"men|strong=\"G0444\";",
      "16": "Prohibiting us|strong=\"G1519\"to|strong=\"G1519\"speak|strong=\"G2980\"to|strong=\"G1519\"the|strong=\"G3588\"Gentiles|strong=\"G1484\", that|strong=\"G2443\"they|strong=\"G0846\"may|strong=\"G2443\"be|strong=\"G3842\"saved|strong=\"G4982\", to|strong=\"G1519\"fill|strong=\"G0378\"up|strong=\"G1519\"their|strong=\"G0846\"sins|strong=\"G0266\"always|strong=\"G3842\": for|strong=\"G1519\"the|strong=\"G3588\"wrath|strong=\"G3709\"of|strong=\"G1909\"God|strong=\"G0846\"is|strong=\"G3588\"come|strong=\"G5348\"upon|strong=\"G1909\"them|strong=\"G0846\"to|strong=\"G1519\"the|strong=\"G3588\"end|strong=\"G5056\".",
      "17": "But|strong=\"G1161\"we|strong=\"G2249\", brethren|strong=\"G0080\", being|strong=\"G4771\"taken|strong=\"G0642\"away|strong=\"G0575\"from|strong=\"G0575\"you|strong=\"G5210\"for|strong=\"G4314\"a|strong=\"G3708\"short time|strong=\"G2540\", in|strong=\"G1722\"sight|strong=\"G4383\", not|strong=\"G3756\"in|strong=\"G1722\"heart|strong=\"G2588\", have|strong=\"G1473\"hastened the|strong=\"G3588\"more|strong=\"G4183\"abundantly to|strong=\"G4314\"see|strong=\"G3708\"your|strong=\"G3708\"face|strong=\"G4383\"with|strong=\"G1722\"great|strong=\"G4183\"desire|strong=\"G1939\".",
      "18": "For|strong=\"G4314\"we|strong=\"G2249\"would|strong=\"G2309\"have|strong=\"G2532\"come|strong=\"G2064\"unto you|strong=\"G5210\", I|strong=\"G1473\"Paul|strong=\"G3972\"indeed|strong=\"G2532\", once|strong=\"G0530\"and|strong=\"G2532\"again|strong=\"G2532\": but|strong=\"G2532\"Satan|strong=\"G4567\"hath hindered|strong=\"G1465\"us.",
      "19": "For|strong=\"G1063\"what|strong=\"G5101\"is|strong=\"G5101\"our|strong=\"G2424\"hope|strong=\"G1680\", or|strong=\"G2228\"joy|strong=\"G5479\", or|strong=\"G2228\"crown|strong=\"G4735\"of|strong=\"G2962\"glory? Are|strong=\"G3588\"not|strong=\"G3780\"you|strong=\"G5210\", in|strong=\"G1722\"the|strong=\"G3588\"presence|strong=\"G1715\"of|strong=\"G2962\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G0846\"at|strong=\"G1722\"his|strong=\"G0846\"coming|strong=\"G3952\"?",
      "20": "For|strong=\"G1063\"you|strong=\"G5210\"are|strong=\"G1510\"our|strong=\"G2532\"glory|strong=\"G1391\"and|strong=\"G2532\"joy|strong=\"G5479\"."
    },
    "3": {
      "1": "For|strong=\"G1722\"which cause, forbearing no|strong=\"G3371\"longer|strong=\"G3371\", we|strong=\"G1352\"thought|strong=\"G2106\"it|strong=\"G2106\"good|strong=\"G2106\"to|strong=\"G1722\"remain at|strong=\"G1722\"Athens|strong=\"G0116\"alone|strong=\"G3441\":",
      "2": "And|strong=\"G2532\"we|strong=\"G2249\"sent|strong=\"G3992\"Timothy|strong=\"G5095\", our|strong=\"G2316\"brother|strong=\"G0080\", and|strong=\"G2532\"the|strong=\"G3588\"minister|strong=\"G1249\"of|strong=\"G2316\"God|strong=\"G2316\"in|strong=\"G1722\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2316\"Christ|strong=\"G5547\", to|strong=\"G1519\"confirm|strong=\"G4741\"you|strong=\"G5210\"and|strong=\"G2532\"exhort|strong=\"G3870\"you|strong=\"G5210\"concerning|strong=\"G5228\"your|strong=\"G2532\"faith|strong=\"G4102\":",
      "3": "That|strong=\"G3754\"no|strong=\"G3367\"man|strong=\"G3778\"should|strong=\"G3778\"be|strong=\"G3778\"moved in|strong=\"G1722\"these|strong=\"G3778\"tribulations|strong=\"G2347\": for|strong=\"G1063\"yourselves|strong=\"G0846\"know|strong=\"G1492\", that|strong=\"G3754\"we|strong=\"G3778\"are|strong=\"G3778\"appointed|strong=\"G2749\"thereunto.",
      "4": "For|strong=\"G1063\"even|strong=\"G2532\"when|strong=\"G3753\"we|strong=\"G2532\"were|strong=\"G1510\"with|strong=\"G4314\"you|strong=\"G5210\", we|strong=\"G2532\"foretold you|strong=\"G5210\"that|strong=\"G3754\"we|strong=\"G2532\"should|strong=\"G2532\"suffer|strong=\"G2346\"tribulations, as|strong=\"G2531\"also|strong=\"G2532\"it|strong=\"G1510\"is|strong=\"G1510\"come|strong=\"G1096\"to|strong=\"G4314\"pass|strong=\"G1096\", and|strong=\"G2532\"you|strong=\"G5210\"know|strong=\"G1492\".",
      "5": "For|strong=\"G1519\"this|strong=\"G3778\"cause also|strong=\"G2532\", I|strong=\"G1473\", forbearing no|strong=\"G3361\"longer|strong=\"G3371\", sent|strong=\"G3992\"to|strong=\"G1519\"know|strong=\"G1097\"your|strong=\"G2532\"faith|strong=\"G4102\": lest|strong=\"G3361\"perhaps he|strong=\"G2532\"that|strong=\"G1097\"tempteth should|strong=\"G3778\"have|strong=\"G2532\"tempted|strong=\"G3985\"you|strong=\"G5210\", and|strong=\"G2532\"our|strong=\"G2532\"labour should|strong=\"G3778\"be|strong=\"G1096\"made|strong=\"G1096\"vain|strong=\"G2756\".",
      "6": "But|strong=\"G1161\"now|strong=\"G1161\"when|strong=\"G2532\"Timothy|strong=\"G5095\"came|strong=\"G2064\"to|strong=\"G4314\"us|strong=\"G2097\"from|strong=\"G0575\"you|strong=\"G5210\", and|strong=\"G2532\"related to|strong=\"G4314\"us|strong=\"G2097\"your|strong=\"G2192\"faith|strong=\"G4102\"and|strong=\"G2532\"charity, and|strong=\"G2532\"that|strong=\"G3754\"you|strong=\"G5210\"have|strong=\"G2192\"a|strong=\"G2192\"good|strong=\"G0018\"remembrance|strong=\"G3417\"of|strong=\"G0575\"us|strong=\"G2097\"always|strong=\"G3842\", desiring to|strong=\"G4314\"see|strong=\"G3708\"us|strong=\"G2097\"as|strong=\"G2509\"we|strong=\"G2249\"also|strong=\"G2532\"to|strong=\"G4314\"see|strong=\"G3708\"you|strong=\"G5210\";",
      "7": "Therefore|strong=\"G1223\"we|strong=\"G2249\"were|strong=\"G3956\"comforted|strong=\"G3870\", brethren|strong=\"G0080\", in|strong=\"G1909\"you|strong=\"G5210\", in|strong=\"G1909\"all|strong=\"G3956\"our|strong=\"G2532\"necessity|strong=\"G0318\"and|strong=\"G2532\"tribulation|strong=\"G2347\", by|strong=\"G1223\"your|strong=\"G2532\"faith|strong=\"G4102\",",
      "8": "Because|strong=\"G3754\"now|strong=\"G3568\"we|strong=\"G1437\"live|strong=\"G2198\", if|strong=\"G1437\"you|strong=\"G5210\"stand|strong=\"G4739\"in|strong=\"G1722\"the|strong=\"G1722\"Lord|strong=\"G2962\".",
      "9": "For|strong=\"G1063\"what|strong=\"G5101\"thanks|strong=\"G2169\"can|strong=\"G1410\"we|strong=\"G2249\"return|strong=\"G0467\"to|strong=\"G1909\"God|strong=\"G2316\"for|strong=\"G1063\"you|strong=\"G5210\", in|strong=\"G1909\"all|strong=\"G3956\"the|strong=\"G3956\"joy|strong=\"G5479\"wherewith we|strong=\"G2249\"rejoice|strong=\"G5463\"for|strong=\"G1063\"you|strong=\"G5210\"before|strong=\"G1715\"our|strong=\"G2316\"God|strong=\"G2316\",",
      "10": "Night|strong=\"G3571\"and|strong=\"G2532\"day|strong=\"G2250\"more|strong=\"G4053\"abundantly|strong=\"G4053\"praying|strong=\"G1189\"that|strong=\"G3708\"we|strong=\"G2532\"may|strong=\"G2532\"see|strong=\"G3708\"your|strong=\"G3708\"face|strong=\"G4383\", and|strong=\"G2532\"may|strong=\"G2532\"accomplish those|strong=\"G3588\"things|strong=\"G3588\"that|strong=\"G3708\"are|strong=\"G3588\"wanting to|strong=\"G1519\"your|strong=\"G3708\"faith|strong=\"G4102\"?",
      "11": "Now|strong=\"G1161\"God|strong=\"G2316\"himself|strong=\"G0846\"and|strong=\"G2532\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G0846\", direct|strong=\"G2720\"our|strong=\"G2316\"way|strong=\"G3598\"unto you|strong=\"G5210\".",
