    "1": {
      "1": "Now|strong=\"H1961\"the|strong=\"H0559\"word|strong=\"H1697\"of|strong=\"H1121\"the|strong=\"H0559\"Lord|strong=\"H3068\"came|strong=\"H1961\"to|strong=\"H0413\"Jonas the|strong=\"H0559\"son|strong=\"H1121\"of|strong=\"H1121\"Amathi, saying|strong=\"H0559\":",
      "2": "Arise|strong=\"H6965\", and|strong=\"H6965\"go|strong=\"H5927\"to|strong=\"H0413\"Ninive the|strong=\"H6440\"great|strong=\"H1419\"city|strong=\"H5892\", and|strong=\"H6965\"preach in|strong=\"H5921\"it|strong=\"H5921\": for|strong=\"H3588\"the|strong=\"H6440\"wickedness|strong=\"H7451\"thereof is|strong=\"H6440\"come|strong=\"H5927\"up|strong=\"H5927\"before|strong=\"H6440\"me|strong=\"H0413\".",
      "3": "And|strong=\"H0935\"Jonas rose|strong=\"H6965\"up|strong=\"H6965\"to|strong=\"H0935\"flee|strong=\"H1272\"into|strong=\"H0935\"Tharsis from|strong=\"H0935\"the|strong=\"H6440\"face|strong=\"H6440\"of|strong=\"H3068\"the|strong=\"H6440\"Lord|strong=\"H3068\", and|strong=\"H0935\"he|strong=\"H3068\"went|strong=\"H0935\"down|strong=\"H3381\"to|strong=\"H0935\"Joppe, and|strong=\"H0935\"found|strong=\"H4672\"a|strong=\"H5414\"ship|strong=\"H0591\"going|strong=\"H0935\"to|strong=\"H0935\"Tharsis: and|strong=\"H0935\"he|strong=\"H3068\"paid|strong=\"H5414\"the|strong=\"H6440\"fare|strong=\"H7939\"thereof, and|strong=\"H0935\"went|strong=\"H0935\"down|strong=\"H3381\"into|strong=\"H0935\"it|strong=\"H5414\", to|strong=\"H0935\"go|strong=\"H0935\"with|strong=\"H5973\"them|strong=\"H5414\"to|strong=\"H0935\"Tharsis from|strong=\"H0935\"the|strong=\"H6440\"face|strong=\"H6440\"of|strong=\"H3068\"the|strong=\"H6440\"Lord|strong=\"H3068\".",
      "4": "But|strong=\"H1961\"the|strong=\"H0413\"Lord|strong=\"H3068\"sent a|strong=\"H1961\"great|strong=\"H1419\"wind|strong=\"H7307\"into|strong=\"H0413\"the|strong=\"H0413\"sea|strong=\"H3220\": and|strong=\"H3068\"a|strong=\"H1961\"great|strong=\"H1419\"tempest|strong=\"H5591\"was|strong=\"H1961\"raised in|strong=\"H0413\"the|strong=\"H0413\"sea|strong=\"H3220\", and|strong=\"H3068\"the|strong=\"H0413\"ship|strong=\"H0591\"was|strong=\"H1961\"in|strong=\"H0413\"danger to|strong=\"H0413\"be|strong=\"H1961\"broken|strong=\"H7665\".",
      "5": "And|strong=\"H0430\"the|strong=\"H0853\"mariners were|strong=\"H0834\"afraid|strong=\"H3372\", and|strong=\"H0430\"the|strong=\"H0853\"men|strong=\"H0376\"cried|strong=\"H2199\"to|strong=\"H0413\"their|strong=\"H5921\"god|strong=\"H0430\": and|strong=\"H0430\"they|strong=\"H0834\"cast|strong=\"H2904\"forth the|strong=\"H0853\"wares that|strong=\"H0834\"were|strong=\"H0834\"in|strong=\"H5921\"the|strong=\"H0853\"ship|strong=\"H0591\", into|strong=\"H0413\"the|strong=\"H0853\"sea|strong=\"H3220\", to|strong=\"H0413\"lighten|strong=\"H7043\"it|strong=\"H5921\"of|strong=\"H0376\"them|strong=\"H0413\": and|strong=\"H0430\"Jonas went|strong=\"H3381\"down|strong=\"H3381\"into|strong=\"H0413\"the|strong=\"H0853\"inner|strong=\"H3411\"part|strong=\"H3411\"of|strong=\"H0376\"the|strong=\"H0853\"ship|strong=\"H0591\", and|strong=\"H0430\"fell|strong=\"H5921\"into|strong=\"H0413\"a|strong=\"H0834\"deep sleep|strong=\"H7901\".",
      "6": "And|strong=\"H6965\"the|strong=\"H0559\"shipmaster came|strong=\"H7126\"to|strong=\"H0413\"him|strong=\"H0413\", and|strong=\"H6965\"said|strong=\"H0559\"to|strong=\"H0413\"him|strong=\"H0413\": Why|strong=\"H4100\"art thou fast asleep? rise|strong=\"H6965\"up|strong=\"H6965\", call|strong=\"H7121\"upon|strong=\"H7121\"thy God|strong=\"H0430\", if|strong=\"H0194\"so|strong=\"H7121\"be|strong=\"H3808\"that|strong=\"H7121\"God|strong=\"H0430\"will|strong=\"H0430\"think|strong=\"H0559\"of|strong=\"H0430\"us|strong=\"H0413\", that|strong=\"H7121\"we may|strong=\"H0430\"not|strong=\"H3808\"perish|strong=\"H0006\".",
      "7": "And|strong=\"H0376\"they|strong=\"H5921\"said|strong=\"H0559\"every|strong=\"H0376\"one|strong=\"H0376\"to|strong=\"H0413\"his|strong=\"H5921\"fellow|strong=\"H0376\": Come|strong=\"H5307\", and|strong=\"H0376\"let us|strong=\"H0413\"cast|strong=\"H5307\"lots|strong=\"H1486\", that|strong=\"H3045\"we may|strong=\"H0376\"know|strong=\"H3045\"why this|strong=\"H2063\"evil|strong=\"H7451\"is|strong=\"H4310\"upon|strong=\"H5921\"us|strong=\"H0413\". And|strong=\"H0376\"they|strong=\"H5921\"cast|strong=\"H5307\"lots|strong=\"H1486\", and|strong=\"H0376\"the|strong=\"H0559\"lot|strong=\"H1486\"fell|strong=\"H5307\"upon|strong=\"H5921\"Jonas.",
      "8": "And|strong=\"H0935\"they|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0413\"him|strong=\"H0413\": Tell|strong=\"H5046\"us|strong=\"H4994\"for|strong=\"H0413\"what|strong=\"H4100\"cause this|strong=\"H2088\"evil|strong=\"H7451\"is|strong=\"H0834\"upon|strong=\"H0935\"us|strong=\"H4994\", what|strong=\"H4100\"is|strong=\"H0834\"thy business|strong=\"H4399\"? of|strong=\"H0776\"what|strong=\"H4100\"country|strong=\"H0776\"art thou? and|strong=\"H0935\"whither goest thou? or|strong=\"H0776\"of|strong=\"H0776\"what|strong=\"H4100\"people|strong=\"H5971\"art thou?",
      "9": "And|strong=\"H3068\"he|strong=\"H0834\"said|strong=\"H0559\"to|strong=\"H0413\"them|strong=\"H0413\": I|strong=\"H0589\"am|strong=\"H0589\"a|strong=\"H0834\"Hebrew|strong=\"H5680\", and|strong=\"H3068\"I|strong=\"H0589\"fear|strong=\"H3373\"the|strong=\"H0853\"Lord|strong=\"H3068\"the|strong=\"H0853\"God|strong=\"H0430\"of|strong=\"H0430\"heaven|strong=\"H8064\", who|strong=\"H0834\"made|strong=\"H6213\"both the|strong=\"H0853\"sea|strong=\"H3220\"and|strong=\"H3068\"the|strong=\"H0853\"dry|strong=\"H3004\"land|strong=\"H3004\".",
      "10": "And|strong=\"H3068\"the|strong=\"H0559\"men|strong=\"H0376\"were|strong=\"H0376\"greatly|strong=\"H1419\"afraid|strong=\"H3372\", and|strong=\"H3068\"they|strong=\"H1992\"said|strong=\"H0559\"to|strong=\"H0413\"him|strong=\"H0413\": Why|strong=\"H4100\"hast thou done|strong=\"H6213\"this|strong=\"H2063\"? (for|strong=\"H3588\"the|strong=\"H0559\"men|strong=\"H0376\"knew|strong=\"H3045\"that|strong=\"H3588\"he|strong=\"H1931\"fled|strong=\"H1272\"from|strong=\"H0376\"the|strong=\"H0559\"face|strong=\"H6440\"of|strong=\"H0376\"the|strong=\"H0559\"Lord|strong=\"H3068\": because|strong=\"H3588\"he|strong=\"H1931\"had|strong=\"H3068\"told|strong=\"H5046\"them|strong=\"H0413\".)",
      "11": "And|strong=\"H1980\"they|strong=\"H3588\"said|strong=\"H0559\"to|strong=\"H0413\"him|strong=\"H0413\": What|strong=\"H4100\"shall|strong=\"H4100\"we|strong=\"H3588\"do|strong=\"H6213\"to|strong=\"H0413\"thee, that|strong=\"H3588\"the|strong=\"H0559\"sea|strong=\"H3220\"may|strong=\"H6213\"be|strong=\"H3220\"calm|strong=\"H8367\"to|strong=\"H0413\"us|strong=\"H0413\"? for|strong=\"H3588\"the|strong=\"H0559\"sea|strong=\"H3220\"flowed|strong=\"H1980\"and|strong=\"H1980\"swelled.",
      "12": "And|strong=\"H1419\"he|strong=\"H3588\"said|strong=\"H0559\"to|strong=\"H0413\"them|strong=\"H0413\": Take|strong=\"H5375\"me|strong=\"H0413\"up|strong=\"H5375\", and|strong=\"H1419\"cast|strong=\"H2904\"me|strong=\"H0413\"into|strong=\"H0413\"the|strong=\"H0559\"sea|strong=\"H3220\", and|strong=\"H1419\"the|strong=\"H0559\"sea|strong=\"H3220\"shall|strong=\"H2088\"be|strong=\"H3220\"calm|strong=\"H8367\"to|strong=\"H0413\"you|strong=\"H3588\": for|strong=\"H3588\"I|strong=\"H0589\"know|strong=\"H3045\"that|strong=\"H3588\"for|strong=\"H3588\"my|strong=\"H5921\"sake|strong=\"H5921\"this|strong=\"H2088\"great|strong=\"H1419\"tempest|strong=\"H5591\"is|strong=\"H2088\"upon|strong=\"H5921\"you|strong=\"H3588\".",
      "13": "And|strong=\"H1980\"the|strong=\"H5921\"men|strong=\"H0376\"rowed|strong=\"H2864\"hard to|strong=\"H0413\"return|strong=\"H7725\"to|strong=\"H0413\"land|strong=\"H3004\", but|strong=\"H3588\"they|strong=\"H3588\"were|strong=\"H0376\"not|strong=\"H3808\"able|strong=\"H3201\": because|strong=\"H3588\"the|strong=\"H5921\"sea|strong=\"H3220\"tossed and|strong=\"H1980\"swelled upon|strong=\"H5921\"them|strong=\"H0413\".",
      "14": "And|strong=\"H3068\"they|strong=\"H0834\"cried|strong=\"H7121\"to|strong=\"H0413\"the|strong=\"H0559\"Lord|strong=\"H3068\", and|strong=\"H3068\"said|strong=\"H0559\": We|strong=\"H3588\"beseech|strong=\"H0577\"thee, O|strong=\"H0577\"Lord|strong=\"H3068\", let|strong=\"H4994\"us|strong=\"H5414\"not|strong=\"H0408\"perish|strong=\"H0006\"for|strong=\"H3588\"this|strong=\"H2088\"man’s|strong=\"H0376\"life|strong=\"H5315\", and|strong=\"H3068\"lay|strong=\"H5414\"not|strong=\"H0408\"upon|strong=\"H5921\"us|strong=\"H5414\"innocent|strong=\"H5355\"blood|strong=\"H1818\": for|strong=\"H3588\"thou, O|strong=\"H0577\"Lord|strong=\"H3068\", hast done|strong=\"H6213\"as|strong=\"H0834\"it|strong=\"H5414\"pleased|strong=\"H2654\"thee.",
      "15": "And|strong=\"H5975\"they|strong=\"H5375\"took|strong=\"H5375\"Jonas, and|strong=\"H5975\"cast|strong=\"H2904\"him|strong=\"H0413\"into|strong=\"H0413\"the|strong=\"H0853\"sea|strong=\"H3220\", and|strong=\"H5975\"the|strong=\"H0853\"sea|strong=\"H3220\"ceased from|strong=\"H0413\"raging|strong=\"H2197\".",
      "16": "And|strong=\"H3068\"the|strong=\"H0853\"men|strong=\"H0376\"feared|strong=\"H3372\"the|strong=\"H0853\"Lord|strong=\"H3068\"exceedingly|strong=\"H1419\", and|strong=\"H3068\"sacrificed|strong=\"H2076\"victims to|strong=\"H3068\"the|strong=\"H0853\"Lord|strong=\"H3068\", and|strong=\"H3068\"made|strong=\"H5087\"vows|strong=\"H5088\"."
    },
    "2": {
      "1": "Now|strong=\"H1961\"the|strong=\"H0853\"Lord|strong=\"H3068\"prepared a|strong=\"H1961\"great|strong=\"H1419\"fish|strong=\"H1709\"to|strong=\"H1961\"swallow|strong=\"H1104\"up|strong=\"H1104\"Jonas: and|strong=\"H3068\"Jonas was|strong=\"H1961\"in|strong=\"H3068\"the|strong=\"H0853\"belly of|strong=\"H3068\"the|strong=\"H0853\"fish|strong=\"H1709\"three|strong=\"H7969\"days|strong=\"H3117\"and|strong=\"H3068\"three|strong=\"H7969\"nights|strong=\"H3915\".",
      "2": "And|strong=\"H3068\"Jonas prayed|strong=\"H6419\"to|strong=\"H0413\"the|strong=\"H0413\"Lord|strong=\"H3068\"his|strong=\"H3068\"God|strong=\"H0430\"out|strong=\"H0413\"of|strong=\"H0430\"the|strong=\"H0413\"belly of|strong=\"H0430\"the|strong=\"H0413\"fish|strong=\"H1710\".",
      "3": "And|strong=\"H3068\"he|strong=\"H3068\"said|strong=\"H0559\": I|strong=\"H0559\"cried|strong=\"H7121\"out|strong=\"H0413\"of|strong=\"H3068\"my|strong=\"H8085\"affliction to|strong=\"H0413\"the|strong=\"H0559\"Lord|strong=\"H3068\", and|strong=\"H3068\"he|strong=\"H3068\"heard|strong=\"H8085\"me|strong=\"H0413\": I|strong=\"H0559\"cried|strong=\"H7121\"out|strong=\"H0413\"of|strong=\"H3068\"the|strong=\"H0559\"belly|strong=\"H0990\"of|strong=\"H3068\"hell, and|strong=\"H3068\"thou hast heard|strong=\"H8085\"my|strong=\"H8085\"voice|strong=\"H6963\".",
      "4": "And|strong=\"H3220\"thou hast cast|strong=\"H7993\"me|strong=\"H5921\"forth into|strong=\"H5921\"the|strong=\"H3605\"deep|strong=\"H4688\"in|strong=\"H5921\"the|strong=\"H3605\"heart|strong=\"H3824\"of|strong=\"H5921\"the|strong=\"H3605\"sea|strong=\"H3220\", and|strong=\"H3220\"a|strong=\"H5921\"flood hath compassed me|strong=\"H5921\": all|strong=\"H3605\"thy billows|strong=\"H1530\", and|strong=\"H3220\"thy waves|strong=\"H1530\"have|strong=\"H3605\"passed|strong=\"H5674\"over|strong=\"H5921\"me|strong=\"H5921\".",
      "5": "And|strong=\"H5869\"I|strong=\"H0589\"said|strong=\"H0559\": I|strong=\"H0589\"am|strong=\"H0589\"cast away|strong=\"H1644\"out|strong=\"H1644\"of|strong=\"H5869\"the|strong=\"H0559\"sight|strong=\"H5869\"of|strong=\"H5869\"thy eyes|strong=\"H5869\": but|strong=\"H0389\"yet|strong=\"H0389\"I|strong=\"H0589\"shall|strong=\"H0589\"see|strong=\"H5869\"thy holy|strong=\"H6944\"temple|strong=\"H1964\"again|strong=\"H3254\".",
      "6": "The|strong=\"H5704\"waters|strong=\"H4325\"compassed me|strong=\"H5315\"about|strong=\"H5437\"even|strong=\"H5704\"to|strong=\"H5704\"the|strong=\"H5704\"soul|strong=\"H5315\": the|strong=\"H5704\"deep|strong=\"H8415\"hath closed me|strong=\"H5315\"round|strong=\"H5437\"about|strong=\"H5437\", the|strong=\"H5704\"sea hath covered my|strong=\"H5704\"head|strong=\"H7218\".",
      "7": "I|strong=\"H0776\"went|strong=\"H5927\"down|strong=\"H3381\"to|strong=\"H3381\"the|strong=\"H3068\"lowest parts of|strong=\"H0776\"the|strong=\"H3068\"mountains|strong=\"H2022\": the|strong=\"H3068\"bars|strong=\"H1280\"of|strong=\"H0776\"the|strong=\"H3068\"earth|strong=\"H0776\"have|strong=\"H0776\"shut me|strong=\"H1157\"up|strong=\"H5927\"for|strong=\"H1157\"ever|strong=\"H5769\": and|strong=\"H3068\"thou wilt bring|strong=\"H5927\"up|strong=\"H5927\"my|strong=\"H3068\"life|strong=\"H2416\"from|strong=\"H3381\"corruption|strong=\"H7845\", O|strong=\"H3068\"Lord|strong=\"H3068\"my|strong=\"H3068\"God|strong=\"H0430\".",
      "8": "When|strong=\"H0935\"my|strong=\"H3068\"soul|strong=\"H5315\"was|strong=\"H3068\"in|strong=\"H5921\"distress within|strong=\"H5921\"me|strong=\"H0413\", I|strong=\"H5315\"remembered|strong=\"H2142\"the|strong=\"H0853\"Lord|strong=\"H3068\": that|strong=\"H3068\"my|strong=\"H3068\"prayer|strong=\"H8605\"may|strong=\"H3068\"come|strong=\"H0935\"to|strong=\"H0413\"thee, unto thy holy|strong=\"H6944\"temple|strong=\"H1964\".",
      "9": "They|strong=\"H5800\"that are vain|strong=\"H7723\"observe|strong=\"H8104\"vanities|strong=\"H1892\", forsake|strong=\"H5800\"their|strong=\"H8104\"own mercy.",
      "10": "But|strong=\"H0834\"I|strong=\"H0589\"with|strong=\"H3068\"the|strong=\"H0834\"voice|strong=\"H6963\"of|strong=\"H3068\"praise|strong=\"H8426\"will|strong=\"H3068\"sacrifice|strong=\"H2076\"to|strong=\"H3068\"thee: I|strong=\"H0589\"will|strong=\"H3068\"pay|strong=\"H7999\"whatsoever I|strong=\"H0589\"have|strong=\"H0834\"vowed|strong=\"H5087\"for|strong=\"H3068\"my|strong=\"H3068\"salvation|strong=\"H3444\"to|strong=\"H3068\"the|strong=\"H0834\"Lord|strong=\"H3068\".",
      "11": "And|strong=\"H3068\"the|strong=\"H0853\"Lord|strong=\"H3068\"spoke|strong=\"H0559\"to|strong=\"H0413\"the|strong=\"H0853\"fish|strong=\"H1709\": and|strong=\"H3068\"it|strong=\"H3068\"vomited out|strong=\"H0413\"Jonas upon|strong=\"H0413\"the|strong=\"H0853\"dry|strong=\"H3004\"land|strong=\"H3004\"."
    },
    "3": {
      "1": "And|strong=\"H3068\"the|strong=\"H0559\"word|strong=\"H1697\"of|strong=\"H3068\"the|strong=\"H0559\"Lord|strong=\"H3068\"came|strong=\"H1961\"to|strong=\"H0413\"Jonas the|strong=\"H0559\"second|strong=\"H8145\"time|strong=\"H8145\", saying|strong=\"H0559\":",
      "2": "Arise|strong=\"H6965\", and|strong=\"H6965\"go|strong=\"H6965\"to|strong=\"H0413\"Ninive the|strong=\"H0853\"great|strong=\"H1419\"city|strong=\"H5892\": and|strong=\"H6965\"preach in|strong=\"H0413\"it|strong=\"H7121\"the|strong=\"H0853\"preaching that|strong=\"H0834\"I|strong=\"H0834\"bid thee.",
      "3": "And|strong=\"H6965\"Jonas arose|strong=\"H6965\", and|strong=\"H6965\"went|strong=\"H6965\"to|strong=\"H0413\"Ninive, according|strong=\"H0413\"to|strong=\"H0413\"the|strong=\"H0413\"word|strong=\"H1697\"of|strong=\"H0430\"the|strong=\"H0413\"Lord|strong=\"H3068\": now|strong=\"H1961\"Ninive was|strong=\"H1961\"a|strong=\"H1961\"great|strong=\"H1419\"city|strong=\"H5892\"of|strong=\"H0430\"three|strong=\"H7969\"days’|strong=\"H3117\"journey|strong=\"H4109\".",
      "4": "And|strong=\"H0935\"Jonas began|strong=\"H2490\"to|strong=\"H0559\"enter|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H0559\"city|strong=\"H5892\"one|strong=\"H0259\"day’s|strong=\"H3117\"journey|strong=\"H4109\": and|strong=\"H0935\"he|strong=\"H3117\"cried|strong=\"H7121\", and|strong=\"H0935\"said|strong=\"H0559\": Yet|strong=\"H5750\"forty|strong=\"H0705\"days|strong=\"H3117\", and|strong=\"H0935\"Ninive shall|strong=\"H3117\"be|strong=\"H5750\"destroyed|strong=\"H2015\".",
      "5": "And|strong=\"H0430\"the|strong=\"H5704\"men|strong=\"H0376\"of|strong=\"H0376\"Ninive believed|strong=\"H0539\"in|strong=\"H0430\"God|strong=\"H0430\": and|strong=\"H0430\"they|strong=\"H0376\"proclaimed|strong=\"H7121\"a|strong=\"H7121\"fast|strong=\"H6685\", and|strong=\"H0430\"put|strong=\"H3847\"on|strong=\"H3847\"sackcloth|strong=\"H8242\"from|strong=\"H0376\"the|strong=\"H5704\"greatest|strong=\"H1419\"to|strong=\"H5704\"the|strong=\"H5704\"least.",
      "6": "And|strong=\"H6965\"the|strong=\"H5921\"word|strong=\"H1697\"came|strong=\"H5060\"to|strong=\"H0413\"the|strong=\"H5921\"king|strong=\"H4428\"of|strong=\"H4428\"Ninive; and|strong=\"H6965\"he|strong=\"H5921\"rose|strong=\"H6965\"up|strong=\"H6965\"out|strong=\"H5921\"of|strong=\"H4428\"his|strong=\"H5921\"throne|strong=\"H3678\", and|strong=\"H6965\"cast|strong=\"H5060\"away|strong=\"H5674\"his|strong=\"H5921\"robe|strong=\"H0155\"from|strong=\"H5921\"him|strong=\"H0413\", and|strong=\"H6965\"was|strong=\"H4428\"clothed|strong=\"H3680\"with|strong=\"H0413\"sackcloth|strong=\"H8242\", and|strong=\"H6965\"sat|strong=\"H3427\"in|strong=\"H3427\"ashes|strong=\"H0665\".",
      "7": "And|strong=\"H4428\"he|strong=\"H0559\"caused it|strong=\"H8354\"to|strong=\"H0559\"be|strong=\"H0408\"proclaimed and|strong=\"H4428\"published in|strong=\"H4428\"Ninive from|strong=\"H0929\"the|strong=\"H0559\"mouth of|strong=\"H4428\"the|strong=\"H0559\"king|strong=\"H4428\"and|strong=\"H4428\"of|strong=\"H4428\"his|strong=\"H4428\"princes, saying|strong=\"H0559\": Let|strong=\"H0408\"neither|strong=\"H0408\"men|strong=\"H0120\"nor|strong=\"H0408\"beasts|strong=\"H0929\", oxen|strong=\"H1241\"nor|strong=\"H0408\"sheep|strong=\"H6629\", taste|strong=\"H2938\"any|strong=\"H0120\"thing|strong=\"H3972\": let|strong=\"H0408\"them|strong=\"H7462\"not|strong=\"H0408\"feed|strong=\"H7462\", nor|strong=\"H0408\"drink|strong=\"H8354\"water|strong=\"H4325\".",
      "8": "And|strong=\"H0430\"let men|strong=\"H0376\"and|strong=\"H0430\"beasts|strong=\"H0929\"be|strong=\"H0376\"covered|strong=\"H3680\"with|strong=\"H0413\"sackcloth|strong=\"H8242\", and|strong=\"H0430\"cry|strong=\"H7121\"to|strong=\"H0413\"the|strong=\"H0834\"Lord with|strong=\"H0413\"all|strong=\"H0376\"their|strong=\"H7725\"strength, and|strong=\"H0430\"let them|strong=\"H0413\"turn|strong=\"H7725\"every|strong=\"H0376\"one|strong=\"H0376\"from|strong=\"H4480\"his|strong=\"H7725\"evil|strong=\"H7451\"way|strong=\"H1870\", and|strong=\"H0430\"from|strong=\"H4480\"the|strong=\"H0834\"iniquity that|strong=\"H0834\"is|strong=\"H0834\"in|strong=\"H0413\"their|strong=\"H7725\"hands|strong=\"H3709\".",
      "9": "Who|strong=\"H4310\"can|strong=\"H4310\"tell|strong=\"H3045\"if God|strong=\"H0430\"will|strong=\"H0430\"turn|strong=\"H7725\", and|strong=\"H0430\"forgive: and|strong=\"H0430\"will|strong=\"H0430\"turn|strong=\"H7725\"away|strong=\"H7725\"from|strong=\"H7725\"his|strong=\"H7725\"fierce|strong=\"H2740\"anger|strong=\"H0639\", and|strong=\"H0430\"we|strong=\"H7725\"shall|strong=\"H3808\"not|strong=\"H3808\"perish|strong=\"H0006\"?",
      "10": "And|strong=\"H0430\"God|strong=\"H0430\"saw|strong=\"H7200\"their|strong=\"H1992\"works|strong=\"H4639\", that|strong=\"H0834\"they|strong=\"H1992\"were|strong=\"H0834\"turned|strong=\"H7725\"from|strong=\"H7725\"their|strong=\"H1992\"evil|strong=\"H7451\"way|strong=\"H1870\": and|strong=\"H0430\"God|strong=\"H0430\"had|strong=\"H0834\"mercy with|strong=\"H5921\"regard|strong=\"H7200\"to|strong=\"H1696\"the|strong=\"H0853\"evil|strong=\"H7451\"which|strong=\"H0834\"he|strong=\"H0834\"had|strong=\"H0834\"said|strong=\"H1696\"that|strong=\"H0834\"he|strong=\"H0834\"would|strong=\"H0834\"do|strong=\"H6213\"to|strong=\"H1696\"them|strong=\"H1992\", and|strong=\"H0430\"he|strong=\"H0834\"did|strong=\"H6213\"it|strong=\"H5921\"not|strong=\"H3808\"."
    },
    "4": {
      "1": "And|strong=\"H1419\"Jonas was|strong=\"H1419\"exceedingly|strong=\"H1419\"troubled, and|strong=\"H1419\"was|strong=\"H1419\"angry|strong=\"H2734\":",
      "2": "And|strong=\"H3068\"he|strong=\"H3588\"prayed|strong=\"H6419\"to|strong=\"H0413\"the|strong=\"H0559\"Lord|strong=\"H3068\", and|strong=\"H3068\"said|strong=\"H0559\": I|strong=\"H3588\"beseech|strong=\"H0577\"thee, O|strong=\"H0577\"Lord|strong=\"H3068\", is|strong=\"H3068\"not|strong=\"H3808\"this|strong=\"H2088\"what|strong=\"H1697\"I|strong=\"H3588\"said|strong=\"H0559\", when|strong=\"H3588\"I|strong=\"H3588\"was|strong=\"H1961\"yet|strong=\"H3588\"in|strong=\"H5921\"my|strong=\"H3068\"own|strong=\"H1961\"country|strong=\"H0127\"? therefore|strong=\"H3651\"I|strong=\"H3588\"went|strong=\"H0413\"before|strong=\"H0413\"to|strong=\"H0413\"flee|strong=\"H1272\"into|strong=\"H0413\"Tharsis: for|strong=\"H3588\"I|strong=\"H3588\"know|strong=\"H3045\"that|strong=\"H3588\"thou art a|strong=\"H1961\"gracious|strong=\"H2587\"and|strong=\"H3068\"merciful|strong=\"H7349\"God|strong=\"H0410\", patient|strong=\"H0750\", and|strong=\"H3068\"of|strong=\"H3068\"much|strong=\"H7227\"compassion|strong=\"H5162\", and|strong=\"H3068\"easy to|strong=\"H0413\"forgive evil|strong=\"H7451\".",
      "3": "And|strong=\"H3068\"now|strong=\"H6258\", O|strong=\"H4994\"Lord|strong=\"H3068\", I|strong=\"H3588\"beseech|strong=\"H4994\"thee take|strong=\"H3947\"my|strong=\"H3068\"life|strong=\"H5315\"from|strong=\"H4480\"me|strong=\"H4994\": for|strong=\"H3588\"it|strong=\"H3588\"is|strong=\"H3068\"better|strong=\"H2896\"for|strong=\"H3588\"me|strong=\"H4994\"to|strong=\"H3068\"die|strong=\"H4194\"than|strong=\"H4480\"to|strong=\"H3068\"live|strong=\"H2416\".",
      "4": "And|strong=\"H3068\"the|strong=\"H0559\"Lord|strong=\"H3068\"said|strong=\"H0559\": Dost thou think|strong=\"H0559\"thou hast reason|strong=\"H3190\"to|strong=\"H0559\"be|strong=\"H3068\"angry|strong=\"H2734\"?",
      "5": "Then|strong=\"H1961\"Jonas went|strong=\"H3318\"out|strong=\"H3318\"of|strong=\"H3427\"the|strong=\"H0834\"city|strong=\"H5892\", and|strong=\"H8033\"sat|strong=\"H3427\"toward|strong=\"H4480\"the|strong=\"H0834\"east|strong=\"H6924\"side of|strong=\"H3427\"the|strong=\"H0834\"city|strong=\"H5892\": and|strong=\"H8033\"he|strong=\"H0834\"made|strong=\"H6213\"himself|strong=\"H3427\"a|strong=\"H1961\"booth|strong=\"H5521\"there|strong=\"H8033\", and|strong=\"H8033\"he|strong=\"H0834\"sat|strong=\"H3427\"under|strong=\"H8478\"it|strong=\"H8033\"in|strong=\"H3427\"the|strong=\"H0834\"shadow|strong=\"H6738\", till|strong=\"H5704\"he|strong=\"H0834\"might|strong=\"H0834\"see|strong=\"H7200\"what|strong=\"H4100\"would|strong=\"H4100\"befall|strong=\"H1961\"the|strong=\"H0834\"city|strong=\"H5892\".",
      "6": "And|strong=\"H3068\"the|strong=\"H5921\"Lord|strong=\"H3068\"God|strong=\"H0430\"prepared an|strong=\"H1961\"ivy, and|strong=\"H3068\"it|strong=\"H5921\"came|strong=\"H1961\"up|strong=\"H5927\"over|strong=\"H5921\"the|strong=\"H5921\"head|strong=\"H7218\"of|strong=\"H0430\"Jonas, to|strong=\"H1961\"be|strong=\"H1961\"a|strong=\"H1961\"shadow|strong=\"H6738\"over|strong=\"H5921\"his|strong=\"H5921\"head|strong=\"H7218\", and|strong=\"H3068\"to|strong=\"H1961\"cover him|strong=\"H5921\"(for|strong=\"H5921\"he|strong=\"H0430\"was|strong=\"H1961\"fatigued), and|strong=\"H3068\"Jonas was|strong=\"H1961\"exceeding|strong=\"H8057\"glad|strong=\"H8055\"of|strong=\"H0430\"the|strong=\"H5921\"ivy.",
      "7": "But|strong=\"H5221\"God|strong=\"H0430\"prepared a|strong=\"H5221\"worm, when|strong=\"H5927\"the|strong=\"H0853\"morning|strong=\"H4283\"arose|strong=\"H5927\"on|strong=\"H0430\"the|strong=\"H0853\"following|strong=\"H4283\"day|strong=\"H4283\": and|strong=\"H0430\"it|strong=\"H5221\"struck|strong=\"H5221\"the|strong=\"H0853\"ivy and|strong=\"H0430\"it|strong=\"H5221\"withered|strong=\"H3001\".",
      "8": "And|strong=\"H0430\"when|strong=\"H1961\"the|strong=\"H0853\"sun|strong=\"H8121\"was|strong=\"H1961\"risen|strong=\"H2224\", the|strong=\"H0853\"Lord commanded|strong=\"H0559\"a|strong=\"H1961\"hot and|strong=\"H0430\"burning wind|strong=\"H7307\": and|strong=\"H0430\"the|strong=\"H0853\"sun|strong=\"H8121\"beat|strong=\"H5221\"upon|strong=\"H5921\"the|strong=\"H0853\"head|strong=\"H7218\"of|strong=\"H0430\"Jonas, and|strong=\"H0430\"he|strong=\"H0430\"broiled with|strong=\"H5921\"the|strong=\"H0853\"heat: and|strong=\"H0430\"he|strong=\"H0430\"desired|strong=\"H0559\"for|strong=\"H5921\"his|strong=\"H5921\"soul|strong=\"H5315\"that|strong=\"H0559\"he|strong=\"H0430\"might die|strong=\"H4191\", and|strong=\"H0430\"said|strong=\"H0559\": It|strong=\"H5921\"is|strong=\"H0430\"better|strong=\"H2896\"for|strong=\"H5921\"me|strong=\"H5315\"to|strong=\"H0559\"die|strong=\"H4191\"than|strong=\"H2896\"to|strong=\"H0559\"live|strong=\"H2416\".",
      "9": "And|strong=\"H0430\"the|strong=\"H0559\"Lord said|strong=\"H0559\"to|strong=\"H0413\"Jonas: Dost thou think|strong=\"H0559\"thou hast reason|strong=\"H3190\"to|strong=\"H0413\"be|strong=\"H0430\"angry|strong=\"H2734\", for|strong=\"H5921\"the|strong=\"H0559\"ivy? And|strong=\"H0430\"he|strong=\"H5704\"said|strong=\"H0559\": I|strong=\"H5704\"am|strong=\"H0430\"angry|strong=\"H2734\"with|strong=\"H0413\"reason|strong=\"H3190\"even|strong=\"H5704\"unto death|strong=\"H4194\".",
      "10": "And|strong=\"H1121\"the|strong=\"H0559\"Lord|strong=\"H3068\"said|strong=\"H0559\": Thou art grieved for|strong=\"H5921\"the|strong=\"H0559\"ivy, for|strong=\"H5921\"which|strong=\"H0834\"thou hast not|strong=\"H3808\"laboured, nor|strong=\"H3808\"made|strong=\"H1961\"it|strong=\"H5921\"to|strong=\"H0559\"grow|strong=\"H1431\", which|strong=\"H0834\"in|strong=\"H5921\"one|strong=\"H3808\"night|strong=\"H3915\"came|strong=\"H1961\"up|strong=\"H5921\", and|strong=\"H1121\"in|strong=\"H5921\"one|strong=\"H3808\"night|strong=\"H3915\"perished|strong=\"H0006\".",
      "11": "And|strong=\"H1419\"shall|strong=\"H3808\"not|strong=\"H3808\"I|strong=\"H0589\"spare|strong=\"H2347\"Ninive, that|strong=\"H0834\"great|strong=\"H1419\"city|strong=\"H5892\", in|strong=\"H5921\"which|strong=\"H0834\"there|strong=\"H3426\"are|strong=\"H0834\"more|strong=\"H3808\"than|strong=\"H3808\"a|strong=\"H0834\"hundred and|strong=\"H1419\"twenty thousand|strong=\"H7239\"persons|strong=\"H0120\"that|strong=\"H0834\"know|strong=\"H3045\"not|strong=\"H3808\"how|strong=\"H0834\"to|strong=\"H5921\"distinguish|strong=\"H3045\"between|strong=\"H0996\"their|strong=\"H5921\"right|strong=\"H3225\"hand|strong=\"H3225\"and|strong=\"H1419\"their|strong=\"H5921\"left|strong=\"H8040\", and|strong=\"H1419\"many|strong=\"H7227\"beasts|strong=\"H0929\"?"
    }
