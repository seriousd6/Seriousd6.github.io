    "1": {
      "1": "The|strong=\"H0413\"burden|strong=\"H4853\"of|strong=\"H3068\"the|strong=\"H0413\"word|strong=\"H1697\"of|strong=\"H3068\"the|strong=\"H0413\"Lord|strong=\"H3068\"to|strong=\"H0413\"Israel|strong=\"H3478\"by|strong=\"H3027\"the|strong=\"H0413\"hand|strong=\"H3027\"of|strong=\"H3068\"Malachias.",
      "2": "I|strong=\"H0559\"have|strong=\"H0251\"loved|strong=\"H0157\"you|strong=\"H3808\", saith the|strong=\"H0853\"Lord|strong=\"H3068\": and|strong=\"H3068\"you|strong=\"H3808\"have|strong=\"H0251\"said|strong=\"H0559\": Wherein hast thou loved|strong=\"H0157\"us|strong=\"H0559\"? Was|strong=\"H3068\"not|strong=\"H3808\"Esau|strong=\"H6215\"brother|strong=\"H0251\"to|strong=\"H0559\"Jacob|strong=\"H3290\", saith the|strong=\"H0853\"Lord|strong=\"H3068\", and|strong=\"H3068\"I|strong=\"H0559\"have|strong=\"H0251\"loved|strong=\"H0157\"Jacob|strong=\"H3290\",",
      "3": "But have|strong=\"H8130\"hated|strong=\"H8130\"Esau|strong=\"H6215\"? and|strong=\"H2022\"I|strong=\"H7760\"have|strong=\"H8130\"made|strong=\"H7760\"his|strong=\"H7760\"mountains|strong=\"H2022\"a|strong=\"H7760\"wilderness|strong=\"H4057\", and|strong=\"H2022\"given his|strong=\"H7760\"inheritance|strong=\"H5159\"to|strong=\"H5159\"the|strong=\"H0853\"dragons of|strong=\"H2022\"the|strong=\"H0853\"desert|strong=\"H4057\".",
      "4": "But|strong=\"H3588\"if|strong=\"H3588\"Edom|strong=\"H0123\"shall|strong=\"H3068\"say|strong=\"H0559\": We|strong=\"H3588\"are|strong=\"H0834\"destroyed|strong=\"H2040\", but|strong=\"H3588\"we|strong=\"H3588\"will|strong=\"H3068\"return|strong=\"H7725\"and|strong=\"H3068\"build|strong=\"H1129\"up|strong=\"H5704\"what|strong=\"H0834\"hath been|strong=\"H5769\"destroyed|strong=\"H2040\": thus|strong=\"H3541\"saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\": They|strong=\"H1992\"shall|strong=\"H3068\"build|strong=\"H1129\"up|strong=\"H5704\", and|strong=\"H3068\"I|strong=\"H0589\"will|strong=\"H3068\"throw down|strong=\"H2040\": and|strong=\"H3068\"they|strong=\"H1992\"shall|strong=\"H3068\"be|strong=\"H3068\"called|strong=\"H7121\"the|strong=\"H0559\"borders|strong=\"H1366\"of|strong=\"H3068\"wickedness|strong=\"H7564\", and|strong=\"H3068\"the|strong=\"H0559\"people|strong=\"H5971\"with|strong=\"H3068\"whom|strong=\"H0834\"the|strong=\"H0559\"Lord|strong=\"H3068\"is|strong=\"H0834\"angry|strong=\"H2194\"for|strong=\"H3588\"ever|strong=\"H5769\".",
      "5": "And|strong=\"H3068\"your|strong=\"H3068\"eyes|strong=\"H5869\"shall|strong=\"H3068\"see|strong=\"H7200\", and|strong=\"H3068\"you|strong=\"H0859\"shall|strong=\"H3068\"say|strong=\"H0559\": The|strong=\"H0559\"Lord|strong=\"H3068\"be|strong=\"H3478\"magnified|strong=\"H1431\"upon|strong=\"H5921\"the|strong=\"H0559\"border|strong=\"H1366\"of|strong=\"H3068\"Israel|strong=\"H3478\".",
      "6": "The|strong=\"H0853\"son|strong=\"H1121\"honoureth the|strong=\"H0853\"father|strong=\"H0001\", and|strong=\"H1121\"the|strong=\"H0853\"servant|strong=\"H5650\"his|strong=\"H3068\"master|strong=\"H0113\": if|strong=\"H0518\"then|strong=\"H0853\"I|strong=\"H0589\"be|strong=\"H8034\"a|strong=\"H0518\"father|strong=\"H0001\", where|strong=\"H0346\"is|strong=\"H3068\"my|strong=\"H3068\"honour? and|strong=\"H1121\"if|strong=\"H0518\"I|strong=\"H0589\"be|strong=\"H8034\"a|strong=\"H0518\"master|strong=\"H0113\", where|strong=\"H0346\"is|strong=\"H3068\"my|strong=\"H3068\"fear|strong=\"H4172\"? saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H1121\"hosts|strong=\"H6635\".",
      "7": "To|strong=\"H0559\"you|strong=\"H5921\", O|strong=\"H3068\"priests, that|strong=\"H1931\"despise|strong=\"H0959\"my|strong=\"H3068\"name|strong=\"H0559\", and|strong=\"H3068\"have|strong=\"H3068\"said|strong=\"H0559\": Wherein have|strong=\"H3068\"we despised|strong=\"H0959\"thy name|strong=\"H0559\"? You|strong=\"H5921\"offer polluted bread|strong=\"H3899\"upon|strong=\"H5921\"my|strong=\"H3068\"altar|strong=\"H4196\", and|strong=\"H3068\"you|strong=\"H5921\"say|strong=\"H0559\": Wherein have|strong=\"H3068\"we polluted thee? In|strong=\"H5921\"that|strong=\"H1931\"you|strong=\"H5921\"say|strong=\"H0559\": The|strong=\"H0559\"table|strong=\"H7979\"of|strong=\"H3068\"the|strong=\"H0559\"Lord|strong=\"H3068\"is|strong=\"H3068\"contemptible.",
      "8": "If|strong=\"H3588\"you|strong=\"H3588\"offer|strong=\"H7126\"the|strong=\"H0559\"blind|strong=\"H5787\"for|strong=\"H3588\"sacrifice|strong=\"H2076\", is|strong=\"H0369\"it|strong=\"H3588\"not|strong=\"H0369\"evil|strong=\"H7451\"? and|strong=\"H3068\"if|strong=\"H3588\"you|strong=\"H3588\"offer|strong=\"H7126\"the|strong=\"H0559\"lame|strong=\"H6455\"and|strong=\"H3068\"the|strong=\"H0559\"sick|strong=\"H2470\", is|strong=\"H0369\"it|strong=\"H3588\"not|strong=\"H0369\"evil|strong=\"H7451\"? offer|strong=\"H7126\"it|strong=\"H3588\"to|strong=\"H0559\"thy prince, if|strong=\"H3588\"he|strong=\"H3588\"will|strong=\"H3068\"be|strong=\"H3068\"pleased|strong=\"H7521\"with|strong=\"H3068\"it|strong=\"H3588\", or|strong=\"H0176\"if|strong=\"H3588\"he|strong=\"H3588\"will|strong=\"H3068\"regard|strong=\"H6440\"thy face|strong=\"H6440\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "9": "And|strong=\"H3068\"now|strong=\"H6258\"beseech|strong=\"H4994\"ye the|strong=\"H0559\"face|strong=\"H6440\"of|strong=\"H3068\"God|strong=\"H0410\", that|strong=\"H4480\"he|strong=\"H3068\"may|strong=\"H1961\"have|strong=\"H1961\"mercy|strong=\"H2603\"on|strong=\"H3068\"you|strong=\"H6440\", (for|strong=\"H3027\"by|strong=\"H3027\"your|strong=\"H3068\"hand|strong=\"H3027\"hath this|strong=\"H2063\"been|strong=\"H1961\"done|strong=\"H1961\",) if|strong=\"H1961\"by|strong=\"H3027\"any|strong=\"H4480\"means|strong=\"H3027\"he|strong=\"H3068\"will|strong=\"H3068\"receive|strong=\"H5375\"your|strong=\"H3068\"faces|strong=\"H6440\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "10": "Who|strong=\"H4310\"is|strong=\"H0369\"there|strong=\"H0369\"among|strong=\"H4310\"you|strong=\"H3808\", that|strong=\"H3068\"will|strong=\"H3068\"shut|strong=\"H5462\"the|strong=\"H0559\"doors|strong=\"H1817\", and|strong=\"H3068\"will|strong=\"H3068\"kindle|strong=\"H0215\"the|strong=\"H0559\"fire|strong=\"H0215\"on|strong=\"H3068\"my|strong=\"H3068\"altar|strong=\"H4196\"gratis? I|strong=\"H1571\"have|strong=\"H0369\"no|strong=\"H3808\"pleasure|strong=\"H2656\"in|strong=\"H3068\"you|strong=\"H3808\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\": and|strong=\"H3068\"I|strong=\"H1571\"will|strong=\"H3068\"not|strong=\"H3808\"receive|strong=\"H7521\"a|strong=\"H3068\"gift|strong=\"H4503\"of|strong=\"H3068\"your|strong=\"H3068\"hand|strong=\"H3027\".",
      "11": "For|strong=\"H3588\"from|strong=\"H5704\"the|strong=\"H3605\"rising|strong=\"H4217\"of|strong=\"H3068\"the|strong=\"H3605\"sun|strong=\"H8121\"even|strong=\"H5704\"to|strong=\"H0559\"the|strong=\"H3605\"going down|strong=\"H3588\", my|strong=\"H3605\"name|strong=\"H8034\"is|strong=\"H3068\"great|strong=\"H1419\"among|strong=\"H8034\"the|strong=\"H3605\"Gentiles|strong=\"H1471\", and|strong=\"H3068\"in|strong=\"H3068\"every|strong=\"H3605\"place|strong=\"H4725\"there|strong=\"H3068\"is|strong=\"H3068\"sacrifice|strong=\"H4503\", and|strong=\"H3068\"there|strong=\"H3068\"is|strong=\"H3068\"offered|strong=\"H6999\"to|strong=\"H0559\"my|strong=\"H3605\"name|strong=\"H8034\"a|strong=\"H3588\"clean|strong=\"H2889\"oblation: for|strong=\"H3588\"my|strong=\"H3605\"name|strong=\"H8034\"is|strong=\"H3068\"great|strong=\"H1419\"among|strong=\"H8034\"the|strong=\"H3605\"Gentiles|strong=\"H1471\", saith the|strong=\"H3605\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "12": "And|strong=\"H0853\"you|strong=\"H0859\"have|strong=\"H0859\"profaned|strong=\"H2490\"it|strong=\"H1931\"in|strong=\"H0559\"that|strong=\"H1931\"you|strong=\"H0859\"say|strong=\"H0559\": The|strong=\"H0853\"table|strong=\"H7979\"of|strong=\"H0559\"the|strong=\"H0853\"Lord|strong=\"H0136\"is|strong=\"H1931\"defiled|strong=\"H1351\": and|strong=\"H0853\"that|strong=\"H1931\"which|strong=\"H1931\"is|strong=\"H1931\"laid thereupon is|strong=\"H1931\"contemptible with|strong=\"H1351\"the|strong=\"H0853\"fire that|strong=\"H1931\"devoureth it|strong=\"H1931\".",
      "13": "And|strong=\"H0935\"you|strong=\"H0935\"have|strong=\"H3068\"said|strong=\"H0559\": Behold|strong=\"H2009\"of|strong=\"H3068\"our|strong=\"H3068\"labour, and|strong=\"H0935\"you|strong=\"H0935\"puffed it|strong=\"H5301\"away|strong=\"H1497\", saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\", and|strong=\"H0935\"you|strong=\"H0935\"brought|strong=\"H0935\"in|strong=\"H0935\"of|strong=\"H3068\"rapine the|strong=\"H0853\"lame|strong=\"H6455\", and|strong=\"H0935\"the|strong=\"H0853\"sick|strong=\"H2470\", and|strong=\"H0935\"brought|strong=\"H0935\"in|strong=\"H0935\"an|strong=\"H0935\"offering|strong=\"H4503\": shall|strong=\"H3068\"I|strong=\"H2009\"accept|strong=\"H7521\"it|strong=\"H5301\"at|strong=\"H3068\"your|strong=\"H3068\"hands|strong=\"H3027\", saith the|strong=\"H0853\"Lord|strong=\"H3068\"?",
      "14": "Cursed|strong=\"H0779\"is|strong=\"H3068\"the|strong=\"H0559\"deceitful man|strong=\"H2145\"that|strong=\"H3588\"hath in|strong=\"H3068\"his|strong=\"H3068\"flock|strong=\"H5739\"a|strong=\"H3588\"male|strong=\"H2145\", and|strong=\"H3068\"making a|strong=\"H3588\"vow|strong=\"H5087\"offereth in|strong=\"H3068\"sacrifice|strong=\"H2076\"that|strong=\"H3588\"which|strong=\"H1471\"is|strong=\"H3068\"feeble to|strong=\"H0559\"the|strong=\"H0559\"Lord|strong=\"H3068\": for|strong=\"H3588\"I|strong=\"H0589\"am|strong=\"H0589\"a|strong=\"H3588\"great|strong=\"H1419\"King|strong=\"H4428\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H4428\"hosts|strong=\"H6635\", and|strong=\"H3068\"my|strong=\"H3068\"name|strong=\"H8034\"is|strong=\"H3068\"dreadful among|strong=\"H8034\"the|strong=\"H0559\"Gentiles|strong=\"H1471\"."
    },
    "2": {
      "1": "And|strong=\"H3548\"now|strong=\"H6258\", O ye priests|strong=\"H3548\", this|strong=\"H2063\"commandment|strong=\"H4687\"is|strong=\"H3548\"to|strong=\"H0413\"you|strong=\"H0413\".",
      "2": "If|strong=\"H0518\"you|strong=\"H3588\"will|strong=\"H3068\"not|strong=\"H3808\"hear|strong=\"H8085\", and|strong=\"H3068\"if|strong=\"H0518\"you|strong=\"H3588\"will|strong=\"H3068\"not|strong=\"H3808\"lay|strong=\"H5414\"it|strong=\"H7760\"to|strong=\"H0559\"heart|strong=\"H3820\", to|strong=\"H0559\"give|strong=\"H5414\"glory|strong=\"H3519\"to|strong=\"H0559\"my|strong=\"H5414\"name|strong=\"H8034\", saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\": I|strong=\"H3588\"will|strong=\"H3068\"send|strong=\"H7971\"poverty upon|strong=\"H5921\"you|strong=\"H3588\", and|strong=\"H3068\"will|strong=\"H3068\"curse|strong=\"H0779\"your|strong=\"H3068\"blessings|strong=\"H1293\", yea|strong=\"H3588\"I|strong=\"H3588\"will|strong=\"H3068\"curse|strong=\"H0779\"them|strong=\"H5414\", because|strong=\"H3588\"you|strong=\"H3588\"have|strong=\"H0369\"not|strong=\"H3808\"laid|strong=\"H7760\"it|strong=\"H7760\"to|strong=\"H0559\"heart|strong=\"H3820\".",
      "3": "Behold|strong=\"H2005\", I|strong=\"H2005\"will|strong=\"H2233\"cast the|strong=\"H0853\"shoulder to|strong=\"H0413\"you|strong=\"H6440\", and|strong=\"H6440\"I|strong=\"H2005\"will|strong=\"H2233\"scatter|strong=\"H2219\"upon|strong=\"H5921\"your|strong=\"H5921\"face|strong=\"H6440\"the|strong=\"H0853\"dung|strong=\"H6569\"of|strong=\"H6440\"your|strong=\"H5921\"solemnities, and|strong=\"H6440\"it|strong=\"H5921\"shall|strong=\"H2233\"take|strong=\"H5375\"you|strong=\"H6440\"away|strong=\"H5375\"with|strong=\"H0413\"it|strong=\"H5921\".",
      "4": "And|strong=\"H3068\"you|strong=\"H3588\"shall|strong=\"H3068\"know|strong=\"H3045\"that|strong=\"H3588\"I|strong=\"H3588\"sent|strong=\"H7971\"you|strong=\"H3588\"this|strong=\"H2063\"commandment|strong=\"H4687\", that|strong=\"H3588\"my|strong=\"H3068\"covenant|strong=\"H1285\"might|strong=\"H3068\"be|strong=\"H1961\"with|strong=\"H0854\"Levi|strong=\"H3878\", saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "5": "My|strong=\"H5414\"covenant|strong=\"H1285\"was|strong=\"H8034\"with|strong=\"H0854\"him|strong=\"H5414\"of|strong=\"H6440\"life|strong=\"H2416\"and|strong=\"H6440\"peace|strong=\"H7965\": and|strong=\"H6440\"I|strong=\"H5414\"gave|strong=\"H5414\"him|strong=\"H5414\"fear|strong=\"H3372\": and|strong=\"H6440\"he|strong=\"H1931\"feared|strong=\"H3372\"me|strong=\"H5414\", and|strong=\"H6440\"he|strong=\"H1931\"was|strong=\"H8034\"afraid|strong=\"H3372\"before|strong=\"H6440\"my|strong=\"H5414\"name|strong=\"H8034\".",
      "6": "The|strong=\"H7725\"law|strong=\"H8451\"of|strong=\"H6310\"truth|strong=\"H0571\"was|strong=\"H1961\"in|strong=\"H1980\"his|strong=\"H7725\"mouth|strong=\"H6310\", and|strong=\"H1980\"iniquity|strong=\"H5771\"was|strong=\"H1961\"not|strong=\"H3808\"found|strong=\"H4672\"in|strong=\"H1980\"his|strong=\"H7725\"lips|strong=\"H8193\": he|strong=\"H3808\"walked|strong=\"H1980\"with|strong=\"H0854\"me|strong=\"H7725\"in|strong=\"H1980\"peace|strong=\"H7965\", and|strong=\"H1980\"in|strong=\"H1980\"equity, and|strong=\"H1980\"turned|strong=\"H7725\"many|strong=\"H7227\"away|strong=\"H7725\"from|strong=\"H7725\"iniquity|strong=\"H5771\".",
      "7": "For|strong=\"H3588\"the|strong=\"H3588\"lips|strong=\"H8193\"of|strong=\"H3068\"the|strong=\"H3588\"priest|strong=\"H3548\"shall|strong=\"H3548\"keep|strong=\"H8104\"knowledge|strong=\"H1847\", and|strong=\"H3068\"they|strong=\"H3588\"shall|strong=\"H3548\"seek|strong=\"H1245\"the|strong=\"H3588\"law|strong=\"H8451\"at|strong=\"H3068\"his|strong=\"H8104\"mouth|strong=\"H6310\": because|strong=\"H3588\"he|strong=\"H1931\"is|strong=\"H3068\"the|strong=\"H3588\"angel|strong=\"H4397\"of|strong=\"H3068\"the|strong=\"H3588\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "8": "But|strong=\"H0859\"you|strong=\"H0859\"have|strong=\"H0859\"departed|strong=\"H5493\"out|strong=\"H4480\"of|strong=\"H3068\"the|strong=\"H0559\"way|strong=\"H1870\", and|strong=\"H3068\"have|strong=\"H0859\"caused many|strong=\"H7227\"to|strong=\"H0559\"stumble|strong=\"H3782\"at|strong=\"H3068\"the|strong=\"H0559\"law|strong=\"H8451\": you|strong=\"H0859\"have|strong=\"H0859\"made void the|strong=\"H0559\"covenant|strong=\"H1285\"of|strong=\"H3068\"Levi|strong=\"H3878\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "9": "Therefore|strong=\"H1571\"have|strong=\"H0834\"I|strong=\"H0589\"also|strong=\"H1571\"made|strong=\"H5414\"you|strong=\"H0834\"contemptible, and|strong=\"H6440\"base before|strong=\"H6440\"all|strong=\"H3605\"people|strong=\"H5971\", as|strong=\"H0834\"you|strong=\"H0834\"have|strong=\"H0834\"not|strong=\"H0369\"kept|strong=\"H8104\"my|strong=\"H3605\"ways|strong=\"H1870\", and|strong=\"H6440\"have|strong=\"H0834\"accepted persons in|strong=\"H1870\"the|strong=\"H3605\"law|strong=\"H8451\".",
      "10": "Have|strong=\"H0001\"we|strong=\"H3605\"not|strong=\"H3808\"all|strong=\"H3605\"one|strong=\"H0259\"father|strong=\"H0001\"? hath not|strong=\"H3808\"one|strong=\"H0259\"God|strong=\"H0410\"created|strong=\"H1254\"us? why|strong=\"H4069\"then|strong=\"H3605\"doth every|strong=\"H3605\"one|strong=\"H0259\"of|strong=\"H0376\"us despise his|strong=\"H3605\"brother|strong=\"H0251\", violating the|strong=\"H3605\"covenant|strong=\"H1285\"of|strong=\"H0376\"our|strong=\"H3605\"fathers|strong=\"H0001\"?",
      "11": "Juda hath transgressed, and|strong=\"H3068\"abomination|strong=\"H8441\"hath been|strong=\"H0834\"committed|strong=\"H6213\"in|strong=\"H3068\"Israel|strong=\"H3478\", and|strong=\"H3068\"in|strong=\"H3068\"Jerusalem|strong=\"H3389\": for|strong=\"H3588\"Juda hath profaned|strong=\"H2490\"the|strong=\"H0834\"holiness|strong=\"H6944\"of|strong=\"H3068\"the|strong=\"H0834\"Lord|strong=\"H3068\", which|strong=\"H0834\"he|strong=\"H0834\"loved|strong=\"H0157\", and|strong=\"H3068\"hath married|strong=\"H1166\"the|strong=\"H0834\"daughter|strong=\"H1323\"of|strong=\"H3068\"a|strong=\"H3588\"strange|strong=\"H5236\"God|strong=\"H0410\".",
      "12": "The|strong=\"H0834\"Lord|strong=\"H3068\"will|strong=\"H3068\"cut|strong=\"H3772\"off|strong=\"H3772\"the|strong=\"H0834\"man|strong=\"H0376\"that|strong=\"H0834\"hath done|strong=\"H6213\"this|strong=\"H0834\", both the|strong=\"H0834\"master, and|strong=\"H3068\"the|strong=\"H0834\"scholar, out|strong=\"H0376\"of|strong=\"H0376\"the|strong=\"H0834\"tabernacles of|strong=\"H0376\"Jacob|strong=\"H3290\", and|strong=\"H3068\"him|strong=\"H3772\"that|strong=\"H0834\"offereth an|strong=\"H3772\"offering|strong=\"H4503\"to|strong=\"H3068\"the|strong=\"H0834\"Lord|strong=\"H3068\"of|strong=\"H0376\"hosts|strong=\"H6635\".",
      "13": "And|strong=\"H3068\"this|strong=\"H2063\"again|strong=\"H5750\"have|strong=\"H0369\"you|strong=\"H6213\"done|strong=\"H6213\", you|strong=\"H6213\"have|strong=\"H0369\"covered|strong=\"H3680\"the|strong=\"H0853\"altar|strong=\"H4196\"of|strong=\"H3068\"the|strong=\"H0853\"Lord|strong=\"H3068\"with|strong=\"H0413\"tears|strong=\"H1832\", with|strong=\"H0413\"weeping|strong=\"H1065\", and|strong=\"H3068\"bellowing, so|strong=\"H6213\"that|strong=\"H3068\"I|strong=\"H3068\"have|strong=\"H0369\"no|strong=\"H0369\"more|strong=\"H5750\"a|strong=\"H3947\"regard|strong=\"H6437\"to|strong=\"H0413\"sacrifice|strong=\"H4503\", neither|strong=\"H0369\"do|strong=\"H6213\"I|strong=\"H3068\"accept|strong=\"H3947\"any|strong=\"H5750\"atonement at|strong=\"H0413\"your|strong=\"H3068\"hands|strong=\"H3027\".",
      "14": "And|strong=\"H3068\"you|strong=\"H0859\"have|strong=\"H0834\"said|strong=\"H0559\": For|strong=\"H3588\"what|strong=\"H4100\"cause? Because|strong=\"H3588\"the|strong=\"H0559\"Lord|strong=\"H3068\"hath been|strong=\"H0834\"witness between|strong=\"H0996\"thee, and|strong=\"H3068\"the|strong=\"H0559\"wife|strong=\"H0802\"of|strong=\"H3068\"thy youth|strong=\"H5271\", whom|strong=\"H0834\"thou hast despised: yet|strong=\"H3588\"she|strong=\"H1931\"was|strong=\"H0834\"thy partner, and|strong=\"H3068\"the|strong=\"H0559\"wife|strong=\"H0802\"of|strong=\"H3068\"thy covenant|strong=\"H1285\".",
      "15": "Did|strong=\"H6213\"not|strong=\"H3808\"one|strong=\"H0259\"make|strong=\"H6213\"her|strong=\"H0802\", and|strong=\"H0430\"she|strong=\"H3808\"is|strong=\"H4100\"the|strong=\"H8104\"residue of|strong=\"H0430\"his|strong=\"H8104\"spirit|strong=\"H7307\"? And|strong=\"H0430\"what|strong=\"H4100\"doth one|strong=\"H0259\"seek|strong=\"H1245\", but|strong=\"H3808\"the|strong=\"H8104\"seed|strong=\"H2233\"of|strong=\"H0430\"God|strong=\"H0430\"? Keep|strong=\"H8104\"then|strong=\"H6213\"your|strong=\"H8104\"spirit|strong=\"H7307\", and|strong=\"H0430\"despise not|strong=\"H3808\"the|strong=\"H8104\"wife|strong=\"H0802\"of|strong=\"H0430\"thy youth|strong=\"H5271\".",
      "16": "When|strong=\"H3588\"thou shalt hate|strong=\"H8130\"her|strong=\"H7971\"put|strong=\"H7971\"her|strong=\"H7971\"away|strong=\"H7971\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"the|strong=\"H0559\"God|strong=\"H0430\"of|strong=\"H0430\"Israel|strong=\"H3478\": but|strong=\"H3588\"iniquity shall|strong=\"H3068\"cover|strong=\"H3680\"his|strong=\"H8104\"garment|strong=\"H3830\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H0430\"hosts|strong=\"H6635\", keep|strong=\"H8104\"your|strong=\"H3068\"spirit|strong=\"H7307\", and|strong=\"H3068\"despise|strong=\"H8130\"not|strong=\"H3808\".",
      "17": "You|strong=\"H3605\"have|strong=\"H5869\"wearied|strong=\"H3021\"the|strong=\"H3605\"Lord|strong=\"H3068\"with|strong=\"H3068\"your|strong=\"H3068\"words|strong=\"H1697\", and|strong=\"H3068\"you|strong=\"H3605\"said|strong=\"H0559\": Wherein have|strong=\"H5869\"we|strong=\"H3605\"wearied|strong=\"H3021\"him|strong=\"H3605\"? In|strong=\"H0430\"that|strong=\"H3605\"you|strong=\"H3605\"say|strong=\"H0559\": Every|strong=\"H3605\"one|strong=\"H3605\"that|strong=\"H3605\"doth evil|strong=\"H7451\", is|strong=\"H3068\"good|strong=\"H2896\"in|strong=\"H0430\"the|strong=\"H3605\"sight|strong=\"H5869\"of|strong=\"H0430\"the|strong=\"H3605\"Lord|strong=\"H3068\", and|strong=\"H3068\"such|strong=\"H1931\"please him|strong=\"H3605\": or|strong=\"H0176\"surely where|strong=\"H0346\"is|strong=\"H3068\"the|strong=\"H3605\"God|strong=\"H0430\"of|strong=\"H0430\"judgment|strong=\"H4941\"?"
