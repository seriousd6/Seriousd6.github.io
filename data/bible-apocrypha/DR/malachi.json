    "3": {
      "1": "Behold|strong=\"H2009\"I|strong=\"H0834\"send|strong=\"H7971\"my|strong=\"H3068\"angel|strong=\"H4397\", and|strong=\"H0935\"he|strong=\"H0834\"shall|strong=\"H3068\"prepare|strong=\"H6437\"the|strong=\"H0559\"way|strong=\"H1870\"before|strong=\"H6440\"my|strong=\"H3068\"face|strong=\"H6440\". And|strong=\"H0935\"presently the|strong=\"H0559\"Lord|strong=\"H3068\", whom|strong=\"H0834\"you|strong=\"H0859\"seek|strong=\"H1245\", and|strong=\"H0935\"the|strong=\"H0559\"angel|strong=\"H4397\"of|strong=\"H3068\"the|strong=\"H0559\"testament, whom|strong=\"H0834\"you|strong=\"H0859\"desire|strong=\"H1245\", shall|strong=\"H3068\"come|strong=\"H0935\"to|strong=\"H0413\"his|strong=\"H3068\"temple|strong=\"H1964\". Behold|strong=\"H2009\"he|strong=\"H0834\"cometh, saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "2": "And|strong=\"H0935\"who|strong=\"H4310\"shall|strong=\"H4310\"be|strong=\"H3117\"able to|strong=\"H0935\"think|strong=\"H7200\"of|strong=\"H3117\"the|strong=\"H0853\"day|strong=\"H3117\"of|strong=\"H3117\"his|strong=\"H3526\"coming|strong=\"H0935\"? and|strong=\"H0935\"who|strong=\"H4310\"shall|strong=\"H4310\"stand|strong=\"H5975\"to|strong=\"H0935\"see|strong=\"H7200\"him|strong=\"H0853\"? for|strong=\"H3588\"he|strong=\"H1931\"is|strong=\"H1931\"like|strong=\"H0784\"a|strong=\"H3588\"refining|strong=\"H6884\"fire|strong=\"H0784\", and|strong=\"H0935\"like|strong=\"H0784\"the|strong=\"H0853\"fuller’s|strong=\"H3526\"herb:",
      "3": "And|strong=\"H1121\"he|strong=\"H3068\"shall|strong=\"H1121\"sit|strong=\"H3427\"refining|strong=\"H6884\"and|strong=\"H1121\"cleansing|strong=\"H2891\"the|strong=\"H0853\"silver|strong=\"H3701\", and|strong=\"H1121\"he|strong=\"H3068\"shall|strong=\"H1121\"purify|strong=\"H2891\"the|strong=\"H0853\"sons|strong=\"H1121\"of|strong=\"H1121\"Levi|strong=\"H3878\", and|strong=\"H1121\"shall|strong=\"H1121\"refine|strong=\"H6884\"them|strong=\"H0853\"as|strong=\"H1961\"gold|strong=\"H2091\", and|strong=\"H1121\"as|strong=\"H1961\"silver|strong=\"H3701\", and|strong=\"H1121\"they|strong=\"H3068\"shall|strong=\"H1121\"offer sacrifices|strong=\"H4503\"to|strong=\"H1961\"the|strong=\"H0853\"Lord|strong=\"H3068\"in|strong=\"H3427\"justice|strong=\"H6666\".",
      "4": "And|strong=\"H3068\"the|strong=\"H3068\"sacrifice|strong=\"H4503\"of|strong=\"H3068\"Juda and|strong=\"H3068\"of|strong=\"H3068\"Jerusalem|strong=\"H3389\"shall|strong=\"H3068\"please|strong=\"H6149\"the|strong=\"H3068\"Lord|strong=\"H3068\", as|strong=\"H3068\"in|strong=\"H8141\"the|strong=\"H3068\"days|strong=\"H3117\"of|strong=\"H3068\"old|strong=\"H5769\", and|strong=\"H3068\"in|strong=\"H8141\"the|strong=\"H3068\"ancient|strong=\"H5769\"years|strong=\"H8141\".",
      "5": "And|strong=\"H3068\"I|strong=\"H0559\"will|strong=\"H3068\"come|strong=\"H1961\"to|strong=\"H0413\"you|strong=\"H3808\"in|strong=\"H0413\"judgment|strong=\"H4941\", and|strong=\"H3068\"will|strong=\"H3068\"be|strong=\"H1961\"a|strong=\"H1961\"speedy witness|strong=\"H5707\"against|strong=\"H0413\"sorcerers|strong=\"H3784\", and|strong=\"H3068\"adulterers|strong=\"H5003\", and|strong=\"H3068\"false|strong=\"H8267\"swearers, and|strong=\"H3068\"them|strong=\"H0413\"that|strong=\"H3068\"oppress|strong=\"H6231\"the|strong=\"H0559\"hireling in|strong=\"H0413\"his|strong=\"H3068\"wages|strong=\"H7939\"; the|strong=\"H0559\"widows|strong=\"H0490\", and|strong=\"H3068\"the|strong=\"H0559\"fatherless|strong=\"H3490\": and|strong=\"H3068\"oppress|strong=\"H6231\"the|strong=\"H0559\"stranger|strong=\"H1616\", and|strong=\"H3068\"have|strong=\"H1961\"not|strong=\"H3808\"feared|strong=\"H3372\"me|strong=\"H0413\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "6": "For|strong=\"H3588\"I|strong=\"H0589\"am|strong=\"H0589\"the|strong=\"H3588\"Lord|strong=\"H3068\", and|strong=\"H1121\"I|strong=\"H0589\"change not|strong=\"H3808\": and|strong=\"H1121\"you|strong=\"H0859\"the|strong=\"H3588\"sons|strong=\"H1121\"of|strong=\"H1121\"Jacob|strong=\"H3290\"are|strong=\"H1121\"not|strong=\"H3808\"consumed|strong=\"H3615\".",
      "7": "For|strong=\"H0413\"from|strong=\"H7725\"the|strong=\"H0559\"days|strong=\"H3117\"of|strong=\"H3068\"your|strong=\"H3068\"fathers|strong=\"H0001\"you|strong=\"H3117\"have|strong=\"H0001\"departed|strong=\"H5493\"from|strong=\"H7725\"my|strong=\"H8104\"ordinances, and|strong=\"H3068\"have|strong=\"H0001\"not|strong=\"H3808\"kept|strong=\"H8104\"them|strong=\"H0413\": Return|strong=\"H7725\"to|strong=\"H0413\"me|strong=\"H0413\", and|strong=\"H3068\"I|strong=\"H3117\"will|strong=\"H3068\"return|strong=\"H7725\"to|strong=\"H0413\"you|strong=\"H3117\", saith the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\". And|strong=\"H3068\"you|strong=\"H3117\"have|strong=\"H0001\"said|strong=\"H0559\": Wherein shall|strong=\"H3068\"we|strong=\"H3117\"return|strong=\"H7725\"?",
      "8": "Shall|strong=\"H4100\"a|strong=\"H3588\"man|strong=\"H0120\"afflict God|strong=\"H0430\"? for|strong=\"H3588\"you|strong=\"H0859\"afflict me|strong=\"H0859\". And|strong=\"H0430\"you|strong=\"H0859\"have|strong=\"H0859\"said|strong=\"H0559\": Wherein do|strong=\"H4100\"we|strong=\"H3588\"afflict thee? in|strong=\"H0430\"tithes|strong=\"H4643\"and|strong=\"H0430\"in|strong=\"H0430\"firstfruits.",
      "9": "And|strong=\"H1471\"you|strong=\"H0859\"are|strong=\"H1471\"cursed|strong=\"H0779\"with|strong=\"H3605\"want, and|strong=\"H1471\"you|strong=\"H0859\"afflict me|strong=\"H3605\", even|strong=\"H0853\"the|strong=\"H3605\"whole|strong=\"H3605\"nation|strong=\"H1471\"of|strong=\"H3605\"you|strong=\"H0859\".",
      "10": "Bring|strong=\"H0935\"all|strong=\"H3605\"the|strong=\"H3605\"tithes|strong=\"H4643\"into|strong=\"H0413\"the|strong=\"H3605\"storehouse|strong=\"H0214\", that|strong=\"H3605\"there|strong=\"H1961\"may|strong=\"H1961\"be|strong=\"H1961\"meat in|strong=\"H0935\"my|strong=\"H3605\"house|strong=\"H1004\", and|strong=\"H0935\"try|strong=\"H0974\"me|strong=\"H0413\"in|strong=\"H0935\"this|strong=\"H2063\", saith the|strong=\"H3605\"Lord|strong=\"H3068\": if|strong=\"H0518\"I|strong=\"H0518\"open|strong=\"H6605\"not|strong=\"H3808\"unto you|strong=\"H0518\"the|strong=\"H3605\"flood-gates of|strong=\"H1004\"heaven|strong=\"H8064\", and|strong=\"H0935\"pour you|strong=\"H0518\"out|strong=\"H0413\"a|strong=\"H1961\"blessing|strong=\"H1293\"even|strong=\"H5704\"to|strong=\"H0413\"abundance.",
      "11": "And|strong=\"H3068\"I|strong=\"H0559\"will|strong=\"H3068\"rebuke|strong=\"H1605\"for|strong=\"H6635\"your|strong=\"H3068\"sakes the|strong=\"H0853\"devourer|strong=\"H0398\", and|strong=\"H3068\"he|strong=\"H3068\"shall|strong=\"H3068\"not|strong=\"H3808\"spoil the|strong=\"H0853\"fruit|strong=\"H6529\"of|strong=\"H3068\"your|strong=\"H3068\"land|strong=\"H0127\": neither|strong=\"H3808\"shall|strong=\"H3068\"the|strong=\"H0853\"vine|strong=\"H1612\"in|strong=\"H3068\"the|strong=\"H0853\"field|strong=\"H7704\"be|strong=\"H3808\"barren, saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\".",
      "12": "And|strong=\"H3068\"all|strong=\"H3605\"nations|strong=\"H1471\"shall|strong=\"H3068\"call|strong=\"H0833\"you|strong=\"H0859\"blessed|strong=\"H0833\": for|strong=\"H3588\"you|strong=\"H0859\"shall|strong=\"H3068\"be|strong=\"H1961\"a|strong=\"H1961\"delightful|strong=\"H2656\"land|strong=\"H0776\", saith the|strong=\"H3605\"Lord|strong=\"H3068\"of|strong=\"H0776\"hosts|strong=\"H6635\".",
      "13": "Your|strong=\"H3068\"words|strong=\"H1697\"have|strong=\"H1697\"been|strong=\"H2388\"unsufferable to|strong=\"H0559\"me|strong=\"H5921\", saith the|strong=\"H0559\"Lord|strong=\"H3068\".",
      "14": "And|strong=\"H1980\"you|strong=\"H3588\"have|strong=\"H3068\"said|strong=\"H0559\": What|strong=\"H4100\"have|strong=\"H3068\"we|strong=\"H3588\"spoken|strong=\"H0559\"against|strong=\"H6440\"thee? You|strong=\"H3588\"have|strong=\"H3068\"said|strong=\"H0559\": He|strong=\"H3588\"laboureth in|strong=\"H1980\"vain|strong=\"H7723\"that|strong=\"H3588\"serveth God|strong=\"H0430\", and|strong=\"H1980\"what|strong=\"H4100\"profit|strong=\"H1215\"is|strong=\"H3068\"it|strong=\"H3588\"that|strong=\"H3588\"we|strong=\"H3588\"have|strong=\"H3068\"kept|strong=\"H8104\"his|strong=\"H8104\"ordinances, and|strong=\"H1980\"that|strong=\"H3588\"we|strong=\"H3588\"have|strong=\"H3068\"walked|strong=\"H1980\"sorrowful before|strong=\"H6440\"the|strong=\"H0559\"Lord|strong=\"H3068\"of|strong=\"H0430\"hosts|strong=\"H6635\"?",
      "15": "Wherefore now|strong=\"H6258\"we|strong=\"H0587\"call|strong=\"H0833\"the|strong=\"H1129\"proud|strong=\"H2086\"people happy|strong=\"H0833\", for|strong=\"H0430\"they|strong=\"H1571\"that|strong=\"H1571\"work wickedness|strong=\"H7564\"are|strong=\"H0430\"built|strong=\"H1129\"up|strong=\"H1129\", and|strong=\"H0430\"they|strong=\"H1571\"have|strong=\"H1571\"tempted God|strong=\"H0430\"and|strong=\"H0430\"are|strong=\"H0430\"preserved.",
      "16": "Then|strong=\"H0227\"they|strong=\"H0376\"that|strong=\"H8085\"feared|strong=\"H3372\"the|strong=\"H6440\"Lord|strong=\"H3068\"spoke|strong=\"H1696\"every|strong=\"H0376\"one|strong=\"H0376\"with|strong=\"H0854\"his|strong=\"H3068\"neighbour: and|strong=\"H3068\"the|strong=\"H6440\"Lord|strong=\"H3068\"gave|strong=\"H8085\"ear, and|strong=\"H3068\"heard|strong=\"H8085\"it|strong=\"H1696\": and|strong=\"H3068\"a|strong=\"H8085\"book|strong=\"H5612\"of|strong=\"H0376\"remembrance|strong=\"H2146\"was|strong=\"H8034\"written|strong=\"H3789\"before|strong=\"H6440\"him|strong=\"H6440\"for|strong=\"H3068\"them|strong=\"H6440\"that|strong=\"H8085\"fear|strong=\"H3372\"the|strong=\"H6440\"Lord|strong=\"H3068\", and|strong=\"H3068\"think|strong=\"H2803\"on|strong=\"H3068\"his|strong=\"H3068\"name|strong=\"H8034\".",
      "17": "And|strong=\"H1121\"they|strong=\"H0834\"shall|strong=\"H1121\"be|strong=\"H1961\"my|strong=\"H3068\"special possession|strong=\"H5459\", saith the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H1121\"hosts|strong=\"H6635\", in|strong=\"H5921\"the|strong=\"H0853\"day|strong=\"H3117\"that|strong=\"H0834\"I|strong=\"H0589\"do|strong=\"H6213\"judgment|strong=\"H0834\": and|strong=\"H1121\"I|strong=\"H0589\"will|strong=\"H3068\"spare|strong=\"H2550\"them|strong=\"H0853\", as|strong=\"H0834\"a|strong=\"H1961\"man|strong=\"H0376\"spareth his|strong=\"H5921\"son|strong=\"H1121\"that|strong=\"H0834\"serveth him|strong=\"H5921\".",
      "18": "And|strong=\"H0430\"you|strong=\"H0834\"shall|strong=\"H3808\"return|strong=\"H7725\", and|strong=\"H0430\"shall|strong=\"H3808\"see|strong=\"H7200\"the|strong=\"H0834\"difference between|strong=\"H0996\"the|strong=\"H0834\"just|strong=\"H0834\"and|strong=\"H0430\"the|strong=\"H0834\"wicked|strong=\"H7563\": and|strong=\"H0430\"between|strong=\"H0996\"him|strong=\"H7200\"that|strong=\"H0834\"serveth God|strong=\"H0430\", and|strong=\"H0430\"him|strong=\"H7200\"that|strong=\"H0834\"serveth him|strong=\"H7200\"not|strong=\"H3808\"."
    },
    "4": {
      "1": "For behold the day shall come kindled as a furnace: and all the proud, and all that do wickedly shall be stubble: and the day that cometh shall set them on fire, saith the Lord of hosts, it shall not leave them root, nor branch.",
      "2": "But unto you that fear my name, the Sun of justice shall arise, and health in his wings: and you shall go forth, and shall leap like calves of the herd.",
      "3": "And you shall tread down the wicked when they shall be ashes under the sole of your feet in the day that I do this, saith the Lord of hosts.",
      "4": "Remember the law of Moses my servant, which I commanded him in Horeb for all Israel, the precepts, and judgments.",
      "5": "Behold I will send you Elias the prophet, before the coming of the great and dreadful day of the Lord.",
      "6": "And he shall turn the heart of the fathers to the children, and the heart of the children to their fathers: lest I come, and strike the earth with anathema."
    }
