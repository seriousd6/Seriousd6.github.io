  "chapters": {
    "1": {
      "1": "Jude|strong=\"G2455\", the|strong=\"G3588\"servant|strong=\"G1401\"of|strong=\"G2316\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", and|strong=\"G2532\"brother|strong=\"G0080\"of|strong=\"G2316\"James|strong=\"G2385\": to|strong=\"G2532\"them|strong=\"G1722\"that|strong=\"G2316\"are|strong=\"G3588\"beloved|strong=\"G0025\"in|strong=\"G1722\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"preserved|strong=\"G5083\"in|strong=\"G1722\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", and|strong=\"G2532\"called|strong=\"G2822\".",
      "2": "Mercy|strong=\"G1656\"unto you|strong=\"G5210\", and|strong=\"G2532\"peace|strong=\"G1515\", and|strong=\"G2532\"charity be|strong=\"G2532\"fulfilled.",
      "3": "Dearly beloved|strong=\"G0027\", taking all|strong=\"G3956\"care to|strong=\"G3956\"write|strong=\"G1125\"unto you|strong=\"G5210\"concerning|strong=\"G4012\"your|strong=\"G2192\"common|strong=\"G2839\"salvation|strong=\"G4991\", I|strong=\"G1473\"was|strong=\"G3588\"under|strong=\"G2192\"a|strong=\"G2192\"necessity|strong=\"G0318\"to|strong=\"G3956\"write|strong=\"G1125\"unto you|strong=\"G5210\": to|strong=\"G3956\"beseech you|strong=\"G5210\"to|strong=\"G3956\"contend|strong=\"G1864\"earnestly|strong=\"G1864\"for|strong=\"G4012\"the|strong=\"G3956\"faith|strong=\"G4102\"once|strong=\"G0530\"delivered|strong=\"G3860\"to|strong=\"G3956\"the|strong=\"G3956\"saints|strong=\"G0040\".",
      "4": "For|strong=\"G1063\"certain|strong=\"G5100\"men|strong=\"G0444\"are|strong=\"G3778\"secretly entered in|strong=\"G1519\", (who|strong=\"G3588\"were|strong=\"G3778\"written|strong=\"G4270\"of|strong=\"G2316\"long|strong=\"G3819\"ago|strong=\"G3819\"unto this|strong=\"G3778\"judgment|strong=\"G2917\",) ungodly|strong=\"G0765\"men|strong=\"G0444\", turning the|strong=\"G3588\"grace|strong=\"G5485\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"God|strong=\"G2316\"into|strong=\"G1519\"riotousness, and|strong=\"G2532\"denying|strong=\"G0720\"the|strong=\"G3588\"only|strong=\"G3441\"sovereign Ruler, and|strong=\"G2532\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "5": "I|strong=\"G3754\"will|strong=\"G2962\"therefore|strong=\"G1161\"admonish you|strong=\"G5210\", though|strong=\"G1161\"ye once|strong=\"G0530\"knew|strong=\"G1492\"all|strong=\"G3956\"things|strong=\"G3956\", that|strong=\"G3754\"Jesus|strong=\"G2424\", having saved|strong=\"G4982\"the|strong=\"G3956\"people|strong=\"G2992\"out|strong=\"G1537\"of|strong=\"G1537\"the|strong=\"G3956\"land|strong=\"G1093\"of|strong=\"G1537\"Egypt|strong=\"G0125\", did|strong=\"G1492\"afterwards destroy|strong=\"G0622\"them|strong=\"G3708\"that|strong=\"G3754\"believed|strong=\"G4100\"not|strong=\"G3361\":",
      "6": "And|strong=\"G5037\"the|strong=\"G3588\"angels|strong=\"G0032\"who|strong=\"G3588\"kept|strong=\"G5083\"not|strong=\"G3361\"their|strong=\"G1438\"principality, but|strong=\"G0235\"forsook their|strong=\"G1438\"own|strong=\"G2398\"habitation, he|strong=\"G2250\"hath reserved|strong=\"G5083\"under|strong=\"G5259\"darkness|strong=\"G2217\"in|strong=\"G1519\"everlasting chains|strong=\"G1199\", unto the|strong=\"G3588\"judgment|strong=\"G2920\"of|strong=\"G2250\"the|strong=\"G3588\"great|strong=\"G3173\"day|strong=\"G2250\".",
      "7": "As|strong=\"G5613\"Sodom|strong=\"G4670\"and|strong=\"G2532\"Gomorrha, and|strong=\"G2532\"the|strong=\"G3588\"neighbouring cities|strong=\"G4172\", in|strong=\"G2532\"like|strong=\"G5613\"manner, having given themselves|strong=\"G1438\"to|strong=\"G2532\"fornication, and|strong=\"G2532\"going|strong=\"G0565\"after|strong=\"G3694\"other|strong=\"G2087\"flesh|strong=\"G4561\", were|strong=\"G3778\"made an|strong=\"G2532\"example|strong=\"G1164\", suffering the|strong=\"G3588\"punishment|strong=\"G1349\"of|strong=\"G4172\"eternal|strong=\"G0166\"fire|strong=\"G4442\".",
      "8": "In|strong=\"G2532\"like|strong=\"G3668\"manner|strong=\"G3668\"these|strong=\"G3778\"men|strong=\"G3778\"also|strong=\"G2532\"defile|strong=\"G3392\"the|strong=\"G2532\"flesh|strong=\"G4561\", and|strong=\"G2532\"despise dominion|strong=\"G2963\", and|strong=\"G2532\"blaspheme|strong=\"G0987\"majesty.",
      "9": "When|strong=\"G3753\"Michael|strong=\"G3413\"the|strong=\"G3588\"archangel|strong=\"G0743\", disputing with|strong=\"G4012\"the|strong=\"G3588\"devil|strong=\"G1228\", contended about|strong=\"G4012\"the|strong=\"G3588\"body|strong=\"G4983\"of|strong=\"G2962\"Moses|strong=\"G3475\", he|strong=\"G3004\"durst not|strong=\"G3756\"bring|strong=\"G3004\"against|strong=\"G4012\"him|strong=\"G4012\"the|strong=\"G3588\"judgment|strong=\"G2920\"of|strong=\"G2962\"railing|strong=\"G0988\"speech, but|strong=\"G1161\"said|strong=\"G3004\": The|strong=\"G3588\"Lord|strong=\"G2962\"command|strong=\"G3004\"thee.",
      "10": "But|strong=\"G1161\"these|strong=\"G3778\"men|strong=\"G3778\"blaspheme|strong=\"G0987\"whatever|strong=\"G3745\"things|strong=\"G3778\"they|strong=\"G1161\"know|strong=\"G1492\"not|strong=\"G3756\": and|strong=\"G1161\"what|strong=\"G3588\"things|strong=\"G3778\"soever they|strong=\"G1161\"naturally know|strong=\"G1492\", like|strong=\"G5613\"dumb beasts, in|strong=\"G1722\"these|strong=\"G3778\"they|strong=\"G1161\"are|strong=\"G3778\"corrupted|strong=\"G5351\".",
      "11": "Woe|strong=\"G3759\"unto them|strong=\"G0846\", for|strong=\"G3754\"they|strong=\"G0846\"have|strong=\"G2532\"gone|strong=\"G4198\"in|strong=\"G2532\"the|strong=\"G3588\"way|strong=\"G3598\"of|strong=\"G3598\"Cain|strong=\"G2535\": and|strong=\"G2532\"after|strong=\"G2532\"the|strong=\"G3588\"error|strong=\"G4106\"of|strong=\"G3598\"Balaam|strong=\"G0903\"they|strong=\"G0846\"have|strong=\"G2532\"for|strong=\"G3754\"reward|strong=\"G3408\"poured out themselves|strong=\"G0846\", and|strong=\"G2532\"have|strong=\"G2532\"perished|strong=\"G0622\"in|strong=\"G2532\"the|strong=\"G3588\"contradiction of|strong=\"G3598\"Core.",
      "12": "These|strong=\"G3778\"are|strong=\"G1510\"spots in|strong=\"G1722\"their|strong=\"G1438\"banquets, feasting|strong=\"G4910\"together|strong=\"G1722\"without|strong=\"G0870\"fear|strong=\"G0870\", feeding|strong=\"G4165\"themselves|strong=\"G1438\", clouds|strong=\"G3507\"without|strong=\"G0870\"water|strong=\"G0504\", which|strong=\"G3588\"are|strong=\"G1510\"carried|strong=\"G3911\"about|strong=\"G1722\"by|strong=\"G1722\"winds|strong=\"G0417\", trees|strong=\"G1186\"of|strong=\"G0026\"the|strong=\"G3588\"autumn|strong=\"G5352\", unfruitful|strong=\"G0175\", twice|strong=\"G1364\"dead|strong=\"G0599\", plucked up by|strong=\"G1722\"the|strong=\"G3588\"roots,",
      "13": "Raging waves|strong=\"G2949\"of|strong=\"G2281\"the|strong=\"G3588\"sea|strong=\"G2281\", foaming out|strong=\"G1438\"their|strong=\"G1438\"own|strong=\"G1438\"confusion; wandering|strong=\"G4107\"stars|strong=\"G0792\", to|strong=\"G1519\"whom|strong=\"G3739\"the|strong=\"G3588\"storm of|strong=\"G2281\"darkness|strong=\"G4655\"is|strong=\"G3739\"reserved|strong=\"G5083\"for|strong=\"G1519\"ever|strong=\"G0165\".",
      "14": "Now|strong=\"G1161\"of|strong=\"G0575\"these|strong=\"G3778\"Enoch|strong=\"G1802\"also|strong=\"G2532\", the|strong=\"G2532\"seventh|strong=\"G1442\"from|strong=\"G0575\"Adam|strong=\"G0076\", prophesied|strong=\"G4395\", saying|strong=\"G3004\": Behold|strong=\"G2400\", the|strong=\"G2532\"Lord|strong=\"G2962\"cometh with|strong=\"G1722\"thousands|strong=\"G3461\"of|strong=\"G0575\"his|strong=\"G0846\"saints|strong=\"G0040\",",
      "15": "To|strong=\"G2596\"execute|strong=\"G4160\"judgment|strong=\"G2920\"upon|strong=\"G2920\"all|strong=\"G3956\", and|strong=\"G2532\"to|strong=\"G2596\"reprove|strong=\"G1651\"all|strong=\"G3956\"the|strong=\"G3956\"ungodly|strong=\"G0765\"for|strong=\"G4012\"all|strong=\"G3956\"the|strong=\"G3956\"works|strong=\"G2041\"of|strong=\"G3056\"their|strong=\"G0846\"ungodliness|strong=\"G0763\", whereby they|strong=\"G0846\"have|strong=\"G2532\"done|strong=\"G4160\"ungodly|strong=\"G0765\", and|strong=\"G2532\"of|strong=\"G3056\"all|strong=\"G3956\"the|strong=\"G3956\"hard|strong=\"G4642\"things|strong=\"G3956\"which|strong=\"G3739\"ungodly|strong=\"G0765\"sinners|strong=\"G0268\"have|strong=\"G2532\"spoken|strong=\"G2980\"against|strong=\"G2596\"God|strong=\"G0846\".",
      "16": "These|strong=\"G3778\"are|strong=\"G1510\"murmurers, full of|strong=\"G2596\"complaints, walking|strong=\"G4198\"according|strong=\"G2596\"to|strong=\"G2596\"their|strong=\"G0846\"own|strong=\"G0846\"desires|strong=\"G1939\", and|strong=\"G2532\"their|strong=\"G0846\"mouth|strong=\"G4750\"speaketh proud things|strong=\"G3778\", admiring persons|strong=\"G4383\"for|strong=\"G2532\"gain’s sake|strong=\"G5484\".",
      "17": "But|strong=\"G1161\"you|strong=\"G5210\", my|strong=\"G5259\"dearly beloved|strong=\"G0027\", be|strong=\"G5547\"mindful of|strong=\"G2962\"the|strong=\"G3588\"words|strong=\"G4487\"which|strong=\"G3588\"have|strong=\"G1473\"been|strong=\"G5547\"spoken before|strong=\"G3588\"by|strong=\"G5259\"the|strong=\"G3588\"apostles|strong=\"G0652\"of|strong=\"G2962\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\",",
      "18": "Who|strong=\"G3588\"told|strong=\"G3004\"you|strong=\"G5210\", that|strong=\"G3754\"in|strong=\"G1909\"the|strong=\"G3588\"last|strong=\"G2078\"time|strong=\"G5550\"there|strong=\"G1510\"should come|strong=\"G1510\"mockers|strong=\"G1703\", walking|strong=\"G4198\"according|strong=\"G2596\"to|strong=\"G3004\"their|strong=\"G1438\"own|strong=\"G1438\"desires|strong=\"G1939\"in|strong=\"G1909\"ungodlinesses.",
      "19": "These|strong=\"G3778\"are|strong=\"G1510\"they|strong=\"G2192\", who|strong=\"G3588\"separate themselves|strong=\"G1510\", sensual men|strong=\"G3778\", having|strong=\"G2192\"not|strong=\"G3361\"the|strong=\"G3588\"Spirit|strong=\"G4151\".",
      "20": "But|strong=\"G1161\"you|strong=\"G5210\", my|strong=\"G1722\"beloved|strong=\"G0027\", building|strong=\"G2026\"yourselves|strong=\"G1438\"upon your|strong=\"G1722\"most|strong=\"G0040\"holy|strong=\"G0040\"faith|strong=\"G4102\", praying|strong=\"G4336\"in|strong=\"G1722\"the|strong=\"G3588\"Holy|strong=\"G0040\"Ghost,",
      "21": "Keep|strong=\"G5083\"yourselves|strong=\"G1438\"in|strong=\"G1722\"the|strong=\"G3588\"love|strong=\"G0026\"of|strong=\"G2316\"God|strong=\"G2316\", waiting|strong=\"G4327\"for|strong=\"G1519\"the|strong=\"G3588\"mercy|strong=\"G1656\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", unto life|strong=\"G2222\"everlasting.",
      "22": "And|strong=\"G2532\"some|strong=\"G3739\"indeed|strong=\"G2532\"reprove|strong=\"G1651\", being judged|strong=\"G1252\":",
      "23": "But|strong=\"G1161\"others|strong=\"G3588\"save|strong=\"G4982\", pulling them|strong=\"G1722\"out|strong=\"G1537\"of|strong=\"G1537\"the|strong=\"G3588\"fire|strong=\"G4442\". And|strong=\"G2532\"on|strong=\"G1722\"others|strong=\"G3588\"have|strong=\"G1653\"mercy|strong=\"G1653\", in|strong=\"G1722\"fear|strong=\"G5401\", hating|strong=\"G3404\"also|strong=\"G2532\"the|strong=\"G3588\"spotted garment|strong=\"G5509\"which|strong=\"G3739\"is|strong=\"G3739\"carnal.",
      "24": "Now|strong=\"G1161\"to|strong=\"G1410\"him|strong=\"G0846\"who|strong=\"G3588\"is|strong=\"G3588\"able|strong=\"G1410\"to|strong=\"G1410\"preserve you|strong=\"G5210\"without|strong=\"G2532\"sin, and|strong=\"G2532\"to|strong=\"G1410\"present you|strong=\"G5210\"spotless before|strong=\"G2714\"the|strong=\"G3588\"presence|strong=\"G2714\"of|strong=\"G1391\"his|strong=\"G0846\"glory|strong=\"G1391\"with|strong=\"G1722\"exceeding joy|strong=\"G0020\", in|strong=\"G1722\"the|strong=\"G3588\"coming of|strong=\"G1391\"our|strong=\"G2532\"Lord Jesus|strong=\"G0846\"Christ|strong=\"G0846\",",
      "25": "To|strong=\"G1519\"the|strong=\"G3956\"only|strong=\"G3441\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour through|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"our|strong=\"G2316\"Lord|strong=\"G2962\", be|strong=\"G2532\"glory|strong=\"G1391\"and|strong=\"G2532\"magnificence, empire and|strong=\"G2532\"power|strong=\"G1849\", before|strong=\"G4253\"all|strong=\"G3956\"ages|strong=\"G0165\", and|strong=\"G2532\"now|strong=\"G3568\", and|strong=\"G2532\"for|strong=\"G1519\"all|strong=\"G3956\"ages|strong=\"G0165\"of|strong=\"G1223\"ages|strong=\"G0165\". Amen|strong=\"G0281\"."
    }
