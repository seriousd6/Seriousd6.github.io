{
  "chapters": {
    "1": {
      "1": "Paul|strong=\"G3972\", a|strong=\"G2532\"prisoner|strong=\"G1198\"of|strong=\"G0080\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\", and|strong=\"G2532\"Timothy|strong=\"G5095\", a|strong=\"G2532\"brother|strong=\"G0080\": to|strong=\"G2532\"Philemon|strong=\"G5371\", our|strong=\"G2424\"beloved|strong=\"G0027\"and|strong=\"G2532\"fellow|strong=\"G4904\"labourer;",
      "2": "And|strong=\"G2532\"to|strong=\"G2596\"Appia, our|strong=\"G2532\"dearest sister|strong=\"G0079\", and|strong=\"G2532\"to|strong=\"G2596\"Archippus|strong=\"G0751\", our|strong=\"G2532\"fellow|strong=\"G4961\"soldier|strong=\"G4961\", and|strong=\"G2532\"to|strong=\"G2596\"the|strong=\"G3588\"church|strong=\"G1577\"which|strong=\"G3588\"is|strong=\"G3588\"in|strong=\"G2596\"thy house|strong=\"G3624\":",
      "3": "Grace|strong=\"G5485\"to|strong=\"G2532\"you|strong=\"G5210\"and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G0575\"God|strong=\"G2316\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"the|strong=\"G2532\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "4": "I|strong=\"G1473\"give|strong=\"G2168\"thanks|strong=\"G2168\"to|strong=\"G1909\"my|strong=\"G2168\"God|strong=\"G2316\", always|strong=\"G3842\"making|strong=\"G4160\"a|strong=\"G4160\"remembrance|strong=\"G3417\"of|strong=\"G2316\"thee in|strong=\"G1909\"my|strong=\"G2168\"prayers|strong=\"G4335\".",
      "5": "Hearing|strong=\"G0191\"of|strong=\"G2962\"thy charity and|strong=\"G2532\"faith|strong=\"G4102\", which|strong=\"G3739\"thou hast in|strong=\"G1519\"the|strong=\"G3956\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\", and|strong=\"G2532\"towards all|strong=\"G3956\"the|strong=\"G3956\"saints|strong=\"G0040\":",
      "6": "That|strong=\"G3704\"the|strong=\"G3956\"communication of|strong=\"G3956\"thy faith|strong=\"G4102\"may|strong=\"G3956\"be|strong=\"G1096\"made|strong=\"G1096\"evident in|strong=\"G1722\"the|strong=\"G3956\"acknowledgment of|strong=\"G3956\"every|strong=\"G3956\"good|strong=\"G0018\"work, that|strong=\"G3704\"is|strong=\"G0018\"in|strong=\"G1722\"you|strong=\"G4771\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G1096\".",
      "7": "For|strong=\"G1063\"I|strong=\"G2532\"have|strong=\"G2192\"had|strong=\"G2192\"great|strong=\"G4183\"joy|strong=\"G5479\"and|strong=\"G2532\"consolation|strong=\"G3874\"in|strong=\"G1909\"thy charity, because|strong=\"G3754\"the|strong=\"G3588\"bowels of|strong=\"G1223\"the|strong=\"G3588\"saints|strong=\"G0040\"have|strong=\"G2192\"been|strong=\"G2192\"refreshed|strong=\"G0373\"by|strong=\"G1223\"thee, brother|strong=\"G0080\".",
      "8": "Wherefore|strong=\"G1352\"though|strong=\"G1722\"I|strong=\"G1352\"have|strong=\"G2192\"much|strong=\"G4183\"confidence|strong=\"G3954\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus, to|strong=\"G1722\"command|strong=\"G2004\"thee that|strong=\"G1722\"which|strong=\"G3588\"is|strong=\"G3588\"to|strong=\"G1722\"the|strong=\"G3588\"purpose:",
      "9": "For|strong=\"G1223\"charity sake|strong=\"G1223\"I|strong=\"G2532\"rather|strong=\"G3123\"beseech, whereas|strong=\"G1161\"thou art such|strong=\"G5108\"a|strong=\"G5613\"one|strong=\"G3588\", as|strong=\"G5613\"Paul|strong=\"G3972\"an|strong=\"G1510\"old|strong=\"G4246\"man|strong=\"G5108\", and|strong=\"G2532\"now|strong=\"G1161\"a|strong=\"G5613\"prisoner|strong=\"G1198\"also|strong=\"G2532\"of|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "10": "I|strong=\"G1473\"beseech thee for|strong=\"G4012\"my|strong=\"G1699\"son|strong=\"G5043\", whom|strong=\"G3739\"I|strong=\"G1473\"have|strong=\"G1473\"begotten|strong=\"G1080\"in|strong=\"G1722\"my|strong=\"G1699\"bands, Onesimus|strong=\"G3682\",",
      "11": "Who|strong=\"G3739\"hath been|strong=\"G2532\"heretofore unprofitable to|strong=\"G2532\"thee, but|strong=\"G1161\"now|strong=\"G1161\"is|strong=\"G3739\"profitable both|strong=\"G2532\"to|strong=\"G2532\"me|strong=\"G1473\"and|strong=\"G2532\"thee,",
      "12": "Whom|strong=\"G3588\"I|strong=\"G3778\"have|strong=\"G1510\"sent|strong=\"G0375\"back|strong=\"G0375\"to|strong=\"G3778\"thee. And|strong=\"G0846\"do|strong=\"G1510\"thou receive him|strong=\"G0846\"as|strong=\"G0846\"my|strong=\"G1699\"own|strong=\"G1699\"bowels.",
      "13": "Whom|strong=\"G3739\"I|strong=\"G1473\"would|strong=\"G2098\"have|strong=\"G1473\"retained with|strong=\"G1722\"me|strong=\"G1473\", that|strong=\"G3739\"in|strong=\"G1722\"thy stead he|strong=\"G3739\"might|strong=\"G1473\"have|strong=\"G1473\"ministered|strong=\"G1247\"to|strong=\"G4314\"me|strong=\"G1473\"in|strong=\"G1722\"the|strong=\"G3588\"bands of|strong=\"G2098\"the|strong=\"G3588\"gospel|strong=\"G2098\":",
      "14": "But|strong=\"G1161\"without|strong=\"G5565\"thy counsel I|strong=\"G1161\"would|strong=\"G3762\"do|strong=\"G4160\"nothing|strong=\"G3762\": that|strong=\"G2443\"thy good|strong=\"G0018\"deed might not|strong=\"G3361\"be|strong=\"G1510\"as|strong=\"G5613\"it|strong=\"G4160\"were|strong=\"G1510\"of|strong=\"G2596\"necessity|strong=\"G0318\", but|strong=\"G1161\"voluntary.",
      "15": "For|strong=\"G1063\"perhaps|strong=\"G5029\"he|strong=\"G0846\"therefore|strong=\"G1223\"departed|strong=\"G5563\"for|strong=\"G1063\"a|strong=\"G4314\"season from|strong=\"G0568\"thee, that|strong=\"G2443\"thou mightest receive him|strong=\"G0846\"again for|strong=\"G1063\"ever:",
      "16": "Not|strong=\"G3756\"now|strong=\"G1161\"as|strong=\"G5613\"a|strong=\"G5613\"servant|strong=\"G1401\", but|strong=\"G1161\"instead|strong=\"G0235\"of|strong=\"G2962\"a|strong=\"G5613\"servant|strong=\"G1401\", a|strong=\"G5613\"most|strong=\"G5228\"dear|strong=\"G0027\"brother|strong=\"G0080\", especially|strong=\"G3122\"to|strong=\"G2532\"me|strong=\"G1473\": but|strong=\"G1161\"how|strong=\"G5613\"much|strong=\"G4214\"more|strong=\"G3123\"to|strong=\"G2532\"thee both|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G2532\"flesh|strong=\"G4561\"and|strong=\"G2532\"in|strong=\"G1722\"the|strong=\"G2532\"Lord|strong=\"G2962\"?",
      "17": "If|strong=\"G1487\"therefore|strong=\"G3767\"thou count me|strong=\"G1473\"a|strong=\"G2192\"partner|strong=\"G2844\", receive|strong=\"G4355\"him|strong=\"G0846\"as|strong=\"G5613\"myself|strong=\"G0846\".",
      "18": "And|strong=\"G1161\"if|strong=\"G1487\"he|strong=\"G3778\"hath wronged|strong=\"G0091\"thee in|strong=\"G2228\"any|strong=\"G5100\"thing|strong=\"G3778\", or|strong=\"G2228\"is|strong=\"G3778\"in|strong=\"G2228\"thy debt, put that|strong=\"G3778\"to|strong=\"G5100\"my|strong=\"G3784\"account|strong=\"G1677\".",
      "19": "I|strong=\"G1473\"Paul|strong=\"G3972\"have|strong=\"G2532\"written|strong=\"G1125\"it|strong=\"G2532\"with|strong=\"G2532\"my|strong=\"G1699\"own|strong=\"G1699\"hand|strong=\"G5495\": I|strong=\"G1473\"will|strong=\"G3748\"repay|strong=\"G0661\"it|strong=\"G2532\": not|strong=\"G3361\"to|strong=\"G2443\"say|strong=\"G3004\"to|strong=\"G2443\"thee, that|strong=\"G3754\"thou owest me|strong=\"G3004\"thy own|strong=\"G1699\"self|strong=\"G4572\"also|strong=\"G2532\".",
      "20": "Yea, brother|strong=\"G0080\". May|strong=\"G5547\"I|strong=\"G1473\"enjoy thee in|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\". Refresh|strong=\"G0373\"my|strong=\"G1722\"bowels in|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\".",
      "21": "Trusting|strong=\"G3982\"in|strong=\"G2532\"thy obedience|strong=\"G5218\", I|strong=\"G3739\"have|strong=\"G2532\"written|strong=\"G1125\"to|strong=\"G3004\"thee: knowing|strong=\"G1492\"that|strong=\"G3754\"thou wilt also|strong=\"G2532\"do|strong=\"G4160\"more|strong=\"G5228\"than|strong=\"G5228\"I|strong=\"G3739\"say|strong=\"G3004\".",
      "22": "But|strong=\"G1161\"withal prepare|strong=\"G2090\"me|strong=\"G1473\"also|strong=\"G2532\"a|strong=\"G2532\"lodging|strong=\"G3578\". For|strong=\"G1063\"I|strong=\"G1473\"hope|strong=\"G1679\"that|strong=\"G3754\"through|strong=\"G1223\"your|strong=\"G2532\"prayers|strong=\"G4335\"I|strong=\"G1473\"shall|strong=\"G2532\"be|strong=\"G2532\"given|strong=\"G5483\"unto you|strong=\"G5210\".",
      "23": "There|strong=\"G1722\"salute thee Epaphras|strong=\"G1889\", my|strong=\"G1722\"fellow|strong=\"G4869\"prisoner|strong=\"G4869\"in|strong=\"G1722\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\";",
      "24": "Mark|strong=\"G3138\", Aristarchus|strong=\"G0708\", Demas|strong=\"G1214\", and|strong=\"G1473\"Luke|strong=\"G3065\"my fellow|strong=\"G4904\"labourers.",
      "25": "The|strong=\"G3588\"grace|strong=\"G5485\"of|strong=\"G4151\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"be|strong=\"G3326\"with|strong=\"G3326\"your|strong=\"G2962\"spirit|strong=\"G4151\". Amen."
    }
  }
}