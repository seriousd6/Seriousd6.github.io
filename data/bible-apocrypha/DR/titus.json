    "1": {
      "1": "Paul|strong=\"G3972\", a|strong=\"G2532\"servant|strong=\"G1401\"of|strong=\"G2316\"God|strong=\"G2316\", and|strong=\"G2532\"an|strong=\"G2532\"apostle|strong=\"G0652\"of|strong=\"G2316\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"faith|strong=\"G4102\"of|strong=\"G2316\"the|strong=\"G3588\"elect|strong=\"G1588\"of|strong=\"G2316\"God|strong=\"G2316\"and|strong=\"G2532\"the|strong=\"G3588\"acknowledging of|strong=\"G2316\"the|strong=\"G3588\"truth|strong=\"G0225\", which|strong=\"G3588\"is|strong=\"G2316\"according|strong=\"G2596\"to|strong=\"G2596\"godliness|strong=\"G2150\":",
      "2": "Unto the|strong=\"G3588\"hope|strong=\"G1680\"of|strong=\"G2316\"life|strong=\"G2222\"everlasting, which|strong=\"G3739\"God|strong=\"G2316\", who|strong=\"G3739\"lieth not|strong=\"G3739\", hath promised|strong=\"G1861\"before|strong=\"G4253\"the|strong=\"G3588\"times|strong=\"G5550\"of|strong=\"G2316\"the|strong=\"G3588\"world:",
      "3": "But|strong=\"G1161\"hath in|strong=\"G1722\"due|strong=\"G2596\"times|strong=\"G2540\"manifested|strong=\"G5319\"his|strong=\"G0846\"word|strong=\"G3056\"in|strong=\"G1722\"preaching|strong=\"G2782\", which|strong=\"G3739\"is|strong=\"G2316\"committed to|strong=\"G2596\"me|strong=\"G1473\"according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"commandment|strong=\"G2003\"of|strong=\"G3056\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour:",
      "4": "To|strong=\"G2596\"Titus|strong=\"G5103\"my|strong=\"G2596\"beloved son|strong=\"G5043\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"common|strong=\"G2839\"faith|strong=\"G4102\", grace|strong=\"G5485\"and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G0575\"God|strong=\"G2316\"the|strong=\"G3588\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"Christ|strong=\"G5547\"Jesus|strong=\"G2424\"our|strong=\"G2316\"Saviour.",
      "5": "For|strong=\"G1722\"this|strong=\"G3778\"cause I|strong=\"G1473\"left|strong=\"G0620\"thee in|strong=\"G1722\"Crete|strong=\"G2914\", that|strong=\"G2443\"thou shouldest set|strong=\"G1930\"in|strong=\"G1722\"order|strong=\"G2443\"the|strong=\"G3588\"things|strong=\"G3778\"that|strong=\"G2443\"are|strong=\"G3778\"wanting, and|strong=\"G2532\"shouldest ordain priests in|strong=\"G1722\"every|strong=\"G2596\"city|strong=\"G4172\", as|strong=\"G5613\"I|strong=\"G1473\"also|strong=\"G2532\"appointed|strong=\"G2525\"thee:",
      "6": "If|strong=\"G1487\"any|strong=\"G5100\"be|strong=\"G1510\"without|strong=\"G3361\"crime, the|strong=\"G2192\"husband|strong=\"G0435\"of|strong=\"G0435\"one|strong=\"G1520\"wife|strong=\"G1135\", having|strong=\"G2192\"faithful|strong=\"G4103\"children|strong=\"G5043\", not|strong=\"G3361\"accused|strong=\"G2724\"of|strong=\"G0435\"riot, or|strong=\"G2228\"unruly.",
      "7": "For|strong=\"G1063\"a|strong=\"G5613\"bishop must|strong=\"G1163\"be|strong=\"G1510\"without|strong=\"G3361\"crime, as|strong=\"G5613\"the|strong=\"G3588\"steward|strong=\"G3623\"of|strong=\"G2316\"God|strong=\"G2316\": not|strong=\"G3361\"proud, not|strong=\"G3361\"subject to|strong=\"G1163\"anger, not|strong=\"G3361\"given to|strong=\"G1163\"wine|strong=\"G3943\", no|strong=\"G3361\"striker, not|strong=\"G3361\"greedy of|strong=\"G2316\"filthy lucre:",
      "8": "But|strong=\"G0235\"given to|strong=\"G1342\"hospitality, gentle, sober, just|strong=\"G1342\", holy|strong=\"G3741\", continent:",
      "9": "Embracing that|strong=\"G2443\"faithful|strong=\"G4103\"word|strong=\"G3056\"which|strong=\"G3588\"is|strong=\"G1510\"according|strong=\"G2596\"to|strong=\"G2443\"doctrine|strong=\"G1319\", that|strong=\"G2443\"he|strong=\"G2532\"may|strong=\"G2532\"be|strong=\"G1510\"able|strong=\"G1415\"to|strong=\"G2443\"exhort|strong=\"G3870\"in|strong=\"G1722\"sound|strong=\"G5198\"doctrine|strong=\"G1319\", and|strong=\"G2532\"to|strong=\"G2443\"convince the|strong=\"G3588\"gainsayers.",
      "10": "For|strong=\"G1063\"there|strong=\"G1510\"are|strong=\"G1510\"also|strong=\"G2532\"many|strong=\"G4183\"disobedient, vain talkers|strong=\"G3151\", and|strong=\"G2532\"seducers: especially|strong=\"G3122\"they|strong=\"G2532\"who|strong=\"G3588\"are|strong=\"G1510\"of|strong=\"G1537\"the|strong=\"G3588\"circumcision|strong=\"G4061\":",
      "11": "Who|strong=\"G3739\"must|strong=\"G1163\"be|strong=\"G1163\"reproved, who|strong=\"G3739\"subvert whole|strong=\"G3650\"houses, teaching|strong=\"G1321\"things|strong=\"G3739\"which|strong=\"G3739\"they|strong=\"G3739\"ought|strong=\"G1163\"not|strong=\"G3361\", for|strong=\"G3361\"filthy lucre’s sake|strong=\"G5484\".",
      "12": "One|strong=\"G5100\"of|strong=\"G1537\"them|strong=\"G0846\"a|strong=\"G3004\"prophet|strong=\"G4396\"of|strong=\"G1537\"their|strong=\"G0846\"own|strong=\"G2398\", said|strong=\"G3004\", The|strong=\"G3004\"Cretians are|strong=\"G0846\"always|strong=\"G0104\"liars|strong=\"G5583\", evil|strong=\"G2556\"beasts|strong=\"G2342\", slothful bellies.",
      "13": "This|strong=\"G3778\"testimony|strong=\"G3141\"is|strong=\"G1510\"true|strong=\"G0227\". Wherefore rebuke|strong=\"G1651\"them|strong=\"G0846\"sharply|strong=\"G0664\", that|strong=\"G3739\"they|strong=\"G0846\"may|strong=\"G2443\"be|strong=\"G1510\"sound|strong=\"G5198\"in|strong=\"G1722\"the|strong=\"G3588\"faith|strong=\"G4102\";",
      "14": "Not|strong=\"G3361\"giving|strong=\"G4337\"heed to|strong=\"G2532\"Jewish|strong=\"G2451\"fables|strong=\"G3454\"and|strong=\"G2532\"commandments|strong=\"G1785\"of|strong=\"G0444\"men|strong=\"G0444\", who|strong=\"G3588\"turn|strong=\"G0654\"themselves away|strong=\"G0654\"from|strong=\"G3361\"the|strong=\"G3588\"truth|strong=\"G0225\".",
      "15": "All|strong=\"G3956\"things|strong=\"G3956\"are|strong=\"G3956\"clean|strong=\"G2513\"to|strong=\"G2532\"the|strong=\"G3956\"clean|strong=\"G2513\": but|strong=\"G1161\"to|strong=\"G2532\"them|strong=\"G0846\"that|strong=\"G3956\"are|strong=\"G3956\"defiled|strong=\"G3392\", and|strong=\"G2532\"to|strong=\"G2532\"unbelievers|strong=\"G0571\", nothing|strong=\"G3762\"is|strong=\"G3588\"clean|strong=\"G2513\": but|strong=\"G1161\"both|strong=\"G2532\"their|strong=\"G0846\"mind|strong=\"G3563\"and|strong=\"G2532\"their|strong=\"G0846\"conscience|strong=\"G4893\"are|strong=\"G3956\"defiled|strong=\"G3392\".",
      "16": "They|strong=\"G2532\"profess|strong=\"G3670\"that|strong=\"G3956\"they|strong=\"G2532\"know|strong=\"G1492\"God|strong=\"G2316\": but|strong=\"G1161\"in|strong=\"G2316\"their|strong=\"G2532\"works|strong=\"G2041\"they|strong=\"G2532\"deny|strong=\"G0720\"him|strong=\"G2532\"; being|strong=\"G1510\"abominable, and|strong=\"G2532\"incredulous, and|strong=\"G2532\"to|strong=\"G4314\"every|strong=\"G3956\"good|strong=\"G0018\"work|strong=\"G2041\"reprobate."
    },
    "2": {
      "1": "But|strong=\"G1161\"speak|strong=\"G2980\"thou the|strong=\"G3588\"things|strong=\"G3739\"that|strong=\"G3739\"become sound|strong=\"G5198\"doctrine|strong=\"G1319\":",
      "2": "That|strong=\"G1510\"the|strong=\"G3588\"aged|strong=\"G4246\"men|strong=\"G4586\"be|strong=\"G1510\"sober, chaste, prudent|strong=\"G4998\", sound|strong=\"G5198\"in|strong=\"G4102\"faith|strong=\"G4102\", in|strong=\"G4102\"love|strong=\"G0026\", in|strong=\"G4102\"patience|strong=\"G5281\".",
      "3": "The|strong=\"G1722\"aged women|strong=\"G4247\", in|strong=\"G1722\"like manner|strong=\"G5615\", in|strong=\"G1722\"holy attire, not|strong=\"G3361\"false accusers, not|strong=\"G3361\"given to|strong=\"G1722\"much|strong=\"G4183\"wine|strong=\"G3631\", teaching|strong=\"G2567\"well:",
      "4": "That|strong=\"G2443\"they|strong=\"G1510\"may|strong=\"G2443\"teach the|strong=\"G3588\"young|strong=\"G3501\"women to|strong=\"G2443\"be|strong=\"G1510\"wise, to|strong=\"G2443\"love|strong=\"G5362\"their|strong=\"G5362\"husbands|strong=\"G5362\", to|strong=\"G2443\"love|strong=\"G5362\"their|strong=\"G5362\"children|strong=\"G5388\",",
      "5": "To|strong=\"G2443\"be|strong=\"G2316\"discreet, chaste|strong=\"G0053\", sober, having a|strong=\"G2316\"care of|strong=\"G3056\"the|strong=\"G3588\"house, gentle, obedient|strong=\"G5293\"to|strong=\"G2443\"their|strong=\"G2398\"husbands|strong=\"G0435\", that|strong=\"G2443\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G2316\"be|strong=\"G2316\"not|strong=\"G3361\"blasphemed|strong=\"G0987\".",
      "6": "Young|strong=\"G3501\"men, in|strong=\"G3588\"like manner|strong=\"G5615\", exhort|strong=\"G3870\"that|strong=\"G3870\"they be sober.",
      "7": "In|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"shew thyself an example of|strong=\"G2041\"good|strong=\"G2570\"works|strong=\"G2041\", in|strong=\"G1722\"doctrine|strong=\"G1319\", in|strong=\"G1722\"integrity, in|strong=\"G1722\"gravity,",
      "8": "The|strong=\"G3588\"sound|strong=\"G5199\"word|strong=\"G3056\"that|strong=\"G2443\"can|strong=\"G3004\"not|strong=\"G3367\"be|strong=\"G2192\"blamed: that|strong=\"G2443\"he|strong=\"G3004\", who|strong=\"G3588\"is|strong=\"G3588\"on|strong=\"G1537\"the|strong=\"G3588\"contrary|strong=\"G1727\"part|strong=\"G1473\", may|strong=\"G2443\"be|strong=\"G2192\"afraid, having|strong=\"G2192\"no|strong=\"G3367\"evil|strong=\"G5337\"to|strong=\"G2443\"say|strong=\"G3004\"of|strong=\"G1537\"us|strong=\"G3004\".",
      "9": "Exhort servants|strong=\"G1401\"to|strong=\"G1722\"be|strong=\"G1510\"obedient|strong=\"G5293\"to|strong=\"G1722\"their|strong=\"G3956\"masters|strong=\"G1203\", in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"pleasing|strong=\"G2101\", not|strong=\"G3361\"gainsaying:",
      "10": "Not|strong=\"G3361\"defrauding, but|strong=\"G0235\"in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\"shewing good|strong=\"G0018\"fidelity, that|strong=\"G2443\"they|strong=\"G1722\"may|strong=\"G2443\"adorn|strong=\"G2885\"the|strong=\"G3956\"doctrine|strong=\"G1319\"of|strong=\"G2316\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour in|strong=\"G1722\"all|strong=\"G3956\"things|strong=\"G3956\":",
      "11": "For|strong=\"G1063\"the|strong=\"G3956\"grace|strong=\"G5485\"of|strong=\"G2316\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour hath appeared|strong=\"G2014\"to|strong=\"G0444\"all|strong=\"G3956\"men|strong=\"G0444\";",
      "12": "Instructing|strong=\"G3811\"us|strong=\"G1722\", that|strong=\"G2443\", denying|strong=\"G0720\"ungodliness|strong=\"G0763\"and|strong=\"G2532\"worldly|strong=\"G2886\"desires|strong=\"G1939\", we|strong=\"G2249\"should|strong=\"G2443\"live|strong=\"G2198\"soberly, and|strong=\"G2532\"justly|strong=\"G1346\", and|strong=\"G2532\"godly|strong=\"G2153\"in|strong=\"G1722\"this|strong=\"G3588\"world|strong=\"G0165\",",
      "13": "Looking|strong=\"G4327\"for|strong=\"G2316\"the|strong=\"G3588\"blessed|strong=\"G3107\"hope|strong=\"G1680\"and|strong=\"G2532\"coming of|strong=\"G2316\"the|strong=\"G3588\"glory|strong=\"G1391\"of|strong=\"G2316\"the|strong=\"G3588\"great|strong=\"G3173\"God|strong=\"G2316\"and|strong=\"G2532\"our|strong=\"G2316\"Saviour Jesus|strong=\"G2424\"Christ|strong=\"G5547\",",
      "14": "Who|strong=\"G3739\"gave|strong=\"G1325\"himself|strong=\"G1438\"for|strong=\"G5228\"us|strong=\"G1325\", that|strong=\"G3739\"he|strong=\"G2532\"might|strong=\"G2532\"redeem|strong=\"G3084\"us|strong=\"G1325\"from|strong=\"G0575\"all|strong=\"G3956\"iniquity, and|strong=\"G2532\"might|strong=\"G2532\"cleanse|strong=\"G2511\"to|strong=\"G2443\"himself|strong=\"G1438\"a|strong=\"G1325\"people|strong=\"G2992\"acceptable, a|strong=\"G1325\"pursuer of|strong=\"G0575\"good|strong=\"G2570\"works|strong=\"G2041\".",
      "15": "These|strong=\"G3778\"things|strong=\"G3778\"speak|strong=\"G2980\", and|strong=\"G2532\"exhort|strong=\"G3870\"and|strong=\"G2532\"rebuke|strong=\"G1651\"with|strong=\"G3326\"all|strong=\"G3956\"authority|strong=\"G2003\". Let|strong=\"G4065\"no|strong=\"G3367\"man|strong=\"G3778\"despise thee."
    },
    "3": {
      "1": "Admonish them|strong=\"G0846\"to|strong=\"G4314\"be|strong=\"G1510\"subject|strong=\"G5293\"to|strong=\"G4314\"princes and|strong=\"G3956\"powers|strong=\"G1849\", to|strong=\"G4314\"obey|strong=\"G3980\"at|strong=\"G4314\"a|strong=\"G1510\"word, to|strong=\"G4314\"be|strong=\"G1510\"ready|strong=\"G2092\"to|strong=\"G4314\"every|strong=\"G3956\"good|strong=\"G0018\"work|strong=\"G2041\".",
      "2": "To|strong=\"G4314\"speak evil|strong=\"G0987\"of|strong=\"G3956\"no|strong=\"G3367\"man|strong=\"G0444\", not|strong=\"G3367\"to|strong=\"G4314\"be|strong=\"G1510\"litigious, but|strong=\"G0444\"gentle|strong=\"G1933\": shewing all|strong=\"G3956\"mildness towards all|strong=\"G3956\"men|strong=\"G0444\".",
      "3": "For|strong=\"G1063\"we|strong=\"G2249\"ourselves|strong=\"G2249\"also|strong=\"G2532\"were|strong=\"G1510\"some time|strong=\"G4218\"unwise, incredulous, erring|strong=\"G4105\", slaves|strong=\"G1398\"to|strong=\"G2532\"divers desires|strong=\"G1939\"and|strong=\"G2532\"pleasures|strong=\"G2237\", living in|strong=\"G1722\"malice|strong=\"G2549\"and|strong=\"G2532\"envy|strong=\"G5355\", hateful|strong=\"G4767\", and|strong=\"G2532\"hating|strong=\"G3404\"one|strong=\"G0240\"another|strong=\"G0240\".",
      "4": "But|strong=\"G1161\"when|strong=\"G3753\"the|strong=\"G3588\"goodness and|strong=\"G2532\"kindness|strong=\"G5544\"of|strong=\"G2316\"God|strong=\"G2316\"our|strong=\"G2316\"Saviour appeared|strong=\"G2014\":",
      "5": "Not|strong=\"G3756\"by|strong=\"G1722\"the|strong=\"G3588\"works|strong=\"G2041\"of|strong=\"G1537\"justice|strong=\"G1343\", which|strong=\"G3739\"we|strong=\"G2249\"have|strong=\"G2532\"done|strong=\"G4160\", but|strong=\"G0235\"according|strong=\"G2596\"to|strong=\"G2596\"his|strong=\"G0846\"mercy|strong=\"G1656\", he|strong=\"G2532\"saved|strong=\"G4982\"us|strong=\"G4160\", by|strong=\"G1722\"the|strong=\"G3588\"laver of|strong=\"G1537\"regeneration|strong=\"G3824\", and|strong=\"G2532\"renovation of|strong=\"G1537\"the|strong=\"G3588\"Holy|strong=\"G0040\"Ghost;",
      "6": "Whom|strong=\"G3739\"he|strong=\"G3739\"hath poured forth upon|strong=\"G1909\"us|strong=\"G1909\"abundantly|strong=\"G4146\", through|strong=\"G1223\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"our|strong=\"G2424\"Saviour:",
      "7": "That|strong=\"G2443\", being|strong=\"G1096\"justified|strong=\"G1344\"by|strong=\"G2596\"his|strong=\"G2596\"grace|strong=\"G5485\", we|strong=\"G3588\"may|strong=\"G2443\"be|strong=\"G1096\"heirs|strong=\"G2818\", according|strong=\"G2596\"to|strong=\"G2443\"hope|strong=\"G1680\"of|strong=\"G5485\"life|strong=\"G2222\"everlasting.",
      "8": "It|strong=\"G3778\"is|strong=\"G1510\"a|strong=\"G1510\"faithful|strong=\"G4103\"saying|strong=\"G3056\": and|strong=\"G2532\"these|strong=\"G3778\"things|strong=\"G3778\"I|strong=\"G2532\"will|strong=\"G2316\"have|strong=\"G1510\"thee affirm constantly: that|strong=\"G2443\"they|strong=\"G2532\", who|strong=\"G3588\"believe|strong=\"G4100\"in|strong=\"G2316\"God|strong=\"G2316\", may|strong=\"G2532\"be|strong=\"G1510\"careful|strong=\"G5431\"to|strong=\"G2443\"excel in|strong=\"G2316\"good|strong=\"G2570\"works|strong=\"G2041\". These|strong=\"G3778\"things|strong=\"G3778\"are|strong=\"G1510\"good|strong=\"G2570\"and|strong=\"G2532\"profitable|strong=\"G5624\"unto men|strong=\"G0444\".",
      "9": "But|strong=\"G1161\"avoid|strong=\"G4026\"foolish|strong=\"G3474\"questions|strong=\"G2214\", and|strong=\"G2532\"genealogies|strong=\"G1076\", and|strong=\"G2532\"contentions, and|strong=\"G2532\"strivings about|strong=\"G2532\"the|strong=\"G2532\"law|strong=\"G3544\". For|strong=\"G1063\"they|strong=\"G2532\"are|strong=\"G1510\"unprofitable|strong=\"G0512\"and|strong=\"G2532\"vain|strong=\"G3152\".",
      "10": "A|strong=\"G1520\"man|strong=\"G0444\"that|strong=\"G0444\"is|strong=\"G0444\"a|strong=\"G1520\"heretic, after|strong=\"G3326\"the|strong=\"G2532\"first|strong=\"G1520\"and|strong=\"G2532\"second|strong=\"G1208\"admonition, avoid:",
      "11": "Knowing|strong=\"G1492\"that|strong=\"G3754\"he|strong=\"G2532\", that|strong=\"G3754\"is|strong=\"G1510\"such|strong=\"G5108\"an|strong=\"G1510\"one|strong=\"G3588\", is|strong=\"G1510\"subverted, and|strong=\"G2532\"sinneth, being|strong=\"G1510\"condemned by|strong=\"G2532\"his|strong=\"G3708\"own judgment.",
      "12": "When|strong=\"G3752\"I|strong=\"G1473\"shall send|strong=\"G3992\"to|strong=\"G1519\"thee Artemas|strong=\"G0734\"or|strong=\"G2228\"Tychicus|strong=\"G5190\", make|strong=\"G4704\"haste to|strong=\"G1519\"come|strong=\"G2064\"unto me|strong=\"G1473\"to|strong=\"G1519\"Nicopolis|strong=\"G3533\". For|strong=\"G1063\"there|strong=\"G1563\"I|strong=\"G1473\"have|strong=\"G1473\"determined|strong=\"G2919\"to|strong=\"G1519\"winter|strong=\"G3914\".",
      "13": "Send|strong=\"G4311\"forward Zenas|strong=\"G2211\", the|strong=\"G3588\"lawyer|strong=\"G3544\", and|strong=\"G2532\"Apollo, with|strong=\"G2532\"care, that|strong=\"G2443\"nothing|strong=\"G3367\"be|strong=\"G2532\"wanting to|strong=\"G2443\"them|strong=\"G0846\".",
      "14": "And|strong=\"G2532\"let|strong=\"G2443\"our|strong=\"G2532\"men also|strong=\"G2532\"learn|strong=\"G3129\"to|strong=\"G1519\"excel in|strong=\"G1519\"good|strong=\"G2570\"works|strong=\"G2041\"for|strong=\"G1519\"necessary|strong=\"G0316\"uses: that|strong=\"G2443\"they|strong=\"G2532\"be|strong=\"G1510\"not|strong=\"G3361\"unfruitful|strong=\"G0175\".",
      "15": "All|strong=\"G3956\"that|strong=\"G3956\"are|strong=\"G3956\"with|strong=\"G3326\"me|strong=\"G1473\"salute thee: salute them|strong=\"G1722\"that|strong=\"G3956\"love|strong=\"G5368\"us|strong=\"G1722\"in|strong=\"G1722\"the|strong=\"G3956\"faith|strong=\"G4102\". The|strong=\"G3956\"grace|strong=\"G5485\"of|strong=\"G5485\"God be|strong=\"G3956\"with|strong=\"G3326\"you|strong=\"G5210\"all|strong=\"G3956\". Amen."
    }
