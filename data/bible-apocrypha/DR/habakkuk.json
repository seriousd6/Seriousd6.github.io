    "3": {
      "1": "A|strong=\"H5921\"PRAYER|strong=\"H8605\"OF|strong=\"H5921\"HABACUC THE|strong=\"H5921\"PROPHET|strong=\"H5030\"FOR|strong=\"H5921\"IGNORANCES.",
      "2": "O|strong=\"H3068\"Lord|strong=\"H3068\", I|strong=\"H3045\"have|strong=\"H7355\"heard|strong=\"H8085\"thy hearing|strong=\"H8085\", and|strong=\"H3068\"was|strong=\"H3068\"afraid|strong=\"H3372\". O|strong=\"H3068\"Lord|strong=\"H3068\", thy work|strong=\"H6467\", in|strong=\"H8141\"the|strong=\"H8085\"midst|strong=\"H7130\"of|strong=\"H3068\"the|strong=\"H8085\"years|strong=\"H8141\"bring|strong=\"H3045\"it|strong=\"H3045\"to|strong=\"H3068\"life|strong=\"H2421\": In|strong=\"H8141\"the|strong=\"H8085\"midst|strong=\"H7130\"of|strong=\"H3068\"the|strong=\"H8085\"years|strong=\"H8141\"thou shalt make|strong=\"H3045\"it|strong=\"H3045\"known|strong=\"H3045\": when|strong=\"H8085\"thou art angry, thou wilt remember|strong=\"H2142\"mercy|strong=\"H7355\".",
      "3": "God|strong=\"H0433\"will|strong=\"H0776\"come|strong=\"H0935\"from|strong=\"H0935\"the|strong=\"H0935\"south, and|strong=\"H0935\"the|strong=\"H0935\"holy|strong=\"H6918\"one|strong=\"H6918\"from|strong=\"H0935\"mount|strong=\"H2022\"Pharan: His|strong=\"H0935\"glory|strong=\"H1935\"covered|strong=\"H3680\"the|strong=\"H0935\"heavens|strong=\"H8064\", and|strong=\"H0935\"the|strong=\"H0935\"earth|strong=\"H0776\"is|strong=\"H0776\"full|strong=\"H4390\"of|strong=\"H0776\"his|strong=\"H0935\"praise|strong=\"H8416\".",
      "4": "His|strong=\"H1961\"brightness|strong=\"H5051\"shall|strong=\"H3027\"be|strong=\"H1961\"as|strong=\"H1961\"the|strong=\"H1961\"light|strong=\"H0216\"; horns|strong=\"H7161\"are|strong=\"H3027\"in|strong=\"H8033\"his|strong=\"H1961\"hands|strong=\"H3027\": There|strong=\"H8033\"is|strong=\"H3027\"his|strong=\"H1961\"strength|strong=\"H5797\"hid:",
      "5": "Death shall|strong=\"H6440\"go|strong=\"H3318\"before|strong=\"H6440\"his|strong=\"H6440\"face|strong=\"H6440\". And|strong=\"H6440\"the|strong=\"H6440\"devil shall|strong=\"H6440\"go|strong=\"H3318\"forth|strong=\"H3318\"before|strong=\"H6440\"his|strong=\"H6440\"feet|strong=\"H7272\".",
      "6": "He|strong=\"H0776\"stood|strong=\"H5975\"and|strong=\"H0776\"measured the|strong=\"H7200\"earth|strong=\"H0776\". He|strong=\"H0776\"beheld, and|strong=\"H0776\"melted the|strong=\"H7200\"nations|strong=\"H1471\": and|strong=\"H0776\"the|strong=\"H7200\"ancient|strong=\"H5769\"mountains|strong=\"H2042\"were|strong=\"H0776\"crushed to|strong=\"H0776\"pieces. The|strong=\"H7200\"hills|strong=\"H1389\"of|strong=\"H0776\"the|strong=\"H7200\"world|strong=\"H0776\"were|strong=\"H0776\"bowed|strong=\"H7817\"down|strong=\"H7817\"by|strong=\"H0776\"the|strong=\"H7200\"journeys of|strong=\"H0776\"his|strong=\"H7200\"eternity|strong=\"H5769\".",
      "7": "I|strong=\"H7200\"saw|strong=\"H7200\"the|strong=\"H7200\"tents|strong=\"H0168\"of|strong=\"H0776\"Ethiopia for|strong=\"H8478\"their|strong=\"H7200\"iniquity|strong=\"H0205\", the|strong=\"H7200\"curtains|strong=\"H3407\"of|strong=\"H0776\"the|strong=\"H7200\"land|strong=\"H0776\"of|strong=\"H0776\"Madian shall|strong=\"H0776\"be|strong=\"H0776\"troubled|strong=\"H7264\".",
      "8": "Wast thou angry|strong=\"H2734\", O|strong=\"H3068\"Lord|strong=\"H3068\", with|strong=\"H3068\"the|strong=\"H5921\"rivers|strong=\"H5104\"? or|strong=\"H0518\"was|strong=\"H3068\"thy wrath|strong=\"H5678\"upon|strong=\"H5921\"the|strong=\"H5921\"rivers|strong=\"H5104\"? or|strong=\"H0518\"thy indignation in|strong=\"H5921\"the|strong=\"H5921\"sea|strong=\"H3220\"? Who|strong=\"H3068\"will|strong=\"H3068\"ride|strong=\"H7392\"upon|strong=\"H5921\"thy horses|strong=\"H5483\": and|strong=\"H3068\"thy chariots|strong=\"H4818\"are|strong=\"H3068\"salvation|strong=\"H3444\".",
      "9": "Thou wilt surely take up|strong=\"H1234\"thy bow|strong=\"H7198\": according to|strong=\"H0776\"the|strong=\"H0776\"oaths|strong=\"H7621\"which thou hast spoken to|strong=\"H0776\"the|strong=\"H0776\"tribes|strong=\"H4294\". Thou wilt divide|strong=\"H1234\"the|strong=\"H0776\"rivers|strong=\"H5104\"of|strong=\"H0776\"the|strong=\"H0776\"earth|strong=\"H0776\".",
      "10": "The|strong=\"H7200\"mountains|strong=\"H2022\"saw|strong=\"H7200\"thee, and|strong=\"H3027\"were|strong=\"H2022\"grieved: the|strong=\"H7200\"great body of|strong=\"H3027\"waters|strong=\"H4325\"passed|strong=\"H5674\"away|strong=\"H5375\". The|strong=\"H7200\"deep|strong=\"H8415\"put|strong=\"H5414\"forth|strong=\"H5414\"its|strong=\"H5414\"voice|strong=\"H6963\": the|strong=\"H7200\"deep|strong=\"H8415\"lifted|strong=\"H5375\"up|strong=\"H5375\"its|strong=\"H5414\"hands|strong=\"H3027\".",
      "11": "The|strong=\"H1980\"sun|strong=\"H8121\"and|strong=\"H1980\"the|strong=\"H1980\"moon|strong=\"H3394\"stood|strong=\"H5975\"still|strong=\"H5975\"in|strong=\"H1980\"their|strong=\"H5975\"habitation|strong=\"H2073\", in|strong=\"H1980\"the|strong=\"H1980\"light|strong=\"H0216\"of|strong=\"H0216\"thy arrows|strong=\"H2671\", they shall go|strong=\"H1980\"in|strong=\"H1980\"the|strong=\"H1980\"brightness|strong=\"H5051\"of|strong=\"H0216\"thy glittering|strong=\"H1300\"spear|strong=\"H2595\".",
      "12": "In|strong=\"H0776\"thy anger|strong=\"H0639\"thou wilt tread the|strong=\"H0776\"earth|strong=\"H0776\"under foot: in|strong=\"H0776\"thy wrath|strong=\"H0639\"thou wilt astonish the|strong=\"H0776\"nations|strong=\"H1471\".",
      "13": "Thou wentest forth|strong=\"H3318\"for|strong=\"H1004\"the|strong=\"H0853\"salvation|strong=\"H3468\"of|strong=\"H1004\"thy people|strong=\"H5971\": for|strong=\"H1004\"salvation|strong=\"H3468\"with|strong=\"H1004\"thy Christ. Thou struckest the|strong=\"H0853\"head|strong=\"H7218\"of|strong=\"H1004\"the|strong=\"H0853\"house|strong=\"H1004\"of|strong=\"H1004\"the|strong=\"H0853\"wicked|strong=\"H7563\": thou hast laid|strong=\"H6168\"bare|strong=\"H6168\"his|strong=\"H3318\"foundation|strong=\"H3247\"even|strong=\"H5704\"to|strong=\"H5704\"the|strong=\"H0853\"neck|strong=\"H6677\".",
      "14": "Thou hast cursed his|strong=\"H0398\"sceptres, the|strong=\"H0398\"head|strong=\"H7218\"of|strong=\"H4294\"his|strong=\"H0398\"warriors, them|strong=\"H0398\"that|strong=\"H4294\"came out as|strong=\"H3644\"a|strong=\"H3644\"whirlwind to|strong=\"H4294\"scatter|strong=\"H6327\"me|strong=\"H0398\". Their|strong=\"H0398\"joy was|strong=\"H7218\"like|strong=\"H3644\"that|strong=\"H4294\"of|strong=\"H4294\"him|strong=\"H0398\"that|strong=\"H4294\"devoureth the|strong=\"H0398\"poor|strong=\"H6041\"man|strong=\"H6041\"in|strong=\"H7218\"secret|strong=\"H4565\".",
      "15": "Thou madest a|strong=\"H3220\"way in|strong=\"H3220\"the|strong=\"H1869\"sea|strong=\"H3220\"for|strong=\"H4325\"thy horses|strong=\"H5483\", in|strong=\"H3220\"the|strong=\"H1869\"mud of|strong=\"H4325\"many|strong=\"H7227\"waters|strong=\"H4325\".",
      "16": "I|strong=\"H0834\"have|strong=\"H0834\"heard|strong=\"H8085\"and|strong=\"H0935\"my|strong=\"H8085\"bowels were|strong=\"H0834\"troubled|strong=\"H7264\": my|strong=\"H8085\"lips|strong=\"H8193\"trembled|strong=\"H7264\"at|strong=\"H3117\"the|strong=\"H0834\"voice|strong=\"H6963\". Let|strong=\"H5117\"rottenness|strong=\"H7538\"enter|strong=\"H0935\"into|strong=\"H0935\"my|strong=\"H8085\"bones|strong=\"H6106\", and|strong=\"H0935\"swarm under|strong=\"H8478\"me|strong=\"H6963\". That|strong=\"H0834\"I|strong=\"H0834\"may|strong=\"H0834\"rest|strong=\"H5117\"in|strong=\"H0935\"the|strong=\"H0834\"day|strong=\"H3117\"of|strong=\"H3117\"tribulation: that|strong=\"H0834\"I|strong=\"H0834\"may|strong=\"H0834\"go|strong=\"H0935\"up|strong=\"H5927\"to|strong=\"H0935\"our|strong=\"H0935\"people|strong=\"H5971\"that|strong=\"H0834\"are|strong=\"H0834\"girded.",
      "17": "For|strong=\"H3588\"the|strong=\"H3588\"fig|strong=\"H8384\"tree|strong=\"H8384\"shall|strong=\"H3808\"not|strong=\"H3808\"blossom: and|strong=\"H6629\"there|strong=\"H0369\"shall|strong=\"H3808\"be|strong=\"H3808\"no|strong=\"H3808\"spring in|strong=\"H6629\"the|strong=\"H3588\"vines|strong=\"H1612\". The|strong=\"H3588\"labour of|strong=\"H4639\"the|strong=\"H3588\"olive|strong=\"H2132\"tree|strong=\"H8384\"shall|strong=\"H3808\"fail|strong=\"H3584\": and|strong=\"H6629\"the|strong=\"H3588\"fields|strong=\"H7709\"shall|strong=\"H3808\"yield|strong=\"H2981\"no|strong=\"H3808\"food|strong=\"H0400\": the|strong=\"H3588\"flock|strong=\"H6629\"shall|strong=\"H3808\"be|strong=\"H3808\"cut|strong=\"H1504\"off|strong=\"H1504\"from|strong=\"H3808\"the|strong=\"H3588\"fold|strong=\"H4356\", and|strong=\"H6629\"there|strong=\"H0369\"shall|strong=\"H3808\"be|strong=\"H3808\"no|strong=\"H3808\"herd|strong=\"H1241\"in|strong=\"H6629\"the|strong=\"H3588\"stalls|strong=\"H7517\".",
      "18": "But|strong=\"H0589\"I|strong=\"H0589\"will|strong=\"H3068\"rejoice|strong=\"H1523\"in|strong=\"H0430\"the|strong=\"H0589\"Lord|strong=\"H3068\": and|strong=\"H3068\"I|strong=\"H0589\"will|strong=\"H3068\"joy in|strong=\"H0430\"God|strong=\"H0430\"my|strong=\"H3068\"Jesus.",
      "19": "The|strong=\"H5921\"Lord|strong=\"H0136\"God|strong=\"H0136\"is|strong=\"H0136\"my|strong=\"H7760\"strength|strong=\"H2428\": and|strong=\"H2428\"he|strong=\"H5921\"will|strong=\"H0136\"make|strong=\"H7760\"my|strong=\"H7760\"feet|strong=\"H7272\"like|strong=\"H7272\"the|strong=\"H5921\"feet|strong=\"H7272\"of|strong=\"H5921\"harts: and|strong=\"H2428\"he|strong=\"H5921\"the|strong=\"H5921\"conqueror will|strong=\"H0136\"lead|strong=\"H1869\"me|strong=\"H5921\"upon|strong=\"H5921\"my|strong=\"H7760\"high|strong=\"H1116\"places|strong=\"H1116\"singing psalms."
    }
