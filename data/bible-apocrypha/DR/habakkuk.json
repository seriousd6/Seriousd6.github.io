    "1": {
      "1": "The|strong=\"H0834\"burden|strong=\"H4853\"that|strong=\"H0834\"Habacuc the|strong=\"H0834\"prophet|strong=\"H5030\"saw|strong=\"H2372\".",
      "2": "How|strong=\"H0575\"long|strong=\"H5704\", O|strong=\"H3068\"Lord|strong=\"H3068\", shall|strong=\"H3068\"I|strong=\"H5704\"cry|strong=\"H2199\", and|strong=\"H3068\"thou wilt not|strong=\"H3808\"hear|strong=\"H8085\"? shall|strong=\"H3068\"I|strong=\"H5704\"cry|strong=\"H2199\"out|strong=\"H2199\"to|strong=\"H0413\"thee suffering violence|strong=\"H2555\", and|strong=\"H3068\"thou wilt not|strong=\"H3808\"save|strong=\"H3467\"?",
      "3": "Why|strong=\"H4100\"hast thou shewn me|strong=\"H7200\"iniquity|strong=\"H0205\"and|strong=\"H7200\"grievance, to|strong=\"H1961\"see|strong=\"H7200\"rapine and|strong=\"H7200\"injustice|strong=\"H0205\"before|strong=\"H5048\"me|strong=\"H7200\"? and|strong=\"H7200\"there|strong=\"H1961\"is|strong=\"H4100\"a|strong=\"H1961\"judgment, but|strong=\"H1961\"opposition is|strong=\"H4100\"more powerful.",
      "4": "Therefore|strong=\"H3651\"the|strong=\"H0853\"law|strong=\"H8451\"is|strong=\"H3651\"torn in|strong=\"H5921\"pieces, and|strong=\"H4941\"judgment|strong=\"H4941\"cometh not|strong=\"H3808\"to|strong=\"H5921\"the|strong=\"H0853\"end|strong=\"H5331\": because|strong=\"H3588\"the|strong=\"H0853\"wicked|strong=\"H7563\"prevaileth against|strong=\"H5921\"the|strong=\"H0853\"just|strong=\"H4941\", therefore|strong=\"H3651\"wrong judgment|strong=\"H4941\"goeth forth|strong=\"H3318\".",
      "5": "Behold|strong=\"H7200\"ye among|strong=\"H3808\"the|strong=\"H3588\"nations|strong=\"H1471\", and|strong=\"H3117\"see|strong=\"H7200\": wonder|strong=\"H8539\", and|strong=\"H3117\"be|strong=\"H3808\"astonished|strong=\"H8539\": for|strong=\"H3588\"a|strong=\"H3588\"work|strong=\"H6467\"is|strong=\"H3117\"done|strong=\"H6466\"in|strong=\"H3117\"your|strong=\"H7200\"days|strong=\"H3117\", which|strong=\"H1471\"no|strong=\"H3808\"man|strong=\"H7200\"will|strong=\"H1471\"believe|strong=\"H0539\"when|strong=\"H3588\"it|strong=\"H3588\"shall|strong=\"H3808\"be|strong=\"H3808\"told|strong=\"H5608\".",
      "6": "For|strong=\"H3588\"behold|strong=\"H2005\", I|strong=\"H3588\"will|strong=\"H0776\"raise|strong=\"H6965\"up|strong=\"H6965\"the|strong=\"H0853\"Chaldeans|strong=\"H3778\", a|strong=\"H3588\"bitter|strong=\"H4751\"and|strong=\"H1980\"swift|strong=\"H4116\"nation|strong=\"H1471\", marching upon the|strong=\"H0853\"breadth of|strong=\"H0776\"the|strong=\"H0853\"earth|strong=\"H0776\", to|strong=\"H1980\"possess|strong=\"H3423\"the|strong=\"H0853\"dwelling|strong=\"H4908\"places|strong=\"H4908\"that|strong=\"H3588\"are|strong=\"H0776\"not|strong=\"H3808\"their|strong=\"H3588\"own.",
      "7": "They|strong=\"H1931\"are|strong=\"H4941\"dreadful, and|strong=\"H4941\"terrible: from|strong=\"H4480\"themselves shall|strong=\"H1931\"their|strong=\"H4480\"judgment|strong=\"H4941\", and|strong=\"H4941\"their|strong=\"H4480\"burden proceed|strong=\"H3318\".",
      "8": "Their|strong=\"H0398\"horses|strong=\"H5483\"are|strong=\"H7350\"lighter|strong=\"H7043\"than leopards|strong=\"H5246\", and|strong=\"H0935\"swifter|strong=\"H7043\"than evening|strong=\"H6153\"wolves|strong=\"H2061\"; and|strong=\"H0935\"their|strong=\"H0398\"horsemen|strong=\"H6571\"shall be spread abroad: for|strong=\"H0398\"their|strong=\"H0398\"horsemen|strong=\"H6571\"shall come|strong=\"H0935\"from|strong=\"H0935\"afar|strong=\"H7350\", they|strong=\"H0935\"shall fly|strong=\"H5774\"as|strong=\"H0935\"an|strong=\"H0935\"eagle|strong=\"H5404\"that|strong=\"H5404\"maketh haste to|strong=\"H0935\"eat|strong=\"H0398\".",
      "9": "They|strong=\"H0935\"shall|strong=\"H6440\"all|strong=\"H3605\"come|strong=\"H0935\"to|strong=\"H0935\"the|strong=\"H3605\"prey, their|strong=\"H3605\"face|strong=\"H6440\"is|strong=\"H3605\"like|strong=\"H6440\"a|strong=\"H0935\"burning wind|strong=\"H6921\": and|strong=\"H0935\"they|strong=\"H0935\"shall|strong=\"H6440\"gather|strong=\"H0622\"together|strong=\"H0622\"captives|strong=\"H7628\"as|strong=\"H0935\"the|strong=\"H3605\"sand|strong=\"H2344\".",
      "10": "And|strong=\"H4428\"their|strong=\"H3605\"prince shall|strong=\"H1931\"triumph over|strong=\"H4428\"kings|strong=\"H4428\", and|strong=\"H4428\"princes shall|strong=\"H1931\"be|strong=\"H4428\"his|strong=\"H3605\"laughingstock: and|strong=\"H4428\"he|strong=\"H1931\"shall|strong=\"H1931\"laugh|strong=\"H7832\"at|strong=\"H4428\"every|strong=\"H3605\"strong hold|strong=\"H7832\", and|strong=\"H4428\"shall|strong=\"H1931\"cast up|strong=\"H6651\"a|strong=\"H3920\"mount, and|strong=\"H4428\"shall|strong=\"H1931\"take|strong=\"H3920\"it|strong=\"H1931\".",
      "11": "Then|strong=\"H0227\"shall his|strong=\"H2498\"spirit|strong=\"H7307\"be|strong=\"H0430\"changed|strong=\"H2498\", and|strong=\"H0430\"he|strong=\"H0430\"shall pass|strong=\"H5674\", and|strong=\"H0430\"fall: this|strong=\"H2098\"is|strong=\"H0430\"his|strong=\"H2498\"strength|strong=\"H3581\"of|strong=\"H0430\"his|strong=\"H2498\"god|strong=\"H0430\".",
      "12": "Wast thou not|strong=\"H3808\"from|strong=\"H3068\"the|strong=\"H3068\"beginning, O|strong=\"H0859\"Lord|strong=\"H3068\"my|strong=\"H7760\"God|strong=\"H0430\", my|strong=\"H7760\"holy|strong=\"H6918\"one|strong=\"H6918\", and|strong=\"H3068\"we|strong=\"H4191\"shall|strong=\"H3068\"not|strong=\"H3808\"die|strong=\"H4191\"? Lord|strong=\"H3068\", thou hast appointed|strong=\"H7760\"him|strong=\"H7760\"for|strong=\"H4941\"judgment|strong=\"H4941\": and|strong=\"H3068\"made|strong=\"H7760\"him|strong=\"H7760\"strong for|strong=\"H4941\"correction.",
      "13": "Thy eyes|strong=\"H5869\"are|strong=\"H4100\"too|strong=\"H4480\"pure to|strong=\"H0413\"behold|strong=\"H7200\"evil|strong=\"H7451\", and|strong=\"H5869\"thou canst not|strong=\"H3808\"look|strong=\"H7200\"on|strong=\"H0413\"iniquity. Why|strong=\"H4100\"lookest thou upon|strong=\"H0413\"them|strong=\"H0413\"that|strong=\"H7200\"do|strong=\"H4100\"unjust|strong=\"H5999\"things|strong=\"H3808\", and|strong=\"H5869\"holdest thy peace when|strong=\"H7200\"the|strong=\"H0413\"wicked|strong=\"H7563\"devoureth the|strong=\"H0413\"man|strong=\"H7563\"that|strong=\"H7200\"is|strong=\"H4100\"more|strong=\"H4480\"just|strong=\"H6662\"than|strong=\"H4480\"himself|strong=\"H0413\"?",
      "14": "And|strong=\"H0120\"thou wilt make|strong=\"H6213\"men|strong=\"H0120\"as the|strong=\"H3808\"fishes of|strong=\"H3220\"the|strong=\"H3808\"sea|strong=\"H3220\", and|strong=\"H0120\"as the|strong=\"H3808\"creeping|strong=\"H7431\"things|strong=\"H7431\"that|strong=\"H7431\"have|strong=\"H3808\"no|strong=\"H3808\"ruler|strong=\"H4910\".",
      "15": "He|strong=\"H3651\"lifted|strong=\"H5927\"up|strong=\"H5927\"all|strong=\"H3605\"them|strong=\"H5921\"with|strong=\"H5921\"his|strong=\"H3605\"hook|strong=\"H2443\", he|strong=\"H3651\"drew|strong=\"H0622\"them|strong=\"H5921\"in|strong=\"H5921\"his|strong=\"H3605\"drag|strong=\"H1641\", and|strong=\"H5927\"gathered|strong=\"H0622\"them|strong=\"H5921\"into|strong=\"H5921\"his|strong=\"H3605\"net: for|strong=\"H5921\"this|strong=\"H3651\"he|strong=\"H3651\"will|strong=\"H3605\"be|strong=\"H3605\"glad|strong=\"H8055\"and|strong=\"H5927\"rejoice|strong=\"H8055\".",
      "16": "Therefore|strong=\"H3651\"will|strong=\"H2076\"he|strong=\"H3588\"offer|strong=\"H6999\"victims to|strong=\"H5921\"his|strong=\"H5921\"drag, and|strong=\"H2076\"he|strong=\"H3588\"will|strong=\"H2076\"sacrifice|strong=\"H2076\"to|strong=\"H5921\"his|strong=\"H5921\"net: because|strong=\"H3588\"through|strong=\"H5921\"them|strong=\"H1992\"his|strong=\"H5921\"portion|strong=\"H2506\"is|strong=\"H3651\"made|strong=\"H2076\"fat|strong=\"H1277\", and|strong=\"H2076\"his|strong=\"H5921\"meat dainty.",
      "17": "For|strong=\"H5921\"this|strong=\"H3651\"cause therefore|strong=\"H3651\"he|strong=\"H3651\"spreadeth his|strong=\"H5921\"net, and|strong=\"H1471\"will|strong=\"H1471\"not|strong=\"H3808\"spare|strong=\"H2550\"continually|strong=\"H8548\"to|strong=\"H5921\"slay|strong=\"H2026\"the|strong=\"H5921\"nations|strong=\"H1471\"."
    },
    "2": {
      "1": "I|strong=\"H7200\"will|strong=\"H4100\"stand|strong=\"H5975\"upon|strong=\"H5921\"my|strong=\"H5921\"watch|strong=\"H6822\", and|strong=\"H7725\"fix my|strong=\"H5921\"foot upon|strong=\"H5921\"the|strong=\"H5921\"tower: and|strong=\"H7725\"I|strong=\"H7200\"will|strong=\"H4100\"watch|strong=\"H6822\", to|strong=\"H1696\"see|strong=\"H7200\"what|strong=\"H4100\"will|strong=\"H4100\"be|strong=\"H7725\"said|strong=\"H1696\"to|strong=\"H1696\"me|strong=\"H7725\", and|strong=\"H7725\"what|strong=\"H4100\"I|strong=\"H7200\"may|strong=\"H7725\"answer|strong=\"H7725\"to|strong=\"H1696\"him|strong=\"H5921\"that|strong=\"H7200\"reproveth me|strong=\"H7725\".",
      "2": "And|strong=\"H3068\"the|strong=\"H0559\"Lord|strong=\"H3068\"answered|strong=\"H0559\"me|strong=\"H5921\", and|strong=\"H3068\"said|strong=\"H0559\": Write|strong=\"H3789\"the|strong=\"H0559\"vision|strong=\"H2377\", and|strong=\"H3068\"make|strong=\"H7121\"it|strong=\"H5921\"plain upon|strong=\"H5921\"tables: that|strong=\"H4616\"he|strong=\"H3068\"that|strong=\"H4616\"readeth it|strong=\"H5921\"may|strong=\"H3068\"run|strong=\"H7323\"over|strong=\"H5921\"it|strong=\"H5921\".",
      "3": "For|strong=\"H3588\"as|strong=\"H0935\"yet|strong=\"H5750\"the|strong=\"H3588\"vision|strong=\"H2377\"is|strong=\"H7093\"far off, and|strong=\"H0935\"it|strong=\"H0518\"shall|strong=\"H3808\"appear at|strong=\"H0935\"the|strong=\"H3588\"end|strong=\"H7093\", and|strong=\"H0935\"shall|strong=\"H3808\"not|strong=\"H3808\"lie|strong=\"H3576\": if|strong=\"H0518\"it|strong=\"H0518\"make|strong=\"H3588\"any|strong=\"H5750\"delay|strong=\"H0309\", wait|strong=\"H2442\"for|strong=\"H3588\"it|strong=\"H0518\": for|strong=\"H3588\"it|strong=\"H0518\"shall|strong=\"H3808\"surely|strong=\"H3588\"come|strong=\"H0935\", and|strong=\"H0935\"it|strong=\"H0518\"shall|strong=\"H3808\"not|strong=\"H3808\"be|strong=\"H5750\"slack.",
      "4": "Behold|strong=\"H2009\", he|strong=\"H3808\"that|strong=\"H5315\"is|strong=\"H5315\"unbelieving, his|strong=\"H3808\"soul|strong=\"H5315\"shall|strong=\"H3808\"not|strong=\"H3808\"be|strong=\"H3808\"right|strong=\"H3474\"in|strong=\"H5315\"himself|strong=\"H5315\": but|strong=\"H3808\"the|strong=\"H2009\"just|strong=\"H6662\"shall|strong=\"H3808\"live|strong=\"H2421\"in|strong=\"H5315\"his|strong=\"H3808\"faith|strong=\"H0530\".",
      "5": "And|strong=\"H1471\"as|strong=\"H0834\"wine|strong=\"H3196\"deceiveth him|strong=\"H0413\"that|strong=\"H0834\"drinketh it|strong=\"H1931\": so|strong=\"H3808\"shall|strong=\"H3808\"the|strong=\"H3605\"proud man|strong=\"H1397\"be|strong=\"H3808\", and|strong=\"H1471\"he|strong=\"H0834\"shall|strong=\"H3808\"not|strong=\"H3808\"be|strong=\"H3808\"honoured: who|strong=\"H0834\"hath enlarged|strong=\"H7337\"his|strong=\"H3605\"desire|strong=\"H5315\"like|strong=\"H0834\"hell: and|strong=\"H1471\"is|strong=\"H0834\"himself|strong=\"H1931\"like|strong=\"H0834\"death|strong=\"H4194\", and|strong=\"H1471\"he|strong=\"H0834\"is|strong=\"H0834\"never|strong=\"H3808\"satisfied|strong=\"H7646\": but|strong=\"H3588\"will|strong=\"H0834\"gather|strong=\"H6908\"together|strong=\"H0622\"unto him|strong=\"H0413\"all|strong=\"H3605\"nations|strong=\"H1471\", and|strong=\"H1471\"heap together|strong=\"H0622\"unto him|strong=\"H0413\"all|strong=\"H3605\"people|strong=\"H5971\".",
      "6": "Shall|strong=\"H3808\"not|strong=\"H3808\"all|strong=\"H3605\"these|strong=\"H0428\"take|strong=\"H5375\"up|strong=\"H5375\"a|strong=\"H5375\"parable|strong=\"H4912\"against|strong=\"H5921\"him|strong=\"H5921\", and|strong=\"H4912\"a|strong=\"H5375\"dark|strong=\"H2420\"speech concerning|strong=\"H5921\"him|strong=\"H5921\": and|strong=\"H4912\"it|strong=\"H5921\"shall|strong=\"H3808\"be|strong=\"H3808\"said|strong=\"H0559\": Woe|strong=\"H1945\"to|strong=\"H0559\"him|strong=\"H5921\"that|strong=\"H3605\"heapeth together|strong=\"H5921\"that|strong=\"H3605\"which|strong=\"H0428\"is|strong=\"H3605\"not|strong=\"H3808\"his|strong=\"H3605\"own? how|strong=\"H4970\"long|strong=\"H5704\"also doth he|strong=\"H5704\"load|strong=\"H5375\"himself|strong=\"H3513\"with|strong=\"H5921\"thick clay?",
      "7": "Shall|strong=\"H3808\"they|strong=\"H3808\"not|strong=\"H3808\"rise|strong=\"H6965\"up|strong=\"H6965\"suddenly|strong=\"H6621\"that|strong=\"H3808\"shall|strong=\"H3808\"bite thee: and|strong=\"H6965\"they|strong=\"H3808\"be|strong=\"H1961\"stirred|strong=\"H6965\"up|strong=\"H6965\"that|strong=\"H3808\"shall|strong=\"H3808\"tear thee, and|strong=\"H6965\"thou shalt be|strong=\"H1961\"a|strong=\"H1961\"spoil|strong=\"H4933\"to|strong=\"H1961\"them|strong=\"H1961\"?",
      "8": "Because|strong=\"H3588\"thou hast spoiled many|strong=\"H7227\"nations|strong=\"H1471\", all|strong=\"H3605\"that|strong=\"H3588\"shall|strong=\"H0776\"be|strong=\"H0776\"left|strong=\"H3427\"of|strong=\"H0776\"the|strong=\"H3605\"people|strong=\"H5971\"shall|strong=\"H0776\"spoil thee: because|strong=\"H3588\"of|strong=\"H0776\"men’s|strong=\"H0120\"blood|strong=\"H1818\", and|strong=\"H0776\"for|strong=\"H3588\"the|strong=\"H3605\"iniquity of|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\", of|strong=\"H0776\"the|strong=\"H3605\"city|strong=\"H7151\", and|strong=\"H0776\"of|strong=\"H0776\"all|strong=\"H3605\"that|strong=\"H3588\"dwell|strong=\"H3427\"therein.",
      "9": "Woe|strong=\"H1945\"to|strong=\"H1004\"him|strong=\"H7760\"that|strong=\"H1004\"gathereth together|strong=\"H1215\"an|strong=\"H7760\"evil|strong=\"H7451\"covetousness to|strong=\"H1004\"his|strong=\"H7760\"house|strong=\"H1004\", that|strong=\"H1004\"his|strong=\"H7760\"nest|strong=\"H7064\"may|strong=\"H1004\"be|strong=\"H1004\"on|strong=\"H1004\"high|strong=\"H4791\", and|strong=\"H1004\"thinketh he|strong=\"H1004\"may|strong=\"H1004\"be|strong=\"H1004\"delivered|strong=\"H5337\"out|strong=\"H7451\"of|strong=\"H1004\"the|strong=\"H7760\"hand|strong=\"H3709\"of|strong=\"H1004\"evil|strong=\"H7451\".",
      "10": "Thou hast devised|strong=\"H3289\"confusion to|strong=\"H1004\"thy house|strong=\"H1004\", thou hast cut|strong=\"H7096\"off|strong=\"H7096\"many|strong=\"H7227\"people|strong=\"H5971\", and|strong=\"H1004\"thy soul|strong=\"H5315\"hath sinned|strong=\"H2398\".",
      "11": "For|strong=\"H3588\"the|strong=\"H3588\"stone|strong=\"H0068\"shall|strong=\"H0068\"cry|strong=\"H2199\"out|strong=\"H2199\"of|strong=\"H6086\"the|strong=\"H3588\"wall|strong=\"H7023\": and|strong=\"H6086\"the|strong=\"H3588\"timber|strong=\"H6086\"that|strong=\"H3588\"is|strong=\"H3588\"between the|strong=\"H3588\"joints of|strong=\"H6086\"the|strong=\"H3588\"building, shall|strong=\"H0068\"answer|strong=\"H6030\".",
      "12": "Woe|strong=\"H1945\"to|strong=\"H3559\"him that|strong=\"H3559\"buildeth a|strong=\"H1129\"town|strong=\"H7151\"with|strong=\"H1129\"blood|strong=\"H1818\", and|strong=\"H1818\"prepareth a|strong=\"H1129\"city|strong=\"H5892\"by|strong=\"H3559\"iniquity|strong=\"H5766\".",
      "13": "Are|strong=\"H3068\"not|strong=\"H3808\"these|strong=\"H5971\"things|strong=\"H3808\"from|strong=\"H3068\"the|strong=\"H0853\"Lord|strong=\"H3068\"of|strong=\"H3068\"hosts|strong=\"H6635\"? for|strong=\"H6635\"the|strong=\"H0853\"people|strong=\"H5971\"shall|strong=\"H3068\"labour in|strong=\"H3068\"a|strong=\"H3068\"great fire|strong=\"H0784\": and|strong=\"H3068\"the|strong=\"H0853\"nations|strong=\"H5971\"in|strong=\"H3068\"vain, and|strong=\"H3068\"they|strong=\"H3808\"shall|strong=\"H3068\"faint.",
      "14": "For|strong=\"H3588\"the|strong=\"H0853\"earth|strong=\"H0776\"shall|strong=\"H3068\"be|strong=\"H3068\"filled|strong=\"H4390\", that|strong=\"H3588\"men may|strong=\"H0776\"know|strong=\"H3045\"the|strong=\"H0853\"glory|strong=\"H3519\"of|strong=\"H0776\"the|strong=\"H0853\"Lord|strong=\"H3068\", as|strong=\"H3068\"waters|strong=\"H4325\"covering|strong=\"H3680\"the|strong=\"H0853\"sea|strong=\"H3220\".",
      "15": "Woe|strong=\"H1945\"to|strong=\"H5921\"him|strong=\"H5921\"that|strong=\"H4616\"giveth drink|strong=\"H8248\"to|strong=\"H5921\"his|strong=\"H5921\"friend|strong=\"H7453\", and|strong=\"H7453\"presenteth his|strong=\"H5921\"gall, and|strong=\"H7453\"maketh him|strong=\"H5921\"drunk|strong=\"H7937\", that|strong=\"H4616\"he|strong=\"H5921\"may|strong=\"H4616\"behold|strong=\"H5027\"his|strong=\"H5921\"nakedness|strong=\"H4589\".",
      "16": "Thou art filled|strong=\"H7646\"with|strong=\"H3068\"shame|strong=\"H7036\"instead of|strong=\"H3068\"glory|strong=\"H3519\": drink|strong=\"H8354\"thou also|strong=\"H1571\", and|strong=\"H3068\"fall fast asleep: the|strong=\"H5921\"cup|strong=\"H3563\"of|strong=\"H3068\"the|strong=\"H5921\"right|strong=\"H3225\"hand|strong=\"H3225\"of|strong=\"H3068\"the|strong=\"H5921\"Lord|strong=\"H3068\"shall|strong=\"H3068\"compass thee, and|strong=\"H3068\"shameful vomiting shall|strong=\"H3068\"be|strong=\"H1571\"on|strong=\"H5921\"thy glory|strong=\"H3519\".",
      "17": "For|strong=\"H3588\"the|strong=\"H3605\"iniquity of|strong=\"H0776\"Libanus shall|strong=\"H0776\"cover|strong=\"H3680\"thee, and|strong=\"H0776\"the|strong=\"H3605\"ravaging of|strong=\"H0776\"beasts|strong=\"H0929\"shall|strong=\"H0776\"terrify them|strong=\"H3427\"because|strong=\"H3588\"of|strong=\"H0776\"the|strong=\"H3605\"blood|strong=\"H1818\"of|strong=\"H0776\"men|strong=\"H0120\", and|strong=\"H0776\"the|strong=\"H3605\"iniquity of|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\", and|strong=\"H0776\"of|strong=\"H0776\"the|strong=\"H3605\"city|strong=\"H7151\", and|strong=\"H0776\"of|strong=\"H0776\"all|strong=\"H3605\"that|strong=\"H3588\"dwell|strong=\"H3427\"therein.",
      "18": "What|strong=\"H4100\"doth the|strong=\"H5921\"graven|strong=\"H6459\"thing|strong=\"H3588\"avail|strong=\"H3276\", because|strong=\"H3588\"the|strong=\"H5921\"maker|strong=\"H3335\"thereof hath graven|strong=\"H6459\"it|strong=\"H5921\", a|strong=\"H3588\"molten, and|strong=\"H6459\"a|strong=\"H3588\"false|strong=\"H8267\"image|strong=\"H6459\"? because|strong=\"H3588\"the|strong=\"H5921\"forger thereof hath trusted|strong=\"H0982\"in|strong=\"H5921\"a|strong=\"H3588\"thing|strong=\"H3588\"of|strong=\"H5921\"his|strong=\"H5921\"own forging, to|strong=\"H5921\"make|strong=\"H6213\"dumb idols|strong=\"H0457\".",
      "19": "Woe|strong=\"H1945\"to|strong=\"H0559\"him|strong=\"H3605\"that|strong=\"H3605\"saith to|strong=\"H0559\"wood|strong=\"H6086\": Awake|strong=\"H5782\": to|strong=\"H0559\"the|strong=\"H3605\"dumb stone|strong=\"H0068\": Arise|strong=\"H5782\": can|strong=\"H0369\"it|strong=\"H1931\"teach|strong=\"H3384\"? Behold|strong=\"H2009\", it|strong=\"H1931\"is|strong=\"H0369\"laid|strong=\"H3384\"over|strong=\"H8610\"with|strong=\"H3605\"gold|strong=\"H2091\", and|strong=\"H3701\"silver|strong=\"H3701\", and|strong=\"H3701\"there|strong=\"H0369\"is|strong=\"H0369\"no|strong=\"H0369\"spirit|strong=\"H7307\"in|strong=\"H7130\"the|strong=\"H3605\"bowels thereof.",
      "20": "But|strong=\"H3605\"the|strong=\"H3605\"Lord|strong=\"H3068\"is|strong=\"H3068\"in|strong=\"H3068\"his|strong=\"H3605\"holy|strong=\"H6944\"temple|strong=\"H1964\": let all|strong=\"H3605\"the|strong=\"H3605\"earth|strong=\"H0776\"keep|strong=\"H2013\"silence|strong=\"H2013\"before|strong=\"H6440\"him|strong=\"H6440\"."
