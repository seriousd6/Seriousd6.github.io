  "chapters": {
    "1": {
      "1": "The|strong=\"G3588\"ancient to|strong=\"G1722\"the|strong=\"G3588\"dearly beloved|strong=\"G0027\"Gaius|strong=\"G1050\", whom|strong=\"G3739\"I|strong=\"G1473\"love|strong=\"G0025\"in|strong=\"G1722\"truth|strong=\"G0225\".",
      "2": "Dearly beloved|strong=\"G0027\", concerning|strong=\"G4012\"all|strong=\"G3956\"things|strong=\"G3956\"I|strong=\"G2532\"make it|strong=\"G2532\"my|strong=\"G3956\"prayer that|strong=\"G3956\"thou mayest proceed prosperously, and|strong=\"G2532\"fare well|strong=\"G2532\"as|strong=\"G2531\"thy soul|strong=\"G5590\"doth prosperously.",
      "3": "I|strong=\"G2532\"was|strong=\"G3588\"exceedingly|strong=\"G3029\"glad|strong=\"G5463\"when|strong=\"G2532\"the|strong=\"G3588\"brethren|strong=\"G0080\"came|strong=\"G2064\"and|strong=\"G2532\"gave testimony|strong=\"G3140\"to|strong=\"G2064\"the|strong=\"G3588\"truth|strong=\"G0225\"in|strong=\"G1722\"thee, even|strong=\"G2532\"as|strong=\"G2531\"thou walkest in|strong=\"G1722\"the|strong=\"G3588\"truth|strong=\"G0225\".",
      "4": "I|strong=\"G3778\"have|strong=\"G2192\"no|strong=\"G3756\"greater|strong=\"G3173\"grace than|strong=\"G3173\"this|strong=\"G3778\", to|strong=\"G2443\"hear|strong=\"G0191\"that|strong=\"G2443\"my|strong=\"G1699\"children|strong=\"G5043\"walk|strong=\"G4043\"in|strong=\"G1722\"truth|strong=\"G0225\".",
      "5": "Dearly beloved|strong=\"G0027\", thou dost faithfully|strong=\"G4103\"whatever|strong=\"G1437\"thou dost for|strong=\"G1519\"the|strong=\"G3588\"brethren|strong=\"G0080\", and|strong=\"G2532\"that|strong=\"G3739\"for|strong=\"G1519\"strangers|strong=\"G3581\",",
      "6": "Who|strong=\"G3739\"have|strong=\"G4160\"given|strong=\"G3140\"testimony|strong=\"G3140\"to|strong=\"G2316\"thy charity in|strong=\"G2316\"the|strong=\"G3588\"sight|strong=\"G1799\"of|strong=\"G2316\"the|strong=\"G3588\"church|strong=\"G1577\": whom|strong=\"G3739\"thou shalt do|strong=\"G4160\"well|strong=\"G2573\"to|strong=\"G2316\"bring|strong=\"G4160\"forward on|strong=\"G4311\"their|strong=\"G3739\"way|strong=\"G4311\"in|strong=\"G2316\"a|strong=\"G4160\"manner|strong=\"G0516\"worthy|strong=\"G0516\"of|strong=\"G2316\"God|strong=\"G2316\".",
      "7": "Because|strong=\"G1063\", for|strong=\"G1063\"his|strong=\"G2983\"name|strong=\"G3686\"they|strong=\"G2983\"went|strong=\"G1831\"out|strong=\"G1831\", taking|strong=\"G2983\"nothing|strong=\"G3367\"of|strong=\"G0575\"the|strong=\"G3588\"Gentiles|strong=\"G1482\".",
      "8": "We|strong=\"G2249\"therefore|strong=\"G3767\"ought|strong=\"G3784\"to|strong=\"G2443\"receive such|strong=\"G5108\", that|strong=\"G2443\"we|strong=\"G2249\"may|strong=\"G2443\"be|strong=\"G1096\"fellow|strong=\"G4904\"helpers of|strong=\"G0225\"the|strong=\"G3588\"truth|strong=\"G0225\".",
      "9": "I|strong=\"G1473\"had|strong=\"G3588\"written|strong=\"G1125\"perhaps to|strong=\"G5100\"the|strong=\"G3588\"church|strong=\"G1577\": but|strong=\"G0235\"Diotrephes|strong=\"G1361\", who|strong=\"G3588\"loveth to|strong=\"G5100\"have|strong=\"G1473\"the|strong=\"G3588\"pre-eminence among them|strong=\"G0846\", doth not|strong=\"G3756\"receive|strong=\"G1926\"us.",
      "10": "For|strong=\"G1223\"this|strong=\"G3778\"cause|strong=\"G4160\", if|strong=\"G1437\"I|strong=\"G1473\"come|strong=\"G2064\", I|strong=\"G1473\"will|strong=\"G3739\"advertise his|strong=\"G0846\"works|strong=\"G2041\"which|strong=\"G3739\"he|strong=\"G2532\"doth, with|strong=\"G1909\"malicious words|strong=\"G3056\"prating against|strong=\"G1909\"us|strong=\"G4160\". And|strong=\"G2532\"as|strong=\"G2532\"if|strong=\"G1437\"these|strong=\"G3778\"things|strong=\"G3778\"were|strong=\"G3778\"not|strong=\"G3361\"enough|strong=\"G0714\"for|strong=\"G1223\"him|strong=\"G0846\", neither|strong=\"G3777\"doth he|strong=\"G2532\"himself|strong=\"G0846\"receive|strong=\"G1926\"the|strong=\"G3588\"brethren|strong=\"G0080\", and|strong=\"G2532\"them|strong=\"G0846\"that|strong=\"G3739\"do|strong=\"G4160\"receive|strong=\"G1926\"them|strong=\"G0846\"he|strong=\"G2532\"forbiddeth, and|strong=\"G2532\"casteth out|strong=\"G1544\"of|strong=\"G3056\"the|strong=\"G3588\"church|strong=\"G1577\".",
      "11": "Dearly beloved|strong=\"G0027\", follow|strong=\"G3401\"not|strong=\"G3756\"that|strong=\"G3708\"which|strong=\"G3588\"is|strong=\"G1510\"evil|strong=\"G2556\", but|strong=\"G0235\"that|strong=\"G3708\"which|strong=\"G3588\"is|strong=\"G1510\"good|strong=\"G0018\". He|strong=\"G1510\"that|strong=\"G3708\"doth good|strong=\"G0018\", is|strong=\"G1510\"of|strong=\"G1537\"God|strong=\"G2316\": he|strong=\"G1510\"that|strong=\"G3708\"doth evil|strong=\"G2556\", hath not|strong=\"G3756\"seen|strong=\"G3708\"God|strong=\"G2316\".",
      "12": "To|strong=\"G2532\"Demetrius|strong=\"G1216\"testimony|strong=\"G3141\"is|strong=\"G1510\"given|strong=\"G3140\"by|strong=\"G5259\"all|strong=\"G3956\", and|strong=\"G2532\"by|strong=\"G5259\"the|strong=\"G3956\"truth|strong=\"G0225\"itself|strong=\"G0846\", yea and|strong=\"G2532\"we|strong=\"G2249\"also|strong=\"G2532\"give testimony|strong=\"G3141\": and|strong=\"G2532\"thou knowest that|strong=\"G3754\"our|strong=\"G2532\"testimony|strong=\"G3141\"is|strong=\"G1510\"true|strong=\"G0227\".",
      "13": "I|strong=\"G2532\"had|strong=\"G2192\"many|strong=\"G4183\"things|strong=\"G4183\"to|strong=\"G2309\"write|strong=\"G1125\"unto thee: but|strong=\"G0235\"I|strong=\"G2532\"would|strong=\"G2309\"not|strong=\"G3756\"by|strong=\"G1223\"ink|strong=\"G3188\"and|strong=\"G2532\"pen|strong=\"G2563\"write|strong=\"G1125\"to|strong=\"G2309\"thee.",
      "14": "But|strong=\"G1161\"I|strong=\"G2532\"hope|strong=\"G1679\"speedily to|strong=\"G4314\"see|strong=\"G3708\"thee, and|strong=\"G2532\"we|strong=\"G2532\"will|strong=\"G2532\"speak|strong=\"G2980\"mouth|strong=\"G4750\"to|strong=\"G4314\"mouth|strong=\"G4750\". Peace be|strong=\"G2532\"to|strong=\"G4314\"thee. Our|strong=\"G2532\"friends salute thee. Salute the|strong=\"G2532\"friends by|strong=\"G2532\"name."
    }
