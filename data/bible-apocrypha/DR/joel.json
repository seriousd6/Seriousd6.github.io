    "2": {
      "1": "Blow|strong=\"H8628\"ye the|strong=\"H3605\"trumpet|strong=\"H7782\"in|strong=\"H3427\"Sion, sound|strong=\"H7321\"an|strong=\"H0935\"alarm|strong=\"H7321\"in|strong=\"H3427\"my|strong=\"H3605\"holy|strong=\"H6944\"mountain|strong=\"H2022\", let all|strong=\"H3605\"the|strong=\"H3605\"inhabitants|strong=\"H3427\"of|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\"tremble|strong=\"H7264\": because|strong=\"H3588\"the|strong=\"H3605\"day|strong=\"H3117\"of|strong=\"H0776\"the|strong=\"H3605\"Lord|strong=\"H3068\"cometh, because|strong=\"H3588\"it|strong=\"H3588\"is|strong=\"H3068\"nigh at|strong=\"H3427\"hand|strong=\"H7138\",",
      "2": "A|strong=\"H1961\"day|strong=\"H3117\"of|strong=\"H3117\"darkness|strong=\"H2822\", and|strong=\"H3117\"of|strong=\"H3117\"gloominess, a|strong=\"H1961\"day|strong=\"H3117\"of|strong=\"H3117\"clouds|strong=\"H6051\"and|strong=\"H3117\"whirlwinds: a|strong=\"H1961\"numerous|strong=\"H7227\"and|strong=\"H3117\"strong|strong=\"H6099\"people|strong=\"H5971\"as|strong=\"H5704\"the|strong=\"H5921\"morning|strong=\"H7837\"spread|strong=\"H6566\"upon|strong=\"H5921\"the|strong=\"H5921\"mountains|strong=\"H2022\": the|strong=\"H5921\"like|strong=\"H3644\"to|strong=\"H5704\"it|strong=\"H5921\"hath not|strong=\"H3808\"been|strong=\"H1961\"from|strong=\"H4480\"the|strong=\"H5921\"beginning|strong=\"H5704\", nor|strong=\"H3808\"shall|strong=\"H3808\"be|strong=\"H1961\"after|strong=\"H0310\"it|strong=\"H5921\"even|strong=\"H5704\"to|strong=\"H5704\"the|strong=\"H5921\"years|strong=\"H8141\"of|strong=\"H3117\"generation|strong=\"H1755\"and|strong=\"H3117\"generation|strong=\"H1755\".",
      "3": "Before|strong=\"H6440\"the|strong=\"H6440\"face|strong=\"H6440\"thereof a|strong=\"H1961\"devouring|strong=\"H0398\"fire|strong=\"H0784\", and|strong=\"H0776\"behind|strong=\"H0310\"it|strong=\"H0398\"a|strong=\"H1961\"burning|strong=\"H0784\"flame|strong=\"H3852\": the|strong=\"H6440\"land|strong=\"H0776\"is|strong=\"H0776\"like|strong=\"H1961\"a|strong=\"H1961\"garden|strong=\"H1588\"of|strong=\"H0776\"pleasure before|strong=\"H6440\"it|strong=\"H0398\", and|strong=\"H0776\"behind|strong=\"H0310\"it|strong=\"H0398\"a|strong=\"H1961\"desolate|strong=\"H8077\"wilderness|strong=\"H4057\", neither|strong=\"H3808\"is|strong=\"H0776\"there|strong=\"H1961\"any|strong=\"H1571\"one|strong=\"H3808\"that|strong=\"H3808\"can|strong=\"H3808\"escape|strong=\"H6413\"it|strong=\"H0398\".",
      "4": "The|strong=\"H3651\"appearance|strong=\"H4758\"of|strong=\"H4758\"them|strong=\"H7323\"is|strong=\"H3651\"as|strong=\"H3651\"the|strong=\"H3651\"appearance|strong=\"H4758\"of|strong=\"H4758\"horses|strong=\"H5483\", and|strong=\"H7323\"they|strong=\"H3651\"shall run|strong=\"H7323\"like|strong=\"H3651\"horsemen|strong=\"H6571\".",
      "5": "They|strong=\"H5921\"shall|strong=\"H2022\"leap|strong=\"H7540\"like|strong=\"H7540\"the|strong=\"H5921\"noise|strong=\"H6963\"of|strong=\"H2022\"chariots|strong=\"H4818\"upon|strong=\"H5921\"the|strong=\"H5921\"tops|strong=\"H7218\"of|strong=\"H2022\"mountains|strong=\"H2022\", like|strong=\"H7540\"the|strong=\"H5921\"noise|strong=\"H6963\"of|strong=\"H2022\"a|strong=\"H5921\"flame|strong=\"H3851\"of|strong=\"H2022\"fire|strong=\"H0784\"devouring|strong=\"H0398\"the|strong=\"H5921\"stubble|strong=\"H7179\", as|strong=\"H0398\"a|strong=\"H5921\"strong|strong=\"H6099\"people|strong=\"H5971\"prepared to|strong=\"H5921\"battle|strong=\"H4421\".",
      "6": "At|strong=\"H6908\"their|strong=\"H3605\"presence|strong=\"H6440\"the|strong=\"H3605\"people|strong=\"H5971\"shall|strong=\"H6440\"be|strong=\"H3605\"in|strong=\"H6440\"grievous pains: all|strong=\"H3605\"faces|strong=\"H6440\"shall|strong=\"H6440\"be|strong=\"H3605\"made|strong=\"H3605\"like|strong=\"H6440\"a|strong=\"H3605\"kettle.",
      "7": "They|strong=\"H3808\"shall|strong=\"H0376\"run|strong=\"H7323\"like|strong=\"H3808\"valiant|strong=\"H1368\"men|strong=\"H0376\": like|strong=\"H3808\"men|strong=\"H0376\"of|strong=\"H0376\"war|strong=\"H4421\"they|strong=\"H3808\"shall|strong=\"H0376\"scale the|strong=\"H1870\"wall|strong=\"H2346\": the|strong=\"H1870\"men|strong=\"H0376\"shall|strong=\"H0376\"march every|strong=\"H0376\"one|strong=\"H0376\"on|strong=\"H1870\"his|strong=\"H0376\"way|strong=\"H1870\", and|strong=\"H0376\"they|strong=\"H3808\"shall|strong=\"H0376\"not|strong=\"H3808\"turn aside from|strong=\"H0376\"their|strong=\"H3808\"ranks.",
      "8": "No|strong=\"H3808\"one|strong=\"H0376\"shall|strong=\"H0376\"press upon|strong=\"H5307\"his|strong=\"H0376\"brother|strong=\"H0251\": they|strong=\"H3808\"shall|strong=\"H0376\"walk every|strong=\"H0376\"one|strong=\"H0376\"in|strong=\"H0376\"his|strong=\"H0376\"path|strong=\"H4546\": yea, and|strong=\"H0376\"they|strong=\"H3808\"shall|strong=\"H0376\"fall|strong=\"H5307\"through|strong=\"H1157\"the|strong=\"H3808\"windows, and|strong=\"H0376\"shall|strong=\"H0376\"take no|strong=\"H3808\"harm.",
      "9": "They|strong=\"H0935\"shall|strong=\"H1004\"enter|strong=\"H0935\"into|strong=\"H0935\"the|strong=\"H0935\"city|strong=\"H5892\": they|strong=\"H0935\"shall|strong=\"H1004\"run|strong=\"H7323\"upon|strong=\"H0935\"the|strong=\"H0935\"wall|strong=\"H2346\", they|strong=\"H0935\"shall|strong=\"H1004\"climb|strong=\"H5927\"up|strong=\"H5927\"the|strong=\"H0935\"houses|strong=\"H1004\", they|strong=\"H0935\"shall|strong=\"H1004\"come|strong=\"H0935\"in|strong=\"H0935\"at|strong=\"H1004\"the|strong=\"H0935\"windows|strong=\"H2474\"as|strong=\"H0935\"a|strong=\"H0935\"thief|strong=\"H1590\".",
      "10": "At|strong=\"H0622\"their|strong=\"H6440\"presence|strong=\"H6440\"the|strong=\"H6440\"earth|strong=\"H0776\"hath trembled|strong=\"H7264\", the|strong=\"H6440\"heavens|strong=\"H8064\"are|strong=\"H8064\"moved|strong=\"H7264\": the|strong=\"H6440\"sun|strong=\"H8121\"and|strong=\"H0776\"moon|strong=\"H3394\"are|strong=\"H8064\"darkened, and|strong=\"H0776\"the|strong=\"H6440\"stars|strong=\"H3556\"have|strong=\"H0776\"withdrawn|strong=\"H0622\"their|strong=\"H6440\"shining.",
      "11": "And|strong=\"H3068\"the|strong=\"H6440\"Lord|strong=\"H3068\"hath uttered|strong=\"H5414\"his|strong=\"H5414\"voice|strong=\"H6963\"before|strong=\"H6440\"the|strong=\"H6440\"face|strong=\"H6440\"of|strong=\"H3068\"his|strong=\"H5414\"army|strong=\"H4264\": for|strong=\"H3588\"his|strong=\"H5414\"armies|strong=\"H4264\"are|strong=\"H3117\"exceeding|strong=\"H3966\"great|strong=\"H1419\", for|strong=\"H3588\"they|strong=\"H3588\"are|strong=\"H3117\"strong|strong=\"H6099\"and|strong=\"H3068\"execute|strong=\"H5414\"his|strong=\"H5414\"word|strong=\"H1697\": for|strong=\"H3588\"the|strong=\"H6440\"day|strong=\"H3117\"of|strong=\"H3068\"the|strong=\"H6440\"Lord|strong=\"H3068\"is|strong=\"H3068\"great|strong=\"H1419\"and|strong=\"H3068\"very|strong=\"H3966\"terrible: and|strong=\"H3068\"who|strong=\"H4310\"can|strong=\"H4310\"stand it|strong=\"H5414\"?",
      "12": "Now|strong=\"H6258\"therefore|strong=\"H6258\"saith the|strong=\"H3605\"Lord|strong=\"H3068\": Be|strong=\"H1571\"converted|strong=\"H7725\"to|strong=\"H5704\"me|strong=\"H7725\"with|strong=\"H3068\"all|strong=\"H3605\"your|strong=\"H3068\"heart|strong=\"H3824\", in|strong=\"H3068\"fasting|strong=\"H6685\", and|strong=\"H3068\"in|strong=\"H3068\"weeping|strong=\"H1065\", and|strong=\"H3068\"in|strong=\"H3068\"mourning|strong=\"H4553\".",
      "13": "And|strong=\"H3068\"rend|strong=\"H7167\"your|strong=\"H3068\"hearts|strong=\"H3824\", and|strong=\"H3068\"not|strong=\"H0408\"your|strong=\"H3068\"garments|strong=\"H0899\", and|strong=\"H3068\"turn|strong=\"H7725\"to|strong=\"H0413\"the|strong=\"H5921\"Lord|strong=\"H3068\"your|strong=\"H3068\"God|strong=\"H0430\": for|strong=\"H3588\"he|strong=\"H1931\"is|strong=\"H3068\"gracious|strong=\"H2587\"and|strong=\"H3068\"merciful|strong=\"H7349\", patient|strong=\"H0750\"and|strong=\"H3068\"rich in|strong=\"H5921\"mercy|strong=\"H3068\", and|strong=\"H3068\"ready to|strong=\"H0413\"repent|strong=\"H7725\"of|strong=\"H0430\"the|strong=\"H5921\"evil|strong=\"H7451\".",
      "14": "Who|strong=\"H4310\"knoweth but|strong=\"H7725\"he|strong=\"H0310\"will|strong=\"H3068\"return|strong=\"H7725\", and|strong=\"H3068\"forgive, and|strong=\"H3068\"leave|strong=\"H7604\"a|strong=\"H3068\"blessing|strong=\"H1293\"behind|strong=\"H0310\"him|strong=\"H0310\", sacrifice|strong=\"H4503\"and|strong=\"H3068\"libation to|strong=\"H7725\"the|strong=\"H3068\"Lord|strong=\"H3068\"your|strong=\"H3068\"God|strong=\"H0430\"?",
