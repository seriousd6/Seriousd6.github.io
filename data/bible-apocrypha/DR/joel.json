      "16": "Gather|strong=\"H6908\"together|strong=\"H0622\"the|strong=\"H3318\"people|strong=\"H5971\", sanctify|strong=\"H6942\"the|strong=\"H3318\"church, assemble|strong=\"H0622\"the|strong=\"H3318\"ancients, gather|strong=\"H6908\"together|strong=\"H0622\"the|strong=\"H3318\"little|strong=\"H5768\"ones|strong=\"H5768\", and|strong=\"H3318\"them|strong=\"H3318\"that|strong=\"H6951\"suck|strong=\"H3243\"at|strong=\"H0622\"the|strong=\"H3318\"breasts|strong=\"H7699\": let the|strong=\"H3318\"bridegroom go|strong=\"H3318\"forth|strong=\"H3318\"from|strong=\"H3318\"his|strong=\"H6942\"bed, and|strong=\"H3318\"the|strong=\"H3318\"bride|strong=\"H3618\"out|strong=\"H3318\"of|strong=\"H2205\"her|strong=\"H3243\"bride|strong=\"H3618\"chamber|strong=\"H2315\".",
      "17": "Between|strong=\"H0996\"the|strong=\"H0559\"porch|strong=\"H0197\"and|strong=\"H3068\"the|strong=\"H0559\"altar|strong=\"H4196\"the|strong=\"H0559\"priests|strong=\"H3548\"the|strong=\"H0559\"Lord’s|strong=\"H3068\"ministers|strong=\"H8334\"shall|strong=\"H3548\"weep|strong=\"H1058\", and|strong=\"H3068\"shall|strong=\"H3548\"say|strong=\"H0559\": Spare|strong=\"H2347\", O|strong=\"H3068\"Lord|strong=\"H3068\", spare|strong=\"H2347\"thy people|strong=\"H5971\": and|strong=\"H3068\"give|strong=\"H5414\"not|strong=\"H0408\"thy inheritance|strong=\"H5159\"to|strong=\"H0559\"reproach|strong=\"H2781\", that|strong=\"H3068\"the|strong=\"H0559\"heathen should|strong=\"H4100\"rule|strong=\"H4910\"over|strong=\"H5921\"them|strong=\"H5414\". Why|strong=\"H4100\"should|strong=\"H4100\"they|strong=\"H5921\"say|strong=\"H0559\"among|strong=\"H0996\"the|strong=\"H0559\"nations|strong=\"H1471\": Where|strong=\"H0346\"is|strong=\"H3068\"their|strong=\"H3068\"God|strong=\"H0430\"?",
      "18": "The|strong=\"H5921\"Lord|strong=\"H3068\"hath been|strong=\"H7065\"zealous|strong=\"H7065\"for|strong=\"H5921\"his|strong=\"H5921\"land|strong=\"H0776\", and|strong=\"H3068\"hath spared|strong=\"H2550\"his|strong=\"H5921\"people|strong=\"H5971\".",
      "19": "And|strong=\"H3068\"the|strong=\"H0853\"Lord|strong=\"H3068\"answered|strong=\"H0559\"and|strong=\"H3068\"said|strong=\"H0559\"to|strong=\"H0559\"his|strong=\"H5414\"people|strong=\"H5971\": Behold|strong=\"H2005\"I|strong=\"H2005\"will|strong=\"H3068\"send|strong=\"H7971\"you|strong=\"H5414\"corn, and|strong=\"H3068\"wine|strong=\"H8492\", and|strong=\"H3068\"oil|strong=\"H3323\", and|strong=\"H3068\"you|strong=\"H5414\"shall|strong=\"H3068\"be|strong=\"H5750\"filled|strong=\"H7646\"with|strong=\"H0854\"them|strong=\"H5414\": and|strong=\"H3068\"I|strong=\"H2005\"will|strong=\"H3068\"no|strong=\"H3808\"more|strong=\"H5750\"make|strong=\"H5414\"you|strong=\"H5414\"a|strong=\"H5414\"reproach|strong=\"H2781\"among|strong=\"H0854\"the|strong=\"H0853\"nations|strong=\"H1471\".",
      "20": "And|strong=\"H0776\"I|strong=\"H3588\"will|strong=\"H0776\"remove|strong=\"H7368\"far|strong=\"H7368\"off|strong=\"H5921\"from|strong=\"H5921\"you|strong=\"H3588\"the|strong=\"H0853\"northern|strong=\"H6830\"enemy: and|strong=\"H0776\"I|strong=\"H3588\"will|strong=\"H0776\"drive|strong=\"H5080\"him|strong=\"H0413\"into|strong=\"H0413\"a|strong=\"H3588\"land|strong=\"H0776\"unpassable, and|strong=\"H0776\"desert|strong=\"H6723\", with|strong=\"H0854\"his|strong=\"H5921\"face|strong=\"H6440\"towards the|strong=\"H0853\"east|strong=\"H6931\"sea|strong=\"H3220\", and|strong=\"H0776\"his|strong=\"H5921\"hinder part|strong=\"H5921\"towards the|strong=\"H0853\"utmost sea|strong=\"H3220\": and|strong=\"H0776\"his|strong=\"H5921\"stench|strong=\"H0889\"shall|strong=\"H0776\"ascend|strong=\"H5927\", and|strong=\"H0776\"his|strong=\"H5921\"rottenness shall|strong=\"H0776\"go|strong=\"H5927\"up|strong=\"H5927\", because|strong=\"H3588\"he|strong=\"H3588\"hath done|strong=\"H6213\"proudly.",
      "21": "Fear|strong=\"H3372\"not|strong=\"H0408\", O|strong=\"H3068\"land|strong=\"H0127\", be|strong=\"H0408\"glad|strong=\"H8055\"and|strong=\"H3068\"rejoice|strong=\"H8055\": for|strong=\"H3588\"the|strong=\"H3588\"Lord|strong=\"H3068\"hath done|strong=\"H6213\"great|strong=\"H1431\"things|strong=\"H1431\".",
      "22": "Fear|strong=\"H3372\"not|strong=\"H0408\", ye beasts|strong=\"H0929\"of|strong=\"H7704\"the|strong=\"H3588\"fields|strong=\"H7704\": for|strong=\"H3588\"the|strong=\"H3588\"beautiful places of|strong=\"H7704\"the|strong=\"H3588\"wilderness|strong=\"H4057\"are sprung, for|strong=\"H3588\"the|strong=\"H3588\"tree|strong=\"H6086\"hath brought|strong=\"H5375\"forth|strong=\"H5414\"its|strong=\"H5414\"fruit|strong=\"H6529\", the|strong=\"H3588\"fig|strong=\"H8384\"tree|strong=\"H6086\", and|strong=\"H6086\"the|strong=\"H3588\"vine|strong=\"H1612\"have|strong=\"H5414\"yielded|strong=\"H5414\"their|strong=\"H5375\"strength|strong=\"H2428\".",
      "23": "And|strong=\"H1121\"you|strong=\"H3588\", O|strong=\"H3068\"children|strong=\"H1121\"of|strong=\"H1121\"Sion, rejoice|strong=\"H8055\", and|strong=\"H1121\"be|strong=\"H1121\"joyful|strong=\"H8055\"in|strong=\"H0430\"the|strong=\"H0853\"Lord|strong=\"H3068\"your|strong=\"H3068\"God|strong=\"H0430\": because|strong=\"H3588\"he|strong=\"H3588\"hath given|strong=\"H5414\"you|strong=\"H3588\"a|strong=\"H3588\"teacher of|strong=\"H1121\"justice|strong=\"H6666\", and|strong=\"H1121\"he|strong=\"H3588\"will|strong=\"H3068\"make|strong=\"H5414\"the|strong=\"H0853\"early and|strong=\"H1121\"the|strong=\"H0853\"latter|strong=\"H4456\"rain|strong=\"H1653\"to|strong=\"H3381\"come|strong=\"H3381\"down|strong=\"H3381\"to|strong=\"H3381\"you|strong=\"H3588\"as|strong=\"H3068\"in|strong=\"H0430\"the|strong=\"H0853\"beginning|strong=\"H7223\".",
      "24": "And|strong=\"H8492\"the|strong=\"H4390\"floors|strong=\"H1637\"shall be filled|strong=\"H4390\"with|strong=\"H4390\"wheat|strong=\"H1250\", and|strong=\"H8492\"the|strong=\"H4390\"presses|strong=\"H3342\"shall overflow|strong=\"H7783\"with|strong=\"H4390\"wine|strong=\"H8492\"and|strong=\"H8492\"oil|strong=\"H3323\".",
      "25": "And|strong=\"H0398\"I|strong=\"H0834\"will|strong=\"H0834\"restore to|strong=\"H7971\"you|strong=\"H0834\"the|strong=\"H0853\"ears which|strong=\"H0834\"the|strong=\"H0853\"locust|strong=\"H0697\", and|strong=\"H0398\"the|strong=\"H0853\"bruchus, and|strong=\"H0398\"the|strong=\"H0853\"mildew, and|strong=\"H0398\"the|strong=\"H0853\"palmerworm have|strong=\"H0834\"eaten|strong=\"H0398\"; my|strong=\"H7971\"great|strong=\"H1419\"host which|strong=\"H0834\"I|strong=\"H0834\"sent|strong=\"H7971\"upon you|strong=\"H0834\".",
      "26": "And|strong=\"H3068\"you|strong=\"H0834\"shall|strong=\"H3068\"eat|strong=\"H0398\"in|strong=\"H0430\"plenty|strong=\"H7646\", and|strong=\"H3068\"shall|strong=\"H3068\"be|strong=\"H3808\"filled|strong=\"H7646\": and|strong=\"H3068\"you|strong=\"H0834\"shall|strong=\"H3068\"praise|strong=\"H1984\"the|strong=\"H0853\"name|strong=\"H8034\"of|strong=\"H0430\"the|strong=\"H0853\"Lord|strong=\"H3068\"your|strong=\"H3068\"God|strong=\"H0430\", who|strong=\"H0834\"hath done|strong=\"H6213\"wonders|strong=\"H6381\"with|strong=\"H5973\"you|strong=\"H0834\", and|strong=\"H3068\"my|strong=\"H3068\"people|strong=\"H5971\"shall|strong=\"H3068\"not|strong=\"H3808\"be|strong=\"H3808\"confounded|strong=\"H0954\"for|strong=\"H3068\"ever|strong=\"H5769\".",
      "27": "And|strong=\"H3068\"you|strong=\"H3588\"shall|strong=\"H3068\"know|strong=\"H3045\"that|strong=\"H3588\"I|strong=\"H0589\"am|strong=\"H0589\"in|strong=\"H0430\"the|strong=\"H3588\"midst|strong=\"H7130\"of|strong=\"H0430\"Israel|strong=\"H3478\": and|strong=\"H3068\"I|strong=\"H0589\"am|strong=\"H0589\"the|strong=\"H3588\"Lord|strong=\"H3068\"your|strong=\"H3068\"God|strong=\"H0430\", and|strong=\"H3068\"there|strong=\"H0369\"is|strong=\"H0369\"none|strong=\"H0369\"besides|strong=\"H5750\": and|strong=\"H3068\"my|strong=\"H3068\"people|strong=\"H5971\"shall|strong=\"H3068\"not|strong=\"H3808\"be|strong=\"H5750\"confounded|strong=\"H0954\"for|strong=\"H3588\"ever|strong=\"H5769\".",
      "28": "And it shall come to pass after this, that I will pour out my spirit upon all flesh: and your sons and your daughters shall prophesy: your old men shall dream dreams, and your young men shall see visions.",
      "29": "Moreover upon my servants and handmaids in those days I will pour forth my spirit.",
      "30": "And I will shew wonders in heaven; and in earth, blood, and fire, and vapour of smoke.",
      "31": "The sun shall be turned into darkness, and the moon into blood: before the great and dreadful day of the Lord doth come.",
      "32": "And it shall come to pass, that every one that shall call upon the name of the Lord shall be saved: for in mount Sion, and in Jerusalem shall be salvation, as the Lord hath said, and in the residue whom the Lord shall call."
    },
    "3": {
      "1": "For|strong=\"H5921\"behold|strong=\"H7200\"in|strong=\"H5921\"those|strong=\"H3605\"days, and|strong=\"H1121\"in|strong=\"H5921\"that|strong=\"H3605\"time|strong=\"H1961\"when|strong=\"H1961\"I|strong=\"H3651\"shall|strong=\"H1121\"bring|strong=\"H1323\"back|strong=\"H0310\"the|strong=\"H3605\"captivity of|strong=\"H1121\"Juda and|strong=\"H1121\"Jerusalem:",
      "2": "I|strong=\"H3117\"will|strong=\"H1571\"gather together|strong=\"H5921\"all|strong=\"H3117\"nations, and|strong=\"H3117\"will|strong=\"H1571\"bring them|strong=\"H1992\"down|strong=\"H5921\"into|strong=\"H5921\"the|strong=\"H0853\"valley of|strong=\"H3117\"Josaphat: and|strong=\"H3117\"I|strong=\"H3117\"will|strong=\"H1571\"plead with|strong=\"H5921\"them|strong=\"H1992\"there|strong=\"H1992\"for|strong=\"H5921\"my|strong=\"H5921\"people, and|strong=\"H3117\"for|strong=\"H5921\"my|strong=\"H5921\"inheritance Israel, whom they|strong=\"H1992\"have|strong=\"H1571\"scattered among|strong=\"H5921\"the|strong=\"H0853\"nations, and|strong=\"H3117\"have|strong=\"H1571\"parted my|strong=\"H5921\"land.",
      "3": "And|strong=\"H0776\"they|strong=\"H0776\"have|strong=\"H0776\"cast|strong=\"H5414\"lots upon|strong=\"H0784\"my|strong=\"H5414\"people|strong=\"H1818\": and|strong=\"H0776\"the|strong=\"H5414\"boy they|strong=\"H0776\"have|strong=\"H0776\"put|strong=\"H5414\"in|strong=\"H0776\"the|strong=\"H5414\"stews, and|strong=\"H0776\"the|strong=\"H5414\"girl they|strong=\"H0776\"have|strong=\"H0776\"sold for|strong=\"H0776\"wine, that|strong=\"H0784\"they|strong=\"H0776\"might|strong=\"H1818\"drink.",
      "4": "But|strong=\"H0935\"what|strong=\"H3372\"have|strong=\"H3068\"you|strong=\"H6440\"to|strong=\"H0935\"do|strong=\"H0935\"with|strong=\"H3068\"me|strong=\"H6440\", O|strong=\"H3068\"Tyre, and|strong=\"H0935\"Sidon, and|strong=\"H0935\"all|strong=\"H3117\"the|strong=\"H6440\"coast of|strong=\"H3068\"the|strong=\"H6440\"Philistines? will|strong=\"H3068\"you|strong=\"H6440\"revenge yourselves|strong=\"H3068\"on|strong=\"H3117\"me|strong=\"H6440\"? and|strong=\"H0935\"if you|strong=\"H6440\"revenge yourselves|strong=\"H3068\"on|strong=\"H3117\"me|strong=\"H6440\", I|strong=\"H3117\"will|strong=\"H3068\"very|strong=\"H1419\"soon return|strong=\"H0935\"you|strong=\"H6440\"a|strong=\"H0935\"recompense upon|strong=\"H0935\"your|strong=\"H3068\"own|strong=\"H6440\"head|strong=\"H6440\".",
      "5": "For|strong=\"H3588\"you|strong=\"H0834\"have|strong=\"H1961\"taken|strong=\"H1961\"away|strong=\"H3605\"my|strong=\"H3605\"silver and|strong=\"H3068\"my|strong=\"H3605\"gold: and|strong=\"H3068\"my|strong=\"H3605\"desirable and|strong=\"H3068\"most beautiful things|strong=\"H3605\"you|strong=\"H0834\"have|strong=\"H1961\"carried into|strong=\"H1961\"your|strong=\"H3068\"temples.",
      "6": "And the children of Juda, and the children of Jerusalem you have sold to the children of the Greeks, that you might remove them far off from their own country.",
      "7": "Behold, I will raise them up out of the place wherein you have sold them: and I will return your recompense upon your own heads.",
      "8": "And I will sell your sons, and your daughters by the hands of the children of Juda, and they shall sell them to the Sabeans, a nation far off, for the Lord hath spoken it.",
      "9": "Proclaim ye this among the nations: prepare war, rouse up the strong: let them come, let all the men of war come up.",
      "10": "Cut your ploughshares into swords, and your spades into spears. Let the weak say: I am strong.",
      "11": "Break forth, and come, all ye nations, from round about, and gather yourselves together: there will the Lord cause all thy strong ones to fall down.",
      "12": "Let them arise, and let the nations come up into the valley of Josaphat: for there I will sit to judge all nations round about.",
      "13": "Put ye in the sickles, for the harvest is ripe: come and go down, for the press is full, the fats run over: for their wickedness is multiplied.",
      "14": "Nations, nations in the valley of destruction: for the day of the Lord is near in the valley of destruction.",
      "15": "The sun and the moon are darkened, and the stars have withdrawn their shining.",
      "16": "And the Lord shall roar out of Sion, and utter his voice from Jerusalem: and the heavens and the earth shall be moved, and the Lord shall be the hope of his people, and the strength of the children of Israel.",
      "17": "And you shall know that I am the Lord your God, dwelling in Sion my holy mountain: and Jerusalem shall be holy and strangers shall pass through it no more.",
      "18": "And it shall come to pass in that day, that the mountains shall drop down sweetness, and the hills shall flow with milk: and waters shall flow through all the rivers of Juda: and a fountain shall come forth of the house of the Lord, and shall water the torrent of thorns.",
      "19": "Egypt shall be a desolation, and Edom a wilderness destroyed: because they have done unjustly against the children of Juda, and have shed innocent blood in their land.",
      "20": "And Judea shall be inhabited for ever, and Jerusalem to generation and generation.",
      "21": "And I will cleanse their blood which I had not cleansed: and the Lord will dwell in Sion."
    }
  }
