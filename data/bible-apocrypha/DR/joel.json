      "1": "The|strong=\"H0834\"word|strong=\"H1697\"of|strong=\"H1121\"the|strong=\"H0834\"Lord|strong=\"H3068\"that|strong=\"H0834\"came|strong=\"H1961\"to|strong=\"H0413\"Joel|strong=\"H3100\"the|strong=\"H0834\"son|strong=\"H1121\"of|strong=\"H1121\"Phatuel.",
      "2": "Hear|strong=\"H8085\"this|strong=\"H2063\", ye old|strong=\"H2205\"men|strong=\"H2205\", and|strong=\"H0776\"give|strong=\"H0238\"ear|strong=\"H0238\", all|strong=\"H3605\"ye inhabitants|strong=\"H3427\"of|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\": did|strong=\"H3117\"this|strong=\"H2063\"ever happen|strong=\"H1961\"in|strong=\"H3427\"your|strong=\"H3605\"days|strong=\"H3117\", or|strong=\"H0518\"in|strong=\"H3427\"the|strong=\"H3605\"days|strong=\"H3117\"of|strong=\"H0776\"your|strong=\"H3605\"fathers|strong=\"H0001\"?",
      "3": "Tell|strong=\"H5608\"ye of|strong=\"H1121\"this to|strong=\"H5921\"your|strong=\"H5921\"children|strong=\"H1121\", and|strong=\"H1121\"let your|strong=\"H5921\"children|strong=\"H1121\"tell|strong=\"H5608\"their|strong=\"H5921\"children|strong=\"H1121\", and|strong=\"H1121\"their|strong=\"H5921\"children|strong=\"H1121\"to|strong=\"H5921\"another|strong=\"H0312\"generation|strong=\"H1755\".",
      "4": "That which the|strong=\"H0398\"palmerworm hath left, the|strong=\"H0398\"locust|strong=\"H0697\"hath eaten|strong=\"H0398\": and|strong=\"H0398\"that which the|strong=\"H0398\"locust|strong=\"H0697\"hath left, the|strong=\"H0398\"bruchus hath eaten|strong=\"H0398\": and|strong=\"H0398\"that which the|strong=\"H0398\"bruchus hath left, the|strong=\"H0398\"mildew hath destroyed|strong=\"H0398\".",
      "5": "Awake, ye that|strong=\"H3588\"are|strong=\"H6310\"drunk|strong=\"H8354\", and|strong=\"H8354\"weep|strong=\"H1058\", and|strong=\"H8354\"mourn|strong=\"H1058\"all|strong=\"H3605\"ye that|strong=\"H3588\"take delight in|strong=\"H5921\"drinking|strong=\"H8354\"sweet|strong=\"H6071\"wine|strong=\"H3196\": for|strong=\"H3588\"it|strong=\"H5921\"is|strong=\"H3605\"cut|strong=\"H3772\"off|strong=\"H3772\"from|strong=\"H5921\"your|strong=\"H3605\"mouth|strong=\"H6310\".",
      "6": "For|strong=\"H3588\"a|strong=\"H3588\"nation|strong=\"H1471\"is|strong=\"H0369\"come|strong=\"H5927\"up|strong=\"H5927\"upon|strong=\"H5921\"my|strong=\"H5921\"land|strong=\"H0776\", strong|strong=\"H6099\"and|strong=\"H0776\"without|strong=\"H0369\"number|strong=\"H4557\": his|strong=\"H5921\"teeth|strong=\"H8127\"are|strong=\"H0776\"like|strong=\"H0776\"the|strong=\"H5921\"teeth|strong=\"H8127\"of|strong=\"H0776\"a|strong=\"H3588\"lion|strong=\"H0738\": and|strong=\"H0776\"his|strong=\"H5921\"cheek teeth|strong=\"H8127\"as|strong=\"H3588\"of|strong=\"H0776\"a|strong=\"H3588\"lion’s|strong=\"H0738\"whelp.",
      "7": "He|strong=\"H7760\"hath laid|strong=\"H7760\"my|strong=\"H7760\"vineyard waste|strong=\"H8047\", and|strong=\"H1612\"hath pilled off|strong=\"H7993\"the|strong=\"H7760\"bark of|strong=\"H8047\"my|strong=\"H7760\"fig|strong=\"H8384\"tree|strong=\"H8384\": he|strong=\"H7760\"hath stripped|strong=\"H2834\"it|strong=\"H7760\"bare|strong=\"H2834\", and|strong=\"H1612\"cast|strong=\"H7993\"it|strong=\"H7760\"away|strong=\"H7993\"; the|strong=\"H7760\"branches|strong=\"H8299\"thereof are|strong=\"H8299\"made|strong=\"H7760\"white|strong=\"H3835\".",
      "8": "Lament like|strong=\"H5921\"a|strong=\"H5921\"virgin|strong=\"H1330\"girded|strong=\"H2296\"with|strong=\"H5921\"sackcloth|strong=\"H8242\"for|strong=\"H5921\"the|strong=\"H5921\"husband|strong=\"H1167\"of|strong=\"H5921\"her|strong=\"H5921\"youth|strong=\"H5271\".",
      "9": "Sacrifice|strong=\"H4503\"and|strong=\"H3068\"libation is|strong=\"H3068\"cut|strong=\"H3772\"off|strong=\"H3772\"from|strong=\"H3772\"the|strong=\"H3068\"house|strong=\"H1004\"of|strong=\"H1004\"the|strong=\"H3068\"Lord|strong=\"H3068\": the|strong=\"H3068\"priests|strong=\"H3548\", the|strong=\"H3068\"Lord’s|strong=\"H3068\"ministers|strong=\"H8334\", have|strong=\"H3068\"mourned|strong=\"H0056\":",
      "10": "The|strong=\"H3588\"country|strong=\"H7704\"is|strong=\"H0127\"destroyed|strong=\"H7703\", the|strong=\"H3588\"ground|strong=\"H0127\"hath mourned|strong=\"H0056\": for|strong=\"H3588\"the|strong=\"H3588\"corn is|strong=\"H0127\"wasted, the|strong=\"H3588\"wine|strong=\"H8492\"is|strong=\"H0127\"confounded, the|strong=\"H3588\"oil|strong=\"H3323\"hath languished|strong=\"H0535\".",
      "11": "The|strong=\"H5921\"husbandmen are ashamed|strong=\"H0954\", the|strong=\"H5921\"vinedressers|strong=\"H3755\"have|strong=\"H3588\"howled for|strong=\"H3588\"the|strong=\"H5921\"wheat|strong=\"H2406\", and|strong=\"H0954\"for|strong=\"H3588\"the|strong=\"H5921\"barley|strong=\"H8184\", because|strong=\"H3588\"the|strong=\"H5921\"harvest|strong=\"H7105\"of|strong=\"H5921\"the|strong=\"H5921\"field|strong=\"H7704\"is|strong=\"H7704\"perished|strong=\"H0006\".",
      "12": "The|strong=\"H3605\"vineyard is|strong=\"H1571\"confounded, and|strong=\"H1121\"the|strong=\"H3605\"fig|strong=\"H8384\"tree|strong=\"H6086\"hath languished|strong=\"H0535\": the|strong=\"H3605\"pomegranate|strong=\"H7416\"tree|strong=\"H6086\", and|strong=\"H1121\"the|strong=\"H3605\"palm|strong=\"H8558\"tree|strong=\"H6086\", and|strong=\"H1121\"the|strong=\"H3605\"apple|strong=\"H8598\"tree|strong=\"H6086\", and|strong=\"H1121\"all|strong=\"H3605\"the|strong=\"H3605\"trees|strong=\"H6086\"of|strong=\"H1121\"the|strong=\"H3605\"field|strong=\"H7704\"are|strong=\"H1121\"withered|strong=\"H3001\": because|strong=\"H3588\"joy|strong=\"H8342\"is|strong=\"H1571\"withdrawn from|strong=\"H4480\"the|strong=\"H3605\"children|strong=\"H1121\"of|strong=\"H1121\"men|strong=\"H0120\".",
      "13": "Gird|strong=\"H2296\"yourselves|strong=\"H2296\", and|strong=\"H0935\"lament|strong=\"H5594\", O|strong=\"H1004\"ye priests|strong=\"H3548\", howl|strong=\"H3213\", ye ministers|strong=\"H8334\"of|strong=\"H1004\"the|strong=\"H3588\"altars|strong=\"H4196\": go|strong=\"H0935\"in|strong=\"H0935\", lie in|strong=\"H0935\"sackcloth|strong=\"H8242\", ye ministers|strong=\"H8334\"of|strong=\"H1004\"my|strong=\"H0935\"God|strong=\"H0430\": because|strong=\"H3588\"sacrifice|strong=\"H4503\"and|strong=\"H0935\"libation is|strong=\"H0430\"cut off from|strong=\"H0935\"the|strong=\"H3588\"house|strong=\"H1004\"of|strong=\"H1004\"your|strong=\"H0935\"God|strong=\"H0430\".",
      "14": "Sanctify|strong=\"H6942\"ye a|strong=\"H7121\"fast|strong=\"H6685\", call|strong=\"H7121\"an|strong=\"H7121\"assembly|strong=\"H6116\"; gather|strong=\"H0622\"together|strong=\"H0622\"the|strong=\"H3605\"ancients, all|strong=\"H3605\"the|strong=\"H3605\"inhabitants|strong=\"H3427\"of|strong=\"H0776\"the|strong=\"H3605\"land|strong=\"H0776\"into|strong=\"H0413\"the|strong=\"H3605\"house|strong=\"H1004\"of|strong=\"H0776\"your|strong=\"H3068\"God|strong=\"H0430\": and|strong=\"H3068\"cry|strong=\"H2199\"ye to|strong=\"H0413\"the|strong=\"H3605\"Lord|strong=\"H3068\":",
      "15": "Ah|strong=\"H0162\", ah|strong=\"H0162\", ah|strong=\"H0162\", for|strong=\"H3588\"the|strong=\"H3588\"day|strong=\"H3117\": because|strong=\"H3588\"the|strong=\"H3588\"day|strong=\"H3117\"of|strong=\"H3068\"the|strong=\"H3588\"Lord|strong=\"H3068\"is|strong=\"H3068\"at|strong=\"H3068\"hand|strong=\"H7138\", and|strong=\"H0935\"it|strong=\"H3588\"shall|strong=\"H3068\"come|strong=\"H0935\"like|strong=\"H3068\"destruction|strong=\"H7701\"from|strong=\"H0935\"the|strong=\"H3588\"mighty.",
      "16": "Is|strong=\"H0430\"not|strong=\"H3808\"your|strong=\"H3808\"food|strong=\"H0400\"cut|strong=\"H3772\"off|strong=\"H3772\"before|strong=\"H5048\"your|strong=\"H3808\"eyes|strong=\"H5869\", joy|strong=\"H8057\"and|strong=\"H0430\"gladness|strong=\"H8057\"from|strong=\"H3772\"the|strong=\"H3772\"house|strong=\"H1004\"of|strong=\"H1004\"our|strong=\"H0430\"God|strong=\"H0430\"?",
      "17": "The|strong=\"H3588\"beasts have|strong=\"H3588\"rotted in|strong=\"H8478\"their|strong=\"H3588\"dung, the|strong=\"H3588\"barns|strong=\"H4460\"are|strong=\"H8478\"destroyed|strong=\"H2040\", the|strong=\"H3588\"storehouses|strong=\"H0214\"are|strong=\"H8478\"broken|strong=\"H2040\"down|strong=\"H2040\": because|strong=\"H3588\"the|strong=\"H3588\"corn is|strong=\"H1715\"confounded.",
      "18": "Why|strong=\"H4100\"did|strong=\"H4100\"the|strong=\"H3588\"beast|strong=\"H0929\"groan|strong=\"H0584\", why|strong=\"H4100\"did|strong=\"H4100\"the|strong=\"H3588\"herds|strong=\"H1241\"of|strong=\"H6629\"cattle|strong=\"H0929\"low? because|strong=\"H3588\"there|strong=\"H0369\"is|strong=\"H0369\"no|strong=\"H0369\"pasture|strong=\"H4829\"for|strong=\"H3588\"them|strong=\"H1992\": yea|strong=\"H3588\", and|strong=\"H6629\"the|strong=\"H3588\"flocks|strong=\"H6629\"of|strong=\"H6629\"sheep|strong=\"H6629\"are|strong=\"H1992\"perished.",
      "19": "To|strong=\"H0413\"thee, O|strong=\"H3068\"Lord|strong=\"H3068\", will|strong=\"H3068\"I|strong=\"H3588\"cry|strong=\"H7121\": because|strong=\"H3588\"fire|strong=\"H0784\"hath devoured|strong=\"H0398\"the|strong=\"H3605\"beautiful places|strong=\"H3605\"of|strong=\"H3068\"the|strong=\"H3605\"wilderness|strong=\"H4057\", and|strong=\"H3068\"the|strong=\"H3605\"flame|strong=\"H3852\"hath burnt all|strong=\"H3605\"the|strong=\"H3605\"trees|strong=\"H6086\"of|strong=\"H3068\"the|strong=\"H3605\"country|strong=\"H7704\".",
      "20": "Yea|strong=\"H3588\"and|strong=\"H0398\"the|strong=\"H3588\"beasts|strong=\"H0929\"of|strong=\"H4325\"the|strong=\"H3588\"field|strong=\"H7704\"have|strong=\"H1571\"looked up|strong=\"H3001\"to|strong=\"H0413\"thee, as|strong=\"H1571\"a|strong=\"H3588\"garden bed that|strong=\"H3588\"thirsteth after|strong=\"H0413\"rain|strong=\"H4325\", for|strong=\"H3588\"the|strong=\"H3588\"springs of|strong=\"H4325\"waters|strong=\"H4325\"are|strong=\"H1571\"dried|strong=\"H3001\"up|strong=\"H3001\", and|strong=\"H0398\"fire|strong=\"H0784\"hath devoured|strong=\"H0398\"the|strong=\"H3588\"beautiful places of|strong=\"H4325\"the|strong=\"H3588\"wilderness|strong=\"H4057\"."
