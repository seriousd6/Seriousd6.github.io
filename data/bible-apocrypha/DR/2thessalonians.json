  "chapters": {
    "1": {
      "1": "Paul|strong=\"G3972\", and|strong=\"G2532\"Sylvanus, and|strong=\"G2532\"Timothy|strong=\"G5095\", to|strong=\"G2532\"the|strong=\"G3588\"church|strong=\"G1577\"of|strong=\"G2316\"the|strong=\"G3588\"Thessalonians|strong=\"G2331\"in|strong=\"G1722\"God|strong=\"G2316\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "2": "Grace|strong=\"G5485\"unto you|strong=\"G5210\", and|strong=\"G2532\"peace|strong=\"G1515\"from|strong=\"G0575\"God|strong=\"G2316\"our|strong=\"G2316\"Father|strong=\"G3962\", and|strong=\"G2532\"from|strong=\"G0575\"the|strong=\"G2532\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\".",
      "3": "We|strong=\"G2532\"are|strong=\"G1510\"bound to|strong=\"G1519\"give|strong=\"G2168\"thanks|strong=\"G2168\"always|strong=\"G3842\"to|strong=\"G1519\"God|strong=\"G2316\"for|strong=\"G1519\"you|strong=\"G5210\", brethren|strong=\"G0080\", as|strong=\"G2531\"it|strong=\"G1510\"is|strong=\"G1510\"fitting|strong=\"G0514\", because|strong=\"G3754\"your|strong=\"G2532\"faith|strong=\"G4102\"groweth exceedingly, and|strong=\"G2532\"the|strong=\"G3956\"charity of|strong=\"G2316\"every|strong=\"G3956\"one|strong=\"G1520\"of|strong=\"G2316\"you|strong=\"G5210\"towards each|strong=\"G1538\"other|strong=\"G0240\", aboundeth:",
      "4": "So|strong=\"G2532\"that|strong=\"G3739\"we|strong=\"G2249\"ourselves|strong=\"G1438\"also|strong=\"G2532\"glory|strong=\"G2744\"in|strong=\"G1722\"you|strong=\"G5210\"in|strong=\"G1722\"the|strong=\"G3956\"churches|strong=\"G1577\"of|strong=\"G2316\"God|strong=\"G2316\", for|strong=\"G5228\"your|strong=\"G2532\"patience|strong=\"G5281\"and|strong=\"G2532\"faith|strong=\"G4102\", and|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\"your|strong=\"G2532\"persecutions|strong=\"G1375\"and|strong=\"G2532\"tribulations|strong=\"G2347\", which|strong=\"G3739\"you|strong=\"G5210\"endure|strong=\"G0430\",",
      "5": "For|strong=\"G1519\"an|strong=\"G2532\"example of|strong=\"G0932\"the|strong=\"G3588\"just|strong=\"G1342\"judgment|strong=\"G2920\"of|strong=\"G0932\"God|strong=\"G2316\", that|strong=\"G3739\"you|strong=\"G5210\"may|strong=\"G2532\"be|strong=\"G2532\"counted worthy|strong=\"G2661\"of|strong=\"G0932\"the|strong=\"G3588\"kingdom|strong=\"G0932\"of|strong=\"G0932\"God|strong=\"G2316\", for|strong=\"G1519\"which|strong=\"G3739\"also|strong=\"G2532\"you|strong=\"G5210\"suffer|strong=\"G3958\".",
      "6": "Seeing it is|strong=\"G2316\"a|strong=\"G2316\"just|strong=\"G1342\"thing with|strong=\"G3844\"God|strong=\"G2316\"to|strong=\"G2316\"repay|strong=\"G0467\"tribulation|strong=\"G2347\"to|strong=\"G2316\"them that|strong=\"G2316\"trouble|strong=\"G2347\"you|strong=\"G5210\":",
      "7": "And|strong=\"G2532\"to|strong=\"G2532\"you|strong=\"G5210\"who|strong=\"G3588\"are|strong=\"G3588\"troubled, rest|strong=\"G0425\"with|strong=\"G3326\"us|strong=\"G1722\"when|strong=\"G2532\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"shall|strong=\"G2532\"be|strong=\"G2532\"revealed|strong=\"G0602\"from|strong=\"G0575\"heaven|strong=\"G3772\", with|strong=\"G3326\"the|strong=\"G3588\"angels|strong=\"G0032\"of|strong=\"G0575\"his|strong=\"G0846\"power|strong=\"G1411\":",
      "8": "In|strong=\"G1722\"a|strong=\"G1325\"flame|strong=\"G5395\"of|strong=\"G2316\"fire|strong=\"G4442\", giving|strong=\"G1325\"vengeance|strong=\"G1557\"to|strong=\"G2532\"them|strong=\"G1325\"who|strong=\"G3588\"know|strong=\"G1492\"not|strong=\"G3361\"God|strong=\"G2316\", and|strong=\"G2532\"who|strong=\"G3588\"obey|strong=\"G5219\"not|strong=\"G3361\"the|strong=\"G3588\"gospel|strong=\"G2098\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G2962\".",
      "9": "Who|strong=\"G3588\"shall|strong=\"G2532\"suffer eternal|strong=\"G0166\"punishment|strong=\"G1349\"in|strong=\"G2532\"destruction|strong=\"G3639\", from|strong=\"G0575\"the|strong=\"G3588\"face|strong=\"G4383\"of|strong=\"G0575\"the|strong=\"G3588\"Lord|strong=\"G2962\", and|strong=\"G2532\"from|strong=\"G0575\"the|strong=\"G3588\"glory|strong=\"G1391\"of|strong=\"G0575\"his|strong=\"G0846\"power|strong=\"G2479\":",
      "10": "When|strong=\"G3752\"he|strong=\"G2532\"shall|strong=\"G2532\"come|strong=\"G2064\"to|strong=\"G1909\"be|strong=\"G2532\"glorified|strong=\"G1740\"in|strong=\"G1722\"his|strong=\"G0846\"saints|strong=\"G0040\", and|strong=\"G2532\"to|strong=\"G1909\"be|strong=\"G2532\"made wonderful in|strong=\"G1722\"all|strong=\"G3956\"them|strong=\"G0846\"who|strong=\"G3588\"have|strong=\"G2532\"believed|strong=\"G4100\"; because|strong=\"G3754\"our|strong=\"G2532\"testimony|strong=\"G3142\"was|strong=\"G3588\"believed|strong=\"G4100\"upon|strong=\"G1909\"you|strong=\"G5210\"in|strong=\"G1722\"that|strong=\"G3754\"day|strong=\"G2250\".",
      "11": "Wherefore also|strong=\"G2532\"we|strong=\"G2249\"pray|strong=\"G4336\"always|strong=\"G3842\"for|strong=\"G1519\"you|strong=\"G5210\"; that|strong=\"G3739\"our|strong=\"G2316\"God|strong=\"G2316\"would|strong=\"G2532\"make|strong=\"G4336\"you|strong=\"G5210\"worthy|strong=\"G0515\"of|strong=\"G2316\"his|strong=\"G3956\"vocation, and|strong=\"G2532\"fulfill|strong=\"G4137\"all|strong=\"G3956\"the|strong=\"G3956\"good|strong=\"G2107\"pleasure|strong=\"G2107\"of|strong=\"G2316\"his|strong=\"G3956\"goodness|strong=\"G0019\"and|strong=\"G2532\"the|strong=\"G3956\"work|strong=\"G2041\"of|strong=\"G2316\"faith|strong=\"G4102\"in|strong=\"G1722\"power|strong=\"G1411\";",
      "12": "That|strong=\"G3704\"the|strong=\"G3588\"name|strong=\"G3686\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"may|strong=\"G2532\"be|strong=\"G2532\"glorified|strong=\"G1740\"in|strong=\"G1722\"you|strong=\"G5210\", and|strong=\"G2532\"you|strong=\"G5210\"in|strong=\"G1722\"him|strong=\"G0846\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"grace|strong=\"G5485\"of|strong=\"G2316\"our|strong=\"G2316\"God|strong=\"G2316\", and|strong=\"G2532\"of|strong=\"G2316\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"."
    },
    "2": {
      "1": "And|strong=\"G2532\"we|strong=\"G2249\"beseech you|strong=\"G5210\", brethren|strong=\"G0080\", by|strong=\"G1909\"the|strong=\"G3588\"coming|strong=\"G3952\"of|strong=\"G2962\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", and|strong=\"G2532\"of|strong=\"G2962\"our|strong=\"G2424\"gathering|strong=\"G1997\"together|strong=\"G1997\"unto him|strong=\"G0846\":",
      "2": "That|strong=\"G3754\"you|strong=\"G5210\"be|strong=\"G3366\"not|strong=\"G3361\"easily|strong=\"G5030\"moved from|strong=\"G0575\"your|strong=\"G2962\"sense, nor|strong=\"G3366\"be|strong=\"G3366\"terrified, neither|strong=\"G3383\"by|strong=\"G1223\"spirit|strong=\"G4151\", nor|strong=\"G3366\"by|strong=\"G1223\"word|strong=\"G3056\", nor|strong=\"G3366\"by|strong=\"G1223\"epistle, as|strong=\"G5613\"sent from|strong=\"G0575\"us|strong=\"G1519\", as|strong=\"G5613\"if|strong=\"G5613\"the|strong=\"G3588\"day|strong=\"G2250\"of|strong=\"G3056\"the|strong=\"G3588\"Lord|strong=\"G2962\"were|strong=\"G3588\"at|strong=\"G1519\"hand.",
      "3": "Let|strong=\"G1818\"no|strong=\"G3361\"man|strong=\"G0444\"deceive|strong=\"G1818\"you|strong=\"G5210\"by|strong=\"G2596\"any|strong=\"G5100\"means, for|strong=\"G3754\"unless|strong=\"G1437\"there|strong=\"G2596\"come|strong=\"G2064\"a|strong=\"G1437\"revolt first|strong=\"G4413\", and|strong=\"G2532\"the|strong=\"G3588\"man|strong=\"G0444\"of|strong=\"G5207\"sin be|strong=\"G2532\"revealed|strong=\"G0601\", the|strong=\"G3588\"son|strong=\"G5207\"of|strong=\"G5207\"perdition|strong=\"G0684\",",
      "4": "Who|strong=\"G3588\"opposeth, and|strong=\"G2532\"is|strong=\"G1510\"lifted up|strong=\"G1519\"above|strong=\"G1909\"all|strong=\"G3956\"that|strong=\"G3754\"is|strong=\"G1510\"called|strong=\"G3004\"God|strong=\"G2316\", or|strong=\"G2228\"that|strong=\"G3754\"is|strong=\"G1510\"worshipped, so|strong=\"G2532\"that|strong=\"G3754\"he|strong=\"G2532\"sitteth in|strong=\"G1519\"the|strong=\"G3956\"temple|strong=\"G3485\"of|strong=\"G2316\"God|strong=\"G2316\", shewing himself|strong=\"G1438\"as|strong=\"G1519\"if|strong=\"G3748\"he|strong=\"G2532\"were|strong=\"G1510\"God|strong=\"G2316\".",
      "5": "Remember|strong=\"G3421\"you|strong=\"G5210\"not|strong=\"G3756\", that|strong=\"G3754\"when|strong=\"G1510\"I|strong=\"G3778\"was|strong=\"G1510\"yet|strong=\"G2089\"with|strong=\"G4314\"you|strong=\"G5210\", I|strong=\"G3778\"told|strong=\"G3004\"you|strong=\"G5210\"these|strong=\"G3778\"things|strong=\"G3778\"?",
      "6": "And|strong=\"G2532\"now|strong=\"G3568\"you|strong=\"G1722\"know|strong=\"G1492\"what|strong=\"G3588\"withholdeth, that|strong=\"G0846\"he|strong=\"G2532\"may|strong=\"G2532\"be|strong=\"G2532\"revealed|strong=\"G0601\"in|strong=\"G1722\"his|strong=\"G0846\"time|strong=\"G2540\".",
      "7": "For|strong=\"G1063\"the|strong=\"G3588\"mystery|strong=\"G3466\"of|strong=\"G1537\"iniquity already|strong=\"G2235\"worketh; only|strong=\"G3440\"that|strong=\"G1096\"he|strong=\"G2193\"who|strong=\"G3588\"now|strong=\"G0737\"holdeth, do|strong=\"G1096\"hold|strong=\"G2722\", until|strong=\"G2193\"he|strong=\"G2193\"be|strong=\"G1096\"taken|strong=\"G1096\"out|strong=\"G1537\"of|strong=\"G1537\"the|strong=\"G3588\"way|strong=\"G3319\".",
      "8": "And|strong=\"G2532\"then|strong=\"G2532\"that|strong=\"G3739\"wicked one|strong=\"G3739\"shall|strong=\"G2532\"be|strong=\"G2532\"revealed|strong=\"G0601\"whom|strong=\"G3739\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"shall|strong=\"G2532\"kill|strong=\"G0337\"with|strong=\"G2532\"the|strong=\"G3588\"spirit|strong=\"G4151\"of|strong=\"G4151\"his|strong=\"G0846\"mouth|strong=\"G4750\"; and|strong=\"G2532\"shall|strong=\"G2532\"destroy with|strong=\"G2532\"the|strong=\"G3588\"brightness of|strong=\"G4151\"his|strong=\"G0846\"coming|strong=\"G3952\", him|strong=\"G0846\",",
      "9": "Whose|strong=\"G3739\"coming|strong=\"G3952\"is|strong=\"G1510\"according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3956\"working|strong=\"G1753\"of|strong=\"G1411\"Satan|strong=\"G4567\", in|strong=\"G1722\"all|strong=\"G3956\"power|strong=\"G1411\", and|strong=\"G2532\"signs|strong=\"G4592\", and|strong=\"G2532\"lying|strong=\"G5579\"wonders|strong=\"G5059\",",
      "10": "And|strong=\"G2532\"in|strong=\"G1722\"all|strong=\"G3956\"seduction of|strong=\"G0026\"iniquity|strong=\"G0093\"to|strong=\"G1519\"them|strong=\"G0846\"that|strong=\"G3739\"perish|strong=\"G0622\"; because|strong=\"G1722\"they|strong=\"G0846\"receive|strong=\"G1209\"not|strong=\"G3756\"the|strong=\"G3956\"love|strong=\"G0026\"of|strong=\"G0026\"the|strong=\"G3956\"truth|strong=\"G0225\", that|strong=\"G3739\"they|strong=\"G0846\"might|strong=\"G2532\"be|strong=\"G2532\"saved|strong=\"G4982\". Therefore God|strong=\"G0846\"shall|strong=\"G2532\"send them|strong=\"G0846\"the|strong=\"G3956\"operation of|strong=\"G0026\"error, to|strong=\"G1519\"believe lying:",
      "11": "That|strong=\"G4100\"all|strong=\"G3588\"may|strong=\"G2532\"be|strong=\"G2532\"judged who|strong=\"G3588\"have|strong=\"G2532\"not|strong=\"G2532\"believed|strong=\"G4100\"the|strong=\"G3588\"truth, but|strong=\"G2532\"have|strong=\"G2532\"consented to|strong=\"G1519\"iniquity.",
      "12": "But|strong=\"G0235\"we|strong=\"G3588\"ought to|strong=\"G2443\"give thanks to|strong=\"G2443\"God|strong=\"G2106\"always|strong=\"G3956\"for|strong=\"G2443\"you|strong=\"G3956\", brethren, beloved of|strong=\"G3956\"God|strong=\"G2106\", for|strong=\"G2443\"that|strong=\"G2443\"God|strong=\"G2106\"hath chosen|strong=\"G2106\"you|strong=\"G3956\"firstfruits unto salvation, in|strong=\"G3956\"sanctification of|strong=\"G3956\"the|strong=\"G3956\"spirit, and|strong=\"G3956\"faith|strong=\"G4100\"of|strong=\"G3956\"the|strong=\"G3956\"truth|strong=\"G0225\":",
      "13": "Whereunto also|strong=\"G2532\"he|strong=\"G2532\"hath called you|strong=\"G5210\"by|strong=\"G1722\"our|strong=\"G2316\"gospel, unto the|strong=\"G3588\"purchasing of|strong=\"G4151\"the|strong=\"G3588\"glory of|strong=\"G4151\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2532\"Christ|strong=\"G2962\".",
      "14": "Therefore|strong=\"G1223\", brethren, stand fast; and|strong=\"G2532\"hold the|strong=\"G3588\"traditions which|strong=\"G3739\"you|strong=\"G5210\"have|strong=\"G2532\"learned, whether|strong=\"G2532\"by|strong=\"G1223\"word, or|strong=\"G2532\"by|strong=\"G1223\"our|strong=\"G2424\"epistle.",
      "15": "Now|strong=\"G2532\"our|strong=\"G2532\"Lord Jesus|strong=\"G2532\"Christ himself, and|strong=\"G2532\"God and|strong=\"G2532\"our|strong=\"G2532\"Father, who|strong=\"G3739\"hath loved us, and|strong=\"G2532\"hath given us everlasting consolation, and|strong=\"G2532\"good hope in|strong=\"G2532\"grace,",
      "16": "Exhort your|strong=\"G0025\"hearts, and|strong=\"G2532\"confirm you|strong=\"G1325\"in|strong=\"G1722\"every good|strong=\"G0018\"work|strong=\"G5485\"and|strong=\"G2532\"word."
    },
    "3": {
      "1": "For|strong=\"G4012\"the|strong=\"G3588\"rest, brethren|strong=\"G0080\", pray|strong=\"G4336\"for|strong=\"G4012\"us|strong=\"G4012\", that|strong=\"G2443\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"God|strong=\"G4314\"may|strong=\"G2532\"run|strong=\"G5143\", and|strong=\"G2532\"may|strong=\"G2532\"be|strong=\"G2532\"glorified|strong=\"G1392\", even|strong=\"G2532\"as|strong=\"G2531\"among|strong=\"G4314\"you|strong=\"G5210\";",
      "2": "And|strong=\"G2532\"that|strong=\"G2443\"we|strong=\"G2532\"may|strong=\"G2532\"be|strong=\"G2532\"delivered|strong=\"G4506\"from|strong=\"G0575\"importunate and|strong=\"G2532\"evil|strong=\"G4190\"men|strong=\"G0444\"; for|strong=\"G1063\"all|strong=\"G3956\"men|strong=\"G0444\"have|strong=\"G2532\"not|strong=\"G3756\"faith|strong=\"G4102\".",
      "3": "But|strong=\"G1161\"God is|strong=\"G1510\"faithful|strong=\"G4103\", who|strong=\"G3739\"will|strong=\"G1510\"strengthen|strong=\"G4741\"and|strong=\"G2532\"keep|strong=\"G5442\"you|strong=\"G5210\"from|strong=\"G0575\"evil|strong=\"G4190\".",
      "4": "And|strong=\"G2532\"we|strong=\"G3739\"have|strong=\"G2532\"confidence|strong=\"G3982\"concerning|strong=\"G1909\"you|strong=\"G5210\"in|strong=\"G1722\"the|strong=\"G2532\"Lord|strong=\"G2962\", that|strong=\"G3754\"the|strong=\"G2532\"things|strong=\"G3739\"which|strong=\"G3739\"we|strong=\"G3739\"command|strong=\"G3853\", you|strong=\"G5210\"both|strong=\"G2532\"do|strong=\"G4160\", and|strong=\"G2532\"will|strong=\"G3739\"do|strong=\"G4160\".",
      "5": "And|strong=\"G2532\"the|strong=\"G3588\"Lord|strong=\"G2962\"direct|strong=\"G2720\"your|strong=\"G2962\"hearts|strong=\"G2588\", in|strong=\"G1519\"the|strong=\"G3588\"charity of|strong=\"G2316\"God|strong=\"G2316\", and|strong=\"G2532\"the|strong=\"G3588\"patience|strong=\"G5281\"of|strong=\"G2316\"Christ|strong=\"G5547\".",
      "6": "And|strong=\"G2532\"we|strong=\"G2249\"charge|strong=\"G3853\"you|strong=\"G5210\", brethren|strong=\"G0080\", in|strong=\"G1722\"the|strong=\"G3956\"name|strong=\"G3686\"of|strong=\"G0575\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", that|strong=\"G3739\"you|strong=\"G5210\"withdraw yourselves|strong=\"G4771\"from|strong=\"G0575\"every|strong=\"G3956\"brother|strong=\"G0080\"walking|strong=\"G4043\"disorderly, and|strong=\"G2532\"not|strong=\"G3361\"according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3956\"tradition|strong=\"G3862\"which|strong=\"G3739\"they|strong=\"G3739\"have|strong=\"G2532\"received|strong=\"G3880\"of|strong=\"G0575\"us|strong=\"G1722\".",
      "7": "For|strong=\"G1063\"yourselves|strong=\"G0846\"know|strong=\"G1492\"how|strong=\"G4459\"you|strong=\"G5210\"ought|strong=\"G1163\"to|strong=\"G1722\"imitate|strong=\"G3401\"us|strong=\"G1722\": for|strong=\"G1063\"we|strong=\"G2249\"were|strong=\"G3748\"not|strong=\"G3756\"disorderly among|strong=\"G1722\"you|strong=\"G5210\";",
      "8": "Neither|strong=\"G3761\"did|strong=\"G3761\"we|strong=\"G2532\"eat|strong=\"G2068\"any|strong=\"G5100\"man’s|strong=\"G5100\"bread|strong=\"G0740\"for|strong=\"G4314\"nothing|strong=\"G3361\", but|strong=\"G0235\"in|strong=\"G1722\"labour and|strong=\"G2532\"in|strong=\"G1722\"toil|strong=\"G2873\"we|strong=\"G2532\"worked|strong=\"G2038\"night|strong=\"G3571\"and|strong=\"G2532\"day|strong=\"G2250\", lest|strong=\"G3361\"we|strong=\"G2532\"should|strong=\"G5100\"be|strong=\"G2532\"chargeable to|strong=\"G4314\"any|strong=\"G5100\"of|strong=\"G2250\"you|strong=\"G5210\".",
      "9": "Not|strong=\"G3756\"as|strong=\"G1519\"if|strong=\"G2443\"we|strong=\"G2249\"had|strong=\"G2192\"not|strong=\"G3756\"power|strong=\"G1849\": but|strong=\"G0235\"that|strong=\"G3754\"we|strong=\"G2249\"might|strong=\"G1473\"give|strong=\"G1325\"ourselves|strong=\"G1438\"a|strong=\"G2192\"pattern|strong=\"G5179\"unto you|strong=\"G5210\", to|strong=\"G1519\"imitate|strong=\"G3401\"us|strong=\"G1325\".",
      "10": "For|strong=\"G1063\"also|strong=\"G2532\"when|strong=\"G3753\"we|strong=\"G3778\"were|strong=\"G1510\"with|strong=\"G4314\"you|strong=\"G5210\", this|strong=\"G3778\"we|strong=\"G3778\"declared to|strong=\"G4314\"you|strong=\"G5210\": that|strong=\"G3754\", if|strong=\"G1487\"any|strong=\"G5100\"man|strong=\"G3778\"will|strong=\"G1510\"not|strong=\"G3756\"work|strong=\"G2038\", neither|strong=\"G3756\"let|strong=\"G1510\"him|strong=\"G2532\"eat|strong=\"G2068\".",
      "11": "For|strong=\"G1063\"we|strong=\"G0191\"have|strong=\"G5100\"heard|strong=\"G0191\"there|strong=\"G1722\"are some|strong=\"G5100\"among|strong=\"G1722\"you|strong=\"G5210\"who|strong=\"G5100\"walk|strong=\"G4043\"disorderly, working not|strong=\"G3367\"at|strong=\"G1722\"all|strong=\"G3367\", but|strong=\"G0235\"curiously meddling.",
      "12": "Now|strong=\"G1161\"we|strong=\"G2532\"charge|strong=\"G3853\"them|strong=\"G1722\"that|strong=\"G2443\"are|strong=\"G3588\"such|strong=\"G5108\", and|strong=\"G2532\"beseech them|strong=\"G1722\"by|strong=\"G1722\"the|strong=\"G3588\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", that|strong=\"G2443\", working with|strong=\"G3326\"silence, they|strong=\"G2532\"would|strong=\"G5547\"eat|strong=\"G2068\"their|strong=\"G1438\"own|strong=\"G1438\"bread|strong=\"G0740\".",
      "13": "But|strong=\"G1161\"you|strong=\"G5210\", brethren|strong=\"G0080\", be|strong=\"G3361\"not|strong=\"G3361\"weary in|strong=\"G0080\"well doing|strong=\"G2569\".",
      "14": "And|strong=\"G1161\"if|strong=\"G1487\"any|strong=\"G5100\"man|strong=\"G3778\"obey|strong=\"G5219\"not|strong=\"G3756\"our|strong=\"G1223\"word|strong=\"G3056\"by|strong=\"G1223\"this|strong=\"G3778\"epistle, note|strong=\"G4593\"that|strong=\"G2443\"man|strong=\"G3778\", and|strong=\"G1161\"do|strong=\"G3361\"not|strong=\"G3756\"keep|strong=\"G3361\"company with|strong=\"G1223\"him|strong=\"G0846\", that|strong=\"G2443\"he|strong=\"G0846\"may|strong=\"G2443\"be|strong=\"G5100\"ashamed:",
      "15": "Yet|strong=\"G2532\"do|strong=\"G3361\"not|strong=\"G3361\"esteem|strong=\"G2233\"him|strong=\"G2532\"as|strong=\"G5613\"an|strong=\"G2532\"enemy|strong=\"G2190\", but|strong=\"G0235\"admonish|strong=\"G3560\"him|strong=\"G2532\"as|strong=\"G5613\"a|strong=\"G5613\"brother|strong=\"G0080\".",
      "16": "Now|strong=\"G1161\"the|strong=\"G3956\"Lord|strong=\"G2962\"of|strong=\"G1223\"peace|strong=\"G1515\"himself|strong=\"G0846\"give|strong=\"G1325\"you|strong=\"G5210\"everlasting peace|strong=\"G1515\"in|strong=\"G1722\"every|strong=\"G3956\"place|strong=\"G1722\". The|strong=\"G3956\"Lord|strong=\"G2962\"be|strong=\"G3956\"with|strong=\"G3326\"you|strong=\"G5210\"all|strong=\"G3956\".",
      "17": "The|strong=\"G3956\"salutation|strong=\"G0783\"of|strong=\"G3956\"Paul|strong=\"G3972\"with|strong=\"G1722\"my|strong=\"G1699\"own|strong=\"G1699\"hand|strong=\"G5495\"; which|strong=\"G3739\"is|strong=\"G1510\"the|strong=\"G3956\"sign|strong=\"G4592\"in|strong=\"G1722\"every|strong=\"G3956\"epistle. So|strong=\"G3779\"I|strong=\"G3739\"write|strong=\"G1125\".",
      "18": "The|strong=\"G3956\"grace|strong=\"G5485\"of|strong=\"G5485\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"be|strong=\"G3956\"with|strong=\"G3326\"you|strong=\"G5210\"all|strong=\"G3956\". Amen."
    }
  }
