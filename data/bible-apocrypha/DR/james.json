      "14": "Is|strong=\"G2962\"any|strong=\"G5100\"man|strong=\"G5100\"sick|strong=\"G0770\"among|strong=\"G1722\"you|strong=\"G5210\"? Let him|strong=\"G0846\"bring in|strong=\"G1722\"the|strong=\"G3588\"priests of|strong=\"G2962\"the|strong=\"G3588\"church|strong=\"G1577\", and|strong=\"G2532\"let them|strong=\"G0846\"pray|strong=\"G4336\"over|strong=\"G1909\"him|strong=\"G0846\", anointing him|strong=\"G0846\"with|strong=\"G1722\"oil|strong=\"G1637\"in|strong=\"G1722\"the|strong=\"G3588\"name|strong=\"G3686\"of|strong=\"G2962\"the|strong=\"G3588\"Lord|strong=\"G2962\".",
      "15": "And|strong=\"G2532\"the|strong=\"G3588\"prayer|strong=\"G2171\"of|strong=\"G2962\"faith|strong=\"G4102\"shall|strong=\"G2532\"save|strong=\"G4982\"the|strong=\"G3588\"sick|strong=\"G2577\"man|strong=\"G4160\": and|strong=\"G2532\"the|strong=\"G3588\"Lord|strong=\"G2962\"shall|strong=\"G2532\"raise|strong=\"G1453\"him|strong=\"G0846\"up|strong=\"G1453\": and|strong=\"G2532\"if|strong=\"G2579\"he|strong=\"G2532\"be|strong=\"G1510\"in|strong=\"G2532\"sins|strong=\"G0266\", they|strong=\"G0846\"shall|strong=\"G2532\"be|strong=\"G1510\"forgiven|strong=\"G0863\"him|strong=\"G0846\".",
      "16": "Confess|strong=\"G1843\"therefore|strong=\"G3767\"your|strong=\"G2532\"sins|strong=\"G0266\"one|strong=\"G0240\"to|strong=\"G2532\"another|strong=\"G0240\": and|strong=\"G2532\"pray|strong=\"G2172\"one|strong=\"G0240\"for|strong=\"G5228\"another|strong=\"G0240\", that|strong=\"G3704\"you|strong=\"G2532\"may|strong=\"G2532\"be|strong=\"G2532\"saved. For|strong=\"G5228\"the|strong=\"G3588\"continual prayer|strong=\"G1162\"of|strong=\"G5228\"a|strong=\"G2532\"just|strong=\"G1342\"man|strong=\"G1342\"availeth much|strong=\"G4183\".",
      "17": "Elias was|strong=\"G1510\"a|strong=\"G1510\"man|strong=\"G0444\"passible like|strong=\"G3663\"unto us|strong=\"G1909\": and|strong=\"G2532\"with|strong=\"G1909\"prayer|strong=\"G4335\"he|strong=\"G2532\"prayed|strong=\"G4336\"that|strong=\"G0444\"it|strong=\"G1510\"might|strong=\"G2532\"not|strong=\"G3756\"rain|strong=\"G1026\"upon|strong=\"G1909\"the|strong=\"G3588\"earth|strong=\"G1093\", and|strong=\"G2532\"it|strong=\"G1510\"rained|strong=\"G1026\"not|strong=\"G3756\"for|strong=\"G1909\"three|strong=\"G5140\"years|strong=\"G1763\"and|strong=\"G2532\"six|strong=\"G1803\"months|strong=\"G3376\".",
      "18": "And|strong=\"G2532\"he|strong=\"G2532\"prayed|strong=\"G4336\"again|strong=\"G3825\": and|strong=\"G2532\"the|strong=\"G3588\"heaven|strong=\"G3772\"gave|strong=\"G1325\"rain|strong=\"G5205\", and|strong=\"G2532\"the|strong=\"G3588\"earth|strong=\"G1093\"brought forth her|strong=\"G0846\"fruit|strong=\"G2590\".",
      "19": "My|strong=\"G1722\"brethren|strong=\"G0080\", if|strong=\"G1437\"any|strong=\"G5100\"of|strong=\"G0575\"you|strong=\"G5210\"err from|strong=\"G0575\"the|strong=\"G3588\"truth|strong=\"G0225\", and|strong=\"G2532\"one|strong=\"G5100\"convert him|strong=\"G0846\":",
      "20": "He|strong=\"G2532\"must|strong=\"G1994\"know|strong=\"G1097\"that|strong=\"G3754\"he|strong=\"G2532\"who|strong=\"G3588\"causeth a|strong=\"G2532\"sinner|strong=\"G0268\"to|strong=\"G2532\"be|strong=\"G2532\"converted from|strong=\"G1537\"the|strong=\"G3588\"error|strong=\"G4106\"of|strong=\"G1537\"his|strong=\"G0846\"way|strong=\"G3598\", shall|strong=\"G2532\"save|strong=\"G4982\"his|strong=\"G0846\"soul|strong=\"G5590\"from|strong=\"G1537\"death|strong=\"G2288\", and|strong=\"G2532\"shall|strong=\"G2532\"cover|strong=\"G2572\"a|strong=\"G2532\"multitude|strong=\"G4128\"of|strong=\"G1537\"sins|strong=\"G0266\"."
