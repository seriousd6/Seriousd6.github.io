    "1": {
      "1": "James|strong=\"G2385\"the|strong=\"G3588\"servant|strong=\"G1401\"of|strong=\"G2316\"God|strong=\"G2316\", and|strong=\"G2532\"of|strong=\"G2316\"our|strong=\"G2316\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\", to|strong=\"G2532\"the|strong=\"G3588\"twelve|strong=\"G1427\"tribes|strong=\"G5443\"which|strong=\"G3588\"are|strong=\"G3588\"scattered|strong=\"G1290\"abroad|strong=\"G1290\", greeting|strong=\"G5463\".",
      "2": "My|strong=\"G3956\"brethren|strong=\"G0080\", count|strong=\"G2233\"it|strong=\"G2233\"all|strong=\"G3956\"joy|strong=\"G5479\", when|strong=\"G3752\"you|strong=\"G3752\"shall fall into divers temptations;",
      "3": "Knowing|strong=\"G1097\"that|strong=\"G3754\"the|strong=\"G3588\"trying of|strong=\"G3588\"your|strong=\"G4102\"faith|strong=\"G4102\"worketh patience|strong=\"G5281\".",
      "4": "And|strong=\"G2532\"patience|strong=\"G5281\"hath a|strong=\"G2192\"perfect|strong=\"G5046\"work|strong=\"G2041\"; that|strong=\"G2443\"you|strong=\"G1722\"may|strong=\"G2532\"be|strong=\"G1510\"perfect|strong=\"G5046\"and|strong=\"G2532\"entire, failing in|strong=\"G1722\"nothing|strong=\"G3367\".",
      "5": "But|strong=\"G1161\"if|strong=\"G1487\"any|strong=\"G5100\"of|strong=\"G2316\"you|strong=\"G5210\"want wisdom|strong=\"G4678\", let him|strong=\"G0846\"ask|strong=\"G0154\"of|strong=\"G2316\"God|strong=\"G2316\", who|strong=\"G3588\"giveth to|strong=\"G2532\"all|strong=\"G3956\"men|strong=\"G3956\"abundantly, and|strong=\"G2532\"upbraideth not|strong=\"G3361\"; and|strong=\"G2532\"it|strong=\"G0846\"shall|strong=\"G2532\"be|strong=\"G2532\"given|strong=\"G1325\"him|strong=\"G0846\".",
      "6": "But|strong=\"G1161\"let him|strong=\"G2532\"ask|strong=\"G0154\"in|strong=\"G1722\"faith|strong=\"G4102\", nothing|strong=\"G3367\"wavering. For|strong=\"G1063\"he|strong=\"G2532\"that|strong=\"G1161\"wavereth is|strong=\"G3588\"like a|strong=\"G2532\"wave of|strong=\"G1722\"the|strong=\"G3588\"sea|strong=\"G2281\", which|strong=\"G3588\"is|strong=\"G3588\"moved and|strong=\"G2532\"carried about|strong=\"G1722\"by|strong=\"G1722\"the|strong=\"G3588\"wind|strong=\"G4494\".",
      "7": "Therefore let not|strong=\"G3361\"that|strong=\"G3754\"man|strong=\"G0444\"think that|strong=\"G3754\"he|strong=\"G3754\"shall|strong=\"G0444\"receive|strong=\"G2983\"any|strong=\"G5100\"thing of|strong=\"G2962\"the|strong=\"G3588\"Lord|strong=\"G2962\".",
      "8": "A|strong=\"G0435\"double minded man|strong=\"G0435\"is|strong=\"G3588\"inconstant in|strong=\"G1722\"all|strong=\"G3956\"his|strong=\"G0846\"ways|strong=\"G3598\".",
      "9": "But|strong=\"G1161\"let the|strong=\"G3588\"brother|strong=\"G0080\"of|strong=\"G1722\"low condition glory|strong=\"G2744\"in|strong=\"G1722\"his|strong=\"G0846\"exaltation:",
      "10": "And|strong=\"G1161\"the|strong=\"G3588\"rich|strong=\"G4145\", in|strong=\"G1722\"his|strong=\"G0846\"being low; because|strong=\"G3754\"as|strong=\"G5613\"the|strong=\"G3588\"flower|strong=\"G0438\"of|strong=\"G1722\"the|strong=\"G3588\"grass|strong=\"G5528\"shall he|strong=\"G0846\"pass|strong=\"G3928\"away|strong=\"G3928\".",
      "11": "For|strong=\"G1063\"the|strong=\"G3588\"sun|strong=\"G2246\"rose with|strong=\"G1722\"a|strong=\"G3779\"burning heat|strong=\"G2742\", and|strong=\"G2532\"parched the|strong=\"G3588\"grass|strong=\"G5528\", and|strong=\"G2532\"the|strong=\"G3588\"flower|strong=\"G0438\"thereof fell off, and|strong=\"G2532\"the|strong=\"G3588\"beauty|strong=\"G2143\"of|strong=\"G1722\"the|strong=\"G3588\"shape thereof perished|strong=\"G0622\": so|strong=\"G2532\"also|strong=\"G2532\"shall|strong=\"G2532\"the|strong=\"G3588\"rich|strong=\"G4145\"man|strong=\"G4145\"fade|strong=\"G3133\"away|strong=\"G3583\"in|strong=\"G1722\"his|strong=\"G0846\"ways.",
      "12": "Blessed|strong=\"G3107\"is|strong=\"G3739\"the|strong=\"G3588\"man|strong=\"G0435\"that|strong=\"G3754\"endureth temptation|strong=\"G3986\"; for|strong=\"G3754\"when|strong=\"G1096\"he|strong=\"G0846\"hath been|strong=\"G1096\"proved|strong=\"G1096\", he|strong=\"G0846\"shall receive|strong=\"G2983\"a|strong=\"G1096\"crown|strong=\"G4735\"of|strong=\"G0435\"life|strong=\"G2222\", which|strong=\"G3739\"God|strong=\"G0846\"hath promised|strong=\"G1861\"to|strong=\"G1096\"them|strong=\"G0846\"that|strong=\"G3754\"love|strong=\"G0025\"him|strong=\"G0846\".",
      "13": "Let|strong=\"G1510\"no|strong=\"G3762\"man|strong=\"G3762\", when|strong=\"G1161\"he|strong=\"G0846\"is|strong=\"G1510\"tempted|strong=\"G3985\", say|strong=\"G3004\"that|strong=\"G3754\"he|strong=\"G0846\"is|strong=\"G1510\"tempted|strong=\"G3985\"by|strong=\"G0575\"God|strong=\"G2316\". For|strong=\"G1063\"God|strong=\"G2316\"is|strong=\"G1510\"not|strong=\"G3367\"a|strong=\"G1510\"tempter|strong=\"G3985\"of|strong=\"G0575\"evils|strong=\"G2556\", and|strong=\"G1161\"he|strong=\"G0846\"tempteth no|strong=\"G3762\"man|strong=\"G3762\".",
      "14": "But|strong=\"G1161\"every|strong=\"G1538\"man|strong=\"G1538\"is|strong=\"G3588\"tempted|strong=\"G3985\"by|strong=\"G5259\"his|strong=\"G2532\"own|strong=\"G2398\"concupiscence, being drawn away|strong=\"G1828\"and|strong=\"G2532\"allured.",
      "15": "Then|strong=\"G1161\"when|strong=\"G1161\"concupiscence hath conceived|strong=\"G4815\", it|strong=\"G1161\"bringeth forth|strong=\"G0616\"sin|strong=\"G0266\". But|strong=\"G1161\"sin|strong=\"G0266\", when|strong=\"G1161\"it|strong=\"G1161\"is|strong=\"G3588\"completed, begetteth death|strong=\"G2288\".",
      "16": "Do|strong=\"G3361\"not|strong=\"G3361\"err, therefore, my|strong=\"G4105\"dearest brethren|strong=\"G0080\".",
      "17": "Every|strong=\"G3956\"best gift|strong=\"G1434\", and|strong=\"G2532\"every|strong=\"G3956\"perfect|strong=\"G5046\"gift|strong=\"G1434\", is|strong=\"G1510\"from|strong=\"G0575\"above|strong=\"G0509\", coming|strong=\"G2597\"down|strong=\"G2597\"from|strong=\"G0575\"the|strong=\"G3956\"Father|strong=\"G3962\"of|strong=\"G0575\"lights|strong=\"G5457\", with|strong=\"G3844\"whom|strong=\"G3739\"there|strong=\"G1510\"is|strong=\"G1510\"no|strong=\"G3756\"change, nor|strong=\"G2532\"shadow|strong=\"G0644\"of|strong=\"G0575\"alteration.",
      "18": "For|strong=\"G1519\"of|strong=\"G3056\"his|strong=\"G0846\"own|strong=\"G0846\"will|strong=\"G1510\"hath he|strong=\"G0846\"begotten us|strong=\"G1519\"by|strong=\"G1519\"the|strong=\"G3588\"word|strong=\"G3056\"of|strong=\"G3056\"truth|strong=\"G0225\", that|strong=\"G0846\"we|strong=\"G2249\"might|strong=\"G5100\"be|strong=\"G1510\"some|strong=\"G5100\"beginning of|strong=\"G3056\"his|strong=\"G0846\"creatures|strong=\"G2938\".",
      "19": "You|strong=\"G1510\"know|strong=\"G1492\", my|strong=\"G0191\"dearest brethren|strong=\"G0080\". And|strong=\"G1161\"let|strong=\"G1510\"every|strong=\"G3956\"man|strong=\"G0444\"be|strong=\"G1510\"swift to|strong=\"G1519\"hear|strong=\"G0191\", but|strong=\"G1161\"slow|strong=\"G1021\"to|strong=\"G1519\"speak|strong=\"G2980\", and|strong=\"G1161\"slow|strong=\"G1021\"to|strong=\"G1519\"anger|strong=\"G3709\".",
      "20": "For|strong=\"G1063\"the|strong=\"G2316\"anger|strong=\"G3709\"of|strong=\"G2316\"man|strong=\"G0435\"worketh not|strong=\"G3756\"the|strong=\"G2316\"justice|strong=\"G1343\"of|strong=\"G2316\"God|strong=\"G2316\".",
      "21": "Wherefore|strong=\"G1352\"casting away all|strong=\"G3956\"uncleanness, and|strong=\"G2532\"abundance|strong=\"G4050\"of|strong=\"G3056\"naughtiness, with|strong=\"G1722\"meekness|strong=\"G4240\"receive|strong=\"G1209\"the|strong=\"G3956\"ingrafted word|strong=\"G3056\", which|strong=\"G3588\"is|strong=\"G3588\"able|strong=\"G1410\"to|strong=\"G1410\"save|strong=\"G4982\"your|strong=\"G2532\"souls|strong=\"G5590\".",
      "22": "But|strong=\"G1161\"be|strong=\"G1096\"ye doers|strong=\"G4163\"of|strong=\"G3056\"the|strong=\"G2532\"word|strong=\"G3056\", and|strong=\"G2532\"not|strong=\"G3361\"hearers|strong=\"G0202\"only|strong=\"G3440\", deceiving your|strong=\"G2532\"own|strong=\"G1438\"selves.",
      "23": "For|strong=\"G3754\"if|strong=\"G1487\"a|strong=\"G1510\"man|strong=\"G0435\"be|strong=\"G1510\"a|strong=\"G1510\"hearer|strong=\"G0202\"of|strong=\"G3056\"the|strong=\"G3588\"word|strong=\"G3056\", and|strong=\"G2532\"not|strong=\"G3756\"a|strong=\"G1510\"doer|strong=\"G4163\", he|strong=\"G2532\"shall|strong=\"G3778\"be|strong=\"G1510\"compared|strong=\"G1510\"to|strong=\"G2532\"a|strong=\"G1510\"man|strong=\"G0435\"beholding his|strong=\"G0846\"own|strong=\"G0846\"countenance in|strong=\"G1722\"a|strong=\"G1510\"glass.",
      "24": "For|strong=\"G1063\"he|strong=\"G2532\"beheld himself|strong=\"G1438\", and|strong=\"G2532\"went|strong=\"G0565\"his|strong=\"G1438\"way|strong=\"G0565\", and|strong=\"G2532\"presently forgot what|strong=\"G3697\"manner of|strong=\"G2532\"man he|strong=\"G2532\"was|strong=\"G1510\".",
      "25": "But|strong=\"G1161\"he|strong=\"G2532\"that|strong=\"G3778\"hath looked|strong=\"G1096\"into|strong=\"G1519\"the|strong=\"G3588\"perfect|strong=\"G5046\"law|strong=\"G3551\"of|strong=\"G3551\"liberty|strong=\"G1657\", and|strong=\"G2532\"hath continued therein, not|strong=\"G3756\"becoming|strong=\"G1096\"a|strong=\"G1096\"forgetful|strong=\"G1953\"hearer|strong=\"G0202\", but|strong=\"G1161\"a|strong=\"G1096\"doer|strong=\"G4163\"of|strong=\"G3551\"the|strong=\"G3588\"work|strong=\"G2041\"; this|strong=\"G3778\"man|strong=\"G3778\"shall|strong=\"G3778\"be|strong=\"G1510\"blessed|strong=\"G3107\"in|strong=\"G1722\"his|strong=\"G0846\"deed|strong=\"G2041\".",
      "26": "And|strong=\"G0846\"if|strong=\"G1487\"any|strong=\"G5100\"man|strong=\"G3778\"think|strong=\"G1380\"himself|strong=\"G0846\"to|strong=\"G5100\"be|strong=\"G1510\"religious|strong=\"G2357\", not|strong=\"G3361\"bridling his|strong=\"G0846\"tongue|strong=\"G1100\", but|strong=\"G0235\"deceiving his|strong=\"G0846\"own|strong=\"G0846\"heart|strong=\"G2588\", this|strong=\"G3778\"man’s|strong=\"G5100\"religion|strong=\"G2356\"is|strong=\"G1510\"vain|strong=\"G3152\".",
      "27": "Religion|strong=\"G2356\"clean|strong=\"G2513\"and|strong=\"G2532\"undefiled|strong=\"G0283\"before|strong=\"G3844\"God|strong=\"G2316\"and|strong=\"G2532\"the|strong=\"G3588\"Father|strong=\"G3962\", is|strong=\"G1510\"this|strong=\"G3778\": to|strong=\"G2532\"visit|strong=\"G1980\"the|strong=\"G3588\"fatherless and|strong=\"G2532\"widows|strong=\"G5503\"in|strong=\"G1722\"their|strong=\"G0846\"tribulation|strong=\"G2347\": and|strong=\"G2532\"to|strong=\"G2532\"keep|strong=\"G5083\"one’s|strong=\"G0846\"self unspotted from|strong=\"G0575\"this|strong=\"G3778\"world|strong=\"G2889\"."
    },
    "2": {
      "1": "My|strong=\"G1722\"brethren|strong=\"G0080\", have|strong=\"G2192\"not|strong=\"G3361\"the|strong=\"G3588\"faith|strong=\"G4102\"of|strong=\"G1391\"our|strong=\"G2424\"Lord|strong=\"G2962\"Jesus|strong=\"G2424\"Christ|strong=\"G5547\"of|strong=\"G1391\"glory|strong=\"G1391\"with|strong=\"G1722\"respect of|strong=\"G1391\"persons.",
      "2": "For|strong=\"G1063\"if|strong=\"G1437\"there|strong=\"G1722\"shall|strong=\"G2532\"come|strong=\"G1525\"into|strong=\"G1519\"your|strong=\"G1437\"assembly|strong=\"G4864\"a|strong=\"G1437\"man|strong=\"G0435\"having a|strong=\"G1437\"golden ring|strong=\"G5554\", in|strong=\"G1722\"fine|strong=\"G2986\"apparel|strong=\"G2066\", and|strong=\"G2532\"there|strong=\"G1722\"shall|strong=\"G2532\"come|strong=\"G1525\"in|strong=\"G1722\"also|strong=\"G2532\"a|strong=\"G1437\"poor|strong=\"G4434\"man|strong=\"G0435\"in|strong=\"G1722\"mean attire|strong=\"G2066\",",
      "3": "And|strong=\"G2532\"you|strong=\"G4771\"have|strong=\"G2532\"respect to|strong=\"G3004\"him|strong=\"G2476\"that|strong=\"G3004\"is|strong=\"G3588\"clothed with|strong=\"G1909\"the|strong=\"G3588\"fine|strong=\"G2986\"apparel|strong=\"G2066\", and|strong=\"G2532\"shall|strong=\"G2532\"say|strong=\"G3004\"to|strong=\"G3004\"him|strong=\"G2476\": Sit|strong=\"G2521\"thou here|strong=\"G5602\"well|strong=\"G2573\"; but|strong=\"G1161\"say|strong=\"G3004\"to|strong=\"G3004\"the|strong=\"G3588\"poor|strong=\"G4434\"man|strong=\"G4434\": Stand|strong=\"G2476\"thou there|strong=\"G1563\", or|strong=\"G2228\"sit|strong=\"G2521\"under|strong=\"G5259\"my|strong=\"G5259\"footstool|strong=\"G5286\":",
      "4": "Do|strong=\"G1096\"you|strong=\"G1722\"not|strong=\"G3756\"judge|strong=\"G2923\"within|strong=\"G1722\"yourselves|strong=\"G1438\", and|strong=\"G2532\"are|strong=\"G2532\"become|strong=\"G1096\"judges|strong=\"G2923\"of|strong=\"G1722\"unjust thoughts|strong=\"G1261\"?",
      "5": "Hearken, my|strong=\"G0191\"dearest brethren|strong=\"G0080\": hath not|strong=\"G3756\"God|strong=\"G2316\"chosen|strong=\"G1586\"the|strong=\"G3588\"poor|strong=\"G4434\"in|strong=\"G1722\"this|strong=\"G3588\"world|strong=\"G2889\", rich|strong=\"G4145\"in|strong=\"G1722\"faith|strong=\"G4102\", and|strong=\"G2532\"heirs|strong=\"G2818\"of|strong=\"G0932\"the|strong=\"G3588\"kingdom|strong=\"G0932\"which|strong=\"G3739\"God|strong=\"G2316\"hath promised|strong=\"G1861\"to|strong=\"G2532\"them|strong=\"G0846\"that|strong=\"G3739\"love|strong=\"G0025\"him|strong=\"G0846\"?",
      "6": "But|strong=\"G1161\"you|strong=\"G5210\"have|strong=\"G2532\"dishonoured the|strong=\"G3588\"poor|strong=\"G4434\"man|strong=\"G4145\". Do|strong=\"G2532\"not|strong=\"G3756\"the|strong=\"G3588\"rich|strong=\"G4145\"oppress you|strong=\"G5210\"by|strong=\"G2532\"might|strong=\"G2532\"? and|strong=\"G2532\"do|strong=\"G2532\"not|strong=\"G3756\"they|strong=\"G0846\"draw|strong=\"G1670\"you|strong=\"G5210\"before|strong=\"G1519\"the|strong=\"G3588\"judgment seats?",
      "7": "Do|strong=\"G3756\"not|strong=\"G3756\"they|strong=\"G0846\"blaspheme|strong=\"G0987\"the|strong=\"G3588\"good|strong=\"G2570\"name|strong=\"G3686\"that|strong=\"G0846\"is|strong=\"G3588\"invoked upon|strong=\"G1909\"you|strong=\"G5210\"?",
      "8": "If|strong=\"G1487\"then you|strong=\"G4771\"fulfill the|strong=\"G3588\"royal|strong=\"G0937\"law|strong=\"G3551\", according|strong=\"G2596\"to|strong=\"G2596\"the|strong=\"G3588\"scriptures|strong=\"G1124\", Thou shalt love|strong=\"G0025\"thy neighbour as|strong=\"G5613\"thyself; you|strong=\"G4771\"do|strong=\"G4160\"well|strong=\"G2573\".",
      "9": "But|strong=\"G1161\"if|strong=\"G1487\"you|strong=\"G1487\"have|strong=\"G3588\"respect to|strong=\"G3551\"persons, you|strong=\"G1487\"commit sin|strong=\"G0266\", being reproved|strong=\"G1651\"by|strong=\"G5259\"the|strong=\"G3588\"law|strong=\"G3551\"as|strong=\"G5613\"transgressors|strong=\"G3848\".",
      "10": "And|strong=\"G1161\"whosoever shall keep|strong=\"G5083\"the|strong=\"G3956\"whole|strong=\"G3650\"law|strong=\"G3551\", but|strong=\"G1161\"offend in|strong=\"G1722\"one|strong=\"G1520\"point, is|strong=\"G3588\"become|strong=\"G1096\"guilty|strong=\"G1777\"of|strong=\"G3551\"all|strong=\"G3956\".",
      "11": "For|strong=\"G1063\"he|strong=\"G2532\"that|strong=\"G3004\"said|strong=\"G3004\", Thou shalt not|strong=\"G3756\"commit|strong=\"G3431\"adultery|strong=\"G3431\", said|strong=\"G3004\"also|strong=\"G2532\", Thou shalt not|strong=\"G3756\"kill. Now|strong=\"G1161\"if|strong=\"G1487\"thou do|strong=\"G1096\"not|strong=\"G3756\"commit|strong=\"G3431\"adultery|strong=\"G3431\", but|strong=\"G1161\"shalt kill, thou art become|strong=\"G1096\"a|strong=\"G1096\"transgressor|strong=\"G3848\"of|strong=\"G3551\"the|strong=\"G3588\"law|strong=\"G3551\".",
      "12": "So|strong=\"G2532\"speak|strong=\"G2980\"ye, and|strong=\"G2532\"so|strong=\"G2532\"do|strong=\"G4160\", as|strong=\"G5613\"being to|strong=\"G3195\"be|strong=\"G2532\"judged|strong=\"G2919\"by|strong=\"G1223\"the|strong=\"G1223\"law|strong=\"G3551\"of|strong=\"G1223\"liberty|strong=\"G1657\".",
      "13": "For|strong=\"G1063\"judgment|strong=\"G2920\"without|strong=\"G3361\"mercy|strong=\"G1656\"to|strong=\"G4160\"him|strong=\"G4160\"that|strong=\"G3361\"hath not|strong=\"G3361\"done|strong=\"G4160\"mercy|strong=\"G1656\". And|strong=\"G4160\"mercy|strong=\"G1656\"exalteth itself above judgment|strong=\"G2920\".",
      "14": "What|strong=\"G5101\"shall it|strong=\"G0846\"profit|strong=\"G3786\", my|strong=\"G2192\"brethren|strong=\"G0080\", if|strong=\"G1437\"a|strong=\"G2192\"man|strong=\"G5100\"say|strong=\"G3004\"he|strong=\"G0846\"hath faith|strong=\"G4102\", but|strong=\"G1161\"hath not|strong=\"G3361\"works|strong=\"G2041\"? Shall faith|strong=\"G4102\"be|strong=\"G1410\"able|strong=\"G1410\"to|strong=\"G3004\"save|strong=\"G4982\"him|strong=\"G0846\"?",
      "15": "And|strong=\"G2532\"if|strong=\"G1437\"a|strong=\"G1437\"brother|strong=\"G0080\"or|strong=\"G2228\"sister|strong=\"G0079\"be|strong=\"G2532\"naked|strong=\"G1131\", and|strong=\"G2532\"want daily|strong=\"G2184\"food|strong=\"G5160\":",
      "16": "And|strong=\"G2532\"one|strong=\"G5100\"of|strong=\"G1537\"you|strong=\"G5210\"say|strong=\"G3004\"to|strong=\"G3004\"them|strong=\"G0846\": Go|strong=\"G5217\"in|strong=\"G1722\"peace|strong=\"G1515\", be|strong=\"G2532\"ye warmed|strong=\"G2328\"and|strong=\"G2532\"filled|strong=\"G5526\"; yet|strong=\"G2532\"give|strong=\"G1325\"them|strong=\"G0846\"not|strong=\"G3361\"those|strong=\"G3588\"things|strong=\"G0846\"that|strong=\"G3004\"are|strong=\"G3588\"necessary|strong=\"G2006\"for|strong=\"G1722\"the|strong=\"G3588\"body|strong=\"G4983\", what|strong=\"G5101\"shall|strong=\"G2532\"it|strong=\"G0846\"profit|strong=\"G3786\"?",
      "17": "So|strong=\"G2532\"faith|strong=\"G4102\"also|strong=\"G2532\", if|strong=\"G1437\"it|strong=\"G1437\"have|strong=\"G2192\"not|strong=\"G3361\"works|strong=\"G2041\", is|strong=\"G1510\"dead|strong=\"G3498\"in|strong=\"G2596\"itself|strong=\"G1438\".",
      "18": "But|strong=\"G0235\"some|strong=\"G5100\"man|strong=\"G5100\"will|strong=\"G5100\"say|strong=\"G3004\": Thou hast faith|strong=\"G4102\", and|strong=\"G4102\"I|strong=\"G1473\"have|strong=\"G2192\"works|strong=\"G2041\": shew me|strong=\"G3004\"thy faith|strong=\"G4102\"without|strong=\"G5565\"works|strong=\"G2041\"; and|strong=\"G4102\"I|strong=\"G1473\"will|strong=\"G5100\"shew thee, by|strong=\"G1537\"works|strong=\"G2041\", my|strong=\"G2192\"faith|strong=\"G4102\".",
      "19": "Thou believest that|strong=\"G3754\"there|strong=\"G1510\"is|strong=\"G1510\"one|strong=\"G1520\"God|strong=\"G2316\". Thou dost well|strong=\"G2573\": the|strong=\"G3588\"devils also|strong=\"G2532\"believe|strong=\"G4100\"and|strong=\"G2532\"tremble.",
      "20": "But|strong=\"G1161\"wilt thou know|strong=\"G1097\", O|strong=\"G5599\"vain|strong=\"G2756\"man|strong=\"G0444\", that|strong=\"G3754\"faith|strong=\"G4102\"without|strong=\"G5565\"works|strong=\"G2041\"is|strong=\"G1510\"dead?",
      "21": "Was|strong=\"G3588\"not|strong=\"G3756\"Abraham|strong=\"G0011\"our|strong=\"G0011\"father|strong=\"G3962\"justified|strong=\"G1344\"by|strong=\"G1537\"works|strong=\"G2041\", offering up|strong=\"G0399\"Isaac|strong=\"G2464\"his|strong=\"G0846\"son|strong=\"G5207\"upon|strong=\"G1909\"the|strong=\"G3588\"altar|strong=\"G2379\"?",
      "22": "Seest thou, that|strong=\"G3754\"faith|strong=\"G4102\"did co-operate with|strong=\"G1537\"his|strong=\"G0846\"works|strong=\"G2041\"; and|strong=\"G2532\"by|strong=\"G1537\"works|strong=\"G2041\"faith|strong=\"G4102\"was|strong=\"G3588\"made|strong=\"G5048\"perfect|strong=\"G5048\"?",
      "23": "And|strong=\"G2532\"the|strong=\"G3588\"scripture|strong=\"G1124\"was|strong=\"G3588\"fulfilled|strong=\"G4137\", saying|strong=\"G3004\": Abraham|strong=\"G0011\"believed|strong=\"G4100\"God|strong=\"G2316\", and|strong=\"G2532\"it|strong=\"G0846\"was|strong=\"G3588\"reputed to|strong=\"G1519\"him|strong=\"G0846\"to|strong=\"G1519\"justice|strong=\"G1343\", and|strong=\"G2532\"he|strong=\"G2532\"was|strong=\"G3588\"called|strong=\"G2564\"the|strong=\"G3588\"friend|strong=\"G5384\"of|strong=\"G2316\"God|strong=\"G2316\".",
      "24": "Do|strong=\"G3708\"you|strong=\"G3754\"see|strong=\"G3708\"that|strong=\"G3754\"by|strong=\"G1537\"works|strong=\"G2041\"a|strong=\"G3708\"man|strong=\"G0444\"is|strong=\"G0444\"justified|strong=\"G1344\"; and|strong=\"G2532\"not|strong=\"G3756\"by|strong=\"G1537\"faith|strong=\"G4102\"only|strong=\"G3440\"?",
      "25": "And|strong=\"G2532\"in|strong=\"G2532\"like|strong=\"G3668\"manner|strong=\"G3668\"also|strong=\"G2532\"Rahab|strong=\"G4460\"the|strong=\"G3588\"harlot|strong=\"G4204\", was|strong=\"G3588\"not|strong=\"G3756\"she justified|strong=\"G1344\"by|strong=\"G1537\"works|strong=\"G2041\", receiving the|strong=\"G3588\"messengers|strong=\"G0032\", and|strong=\"G2532\"sending them|strong=\"G1544\"out|strong=\"G1537\"another|strong=\"G2087\"way|strong=\"G3598\"?",
      "26": "For|strong=\"G1063\"even|strong=\"G2532\"as|strong=\"G5618\"the|strong=\"G3588\"body|strong=\"G4983\"without|strong=\"G5565\"the|strong=\"G3588\"spirit|strong=\"G4151\"is|strong=\"G1510\"dead|strong=\"G3498\"; so|strong=\"G2532\"also|strong=\"G2532\"faith|strong=\"G4102\"without|strong=\"G5565\"works|strong=\"G2041\"is|strong=\"G1510\"dead|strong=\"G3498\"."
