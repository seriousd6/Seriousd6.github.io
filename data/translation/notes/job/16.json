{"21":{"tokens":[{"code":"H120","text":"as a man","lemma":"אָדָם","translit":"","pos":"noun","disp":0,"lit":"man (mean","med":"man (mean","tho":"of low degree","range":"ruddy i.e. a human being (an individual or the species, mankind, etc.)"},{"code":"H433","text":"with God","lemma":"אֱלוֹהַּ","translit":"","pos":"noun","disp":0,"lit":"God","med":"God","tho":"god. See H430 (אֱלֹהִים)","range":"a deity or the Deity"},{"code":"H1121","text":"pleadeth for his neighbour","lemma":"בֵּן","translit":"","pos":"adverb","disp":1,"lit":"son","med":"son","tho":"son","range":"a son (as a builder of the family name), in the widest sense (of literal and figurative relationship, including grandson, subject, nation, quality or condition, etc., (like father or brother), etc.)"},{"code":"H1397","text":"for a man","lemma":"גֶּבֶר","translit":"","pos":"adverb","disp":0,"lit":"every one","med":"every one","tho":"man","range":"properly, a valiant man or warrior; generally, a person simply"},{"code":"H3198","text":"O that one might plead","lemma":"יָכַח","translit":"","pos":"pronoun","disp":0,"lit":"appoint","med":"appoint","tho":"argue","range":"to be right (i.e. correct); reciprocal, to argue; causatively, to decide, justify or convict"}],"div":[{"code":"H120","lemma":"אָדָם","lit":"man (mean","tho":"of low degree"},{"code":"H433","lemma":"אֱלוֹהַּ","lit":"God","tho":"god. See H430 (אֱלֹהִים)"},{"code":"H1397","lemma":"גֶּבֶר","lit":"every one","tho":"man"},{"code":"H3198","lemma":"יָכַח","lit":"appoint","tho":"argue"}]},"12":{"tokens":[{"code":"H270","text":"he hath also taken","lemma":"אָחַז","translit":"","pos":"verb","disp":0,"lit":"bar","med":"bar","tho":"catch","range":"to seize (often with the accessory idea of holding in possession)"},{"code":"H4307","text":"for his mark","lemma":"מַטָּרָא","translit":"","pos":"noun","disp":0,"lit":"mark","med":"mark","tho":"prison","range":"a jail (as a guard-house); also an aim (as being closely watched)"},{"code":"H6203","text":"me by my neck",