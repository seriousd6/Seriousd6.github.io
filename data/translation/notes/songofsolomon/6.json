ally  ivory; figuratively, a cliff"},{"code":"H8382","text":"whereof every one beareth twins","lemma":"תָּאַם","translit":"","pos":"verb","disp":0,"lit":"coupled (together)","med":"coupled (together)","tho":"bear twins","range":"to be (causatively, make) twinned, i.e. (figuratively) duplicate or (architectural) jointed"}],"div":[{"code":"H5739","lemma":"עֵדֶר","lit":"drove","tho":"flock"},{"code":"H5927","lemma":"עָלָה","lit":"arise (up)","tho":"at once"},{"code":"H7353","lemma":"רָחֵל","lit":"ewe","tho":"sheep"},{"code":"H7909","lemma":"שַׁכּוּל","lit":"barren","tho":"bereaved (robbed) of children (whelps)"},{"code":"H8127","lemma":"שֵׁן","lit":"crag","tho":"ivory"},{"code":"H8382","lemma":"תָּאַם","lit":"coupled (together)","tho":"bear twins"}],"struct":"contains a main verb"}}