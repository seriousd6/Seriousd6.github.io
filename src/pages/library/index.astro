---
// Phase 4: the document list renders statically (default year-asc sort, real
// links to the static /library/read/<id>/ pages) so the catalog is crawlable
// and usable with JS disabled. lib-browser.js rebuilds the column on load —
// it must apply persisted filters and URL state — replacing these anchors
// with its interactive buttons.
import fs from 'node:fs';
import Base from '../../layouts/Base.astro';

const index = JSON.parse(fs.readFileSync('./data/library/index.json', 'utf8'));
const docs = [...index].sort((a, b) => (a.year || 0) - (b.year || 0));
const TRAD = { ecumenical: 'Ecumenical', patristic: 'Patristic', reformed: 'Reformed',
               lutheran: 'Lutheran', anglican: 'Anglican', baptist: 'Baptist',
               catholic: 'Catholic', medieval: 'Medieval' };
const TYPE = { creed: 'Creed', confession: 'Confession', catechism: 'Catechism',
               father: 'Church Father', council: 'Council', treatise: 'Treatise' };
const yearStr = (y) => !y ? '' : (y < 500 ? `c. ${y} AD` : String(y));
---

<Base entry="lib-browser" title={"Library — Kingdom Bible Study"} description={"Christian library — browse creeds, confessions, catechisms, and church fathers with filtering and an inline reader."} bodyAttrs={{"class":"lb-browser-page"}}>
<Fragment slot="head-end">
<link rel="stylesheet" href="../assets/css/library.css"><link rel="stylesheet" href="../assets/css/lib-browser.css">
</Fragment>
<main>
    <div class="container lb-page">

      <div class="lb-header">
        <div class="lb-header-row">
          <h1 class="lb-title">Library</h1>
          <a class="lb-history-link" href="progress/">📚 Reading History</a>
        </div>
        <p class="lb-sub">Creeds · Confessions · Catechisms · Church Fathers</p>
      </div>

      <div class="lb-layout" id="lb-container">

        <!-- Column 1: Filter panel (tradition / era / type — collapsible) -->
        <div class="lb-col lb-col--filters">
          <div class="lb-col-label">
            <span class="lb-col-label-text">Filter</span>
            <button class="lb-col-toggle" id="lb-filter-toggle" aria-label="Collapse filters">‹</button>
          </div>
          <div id="lb-filter-panel">
            <!-- filter chips injected by JS -->
          </div>
        </div>

        <!-- Column 2: Authors panel (collapsible) -->
        <div class="lb-col lb-col--authors">
          <div class="lb-col-label">
            <span class="lb-col-label-text">Authors</span>
            <button class="lb-col-toggle" id="lb-authors-toggle" aria-label="Collapse authors">‹</button>
          </div>
          <div id="lb-authors">
            <!-- author rows injected by JS -->
          </div>
        </div>

        <!-- Column 3: Document list (collapsible) -->
        <div class="lb-col lb-col--list">
          <div class="lb-col-label lb-list-header">
            <span class="lb-col-label-text">Documents</span>
            <span id="lb-list-count"></span>
            <button class="lb-col-toggle" id="lb-list-toggle" aria-label="Collapse document list">‹</button>
          </div>
          <div id="lb-list-controls">
            <!-- sort control injected by JS -->
          </div>
          <div id="lb-list">
            {docs.map(doc => (
              <a class="lb-list-item" href={`/library/read/${doc.id}/`} title={doc.title}>
                <span class={`lb-item-abbrev lb-item-abbrev--${doc.tradition}`}>{doc.abbrev}</span>
                <span class="lb-item-body">
                  <span class="lb-item-title">{doc.title}{doc.volume_label && doc.volume !== 0 && <span class="lb-item-vol-badge">{doc.volume_label}</span>}</span>
                  <span class="lb-item-meta">{[yearStr(doc.year), TRAD[doc.tradition] || doc.tradition, TYPE[doc.type] || doc.type].filter(Boolean).join(' · ')}</span>
                  {doc.desc && <span class="lb-item-desc">{doc.desc}</span>}
                </span>
              </a>
            ))}
          </div>
        </div>

        <!-- Column 4: Inline reader -->
        <div class="lb-col lb-col--reader">
          <div class="lb-col-label">Reader</div>
          <div id="lb-reader">
            <p class="lb-reader-placeholder">← Select a document</p>
          </div>
        </div>

      </div><!-- /.lb-layout -->

    </div><!-- /.container -->
  </main>
</Base>
