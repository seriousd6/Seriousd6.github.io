---
import Base from '../../layouts/Base.astro';
---

<Base entry="wordcloud" title={"Word Cloud — Kingdom Bible Study"} description={"Biblical word cloud — explore the most theologically significant words in Scripture, sized by frequency across the whole Bible or any section."} footer={false}>
<Fragment slot="head-end">
<link rel="stylesheet" href="../assets/css/wordcloud.css">
</Fragment>
<main>
    <div class="container wc-page">

      <a class="hist-back-link" href="../search/?tab=wordcloud" id="explore-back-link" target="_top" hidden="">← Explore</a>
      <header class="wc-header">
        <h1 class="wc-h1">Biblical Word Cloud</h1>
        <p class="wc-subtitle">The most-used words in Scripture, sized by frequency. Each word maps to its underlying Hebrew or Greek lemma — so "love", "loved", and "loving" count together. Click any word for the Strong's entry.</p>
      </header>

      <div id="wc-container">

        <div class="wc-controls">
          <div id="wc-scope-bar" class="wc-scope-bar" role="group" aria-label="Filter by scope"></div>
          <button id="wc-proper-toggle" class="wc-proper-toggle wc-proper-toggle--on">Hide names</button>
        </div>

        <div class="wc-cloud-wrap">
          <div id="wc-svg-wrap">
            <div class="wc-loading">Loading word cloud…</div>
          </div>

          <!-- Legend -->
          <div class="wc-legend" aria-label="Color legend">
            <div class="wc-legend-item" id="wc-legend-heb">
              <span class="wc-legend-swatch" style="background:#b45309"></span>
              Hebrew (OT)
            </div>
            <div class="wc-legend-item" id="wc-legend-grk">
              <span class="wc-legend-swatch" style="background:#1e3a5f"></span>
              Greek (NT)
            </div>
            <div class="wc-legend-item" style="margin-left:auto;font-style:italic;color:var(--color-muted)">
              Larger = more frequent · OT: stone tablets · NT: cross
            </div>
          </div>
        </div>

        <!-- Detail panel (shown when a word is clicked) -->
        <div id="wc-detail" class="wc-detail" hidden="">
          <button id="wc-detail-close" class="wc-detail-close" aria-label="Close">✕</button>
          <h2 class="wc-detail-gloss" id="wc-detail-gloss"></h2>
          <p class="wc-detail-id" id="wc-detail-id"></p>
          <p class="wc-detail-lemma" id="wc-detail-lemma"></p>
          <p class="wc-detail-count" id="wc-detail-count"></p>
          <div id="wc-detail-def"></div>
          <div class="wc-detail-testament" id="wc-detail-testament" style="font-size:0.8rem;color:var(--color-muted);margin-bottom:0.75rem"></div>
          <a id="wc-detail-word-link" class="wc-detail-word-link" href="#" target="_blank">
            View in Word Study →
          </a>
        </div>

      </div><!-- #wc-container -->

    </div>
  </main>
</Base>
