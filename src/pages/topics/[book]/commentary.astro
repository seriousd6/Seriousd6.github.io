---
// Per-book Commentary — Tier 3 of the Studies tool (the capstone).
//
// One static page per book that has data/commentary/exposition/<book>/_book.json,
// generated from that overview plus each data/commentary/exposition/<book>/<ch>.json
// (section -> verse-by-verse). Route: /topics/<book>/commentary.html — the URL
// contract already reserved in data/books-content.json. This dynamic [book] route
// coexists with the five literal topics/<book>/ dirs (which have no commentary.astro),
// so it may include those books too with no conflict.
//
// Render-then-enhance: the prose is real HTML with <a class="ref" data-ref> hotlinks
// that core-boot's wireRefLinks (entry="generic") turns into verse-modal triggers.
// Styling: book-study.css supplies the genre-tinted chrome (tier nav, hero, facts);
// commentary.css adds the illuminated-on-paper capstone treatment.
//
// See docs/agents/book-commentary-loop.md for the data schema this reads and
// docs/plans/book-capstone-plan.md for how the three tiers fit together.
import fs from 'node:fs';
import path from 'node:path';
import Base from '../../../layouts/Base.astro';

// NOTE: getStaticPaths runs in an isolated scope (Astro hoists it before render),
// so its helpers/constants must live INSIDE it — only module imports are visible.
export async function getStaticPaths() {
  const EXPO_ROOT = path.resolve('./data/commentary/exposition');
  const readJSON = (p) => {
    try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch (e) { return null; }
  };
  const books = readJSON(path.resolve('./data/bible/books.json')) || [];
  const content = readJSON(path.resolve('./data/books-content.json')) || { books: {} };
  const out = [];
  for (const b of books) {
    const dir = path.join(EXPO_ROOT, b.id);
    const meta = readJSON(path.join(dir, '_book.json'));
    if (!meta) continue;                       // only books with a commentary overview
    const chapters = [];
    for (let ch = 1; ch <= b.chapters; ch++) {
      const chData = readJSON(path.join(dir, `${ch}.json`));
      if (!chData) continue;
      const sections = Object.keys(chData)
        .sort((a, z) => parseInt(a, 10) - parseInt(z, 10))
        .map(k => ({ start: k, ...chData[k] }));
      chapters.push({ ch, sections });
    }
    const intro = readJSON(path.resolve('./data/books/introductions', `${b.id}.json`));
    const bc = (content.books && content.books[b.id]) || {};
    out.push({
      params: { book: b.id },
      props: {
        book: b, meta, chapters, intro,
        tiers: {
          guide:    !!(bc.guide && bc.guide.exists),
          deepDive: !!(bc.deep_dive && bc.deep_dive.exists),
        },
      },
    });
  }
  return out;
}

const { book, meta, chapters, intro, tiers } = Astro.props;

// books.json genre strings ("pauline epistle", "law", …) → the bk-<genre> classes
// that book-study.css defines. _book.json may name its own genre directly.
function bkGenre(g) {
  g = (g || '').toLowerCase();
  if (/torah|law|pentateuch/.test(g))      return 'torah';
  if (/gospel/.test(g))                    return 'gospel';
  if (/apocalyp|revelation/.test(g))       return 'apocalyptic';
  if (/prophe/.test(g))                    return 'prophecy';
  if (/wisdom|poetry|psalm/.test(g))       return 'wisdom';
  if (/epistle|letter/.test(g))            return 'epistle';
  if (/history|acts|narrative/.test(g))    return 'history';
  return 'epistle';
}
const genre = (meta.genre && /^(torah|history|wisdom|prophecy|gospel|epistle|apocalyptic)$/.test(meta.genre))
  ? meta.genre : bkGenre(book.genre);
const testClass = book.testament === 'OT' ? 'bk-ot' : 'bk-nt';
const bodyClass = `${testClass} bk-${genre} commentary-page`;
const testamentLabel = book.testament === 'OT' ? 'Old Testament' : 'New Testament';
const GENRE_LABEL = {
  torah: 'Torah', history: 'History', wisdom: 'Wisdom & Poetry', prophecy: 'Prophecy',
  gospel: 'Gospel', epistle: 'Epistle', apocalyptic: 'Apocalyptic',
};
const genreLabel = GENRE_LABEL[genre] || 'Scripture';
const ov = meta.overview || {};
const title = `${book.name} — Commentary — Kingdom Bible Study`;
const description = `Verse-by-verse commentary on ${book.name} — the full treatment, section by section, drawing on the Cloud of Witnesses and attributed scholarship. AI-assisted.`;
const readerHref = (ref) => `/read/?ref=${encodeURIComponent(ref)}`;
const multiChapter = chapters.length > 1;
---

<Base entry="generic" title={title} description={description} bodyAttrs={{ class: bodyClass }} footer={false}>
<Fragment slot="head-end">
<link rel="stylesheet" href="../../assets/css/book-study.css"><link rel="stylesheet" href="../../assets/css/commentary.css">
</Fragment>
<main>

  <nav class="bk-tier-nav" aria-label="Study tiers" data-tier="commentary">
    <div class="bk-tier-nav__inner">
      <a class="bk-tier-nav__book" href={tiers.guide ? '.' : readerHref(book.name)}>{book.name}</a>
      <ol class="bk-tier-nav__list">
        <li data-tier-item="guide" hidden={!tiers.guide}><a class="bk-tier-nav__link" href="index.html"><span class="bk-tier-nav__icon">◎</span><span class="bk-tier-nav__label">Book Guide</span><span class="bk-tier-nav__sub">Overview</span></a></li>
        <li data-tier-item="deep-dive" hidden={!tiers.deepDive}><a class="bk-tier-nav__link" href="deep-dive.html"><span class="bk-tier-nav__icon">⊕</span><span class="bk-tier-nav__label">Bible Study Guide</span><span class="bk-tier-nav__sub">Group sessions</span></a></li>
        <li data-tier-item="commentary"><a class="bk-tier-nav__link" href="commentary.html" aria-current="page"><span class="bk-tier-nav__icon">❧</span><span class="bk-tier-nav__label">Commentary</span><span class="bk-tier-nav__sub">Verse by verse</span></a></li>
      </ol>
      <a class="bk-tier-nav__back" href="../../studies/">← All Studies</a>
    </div>
  </nav>

  <div class="container commentary">

    <header class="bk-hero bkc-hero">
      <div class="bk-hero__inner">
        <div class="bk-hero__badges">
          <span class="bk-badge bk-badge--testament">{testamentLabel}</span>
          <span class="bk-badge bk-badge--genre">{genreLabel}</span>
        </div>
        <p class="bkc-hero__eyebrow">Commentary</p>
        <h1 class="bk-hero__title">{book.name}</h1>
        <p class="bk-hero__subtitle">The full treatment — section by section, verse by verse, with the Cloud of Witnesses and attributed scholarship.</p>
      </div>
    </header>

    <div class="bkc-meta-row">
      <span class="bkc-aibadge">✦ AI-assisted · attributed sources · <a href="/about/">details</a></span>
    </div>

    {intro && (intro.author || intro.date || intro.setting || intro.purpose) && (
      <div class="bk-facts bkc-facts">
        <dl class="bk-facts__grid">
          {intro.author  && <Fragment><dt>Author</dt><dd>{intro.author}</dd></Fragment>}
          {intro.date    && <Fragment><dt>Date</dt><dd>{intro.date}</dd></Fragment>}
          {intro.setting && <Fragment><dt>Setting</dt><dd>{intro.setting}</dd></Fragment>}
          {intro.purpose && <Fragment><dt>Purpose</dt><dd>{intro.purpose}</dd></Fragment>}
        </dl>
      </div>
    )}

    <section class="bkc-overview" aria-label="Book overview">
      <div class="bkc-rule" aria-hidden="true"><span class="bkc-rule__mark">✦</span></div>
      <div class="bkc-overview__grid">
        {ov.argument && <div class="bkc-od"><span class="bkc-od__label">The Argument</span><div class="bkc-od__body" set:html={ov.argument} /></div>}
        {ov.occasion && <div class="bkc-od"><span class="bkc-od__label">Occasion</span><div class="bkc-od__body" set:html={ov.occasion} /></div>}
        {ov.theology && <div class="bkc-od"><span class="bkc-od__label">Theology</span><div class="bkc-od__body" set:html={ov.theology} /></div>}
        {ov.christ   && <div class="bkc-od"><span class="bkc-od__label">Christ in {book.name}</span><div class="bkc-od__body" set:html={ov.christ} /></div>}
      </div>
      {ov.structure && ov.structure.length > 0 && (
        <ol class="bkc-structure">
          {ov.structure.map(s => (
            <li class="bkc-structure__item">
              <span class="bkc-structure__range">{s.range}</span>
              <span class="bkc-structure__label">{s.label}</span>
              {s.gist && <span class="bkc-structure__gist">{s.gist}</span>}
            </li>
          ))}
        </ol>
      )}
    </section>

    {chapters.map(chp => (
      <section class="bkc-chapter" id={`ch-${chp.ch}`}>
        {multiChapter && (
          <div class="bkc-chapter__head">
            <span class="bkc-chapter__num">{book.name} {chp.ch}</span>
            <a class="bkc-chapter__read ref" data-ref={`${book.name} ${chp.ch}`} href={readerHref(`${book.name} ${chp.ch}`)}>read the chapter →</a>
          </div>
        )}
        {chp.sections.map((sec, i) => (
          <article class="bkc-section" id={`ch-${chp.ch}-v-${sec.start}`}>
            <h2 class="bkc-rubric">
              <span class="bkc-rubric__mark" aria-hidden="true">❧</span>
              <span class="bkc-rubric__label">{sec.pericope_label}</span>
              {sec.range && <a class="bkc-rubric__ref ref" data-ref={`${book.name} ${chp.ch}:${sec.range}`} href={readerHref(`${book.name} ${chp.ch}:${sec.range}`)}>{book.name} {chp.ch}:{sec.range}</a>}
            </h2>

            {sec.exposition && (
              <div class={`bkc-exposition${i === 0 ? ' bkc-exposition--lead' : ''}`} set:html={sec.exposition} />
            )}

            {sec.verses && sec.verses.length > 0 && (
              <dl class="bkc-verses">
                {sec.verses.map(v => (
                  <div class="bkc-verse">
                    <dt class="bkc-verse__num"><a class="ref" data-ref={`${book.name} ${chp.ch}:${v.v}`} href={readerHref(`${book.name} ${chp.ch}:${v.v}`)}>v.{v.v}</a></dt>
                    <dd class="bkc-verse__note" set:html={v.note} />
                  </div>
                ))}
              </dl>
            )}

            {((sec.witnesses && sec.witnesses.length) || (sec.external && sec.external.length)) && (
              <aside class="bkc-voices">
                <div class="bkc-voices__head">Voices on this section</div>
                {(sec.witnesses || []).map(w => (
                  <div class="bkc-voice">
                    <span class="bkc-voice__name">{w.voice}</span>
                    {w.tradition && <span class="bkc-voice__trad">{w.tradition}</span>}
                    {w.point && <span class="bkc-voice__point" set:html={w.point} />}
                  </div>
                ))}
                {(sec.external || []).map(x => (
                  <div class="bkc-voice bkc-voice--external">
                    <span class="bkc-voice__name">{x.name}{x.work && <span class="bkc-voice__work">, {x.work}{x.year ? ` (${x.year})` : ''}</span>}</span>
                    <span class="bkc-voice__trad bkc-voice__trad--ext">external</span>
                    {x.point && <span class="bkc-voice__point" set:html={x.point} />}
                  </div>
                ))}
              </aside>
            )}

            {sec.application && (
              <div class="bkc-application">
                <span class="bkc-application__label">For today</span>
                <div class="bkc-application__body" set:html={sec.application} />
              </div>
            )}
          </article>
        ))}
      </section>
    ))}

    {(meta.witnesses && meta.witnesses.length > 0) || (meta.external && meta.external.length > 0) ? (
      <section class="bkc-sources" aria-label="Sources drawn on">
        <div class="bkc-rule" aria-hidden="true"><span class="bkc-rule__mark">✦</span></div>
        <h2 class="bkc-sources__head">Sources drawn on</h2>
        {meta.witnesses && meta.witnesses.length > 0 && (
          <p class="bkc-sources__group"><span class="bkc-sources__label">Cloud of Witnesses</span> {meta.witnesses.join(' · ')}</p>
        )}
        {meta.external && meta.external.length > 0 && (
          <ul class="bkc-sources__ext">
            {meta.external.map(x => (
              <li><strong>{x.name}</strong>{x.work && <span>, {x.work}</span>}{x.year && <span> ({x.year})</span>}{x.note && <span> — {x.note}</span>}</li>
            ))}
          </ul>
        )}
        <p class="bkc-sources__note">This commentary is AI-assisted: it distils the site's Cloud-of-Witnesses catena and names external scholarship in paraphrase — no source is reproduced verbatim. See <a href="/about/">Citation &amp; Provenance</a>.</p>
      </section>
    ) : null}

  </div><!-- /.commentary -->
</main>
</Base>
