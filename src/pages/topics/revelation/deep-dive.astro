/* =====================================================================
   Render chapter accordion
===================================================================== */
function renderChapters() {
  const host = document.getElementById('chapterList');
  if (!host) return;
  const roman = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX','XXI','XXII'];
  host.innerHTML = chapters.map(c => `
    <details class="chapter">
      <summary>
        <div class="ch-num">${roman[c.n-1]}</div>
        <div class="ch-info">
          <div class="ch-title">${c.title}</div>
          <div class="ch-tag">${c.tag}</div>
        </div>
      </summary>
      <div class="ch-body">
        <h4>Summary</h4>
        <p>${c.summary}</p>
        <h4>Key Verses</h4>
        <p style="font-family: var(--smallcaps); letter-spacing: 0.06em; color: var(--oxblood); font-size: 15px;">${c.keyverses}</p>
        <h4>Principal Images</h4>
        <p style="font-style: italic; color: var(--ink-soft);">${c.images}</p>
        <h4>Four Lenses on This Chapter</h4>
        <div class="grid-2">
          <div class="card school-card preterist"><div class="school-name" style="font-size: 14px;">Preterist</div><p style="margin: 8px 0 0; font-size: 15px;">${c.notes.preterist}</p></div>
          <div class="card school-card historicist"><div class="school-name" style="font-size: 14px;">Historicist</div><p style="margin: 8px 0 0; font-size: 15px;">${c.notes.historicist}</p></div>
          <div class="card school-card futurist"><div class="school-name" style="font-size: 14px;">Futurist</div><p style="margin: 8px 0 0; font-size: 15px;">${c.notes.futurist}</p></div>
          <div class="card school-card idealist"><div class="school-name" style="font-size: 14px;">Idealist</div><p style="margin: 8px 0 0; font-size: 15px;">${c.notes.idealist}</p></div>
        </div>
      </div>
    </details>
  `).join('');
}
renderChapters();

/* =====================================================================
   Section navigation
===================================================================== */
const navLinks = document.querySelectorAll('a.navlink');
const sections = document.querySelectorAll('section.section');

function showSection(id) {
  sections.forEach(s => s.classList.toggle('is-active', s.dataset.section === id));
  navLinks.forEach(l => l.classList.toggle('active', l.dataset.target === id));
  window.scrollTo({ top: 0, behavior: 'instant' });
  // close mobile nav
  document.getElementById('nav').classList.remove('open');
}

navLinks.forEach(link => {
  link.addEventListener('click', e => {
    e.preventDefault();
    const id = link.dataset.target;
    showSection(id);
    history.replaceState(null, '', '#' + id);
  });
});

// initial section from hash
const initial = location.hash.replace('#','');
if (initial && document.querySelector(`section[data-section="${initial}"]`)) {
  showSection(initial);
} else {
  showSection('overview');
}

/* =====================================================================
   Tab logic (works for any .tabs followed by .tab-panel siblings)
===================================================================== */
function initTabs(containerId) {
  const tabs = document.getElementById(containerId);
  if (!tabs) return;
  const buttons = tabs.querySelectorAll('button');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      buttons.forEach(b => b.classList.toggle('active', b === btn));
      // find sibling panels (all .tab-panel after this .tabs in the same parent)
      let sib = tabs.nextElementSibling;
      while (sib) {
        if (sib.classList && sib.classList.contains('tab-panel')) {
          sib.classList.toggle('active', sib.dataset.panel === target);
        } else if (sib.classList && sib.classList.contains('tabs')) {
          break;
        }
        sib = sib.nextElementSibling;
      }
    });
  });
}
initTabs('schoolTabs');
initTabs('millTabs');

/* =====================================================================
   Sidebar search filter
===================================================================== */
const searchInput = document.getElementById('navSearch');
if (searchInput) {
  searchInput.addEventListener('input', e => {
    const q = e.target.value.trim().toLowerCase();
    document.querySelectorAll('aside.nav a.navlink').forEach(a => {
      const txt = a.textContent.toLowerCase();
      a.parentElement.style.display = (!q || txt.includes(q)) ? '' : 'none';
    });
  });
}

/* =====================================================================
   Sidebar toggle
===================================================================== */
var _sidebarBtn = document.getElementById('topic-sidebar-toggle');
if (window.innerWidth <= 1000) {
  document.body.classList.remove('sidebar-open');
  if (_sidebarBtn) _sidebarBtn.setAttribute('aria-expanded', 'false');
}
if (_sidebarBtn) {
  _sidebarBtn.addEventListener('click', function() {
    var isOpen = document.body.classList.toggle('sidebar-open');
    _sidebarBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
}
// Close sidebar on nav click when narrow (overlay mode)
document.querySelectorAll('aside.nav a.navlink').forEach(function(a) {
  a.addEventListener('click', function() {
    if (window.innerWidth <= 1000) {
      document.body.classList.remove('sidebar-open');
      if (_sidebarBtn) _sidebarBtn.setAttribute('aria-expanded', 'false');
    }
  });
});
</script>
