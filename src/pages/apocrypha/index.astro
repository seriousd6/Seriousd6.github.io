---
import Base from '../../layouts/Base.astro';
---

<Base title={"Apocrypha — Kingdom Bible Study"} description={"Read complete Catholic, Orthodox, and LXX Bible versions including the full deuterocanonical books — Douay-Rheims, WEB-CE, KJV Apocrypha, Brenton's LXX."} bodyAttrs={{"class":"reader-page"}}>
<Fragment slot="head">
<meta property="og:type" content="website"><meta property="og:title" content="Apocrypha — Kingdom Bible Study"><meta property="og:description" content="Complete Catholic, Orthodox, and LXX Bible editions including Tobit, Judith, Sirach, Wisdom, Maccabees, and all deuterocanonical books."><meta name="twitter:card" content="summary"><meta name="twitter:title" content="Apocrypha — Kingdom Bible Study"><meta name="twitter:description" content="Full Catholic, Orthodox, and LXX Bible — Douay-Rheims, WEB-CE, KJV Apocrypha, Brenton's LXX.">
</Fragment>
<Fragment slot="head-end">
<link rel="stylesheet" href="../assets/css/reader.css"><link rel="stylesheet" href="../assets/css/apocrypha.css">
</Fragment>
<main>
    <div class="container">
      <div class="apoc-layout">

        <!-- Left sidebar: chapter navigation -->
        <nav id="apoc-sidebar" class="apoc-sidebar" aria-label="Chapter list"></nav>

        <!-- Main content -->
        <div class="apoc-main">

          <!-- Canon filter + browse controls -->
          <div class="apoc-controls">
            <div class="apoc-controls-top">
              <span class="apoc-controls-label" id="apoc-controls-label">Apocrypha</span>
              <div id="apoc-canon-bar" class="apoc-canon-bar" role="group" aria-label="Filter by tradition"></div>
            </div>
            <div class="apoc-browse-bar">
              <select id="apoc-book-select" class="apoc-select apoc-select--book" aria-label="Select book"></select>
              <select id="apoc-ch-select" class="apoc-select apoc-select--ch" aria-label="Select chapter" disabled=""></select>
              <select id="apoc-ver-select" class="apoc-select apoc-select--ver" aria-label="Select translation"></select>
            </div>
          </div>

          <!-- Chapter text -->
          <div id="apoc-reader-results" class="apoc-results">
            <p class="apoc-msg">Select a book to begin reading.</p>
          </div>

        </div>
      </div>
    </div>
  </main>
</Base>
