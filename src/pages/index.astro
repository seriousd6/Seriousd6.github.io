---
import Base from '../layouts/Base.astro';
import DailyHome from '../components/DailyHome.astro';
---

<Base entry="home" title={"Kingdom Bible Study — Daily"} description={"Daily Bible reading, verse of the day, and devotional."}>
<Fragment slot="head">
<meta property="og:type" content="website"><meta property="og:title" content="Kingdom Bible Study — Daily"><meta property="og:description" content="Daily Bible reading, verse of the day, and devotional."><meta name="twitter:card" content="summary"><meta name="twitter:title" content="Kingdom Bible Study — Daily"><meta name="twitter:description" content="Daily Bible reading, verse of the day, and devotional.">
<script is:inline>
  /* Desk-as-home: wide screens land in the work surface (/desk/); phones and
     embedded frames keep this daily page. Escape hatches: ?classic=1 keeps
     the daily page on desktop, localStorage bsw_desk_home='0' disables the
     redirect entirely (future Settings toggle). Runs pre-paint. */
  (function () {
    try {
      var framed; try { framed = window.self !== window.top; } catch (e) { framed = true; }
      if (!framed && window.innerWidth >= 1000 &&
          !/[?&](classic|minimal)=1/.test(location.search) &&
          localStorage.getItem('bsw_desk_home') !== '0') {
        location.replace('/desk/');
      }
    } catch (e) {}
  })();
</script>
</Fragment>
<Fragment slot="head-end">
<link rel="stylesheet" href="/assets/css/daily.css">
</Fragment>
<DailyHome />
</Base>
