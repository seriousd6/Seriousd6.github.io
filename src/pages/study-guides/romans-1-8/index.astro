            <tr><td><a href="#s-5">5</a></td><td>Dead to Sin, Alive to God</td><td>Romans 6</td></tr>
            <tr><td><a href="#s-6">6</a></td><td>The Law and the Flesh</td><td>Romans 7</td></tr>
            <tr><td><a href="#s-7">7</a></td><td>Life in the Spirit</td><td>Romans 8:1–17</td></tr>
