<script is:inline="">
  (function () {
    var tabs      = Array.from(document.querySelectorAll('.sg-tab-btn'));
    var sections  = Array.from(document.querySelectorAll('.tg-section'));
    var dividers  = Array.from(document.querySelectorAll('.sg-divider'));
    var further   = document.querySelector('.tg-reading');
    var tabNav    = document.querySelector('.sg-tabs');
    var validIds  = sections.map(function (s) { return s.id; });

    function activate(id, scroll) {
      // hide all sections and all visual separators
      sections.forEach(function (s) { s.hidden = true; });
      dividers.forEach(function (d) { d.hidden = true; });

      // further-study block shown alongside ch-13 only
      if (further) further.hidden = (id !== 'ch-13');

      // reveal the target section
      var target = document.getElementById(id);
      if (target) target.hidden = false;

      // sync tab active state
      tabs.forEach(function (t) {
        t.classList.toggle('is-active', t.dataset.target === id);
      });

      // keep the active tab visible in the scrollable bar
      var activeTab = document.querySelector('.sg-tab-btn.is-active');
      if (activeTab) activeTab.scrollIntoView({ block: 'nearest', inline: 'nearest' });

      // update the URL hash so the link is bookmarkable / shareable
      if (history.replaceState) history.replaceState(null, '', '#' + id);

      // on explicit tab click, scroll the tab bar to the top of the viewport
      if (scroll && tabNav) tabNav.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // wire tab buttons
    tabs.forEach(function (t) {
      t.addEventListener('click', function () { activate(t.dataset.target, true); });
    });

