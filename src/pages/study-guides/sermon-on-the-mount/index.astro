    (function () {
      var tabs   = document.querySelectorAll('.sg-tab-btn');
      var active = null;
      function activate(btn) {
        if (active) active.classList.remove('is-active');
        btn.classList.add('is-active');
        active = btn;
        var target = document.getElementById(btn.dataset.target);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      tabs.forEach(function (btn) { btn.addEventListener('click', function () { activate(btn); }); });
      var sections = Array.from(document.querySelectorAll('.tg-section[id]'));
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            var btn = document.querySelector('.sg-tab-btn[data-target="' + e.target.id + '"]');
            if (btn) { if (active) active.classList.remove('is-active'); btn.classList.add('is-active'); active = btn; }
          }
        });
      }, { rootMargin: '-30% 0px -60% 0px' });
      sections.forEach(function (s) { io.observe(s); });
      if (tabs.length) { tabs[0].classList.add('is-active'); active = tabs[0]; }
    }());
  </script>
