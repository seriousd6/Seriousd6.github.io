---
import Base from '../../layouts/Base.astro';
---

<Base title={"Explore — Kingdom Bible Study"} description={"Explore the Bible — search by keyword or phrase, browse topics, study guides, dictionary, and word cloud."}>
<Fragment slot="head-end">
<style is:inline="">
    /* ── Explore hub iframe panels ───────────────────────────── */
    /* Panels sit outside .container so they span the full available width
       (the sidebar pushes them right, but no max-width cap applies). */
    .explore-hub-panel { display: none; }
    .explore-hub-panel.explore-hub-panel--active { display: block; }
    .explore-hub-iframe {
      width: 100%;
      border: none;
      height: calc(100vh - 90px);
      display: block;
    }
    @media (max-width: 1023px) {
      .explore-hub-iframe { height: calc(100vh - var(--topbar-h, 48px) - 48px); }
    }
  </style>
</Fragment>
<main>
    <div class="container">

      <h1>Explore</h1>

      <!-- Top-level hub tabs — search tabs + 4 browse tabs -->
      <div class="search-tab-row" role="tablist" aria-label="Explore sections">
        <button class="search-tab search-tab--active" data-search-tab="verse" role="tab" aria-selected="true" type="button">🔍 Verse Search</button>
        <button class="search-tab" data-search-tab="explore" role="tab" aria-selected="false" type="button">✦ Omni-search</button>
        <button class="search-tab" data-search-tab="topics" role="tab" aria-selected="false" type="button">📑 Topics</button>
        <button class="search-tab" data-search-tab="guides" role="tab" aria-selected="false" type="button">📖 Study Guides</button>
        <button class="search-tab" data-search-tab="dictionary" role="tab" aria-selected="false" type="button">📘 Dictionary</button>
        <button class="search-tab" data-search-tab="wordcloud" role="tab" aria-selected="false" type="button">☁ Word Cloud</button>
      </div>

      <!-- Search panel: verse search + omni-search (hidden when a browse tab is active) -->
      <div id="search-search-panel">

        <div class="search-page-input-wrap">
          <div class="search-input-row">
            <input id="bsw-search-input" class="search-page-input" type="search" placeholder="e.g. love, in the beginning, &quot;the word was God&quot;" autocomplete="off" spellcheck="false">
            <button id="bsw-search-go" class="search-go-btn" type="button" aria-label="Run search">Search</button>
          </div>

          <!-- Verse-mode context controls -->
          <div id="bsw-verse-ctx">
            <div class="search-filter-row" id="bsw-search-filter-row">
              <button class="search-filter-toggle" id="bsw-filter-toggle" type="button">Filter ▾</button>
              <span class="search-filter-summary" id="bsw-filter-summary"></span>
            </div>
            <div class="search-filter-panel" id="bsw-filter-panel" hidden="">
              <div class="search-filter-group">
                <button class="search-mode-btn search-mode-btn--active" data-testament="all" type="button">All</button>
                <button class="search-mode-btn" data-testament="ot" type="button">Old Testament</button>
                <button class="search-mode-btn" data-testament="nt" type="button">New Testament</button>
                <select class="search-filter-book" id="bsw-book-filter" aria-label="Filter by book">
                  <option value="">All books</option>
                </select>
              </div>
            </div>
            <div class="search-sort-row" id="bsw-search-sort-row" hidden="">
              <span class="search-sort-label">Sort:</span>
              <button class="search-mode-btn" data-sort="relevance" type="button">Relevance</button>
              <button class="search-mode-btn" data-sort="canonical" type="button">Bible order</button>
            </div>
          </div>

          <!-- Explore-mode context controls -->
          <div id="bsw-explore-ctx" hidden="">
            <div class="search-explore-filters">
              <span class="search-explore-label">Show:</span>
              <button class="search-explore-filter search-explore-filter--active" data-explore-filter="all" type="button">All</button>
              <button class="search-explore-filter" data-explore-filter="verses" type="button">Verses</button>
              <button class="search-explore-filter" data-explore-filter="sections" type="button">Sections</button>
              <button class="search-explore-filter" data-explore-filter="words" type="button">Word Studies</button>
              <button class="search-explore-filter" data-explore-filter="topics" type="button">Topics</button>
              <button class="search-explore-filter" data-explore-filter="torrey" type="button">Torrey</button>
              <button class="search-explore-filter" data-explore-filter="dictionary" type="button">Dictionary</button>
              <button class="search-explore-filter" data-explore-filter="names" type="button">Names</button>
              <button class="search-explore-filter" data-explore-filter="library" type="button">Library</button>
              <button class="search-explore-filter" data-explore-filter="guides" type="button">Study Guides</button>
            </div>
            <div id="bsw-explore-output"></div>
          </div>

          <p class="search-page-status" id="bsw-search-status"></p>
        </div>

        <div id="bsw-search-output" class="search-page-results" role="list"></div>

      </div><!-- /#search-search-panel -->

    </div><!-- /.container -->

    <!-- Browse hub panels — outside .container so they span full available width -->
    <div id="search-hub-topics" class="explore-hub-panel">
      <iframe class="explore-hub-iframe" data-src="../topics/?minimal=1" title="Topics"></iframe>
    </div>
    <div id="search-hub-guides" class="explore-hub-panel">
      <iframe class="explore-hub-iframe" data-src="../study-guides/?minimal=1" title="Study Guides"></iframe>
    </div>
    <div id="search-hub-dictionary" class="explore-hub-panel">
      <iframe class="explore-hub-iframe" data-src="../dictionary/?minimal=1" title="Dictionary"></iframe>
    </div>
    <div id="search-hub-wordcloud" class="explore-hub-panel">
      <iframe class="explore-hub-iframe" data-src="../wordcloud/?minimal=1" title="Word Cloud"></iframe>
    </div>

  </main>
</Base>
