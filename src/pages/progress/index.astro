---
import Base from '../../layouts/Base.astro';
---

<Base title={"Reading Progress — Kingdom Bible Study"} description={"Track which chapters of the Bible you have read."}>
<Fragment slot="head-end">
<style is:inline="">
    .prog-back-link { display:inline-block; font-family:var(--font-ui); font-size:.8rem; color:var(--color-muted); text-decoration:none; padding:.4rem 0 .2rem; margin-bottom:.5rem; }
    .prog-back-link:hover { color:var(--color-primary); }
    .prog-page { max-width: 860px; margin: 0 auto; padding-bottom: 3rem; }
    .prog-page h1 { font-size: 1.6rem; margin-bottom: 0.2rem; }
    .prog-subtitle { color: var(--color-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }

    /* Summary bar */
    .prog-summary {
      display: flex; gap: 1.5rem; flex-wrap: wrap;
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 8px; padding: 0.9rem 1.2rem; margin-bottom: 1.5rem;
    }
    .prog-stat { display: flex; flex-direction: column; align-items: center; }
    .prog-stat__num { font-size: 1.6rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
    .prog-stat__lbl { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-muted); margin-top: 0.2rem; }

    /* Testament headers */
    .prog-testament {
      font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--color-muted);
      margin: 1.25rem 0 0.65rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.3rem;
    }

    /* Book grid */
    .prog-books { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.6rem; }

    /* Book card */
    .prog-book {
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 7px; padding: 0.6rem 0.75rem; cursor: pointer;
      transition: border-color 0.15s;
    }
    .prog-book:hover { border-color: var(--color-primary); }
    .prog-book--complete { border-color: #4caf50; }
    .prog-book__name { font-size: 0.85rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.3rem; }
    .prog-book__bar-wrap { height: 5px; background: var(--color-border); border-radius: 3px; overflow: hidden; margin-bottom: 0.2rem; }
    .prog-book__bar { height: 100%; background: var(--color-primary); border-radius: 3px; transition: width 0.3s; }
    .prog-book--complete .prog-book__bar { background: #4caf50; }
    .prog-book__pct { font-size: 0.68rem; color: var(--color-muted); }

    /* Chapter grid (shown on expand) */
    .prog-book__chapters { display: none; margin-top: 0.55rem; padding-top: 0.5rem; border-top: 1px solid var(--color-border); }
    .prog-book__chapters--open { display: flex; flex-wrap: wrap; gap: 3px; }
    .prog-ch {
      width: 22px; height: 22px; border-radius: 3px; border: 1px solid var(--color-border);
      font-size: 0.62rem; display: flex; align-items: center; justify-content: center;
      color: var(--color-muted); cursor: pointer; text-decoration: none;
      transition: background 0.12s, border-color 0.12s;
    }
    .prog-ch:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .prog-ch--read { background: var(--color-primary); border-color: var(--color-primary); color: var(--color-on-primary); }
    [data-theme="dark"] .prog-ch--read { background: var(--color-btn-bg, #3a2d18); border-color: var(--color-primary); color: var(--color-btn-text, #e8c87a); }
  </style>
</Fragment>
<main>
    <div class="container prog-page">
      <a class="prog-back-link" id="prog-back-link" href="../discipline/?tab=progress" hidden="">← Disciplines</a>
      <h1>📊 Reading Progress</h1>
      <p class="prog-subtitle">Chapters are marked read automatically when you open them in the Bible reader. Click any chapter number to read it now.</p>

      <div class="prog-summary" id="prog-summary">
        <div class="prog-stat"><span class="prog-stat__num" id="ps-total">—</span><span class="prog-stat__lbl">Chapters read</span></div>
        <div class="prog-stat"><span class="prog-stat__num" id="ps-pct">—</span><span class="prog-stat__lbl">of 1189 total</span></div>
        <div class="prog-stat"><span class="prog-stat__num" id="ps-books">—</span><span class="prog-stat__lbl">Books started</span></div>
        <div class="prog-stat"><span class="prog-stat__num" id="ps-complete">—</span><span class="prog-stat__lbl">Books complete</span></div>
      </div>

      <div id="prog-content"></div>
    </div>
  </main>
<Fragment slot="after-scripts">
<script is:inline="">
  (function () {
    'use strict';

    /* bsw_chapter_read is the canonical key for read/unread chapter state */
    var READ_KEY = 'bsw_chapter_read';
    var READ_URL = '../read/';

    function getRead() {
      try { return JSON.parse(localStorage.getItem(READ_KEY) || '{}'); }
      catch (e) { return {}; }
    }

    function render(books) {
      var read   = getRead();
      var total  = 0, booksStarted = 0, booksComplete = 0;
      books.forEach(function (b) {
        var doneCount = Object.keys(read[b.id] || {}).length;
        if (doneCount > 0) booksStarted++;
        if (doneCount >= b.chapters) booksComplete++;
        total += doneCount;
      });

      document.getElementById('ps-total').textContent    = total;
      document.getElementById('ps-pct').textContent      = Math.round(total / 1189 * 100) + '%';
      document.getElementById('ps-books').textContent    = booksStarted;
      document.getElementById('ps-complete').textContent = booksComplete;

      var content = document.getElementById('prog-content');
      content.innerHTML = '';

      var otBooks = books.filter(function (b) { return b.testament === 'OT'; });
      var ntBooks = books.filter(function (b) { return b.testament === 'NT'; });

      [['Old Testament', otBooks], ['New Testament', ntBooks]].forEach(function (pair) {
        var label = pair[0], subset = pair[1];
        var h = document.createElement('div');
        h.className = 'prog-testament';
        h.textContent = label;
        content.appendChild(h);

        var grid = document.createElement('div');
        grid.className = 'prog-books';

        subset.forEach(function (book) {
          var bookRead  = read[book.id] || {};
          var doneCount = Object.keys(bookRead).length;
          var pct       = Math.round(doneCount / book.chapters * 100);
          var complete  = doneCount >= book.chapters;

          var card = document.createElement('div');
          card.className = 'prog-book' + (complete ? ' prog-book--complete' : '');

          card.innerHTML =
            '<div class="prog-book__name">' + book.name + '</div>' +
            '<div class="prog-book__bar-wrap"><div class="prog-book__bar" style="width:' + pct + '%"></div></div>' +
            '<div class="prog-book__pct">' + doneCount + ' / ' + book.chapters + (complete ? ' ✓' : '') + '</div>';

          var chGrid = document.createElement('div');
          chGrid.className = 'prog-book__chapters';

          for (var ch = 1; ch <= book.chapters; ch++) {
            var a    = document.createElement('a');
            var done = !!bookRead[String(ch)];
            a.className = 'prog-ch' + (done ? ' prog-ch--read' : '');
            a.href      = READ_URL + '?ref=' + encodeURIComponent(book.name + ' ' + ch) + '&stripped=1';
            a.target    = '_top';
            a.title     = book.name + ' ' + ch + (done ? (' — read ' + bookRead[String(ch)]) : ' — not yet read');
            a.textContent = ch;
            chGrid.appendChild(a);
          }

          card.addEventListener('click', function (e) {
            if (e.target.tagName === 'A') return;
            chGrid.classList.toggle('prog-book__chapters--open');
          });

          card.appendChild(chGrid);
          grid.appendChild(card);
        });

        content.appendChild(grid);
      });
    }

    fetch('../data/bible/books.json')
      .then(function (r) { return r.json(); })
      .then(render)
      .catch(function () {
        document.getElementById('prog-content').textContent = 'Could not load book data.';
      });
  }());
  </script>
</Fragment>
</Base>
