          entries.sort(function(a,b){return b.date>a.date?1:(b.date<a.date?-1:(b.created||0)-(a.created||0));});
          var q=_rSearchQ.toLowerCase();
          var filtered=entries.filter(function(e){if(_rTagFilter&&(e.tags||[]).indexOf(_rTagFilter)===-1)return false;if(!q)return true;return[e.title,e.body,e.passage,(e.tags||[]).join(' ')].join(' ').toLowerCase().includes(q);});
          countEl.textContent=filtered.length+' of '+entries.length+' reflections';
          if(!filtered.length){listEl.innerHTML='<div class="journal-empty">'+(entries.length?'No reflections match.':'No reflections yet.')+'</div>';return;}
          listEl.innerHTML='';filtered.forEach(function(entry){listEl.appendChild(buildReflCard(entry));});
        }
        function buildReflCard(entry){
          var card=document.createElement('div');card.className='journal-entry'+(entry.passage?' journal-entry--has-updates':'');
          var preview=(entry.body||'').replace(/\n/g,' ').slice(0,90)+((entry.body||'').length>90?'…':'');
          var tagsHtml=(entry.tags||[]).length?'<div class="journal-entry-tags">'+(entry.tags||[]).map(function(t){return'<span class="journal-tag journal-tag--topic" style="cursor:pointer" data-tag="'+escR(t)+'">'+escR(t)+'</span>';}).join('')+'</div>':'';
          var head=document.createElement('div');head.className='journal-entry__head';
          head.innerHTML='<div class="journal-entry__meta"><div class="journal-entry__date">'+escR(fmtR(entry.date))+'</div>'+(entry.title?'<div class="journal-entry__title">'+escR(entry.title)+'</div>':'')+(preview?'<div class="journal-entry__preview">'+escR(preview)+'</div>':'')+(entry.passage?'<div style="font-size:.78rem;color:var(--color-primary);font-weight:600;margin-top:.12rem">'+escR(entry.passage)+'</div>':'')+tagsHtml+'</div>'+
            '<div class="journal-entry__btns"><button class="journal-entry__btn" data-action="edit" type="button">Edit</button><button class="journal-entry__btn journal-entry__btn--del" data-action="del" type="button">Delete</button></div>';
          var body=document.createElement('div');body.className='journal-entry__body';
          body.innerHTML=(entry.passage?'<p style="margin-bottom:.5rem"><a class="ref" data-ref="'+escR(entry.passage)+'" href="'+escR(READ_URL+'?ref='+encodeURIComponent(entry.passage))+'" style="color:var(--color-primary);font-weight:600;text-decoration:none">'+escR(entry.passage)+'</a></p>':'')+'<p style="font-family:Georgia,serif;font-size:.92rem;line-height:1.7;color:var(--color-text);white-space:pre-wrap;margin:0">'+escR(entry.body||'')+'</p>';
          head.addEventListener('click',function(e){
            if(e.target.closest('[data-action]'))return;
            var chip=e.target.closest('[data-tag]');if(chip){_rTagFilter=(_rTagFilter===chip.dataset.tag)?null:chip.dataset.tag;renderRefl();return;}
            body.classList.toggle('journal-entry__body--open');
          });
          head.querySelector('[data-action="edit"]').addEventListener('click',function(){var e=loadR().find(function(x){return x.id===entry.id;});if(e)showReflForm(e);});
          head.querySelector('[data-action="del"]').addEventListener('click',function(){if(!confirm('Delete this reflection?'))return;saveR(loadR().filter(function(x){return x.id!==entry.id;}));renderRefl();});
          card.appendChild(head);card.appendChild(body);return card;
        }
        document.getElementById('refl-new-btn').addEventListener('click',function(){showReflForm(null);});
        document.getElementById('refl-search').addEventListener('input',function(){_rSearchQ=this.value.trim();clearTimeout(_rSearchTimer);_rSearchTimer=setTimeout(renderRefl,150);});
        renderRefl();
      }());
    } // end initJournal

    /* ══════════════════════════ WORSHIP ════════════════════════════════════ */
    function initWorship() {
      // Worship sub-tab switching with URL + localStorage persistence (D-I)
      function switchWtab(tab, skipUrl) {
        document.getElementById('worship-sermons-panel').hidden=(tab!=='sermons');
        document.getElementById('worship-fasting-panel').hidden=(tab!=='fasting');
        document.querySelectorAll('[data-wtab]').forEach(function(b){
          b.classList.toggle('worship-tab--active',b.getAttribute('data-wtab')===tab);
          b.setAttribute('aria-selected',b.getAttribute('data-wtab')===tab?'true':'false');
        });
        localStorage.setItem('bsw_worship_wtab', tab);
        if (!skipUrl) history.replaceState(null,'','?tab=worship&wtab='+tab);
      }
      document.querySelectorAll('[data-wtab]').forEach(function(btn){
        btn.addEventListener('click',function(){switchWtab(btn.getAttribute('data-wtab'));});
      });
      // Restore persisted sub-tab on init
      var savedWtab = new URLSearchParams(location.search).get('wtab') || localStorage.getItem('bsw_worship_wtab') || 'sermons';
      switchWtab(savedWtab, true);

      var WORSHIP_KEY='bsw_worship', FASTING_KEY='bsw_fasting', READ_URL='../read/';
      function loadW(){try{return JSON.parse(localStorage.getItem(WORSHIP_KEY)||'[]');}catch(e){return[];}}
      function saveW(a){localStorage.setItem(WORSHIP_KEY,JSON.stringify(a));}
      function loadF(){try{return JSON.parse(localStorage.getItem(FASTING_KEY)||'[]');}catch(e){return[];}}
      function saveF(a){localStorage.setItem(FASTING_KEY,JSON.stringify(a));}
      function todayW(){return new Date().toISOString().slice(0,10);}
      function escW(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
      function fmtW(s){if(!s)return'';var d=new Date(s+'T00:00:00');return d.toLocaleDateString(undefined,{weekday:'long',month:'long',day:'numeric',year:'numeric'});}
      function fmtWS(s){if(!s)return'';var d=new Date(s+'T00:00:00');return d.toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'});}

      var _wEditId=null, _wSearchQ='', _wEditFastId=null, _wSearchTimer=null;

      function showSermonForm(entry){
        _wEditId=entry?entry.id:null;var isEdit=!!entry;
        var fc=document.getElementById('worship-form-container');
        var form=document.createElement('div');form.className='worship-form';
        form.innerHTML='<h2>'+(isEdit?'Edit Entry':'New Sermon Entry')+'</h2>'+
          '<div class="worship-row"><div class="worship-field"><label for="ws-date">Date</label><input class="worship-input" type="date" id="ws-date" value="'+escW(isEdit?entry.date:todayW())+'" /></div><div class="worship-field"><label for="ws-church">Church <span>(optional)</span></label><input class="worship-input" type="text" id="ws-church" placeholder="e.g. Grace Church" value="'+escW(isEdit?(entry.church||''):'')+'\" /></div></div>'+
          '<div class="worship-row"><div class="worship-field"><label for="ws-preacher">Preacher <span>(optional)</span></label><input class="worship-input" type="text" id="ws-preacher" placeholder="e.g. John Smith" value="'+escW(isEdit?(entry.preacher||''):'')+'\" /></div><div class="worship-field"><label for="ws-passage">Passage <span>(optional)</span></label><input class="worship-input" type="text" id="ws-passage" placeholder="e.g. Romans 8:28" value="'+escW(isEdit?(entry.passage||''):'')+'\" /></div></div>'+
          '<div class="worship-field"><label for="ws-title">Sermon Title <span>(optional)</span></label><input class="worship-input" type="text" id="ws-title" placeholder="e.g. The Golden Chain" value="'+escW(isEdit?(entry.title||''):'')+'\" /></div>'+
          '<div class="worship-checkbox-row"><label class="worship-checkbox-label"><input type="checkbox" id="ws-attended" '+((!isEdit||entry.attended!==false)?'checked':'')+' /> Attended</label><label class="worship-checkbox-label"><input type="checkbox" id="ws-communion" '+((isEdit&&entry.communion)?'checked':'')+' /> Communion</label></div>'+
          '<div class="worship-field"><label for="ws-notes">Sermon Notes</label><textarea class="worship-textarea" id="ws-notes" placeholder="Main points, observations…">'+escW(isEdit?(entry.notes||''):'')+'</textarea></div>'+
          '<div class="worship-field"><label for="ws-takeaways">Key Takeaways <span>(optional)</span></label><textarea class="worship-textarea" style="min-height:60px" id="ws-takeaways" placeholder="What will you carry into the week?">'+escW(isEdit?(entry.takeaways||''):'')+'</textarea></div>'+
          '<div class="worship-form-actions"><button class="worship-btn" id="ws-cancel" type="button">Cancel</button><button class="worship-btn worship-btn--primary" id="ws-save" type="button">'+(isEdit?'Save changes':'Save entry')+'</button></div>';
        fc.innerHTML='';fc.appendChild(form);
        form.querySelector('#ws-cancel').addEventListener('click',hideSermonForm);
        form.querySelector('#ws-save').addEventListener('click',saveSermonEntry);
        form.querySelector('#ws-notes').focus();
      }
      function hideSermonForm(){_wEditId=null;document.getElementById('worship-form-container').innerHTML='';}
      function saveSermonEntry(){
        var date=(document.getElementById('ws-date').value||todayW()).trim();
        var church=document.getElementById('ws-church').value.trim();
        var preacher=document.getElementById('ws-preacher').value.trim();
        var passage=document.getElementById('ws-passage').value.trim();
        var title=document.getElementById('ws-title').value.trim();
        var attended=document.getElementById('ws-attended').checked;
        var communion=document.getElementById('ws-communion').checked;
        var notes=document.getElementById('ws-notes').value.trim();
        var takeaways=document.getElementById('ws-takeaways').value.trim();
        if(!notes&&!title){alert('Please add a sermon title or notes.');return;}
        var entries=loadW();
        if(_wEditId){entries=entries.map(function(e){return e.id===_wEditId?Object.assign({},e,{date,church,preacher,passage,title,attended,communion,notes,takeaways,modified:Date.now()}):e;});}
        else{entries.unshift({id:Date.now(),date,church,preacher,passage,title,attended,communion,notes,takeaways,created:Date.now()});}
        var isNew = !_wEditId;
        saveW(entries);hideSermonForm();renderSermons();
        // D-K: prompt reflection after a new sermon entry
        if (isNew) {
          var fc2 = document.getElementById('worship-form-container');
          var cta = document.createElement('p'); cta.className = 'worship-post-cta';
          cta.innerHTML = 'Sermon logged. <a href="?tab=journal&amp;jtab=reflections">Write a reflection →</a>';
          fc2.appendChild(cta);
          setTimeout(function () { if (fc2.contains(cta)) cta.remove(); }, 6000);
        }
      }
      function renderSermons(){
        var entries=loadW(),listEl=document.getElementById('worship-list'),countEl=document.getElementById('worship-count');
        entries.sort(function(a,b){return b.date>a.date?1:-1;});
        var q=_wSearchQ.toLowerCase();
        var filtered=q?entries.filter(function(e){return[e.title,e.church,e.preacher,e.passage,e.notes,e.takeaways].join(' ').toLowerCase().includes(q);}):entries;
        countEl.textContent=filtered.length+' of '+entries.length+' entries';
        if(!filtered.length){listEl.innerHTML='<div class="worship-empty">'+(entries.length?'No entries match.':'No sermon entries yet.')+'</div>';return;}
        listEl.innerHTML='';filtered.forEach(function(entry){listEl.appendChild(buildSermonCard(entry));});
      }
      function buildSermonCard(entry){
        var card=document.createElement('div');card.className='worship-entry';
        var sub=[];if(entry.church)sub.push(entry.church);if(entry.preacher)sub.push(entry.preacher);
        var head=document.createElement('div');head.className='worship-entry__head';
        head.innerHTML='<div class="worship-entry__meta"><div class="worship-entry__date">'+escW(fmtW(entry.date))+'</div><div class="worship-entry__title">'+escW(entry.title||'Sermon Entry')+'</div>'+(sub.length?'<div class="worship-entry__sub">'+escW(sub.join(' · '))+'</div>':'')+
          '<div class="worship-badges">'+(entry.passage?'<span class="worship-badge">'+escW(entry.passage)+'</span>':'')+(entry.attended?'<span class="worship-badge worship-badge--green">Attended</span>':'')+(entry.communion?'<span class="worship-badge worship-badge--green">Communion</span>':'')+'</div></div>'+
          '<div class="worship-entry__btns"><button class="worship-btn worship-btn--sm" data-action="edit" type="button">Edit</button><button class="worship-btn worship-btn--sm worship-btn--del" data-action="del" type="button">Delete</button></div>';
        var body=document.createElement('div');body.className='worship-entry__body';
        var bh='';
        if(entry.passage)bh+='<div class="worship-body-section"><div class="worship-body-label">Passage</div><a class="worship-passage-link ref" data-ref="'+escW(entry.passage)+'" href="'+escW(READ_URL+'?ref='+encodeURIComponent(entry.passage))+'">'+escW(entry.passage)+'</a></div>';
        if(entry.notes)bh+='<div class="worship-body-section"><div class="worship-body-label">Sermon Notes</div><p class="worship-body-text">'+escW(entry.notes)+'</p></div>';
        if(entry.takeaways)bh+='<div class="worship-body-section"><div class="worship-body-label">Key Takeaways</div><p class="worship-body-text">'+escW(entry.takeaways)+'</p></div>';
        body.innerHTML=bh;
        head.addEventListener('click',function(e){if(e.target.closest('[data-action]'))return;body.classList.toggle('worship-entry__body--open');});
        head.querySelector('[data-action="edit"]').addEventListener('click',function(){var e=loadW().find(function(x){return x.id===entry.id;});if(e)showSermonForm(e);});
        head.querySelector('[data-action="del"]').addEventListener('click',function(){if(!confirm('Delete this sermon entry?'))return;saveW(loadW().filter(function(x){return x.id!==entry.id;}));renderSermons();});
        card.appendChild(head);card.appendChild(body);return card;
      }

      // Fasting
      function showFastForm(entry){
        _wEditFastId=entry?entry.id:null;var isEdit=!!entry;
        var fc=document.getElementById('fast-form-container');
        var form=document.createElement('div');form.className='worship-form';
        form.innerHTML='<h2>'+(isEdit?'Edit Fast':'Log a Fast')+'</h2>'+
          '<div class="worship-row"><div class="worship-field"><label for="fs-date">Date</label><input class="worship-input" type="date" id="fs-date" value="'+escW(isEdit?entry.date:todayW())+'" /></div>'+
          '<div class="worship-field"><label for="fs-type">Type</label><select class="worship-input" id="fs-type">'+
            ['full','partial','liquid'].map(function(t){return'<option value="'+t+'"'+((isEdit&&entry.type===t)||(!isEdit&&t==='full')?' selected':'')+'>'+{full:'Full fast',partial:'Partial fast',liquid:'Liquid fast'}[t]+'</option>';}).join('')+
          '</select></div><div class="worship-field"><label for="fs-hours">Duration <span>(hours)</span></label><input class="worship-input" type="number" id="fs-hours" min="0" max="168" value="'+escW(isEdit?(entry.hours||0):24)+'" /></div></div>'+
          '<div class="worship-field"><label for="fs-notes">Notes <span>(optional)</span></label><textarea class="worship-textarea" style="min-height:72px" id="fs-notes" placeholder="Purpose, Scripture, how it went…">'+escW(isEdit?(entry.notes||''):'')+'</textarea></div>'+
          '<div class="worship-form-actions"><button class="worship-btn" id="fs-cancel" type="button">Cancel</button><button class="worship-btn worship-btn--primary" id="fs-save" type="button">'+(isEdit?'Save changes':'Save fast')+'</button></div>';
        fc.innerHTML='';fc.appendChild(form);
        form.querySelector('#fs-cancel').addEventListener('click',function(){_wEditFastId=null;fc.innerHTML='';});
        form.querySelector('#fs-save').addEventListener('click',function(){
          var date=(document.getElementById('fs-date').value||todayW()).trim();
          var type=document.getElementById('fs-type').value;
          var hours=parseInt(document.getElementById('fs-hours').value,10)||0;
          var notes=document.getElementById('fs-notes').value.trim();
          var fasts=loadF();
          if(_wEditFastId){fasts=fasts.map(function(e){return e.id===_wEditFastId?Object.assign({},e,{date,type,hours,notes,modified:Date.now()}):e;});}
          else{fasts.unshift({id:Date.now(),date,type,hours,notes,created:Date.now()});}
          saveF(fasts);_wEditFastId=null;fc.innerHTML='';renderFasts();
        });
      }
      function renderFasts(){
        var fasts=loadF(),listEl=document.getElementById('fast-list'),countEl=document.getElementById('fast-count');
        fasts.sort(function(a,b){return b.date>a.date?1:-1;});
        countEl.textContent=fasts.length+' fast'+(fasts.length!==1?'s':'')+' logged';
        if(!fasts.length){listEl.innerHTML='<div class="worship-empty">No fasts logged yet.</div>';return;}
        listEl.innerHTML='';
        fasts.forEach(function(fast){
          var card=document.createElement('div');card.className='worship-entry';
          var typeLabel={full:'Full fast',partial:'Partial fast',liquid:'Liquid fast'}[fast.type]||fast.type;
          var dur=fast.hours>0?fast.hours+'h':'All day';
          var head=document.createElement('div');head.className='worship-entry__head';
          head.innerHTML='<div class="worship-entry__meta"><div class="worship-entry__date">'+escW(fmtW(fast.date))+'</div><div class="worship-entry__title"><span class="worship-badge fast-type-'+escW(fast.type)+'">'+escW(typeLabel)+'</span> <span style="font-size:.85rem;color:var(--color-muted);font-weight:400">'+escW(dur)+'</span></div>'+(fast.notes?'<div class="worship-entry__sub" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:300px">'+escW(fast.notes.slice(0,80))+'</div>':'')+'</div>'+
            '<div class="worship-entry__btns"><button class="worship-btn worship-btn--sm" data-action="edit" type="button">Edit</button><button class="worship-btn worship-btn--sm worship-btn--del" data-action="del" type="button">Delete</button></div>';
          var body=document.createElement('div');body.className='worship-entry__body';
          if(fast.notes)body.innerHTML='<div class="worship-body-section"><div class="worship-body-label">Notes</div><p class="worship-body-text">'+escW(fast.notes)+'</p></div>';
          head.addEventListener('click',function(e){if(e.target.closest('[data-action]'))return;if(fast.notes)body.classList.toggle('worship-entry__body--open');});
          head.querySelector('[data-action="edit"]').addEventListener('click',function(){var e=loadF().find(function(x){return x.id===fast.id;});if(e)showFastForm(e);});
          head.querySelector('[data-action="del"]').addEventListener('click',function(){if(!confirm('Delete this fast?'))return;saveF(loadF().filter(function(x){return x.id!==fast.id;}));renderFasts();});
          card.appendChild(head);card.appendChild(body);listEl.appendChild(card);
        });
      }

      document.getElementById('worship-new-btn').addEventListener('click',function(){showSermonForm(null);});
      document.getElementById('worship-search').addEventListener('input',function(){_wSearchQ=this.value.trim();clearTimeout(_wSearchTimer);_wSearchTimer=setTimeout(renderSermons,150);});
      document.getElementById('fast-new-btn').addEventListener('click',function(){showFastForm(null);});
      renderSermons(); renderFasts();
    } // end initWorship

    /* ══════════════════════════ GRATITUDE ══════════════════════════════════ */
    function initGratitude() {
      var GRAT_KEY='bsw_gratitude';
      var _gEditId=null, _gSearchQ='', _gFormTags=[], _gSearchTimer=null;
      function loadG(){try{return JSON.parse(localStorage.getItem(GRAT_KEY)||'[]');}catch(e){return[];}}
      function saveG(a){localStorage.setItem(GRAT_KEY,JSON.stringify(a));}
      function todayG(){return new Date().toISOString().slice(0,10);}
      function escG(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
      function fmtG(s){if(!s)return'';var d=new Date(s+'T00:00:00');return d.toLocaleDateString(undefined,{weekday:'short',month:'long',day:'numeric',year:'numeric'});}

      function buildGTagInput(existing){
        _gFormTags=existing?existing.slice():[];
        var wrap=document.createElement('div');wrap.className='journal-tag-input-wrap';
        var inp=document.createElement('input');inp.className='journal-tag-bare-input';inp.type='text';inp.placeholder='Add tag…';
        function refresh(){
          wrap.querySelectorAll('.journal-tag').forEach(function(c){c.remove();});
          _gFormTags.forEach(function(t){
            var chip=document.createElement('span');
            chip.innerHTML='<span class="journal-tag journal-tag--default" data-tag="'+escG(t)+'">'+escG(t)+'<button class="journal-tag__rm" data-rm-tag="'+escG(t)+'" type="button">×</button></span>';
            var inner=chip.firstChild;
            inner.querySelector('[data-rm-tag]').addEventListener('click',function(ev){ev.stopPropagation();_gFormTags=_gFormTags.filter(function(x){return x!==t;});refresh();});
            wrap.insertBefore(inner,inp);
          });
        }
        refresh();
        function addTag(raw){var t=raw.trim().toLowerCase().replace(/\s+/g,'-');if(!t||_gFormTags.indexOf(t)!==-1)return;_gFormTags.push(t);refresh();inp.value='';}
        inp.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===','){e.preventDefault();addTag(inp.value);}if(e.key==='Backspace'&&!inp.value&&_gFormTags.length){_gFormTags.pop();refresh();}});
        inp.addEventListener('blur',function(){if(inp.value.trim())addTag(inp.value);});
        wrap.addEventListener('click',function(e){if(e.target===wrap)inp.focus();});
        wrap.appendChild(inp);return wrap;
      }

      function showGratForm(entry){
        _gEditId=entry?entry.id:null;var isEdit=!!entry;
        var fc=document.getElementById('grat-form-container');
        var form=document.createElement('div');form.className='journal-form';
        form.innerHTML='<h2>'+(isEdit?'Edit Entry':'New Gratitude Entry')+'</h2>'+
          '<div class="journal-field"><label for="g-date">Date</label><input class="journal-input" type="date" id="g-date" value="'+escG(isEdit?entry.date:todayG())+'" /></div>'+
          '<div class="journal-field"><label for="g-text">What are you grateful for?</label><textarea class="journal-textarea" id="g-text" placeholder="I am grateful for…">'+escG(isEdit?(entry.text||''):'')+'</textarea></div>'+
          '<div class="journal-field" id="g-tags-field"><label>Tags <span>(Enter to add)</span></label></div>'+
          '<div class="journal-form-actions"><button class="journal-btn" id="g-cancel" type="button">Cancel</button><button class="journal-btn journal-btn--primary" id="g-save" type="button">'+(isEdit?'Save changes':'Save entry')+'</button></div>';
        fc.innerHTML='';fc.appendChild(form);
        form.querySelector('#g-tags-field').appendChild(buildGTagInput(isEdit?(entry.tags||[]):[]));
        form.querySelector('#g-cancel').addEventListener('click',hideGratForm);
        form.querySelector('#g-save').addEventListener('click',saveGratEntry);
        form.querySelector('#g-text').focus();
      }
      function hideGratForm(){_gEditId=null;_gFormTags=[];document.getElementById('grat-form-container').innerHTML='';}
      function saveGratEntry(){
        var bare=document.querySelector('#grat-form-container .journal-tag-bare-input');
        if(bare&&bare.value.trim()){var t=bare.value.trim().toLowerCase().replace(/\s+/g,'-');if(t&&_gFormTags.indexOf(t)===-1)_gFormTags.push(t);}
        var date=(document.getElementById('g-date').value||todayG()).trim();
        var text=document.getElementById('g-text').value.trim();
        var tags=_gFormTags.slice();
        if(!text){alert('Please write what you are grateful for.');return;}
        var entries=loadG();
        if(_gEditId){entries=entries.map(function(e){return e.id===_gEditId?Object.assign({},e,{date,text,tags,modified:Date.now()}):e;});}
        else{entries.unshift({id:Date.now(),date,text,tags,created:Date.now()});}
        saveG(entries);hideGratForm();renderGrat();
      }

      function renderGrat(){
        var entries=loadG(),listEl=document.getElementById('grat-list'),countEl=document.getElementById('grat-count'),exportRow=document.getElementById('grat-export-row');
        entries.sort(function(a,b){return b.date>a.date?1:(b.date<a.date?-1:(b.created||0)-(a.created||0));});
        var q=_gSearchQ.toLowerCase();
        var filtered=q?entries.filter(function(e){return[e.text,(e.tags||[]).join(' ')].join(' ').toLowerCase().includes(q);}):entries;
        countEl.textContent=filtered.length+' of '+entries.length+' entries';
        exportRow.hidden=entries.length===0;
        if(!filtered.length){listEl.innerHTML='<div class="journal-empty">'+(entries.length?'No entries match.':'No gratitude entries yet. Start by recording something you\'re thankful for.')+'</div>';return;}
        listEl.innerHTML='';
        filtered.forEach(function(entry){
          var card=document.createElement('div');card.className='journal-entry';
          var preview=(entry.text||'').replace(/\n/g,' ').slice(0,90)+((entry.text||'').length>90?'…':'');
          var tagsHtml=(entry.tags||[]).length?'<div class="journal-entry-tags">'+(entry.tags||[]).map(function(t){return'<span class="journal-tag journal-tag--default">'+escG(t)+'</span>';}).join('')+'</div>':'';
          var head=document.createElement('div');head.className='journal-entry__head';
          head.innerHTML='<div class="journal-entry__meta"><div class="journal-entry__date">'+escG(fmtG(entry.date))+'</div>'+(preview?'<div class="journal-entry__preview">'+escG(preview)+'</div>':'')+tagsHtml+'</div>'+
            '<div class="journal-entry__btns"><button class="journal-entry__btn" data-action="edit" type="button">Edit</button><button class="journal-entry__btn journal-entry__btn--del" data-action="del" type="button">Delete</button></div>';
          var body=document.createElement('div');body.className='journal-entry__body';
          body.innerHTML='<p style="font-family:Georgia,serif;font-size:.92rem;line-height:1.7;white-space:pre-wrap;margin:0">'+escG(entry.text||'')+'</p>';
          head.addEventListener('click',function(e){if(e.target.closest('[data-action]'))return;body.classList.toggle('journal-entry__body--open');});
          head.querySelector('[data-action="edit"]').addEventListener('click',function(){var e=loadG().find(function(x){return x.id===entry.id;});if(e)showGratForm(e);});
          head.querySelector('[data-action="del"]').addEventListener('click',function(){if(!confirm('Delete this entry?'))return;saveG(loadG().filter(function(x){return x.id!==entry.id;}));renderGrat();});
          card.appendChild(head);card.appendChild(body);listEl.appendChild(card);
        });
      }

      document.getElementById('grat-new-btn').addEventListener('click',function(){showGratForm(null);});
      document.getElementById('grat-search').addEventListener('input',function(){_gSearchQ=this.value.trim();clearTimeout(_gSearchTimer);_gSearchTimer=setTimeout(renderGrat,150);});
      document.getElementById('grat-export-btn').addEventListener('click',function(){
        var d=loadG();if(!d.length)return;
        var blob=new Blob([JSON.stringify(d,null,2)],{type:'application/json'});var url=URL.createObjectURL(blob);var a=document.createElement('a');a.href=url;a.download='bsw-gratitude-'+todayG()+'.json';a.click();URL.revokeObjectURL(url);
      });
      document.getElementById('grat-import-btn').addEventListener('click',function(){document.getElementById('grat-import-file').click();});
      document.getElementById('grat-import-file').addEventListener('change',function(e){
        var file=e.target.files&&e.target.files[0];if(!file)return;this.value='';
        var fr=new FileReader();fr.onload=function(ev){
          var imp;try{imp=JSON.parse(ev.target.result);}catch(e){alert('Invalid JSON.');return;}
          if(!Array.isArray(imp)){alert('Unexpected format.');return;}
          var existing=loadG(),existIds={},added=0,skipped=0;
          existing.forEach(function(x){existIds[x.id]=true;});
          imp.forEach(function(x){if(x.id&&existIds[x.id])skipped++;else{existing.push(x);added++;}});
          saveG(existing);renderGrat();
          alert('Imported '+added+' entr'+(added===1?'y':'ies')+'.'+(skipped?' '+skipped+' duplicate'+(skipped!==1?'s':'')+' skipped.':''));
        };fr.readAsText(file);
      });
      renderGrat();
    } // end initGratitude

    /* Activate the initial tab now that all tab vars + init functions exist. */
    activateTab(initTab, true);

  }()); // end master IIFE
  </script><!-- Original Language flashcard panel — reads bsw_ws_fc_deck / bsw_ws_fc_progress --><script type="module" is:inline="">
  import { loadStrongs } from '../assets/js/core.js';

  var SK_DECK     = 'bsw_ws_fc_deck';
  var SK_PROGRESS = 'bsw_ws_fc_progress';
  var FC_INTERVALS = { again: 1, hard: 3, good: 7, easy: 21 };

  var _strongsCache = {};   // lang → dict object
  var _olInited     = false;
  var _olQueue      = [];   // codes for current review session
  var _olIdx        = 0;
  var _olLang       = 'all';

  function _getDeck() {
    try { var d = JSON.parse(localStorage.getItem(SK_DECK) || '{}'); return { greek: d.greek || [], hebrew: d.hebrew || [] }; }
    catch (e) { return { greek: [], hebrew: [] }; }
  }
  function _removeFromDeck(code) {
    var d = _getDeck();
    d.greek  = d.greek.filter(function (c) { return c !== code; });
    d.hebrew = d.hebrew.filter(function (c) { return c !== code; });
    try { localStorage.setItem(SK_DECK, JSON.stringify(d)); } catch (e) {}
    _renderOlList();
  }
  function _getProgress() {
    try { return JSON.parse(localStorage.getItem(SK_PROGRESS) || '{}'); } catch (e) { return {}; }
  }
  function _saveProgress(p) {
    try { localStorage.setItem(SK_PROGRESS, JSON.stringify(p)); } catch (e) {}
  }
  function _today() {
    return new Date().toISOString().slice(0, 10);
  }
  function _isDue(code) {
    var p = _getProgress()[code];
    if (!p || !p.due) return true;
    return p.due <= _today();
  }

  // Wire the "Original Language" mem-tab button
  var olBtn = document.getElementById('mem-ol-tab');
  if (olBtn) {
    olBtn.addEventListener('click', function () {
      // Switch mem-tab active states
      document.querySelectorAll('.mem-tab').forEach(function (b) {
        b.classList.toggle('mem-tab--active', b === olBtn);
        b.setAttribute('aria-selected', b === olBtn ? 'true' : 'false');
      });
      document.querySelectorAll('.mem-panel').forEach(function (p) { p.hidden = true; });
      var panel = document.getElementById('mem-ol-panel');
      if (panel) { panel.hidden = false; _initOlPanel(); }
    });
  }

  async function _initOlPanel() {
    if (_olInited) { _renderOlList(); return; }
    _olInited = true;

    var deck = _getDeck();
    var allCodes = [...deck.greek, ...deck.hebrew];
    if (allCodes.length === 0) {
      document.getElementById('ol-empty').removeAttribute('hidden');
      document.getElementById('ol-word-list').hidden = true;
      document.getElementById('ol-deck-info').textContent = 'No words in your deck yet.';
      return;
    }

    // Load strongs data for each language that has entries in the deck
    if (deck.greek.length && !_strongsCache.greek) {
      _strongsCache.greek = await loadStrongs('greek').catch(function () { return {}; });
    }
    if (deck.hebrew.length && !_strongsCache.hebrew) {
      _strongsCache.hebrew = await loadStrongs('hebrew').catch(function () { return {}; });
    }

    // Wire lang filter and review button
    var langSel = document.getElementById('ol-lang-filter');
    if (langSel) {
      langSel.addEventListener('change', function () {
        _olLang = langSel.value;
        _renderOlList();
      });
    }
    var reviewBtn = document.getElementById('ol-review-btn');
    if (reviewBtn) {
      reviewBtn.addEventListener('click', _startOlReview);
    }
    document.getElementById('ol-back-btn').addEventListener('click', function () {
      document.getElementById('ol-review-view').hidden = true;
      document.getElementById('ol-list-view').hidden = false;
      _renderOlList();
    });

    _renderOlList();
  }

  function _getFilteredCodes() {
    var deck = _getDeck();
    var codes = [];
    if (_olLang === 'all' || _olLang === 'greek')  codes = codes.concat(deck.greek);
    if (_olLang === 'all' || _olLang === 'hebrew') codes = codes.concat(deck.hebrew);
    return codes;
  }

  function _getEntry(code) {
    var lang = code.startsWith('G') ? 'greek' : 'hebrew';
    return (_strongsCache[lang] || {})[code];
  }

  function _renderOlList() {
    var codes  = _getFilteredCodes();
    var prog   = _getProgress();
    var listEl = document.getElementById('ol-word-list');
    var infoEl = document.getElementById('ol-deck-info');
    var emptyEl = document.getElementById('ol-empty');
    var reviewBtn = document.getElementById('ol-review-btn');

    if (!codes.length) {
      emptyEl.removeAttribute('hidden');
      listEl.innerHTML = '';
      if (infoEl) infoEl.textContent = 'No words match the current filter.';
      if (reviewBtn) reviewBtn.disabled = true;
      return;
    }
    emptyEl.setAttribute('hidden', '');

    var dueCount = codes.filter(_isDue).length;
    if (infoEl) infoEl.textContent = codes.length + ' word' + (codes.length === 1 ? '' : 's') + ' in deck · ' + dueCount + ' due today';
    if (reviewBtn) {
      reviewBtn.disabled = dueCount === 0;
      reviewBtn.textContent = dueCount > 0 ? 'Review Due (' + dueCount + ')' : 'All reviewed';
    }

    // Update badge
    var badge = document.getElementById('ol-due-badge');
    if (badge) {
      if (dueCount > 0) { badge.textContent = dueCount; badge.removeAttribute('hidden'); }
      else badge.setAttribute('hidden', '');
    }

    listEl.innerHTML = '';
    codes.forEach(function (code) {
      var entry = _getEntry(code);
      if (!entry) return;
      var due = _isDue(code);
      var p   = prog[code];
      var daysLabel = '';
      if (!due && p && p.due) {
        var daysLeft = Math.round((new Date(p.due) - new Date()) / 86400000);
        daysLabel = 'in ' + daysLeft + ' day' + (daysLeft === 1 ? '' : 's');
      }
      var item = document.createElement('div');
      item.className = 'mem-item' + (due ? ' mem-item--due' : '');
      item.innerHTML = '<div class="mem-item__ref" style="font-family:\'Noto Serif\',serif;font-size:1.1rem">' + (entry.lemma || code) + '</div>'
        + '<div class="mem-item__text">' + (entry.gloss || entry.meaning || '') + ' <span class="mem-item__badge">' + code + '</span></div>'
        + '<div class="mem-item__status' + (due ? ' mem-item__status--due' : '') + '">' + (due ? 'Due today' : daysLabel) + '</div>'
        + '<button class="mem-ol-remove-btn" type="button" title="Remove from deck" data-code="' + code + '">✕ Remove</button>';
      item.querySelector('.mem-ol-remove-btn').addEventListener('click', function (e) {
        e.stopPropagation();
        _removeFromDeck(code);
      });
      listEl.appendChild(item);
    });
  }

  function _startOlReview() {
    var codes = _getFilteredCodes().filter(_isDue);
    if (!codes.length) return;
    // Shuffle
    _olQueue = codes.slice().sort(function () { return Math.random() - 0.5; });
    _olIdx = 0;
    document.getElementById('ol-list-view').hidden = true;
    document.getElementById('ol-review-view').hidden = false;
    _showOlCard();
  }

  function _showOlCard() {
    var doneEl  = document.getElementById('ol-done');
    var cardEl  = document.getElementById('ol-card');
    var progEl  = document.getElementById('ol-review-progress');

    if (_olIdx >= _olQueue.length) {
      cardEl.hidden = true;
      doneEl.removeAttribute('hidden');
      if (progEl) progEl.textContent = 'Session complete — ' + _olQueue.length + ' word' + (_olQueue.length === 1 ? '' : 's') + ' reviewed.';
      return;
    }

    cardEl.hidden = false;
    doneEl.setAttribute('hidden', '');

    var code  = _olQueue[_olIdx];
    var entry = _getEntry(code);
    var lang  = code.startsWith('G') ? 'Greek' : 'Hebrew';

    var frontEl   = document.getElementById('ol-front');
    var backEl    = document.getElementById('ol-back');
    var actionsEl = document.getElementById('ol-actions');

    frontEl.innerHTML = '<div style="font-size:2rem;font-family:\'Noto Serif\',serif;font-weight:700;margin-bottom:0.5rem">'
      + (entry ? (entry.lemma || code) : code) + '</div>'
      + '<div style="font-size:0.8rem;color:var(--color-text-muted,#888)">' + lang + ' · ' + code + '</div>'
      + '<button class="mem-reveal-btn" id="ol-reveal-btn" type="button">Tap to reveal →</button>';
    backEl.innerHTML = '<div style="font-size:1.8rem;font-family:\'Noto Serif\',serif;font-weight:700">' + (entry ? (entry.lemma || code) : code) + '</div>'
      + (entry && entry.translit ? '<div style="font-style:italic;color:var(--color-text-muted,#888);margin:0.25rem 0">' + entry.translit + '</div>' : '')
      + '<div style="font-size:1.1rem;font-weight:600;color:var(--color-primary,#c8a96e);margin:0.4rem 0">"' + (entry ? (entry.gloss || entry.meaning || '') : '') + '"</div>'
      + (entry && entry.pos ? '<div style="font-size:0.78rem;color:var(--color-text-muted,#888);text-transform:uppercase;letter-spacing:0.05em">' + entry.pos + '</div>' : '');
    backEl.setAttribute('hidden', '');
    actionsEl.setAttribute('hidden', '');

    if (progEl) progEl.textContent = (_olIdx + 1) + ' / ' + _olQueue.length;

    document.getElementById('ol-reveal-btn').addEventListener('click', function () {
      backEl.removeAttribute('hidden');
      actionsEl.removeAttribute('hidden');
      document.querySelector('#ol-front .mem-reveal-btn').style.display = 'none';
    });

    // Wire rating buttons
    actionsEl.querySelectorAll('.mem-rate-btn[data-rating]').forEach(function (btn) {
      btn.onclick = function () {
        var rating = btn.dataset.rating;
        var prog = _getProgress();
        var days = FC_INTERVALS[rating] || 7;
        var nextDue = new Date();
        nextDue.setDate(nextDue.getDate() + days);
        prog[code] = { due: nextDue.toISOString().slice(0, 10), interval: days };
        _saveProgress(prog);
        _olIdx++;
        _showOlCard();
      };
    });
  }

  // Wire keyboard shortcuts during review (1-4)
  document.addEventListener('keydown', function (e) {
    var panel = document.getElementById('mem-ol-panel');
    if (!panel || panel.hidden) return;
    var rv = document.getElementById('ol-review-view');
    if (!rv || rv.hidden) return;
    var actEl = document.getElementById('ol-actions');
    if (actEl && !actEl.hidden) {
      var ratings = ['again', 'hard', 'good', 'easy'];
      var idx = {'1':0,'2':1,'3':2,'4':3}[e.key];
      if (idx !== undefined) { actEl.querySelectorAll('.mem-rate-btn[data-rating]')[idx].click(); }
    } else {
      if (e.key === ' ' || e.key === 'Enter') {
        var revBtn = document.getElementById('ol-reveal-btn');
        if (revBtn) revBtn.click();
        e.preventDefault();
      }
    }
  });
  </script>
