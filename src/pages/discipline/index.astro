---
import Base from '../../layouts/Base.astro';
---

<Base title={"Discipline — Kingdom Bible Study"} description={"Daily spiritual disciplines — reading plans, devotionals, memory, journal, and worship notes."}>
<Fragment slot="head-end">
<link rel="stylesheet" href="../assets/css/memorize.css"><link rel="stylesheet" href="../assets/css/devotionals.css"><link rel="stylesheet" href="../assets/css/discipline.css">
</Fragment>
<main>

    <!-- ── Sticky tab bar ─────────────────────────────────────────────────── -->
    <div class="disc-tabbar-wrap">
      <div class="disc-tabbar" role="tablist" aria-label="Discipline tabs">
        <button class="disc-tab disc-tab--active" data-tab="plans" role="tab" aria-selected="true" id="disc-tab-plans" aria-controls="disc-plans">
          <span class="disc-dot" id="dot-reading"></span>📅 Plans
        </button>
        <button class="disc-tab" data-tab="devotionals" role="tab" aria-selected="false" id="disc-tab-devotionals" aria-controls="disc-devotionals">
          <span class="disc-dot" id="dot-devotional"></span>🌅 Devotionals
        </button>
        <button class="disc-tab" data-tab="memory" role="tab" aria-selected="false" id="disc-tab-memory" aria-controls="disc-memory">
          <span class="disc-dot" id="dot-memory"></span>⭐ Memory
        </button>
        <button class="disc-tab" data-tab="journal" role="tab" aria-selected="false" id="disc-tab-journal" aria-controls="disc-journal">
          <span class="disc-dot" id="dot-prayer"></span>✍️ Journal
        </button>
        <button class="disc-tab" data-tab="worship" role="tab" aria-selected="false" id="disc-tab-worship" aria-controls="disc-worship">
          <span class="disc-dot" id="dot-worship"></span>⛪ Worship
        </button>
        <button class="disc-tab disc-tab--more" id="disc-more-btn" type="button" aria-haspopup="true" aria-expanded="false">More ▾</button>
      </div>
      <div class="disc-more-menu" id="disc-more-menu" hidden="" role="menu">
        <button class="disc-more-item" data-tab="notes" role="menuitem" type="button">📝 My Notes</button>
        <button class="disc-more-item" data-tab="progress" role="menuitem" type="button">📊 Reading Progress</button>
        <button class="disc-more-item" data-tab="history" role="menuitem" type="button">📅 History</button>
      </div>
    </div>

    <!-- ── Daily summary strip ───────────────────────────────────────────── -->
    <div class="disc-today-strip" id="disc-today-strip"></div>

    <!-- ══════════════════════════ PLANS PANEL ══════════════════════════════ -->
    <div id="disc-plans" class="disc-panel disc-body" role="tabpanel" aria-labelledby="disc-tab-plans" hidden="">
      <p class="plans-loading" id="plans-list-msg">Loading plans…</p>
      <div id="plans-list"></div>
    </div>

    <!-- ══════════════════════════ DEVOTIONALS PANEL ════════════════════════ -->
    <div id="disc-devotionals" class="disc-panel disc-devot-body" role="tabpanel" aria-labelledby="disc-tab-devotionals" hidden="">
      <div class="devot-controls" style="margin-bottom:1.25rem">
        <div class="devot-source">
          <label class="devot-source__label" for="devot-collection">Devotional</label>
          <!-- Options are populated from the DEVOT_COLLECTIONS registry in JS so adding a
               new devotional series is data-only. Selection persists in localStorage. -->
          <select class="devot-source__select" id="devot-collection" aria-label="Choose devotional collection"></select>
        </div>
        <div class="devot-date-nav">
          <button class="devot-nav-btn" id="devot-prev" aria-label="Previous day">←</button>
          <input type="date" id="devot-date-input" class="devot-date-input" aria-label="Select date">
          <button class="devot-nav-btn" id="devot-next" aria-label="Next day">→</button>
          <button class="devot-nav-btn devot-today-btn" id="devot-today">Today</button>
        </div>
        <!-- Period tabs (e.g. Morning / Evening) are rebuilt by renderPeriodTabs() to match
             the chosen collection's periods, and hidden for single-period collections. -->
        <div class="devot-period-tabs" id="devot-period-tabs" role="tablist" aria-label="Time of day"></div>
      </div>
      <article class="devot-card" id="devot-card" role="tabpanel" aria-labelledby="devot-tab-morning" aria-live="polite">
        <div class="devot-card__loading" id="devot-loading">Loading…</div>
        <div class="devot-card__body" id="devot-body" hidden="">
          <div class="devot-card__date-label" id="devot-date-label"></div>
          <blockquote class="devot-verse" id="devot-verse-block">
            <p id="devot-verse-text"></p>
            <cite id="devot-verse-ref"></cite>
          </blockquote>
          <div class="devot-text" id="devot-text"></div>
          <p class="devot-attribution" id="devot-attribution" hidden=""></p>
          <div class="devot-complete-row" id="devot-complete-row" hidden="">
            <button class="devot-mark-btn" id="devot-mark-btn" type="button">Mark as read ✓</button>
            <span class="devot-done-msg" id="devot-done-msg" hidden="">
              ✓ Devotional complete for today &nbsp;·&nbsp;
              <a href="?tab=journal&amp;jtab=reflections" style="color:var(--color-primary);font-weight:500;font-size:.82rem">Write a reflection →</a>
            </span>
          </div>
        </div>
        <div class="devot-card__empty" id="devot-empty" hidden="">
          No entry found for this date.
        </div>
      </article>
    </div>

    <!-- ══════════════════════════ MEMORY PANEL ═════════════════════════════ -->
    <div id="disc-memory" class="disc-panel disc-memory-body" role="tabpanel" aria-labelledby="disc-tab-memory" hidden="">
      <div class="mem-header">
        <h1 class="mem-title">⭐ Scripture Memory</h1>
        <p class="mem-subtitle">Memorize verses using spaced repetition — reviewed at the right time, every time.</p>
      </div>
      <div class="mem-tabs" role="tablist">
        <button class="mem-tab mem-tab--active" data-tab="browse" role="tab" aria-selected="true" id="mem-browse-tab" aria-controls="mem-browse-panel">Browse</button>
        <button class="mem-tab" data-tab="review" role="tab" aria-selected="false" id="mem-review-tab" aria-controls="mem-review-panel">Review <span id="mem-due-badge" class="mem-badge" hidden=""></span></button>
        <button class="mem-tab" data-tab="ol" role="tab" aria-selected="false" id="mem-ol-tab" aria-controls="mem-ol-panel">Original Language <span id="ol-due-badge" class="mem-badge" hidden=""></span></button>
      </div>
      <div id="mem-browse-panel" class="mem-panel" role="tabpanel" aria-labelledby="mem-browse-tab">
        <div class="mem-add-row">
          <input id="mem-add-input" type="text" class="mem-add-input" placeholder="Add a verse — e.g. John 3:16" aria-label="Add a verse — e.g. John 3:16" autocomplete="off">
          <button id="mem-add-btn" class="mem-add-btn">Add verse</button>
        </div>
        <div class="mem-add-row">
          <input id="mem-add-passage-input" type="text" class="mem-add-input" placeholder="Add a passage — e.g. Romans 8:28-30" aria-label="Add a passage — e.g. Romans 8:28-30" autocomplete="off">
          <button id="mem-add-passage-btn" class="mem-add-btn" style="white-space:nowrap">Add passage</button>
        </div>
        <p id="mem-add-error" class="mem-add-error" hidden=""></p>
        <div class="mem-mode-row">
          <label class="mem-mode-label" for="mem-mode-select">Flashcard mode:</label>
          <select id="mem-mode-select" class="mem-mode-select">
            <option value="ref-to-text">Reference → Recall text</option>
            <option value="text-to-ref">Text → Recall reference</option>
          </select>
          <label class="mem-mode-label mem-scope-label" for="mem-scope-select">Review:</label>
          <select id="mem-scope-select" class="mem-mode-select" aria-label="Review scope"></select>
        </div>
        <div id="mem-tag-filter-row" class="mem-tag-filter-row" hidden=""></div>
        <div id="mem-list" class="mem-list"></div>
        <div id="mem-list-footer" class="mem-list-footer" hidden="">
          <button id="mem-anki-btn" class="mem-anki-btn" type="button">Export for Anki</button>
        </div>
        <div id="mem-empty" class="bsw-empty-state" hidden="">
          <span class="bsw-empty-state__glyph" aria-hidden="true">◈</span>
          <p class="bsw-empty-state__title">No verses yet</p>
          <p class="bsw-empty-state__desc">Add a reference above, or click the star button inside any verse modal while reading.</p>
          <a class="bsw-empty-state__cta" href="../read/">Open Reader</a>
        </div>
      </div>
      <div id="mem-review-panel" class="mem-panel" role="tabpanel" aria-labelledby="mem-review-tab" hidden="">
        <div id="mem-review-progress" class="mem-progress"></div>
        <div id="mem-card" class="mem-card">
          <div id="mem-card-front" class="mem-card__front"></div>
          <div id="mem-card-back" class="mem-card__back" hidden=""></div>
          <div id="mem-card-actions" class="mem-card__actions" hidden="">
            <button class="mem-rate-btn mem-rate-btn--again" data-score="0">Again <kbd>1</kbd></button>
            <button class="mem-rate-btn mem-rate-btn--hard" data-score="1">Hard <kbd>2</kbd></button>
            <button class="mem-rate-btn mem-rate-btn--good" data-score="2">Good <kbd>3</kbd></button>
            <button class="mem-rate-btn mem-rate-btn--easy" data-score="3">Easy <kbd>4</kbd></button>
          </div>
        </div>
        <div id="mem-review-done" class="mem-review-done" hidden="">
          <p>🎉 All done for today! Come back tomorrow for your next review.</p>
          <p style="font-size:.85rem;margin-bottom:1rem">
            <a href="?tab=journal&amp;jtab=reflections" style="color:var(--color-primary);font-weight:500">📓 Write a reflection on what you studied →</a>
          </p>
          <button id="mem-back-browse" class="mem-back-btn">Back to Browse</button>
        </div>
      </div>

      <!-- ── Original Language flashcard panel ───────────────────── -->
      <div id="mem-ol-panel" class="mem-panel" role="tabpanel" aria-labelledby="mem-ol-tab" hidden="">

        <!-- Deck list view -->
        <div id="ol-list-view">
          <div class="mem-ol-header">
            <p id="ol-deck-info" class="mem-ol-info"></p>
            <div class="mem-ol-controls">
              <select id="ol-lang-filter" class="mem-mode-select" aria-label="Language filter">
                <option value="all">All languages</option>
                <option value="greek">Greek only</option>
                <option value="hebrew">Hebrew only</option>
              </select>
              <button id="ol-review-btn" class="mem-add-btn" type="button" disabled="">Review Due</button>
            </div>
          </div>
          <div id="ol-word-list" class="mem-ol-list"></div>
          <div id="ol-empty" class="bsw-empty-state" hidden="">
            <span class="bsw-empty-state__glyph" aria-hidden="true">α</span>
            <p class="bsw-empty-state__title">No words in your deck yet</p>
            <p class="bsw-empty-state__desc">Study a passage in the Original Language Study tool, then click ☆ on any word to add it here.</p>
            <a class="bsw-empty-state__cta" href="../translation/workshop/">Open Original Language Study</a>
          </div>
        </div>

        <!-- Flashcard review view (hidden until started) -->
        <div id="ol-review-view" hidden="">
          <div id="ol-review-progress" class="mem-progress"></div>
          <div class="mem-card" id="ol-card">
            <div id="ol-front" class="mem-card__front mem-ol-card__front"></div>
            <div id="ol-back" class="mem-card__back  mem-ol-card__back" hidden=""></div>
            <div id="ol-actions" class="mem-card__actions" hidden="">
              <button class="mem-rate-btn mem-rate-btn--again" data-rating="again">Again<br><small>1 day</small></button>
              <button class="mem-rate-btn mem-rate-btn--hard" data-rating="hard">Hard<br><small>3 days</small></button>
              <button class="mem-rate-btn mem-rate-btn--good" data-rating="good">Good<br><small>7 days</small></button>
              <button class="mem-rate-btn mem-rate-btn--easy" data-rating="easy">Easy<br><small>21 days</small></button>
            </div>
          </div>
          <div id="ol-done" class="mem-review-done" hidden="">
            <p>All caught up! Your Greek and Hebrew vocabulary is reviewed for today.</p>
            <p style="font-size:.85rem;margin-bottom:1rem">
              <a href="../translation/workshop/" style="color:var(--color-primary);font-weight:500">Study more passages to discover new words →</a>
            </p>
            <button id="ol-back-btn" class="mem-back-btn" type="button">Back to Deck</button>
          </div>
        </div>

      </div>
    </div>

    <!-- ══════════════════════════ JOURNAL PANEL ════════════════════════════ -->
    <div id="disc-journal" class="disc-panel disc-body" role="tabpanel" aria-labelledby="disc-tab-journal" hidden="">
      <div class="journal-tabs" role="tablist" aria-label="Journal sections">
        <button class="journal-tab journal-tab--active" data-jtab="prayers" role="tab" aria-selected="true" id="journal-tab-prayers" aria-controls="journal-prayers-panel">🙏 Prayers</button>
        <button class="journal-tab" data-jtab="reflections" role="tab" aria-selected="false" id="journal-tab-reflections" aria-controls="journal-reflections-panel">📓 Reflections</button>
        <button class="journal-tab" data-jtab="gratitude" role="tab" aria-selected="false" id="journal-tab-gratitude" aria-controls="journal-gratitude-panel">🌿 Gratitude</button>
      </div>
      <!-- Prayers panel -->
      <div id="journal-prayers-panel" role="tabpanel" aria-labelledby="journal-tab-prayers">
        <div class="journal-bar">
          <button class="journal-btn journal-btn--primary" id="journal-new-btn" type="button">+ New Prayer</button>
          <div class="journal-status-filters" role="group" aria-label="Filter by prayer status">
            <button class="journal-status-btn journal-status-btn--active" data-status="all" type="button">All</button>
            <button class="journal-status-btn" data-status="open" type="button">Open</button>
            <button class="journal-status-btn" data-status="answered" type="button">✓ Answered</button>
          </div>
          <input class="journal-search" type="search" id="journal-search" placeholder="Search prayers…" aria-label="Search prayers">
          <span class="journal-count" id="journal-count"></span>
        </div>
        <div id="journal-tag-filters" class="journal-tag-filters"></div>
        <div id="journal-form-container"></div>
        <div id="journal-list"></div>
        <div class="journal-export-row" id="journal-export-row" hidden="">
          <button class="journal-btn" id="journal-export-btn" type="button">Export JSON</button>
          <button class="journal-btn" id="journal-import-btn" type="button">Import backup</button>
          <input type="file" id="journal-import-file" accept=".json" style="display:none">
        </div>
      </div>
      <!-- Reflections panel -->
      <div id="journal-reflections-panel" role="tabpanel" aria-labelledby="journal-tab-reflections" hidden="">
        <div class="journal-bar">
          <button class="journal-btn journal-btn--primary" id="refl-new-btn" type="button">+ New Reflection</button>
          <input class="journal-search" type="search" id="refl-search" placeholder="Search reflections…" aria-label="Search reflections">
          <span class="journal-count" id="refl-count"></span>
        </div>
        <div id="refl-tag-filters" class="journal-tag-filters"></div>
        <div id="refl-form-container"></div>
        <div id="refl-list"></div>
      </div>
      <!-- Gratitude panel -->
      <div id="journal-gratitude-panel" role="tabpanel" aria-labelledby="journal-tab-gratitude" hidden="">
        <p class="grat-prompt">What are you grateful for today?</p>
        <div class="grat-bar">
          <button class="journal-btn journal-btn--primary" id="grat-new-btn" type="button">+ New Entry</button>
          <input class="journal-search" type="search" id="grat-search" placeholder="Search entries…" aria-label="Search gratitude entries">
          <span class="journal-count" id="grat-count"></span>
        </div>
        <div id="grat-form-container"></div>
        <div id="grat-list"></div>
        <div class="journal-export-row" id="grat-export-row" hidden="">
          <button class="journal-btn" id="grat-export-btn" type="button">Export JSON</button>
          <button class="journal-btn" id="grat-import-btn" type="button">Import backup</button>
          <input type="file" id="grat-import-file" accept=".json" style="display:none">
        </div>
      </div>
    </div>

    <!-- ══════════════════════════ WORSHIP PANEL ════════════════════════════ -->
    <div id="disc-worship" class="disc-panel disc-body" role="tabpanel" aria-labelledby="disc-tab-worship" hidden="">
      <div class="worship-tabs" role="tablist" aria-label="Worship sections">
        <button class="worship-tab worship-tab--active" data-wtab="sermons" role="tab" aria-selected="true" id="worship-tab-sermons" aria-controls="worship-sermons-panel">Sermon Notes</button>
        <button class="worship-tab" data-wtab="fasting" role="tab" aria-selected="false" id="worship-tab-fasting" aria-controls="worship-fasting-panel">Fasting Log</button>
      </div>
      <div id="worship-sermons-panel" role="tabpanel" aria-labelledby="worship-tab-sermons">
        <div class="worship-bar">
          <button class="worship-btn worship-btn--primary" id="worship-new-btn" type="button">+ New Entry</button>
          <input class="worship-search" type="search" id="worship-search" placeholder="Search sermons…" aria-label="Search sermon notes">
          <span class="worship-count" id="worship-count"></span>
        </div>
        <div id="worship-form-container"></div>
        <div id="worship-list"></div>
      </div>
      <div id="worship-fasting-panel" role="tabpanel" aria-labelledby="worship-tab-fasting" hidden="">
        <div class="worship-bar">
          <button class="worship-btn worship-btn--primary" id="fast-new-btn" type="button">+ Log Fast</button>
          <span class="worship-count" id="fast-count"></span>
        </div>
        <div id="fast-form-container"></div>
        <div id="fast-list"></div>
      </div>
    </div>

    <!-- ══════════════════════════ NOTES PANEL ══════════════════════════════ -->
    <div id="disc-notes" class="disc-panel" hidden="">
      <iframe id="disc-notes-iframe" class="disc-embed-frame" data-src="../notes/?minimal=1" src="" style="display:none" title="My Notes"></iframe>
    </div>

    <!-- ══════════════════════════ PROGRESS PANEL ═══════════════════════════ -->
    <div id="disc-progress" class="disc-panel" hidden="">
      <iframe id="disc-progress-iframe" class="disc-embed-frame" data-src="../progress/?minimal=1" src="" style="display:none" title="Reading Progress"></iframe>
    </div>

    <!-- ══════════════════════════ HISTORY PANEL ════════════════════════════ -->
    <div id="disc-history" class="disc-panel" hidden="">
      <iframe id="disc-history-iframe" class="disc-embed-frame" data-src="../tracker/?minimal=1" src="" style="display:none" title="Discipline History"></iframe>
    </div>

  </main>
<Fragment slot="after-scripts">
<!-- Status dots + devotional/memory tracker wiring --><script type="module" is:inline="">
  import { getToday, markDone, isDone, onUpdate } from '../assets/js/tracker.js';

  var DOT_COLORS = {
    reading:    '#5c3d1e',
    devotional: '#e67e22',
    memory:     '#2980b9',
    prayer:     '#8e44ad',
    reflection: '#16a085',
    worship:    '#4caf50',
  };
  // Tab → primary discipline key for that tab's dot
  var TAB_KEYS = { plans: 'reading', devotionals: 'devotional', memory: 'memory', journal: 'prayer', worship: 'worship' };

  function updateDots() {
    var status = getToday();
    Object.entries(TAB_KEYS).forEach(function (pair) {
      var tab = pair[0], key = pair[1];
      var el = document.getElementById('dot-' + key);
      if (!el) return;
      var done = !!status[key];
      el.style.background = done ? DOT_COLORS[key] : 'var(--color-border)';
      el.title = key.charAt(0).toUpperCase() + key.slice(1) + (done ? ' ✓' : ' ○');
    });
  }

  function updateStrip() {
    var strip = document.getElementById('disc-today-strip');
    if (!strip) return;
    var status = getToday();
    var keys = ['reading', 'devotional', 'memory', 'prayer', 'worship', 'gratitude'];
    var done = keys.filter(function (k) { return !!status[k]; }).length;
    if (done === 0) { strip.style.display = 'none'; return; }
    strip.style.display = '';
    var dotsHtml = keys.map(function (k) {
      var color = !!status[k] ? (DOT_COLORS[k] || '#16a085') : 'var(--color-border)';
      return '<span class="disc-dot disc-dot--strip" style="background:' + color + '" title="' + k + (status[k] ? ' ✓' : '') + '"></span>';
    }).join('');
    strip.innerHTML = '<span class="disc-strip-label">Today: ' + done + ' / ' + keys.length + ' complete</span>' + dotsHtml;
  }

  updateDots();
  updateStrip();
  onUpdate(function () { updateDots(); updateStrip(); });
  window.addEventListener('storage', function (e) {
    var keys = ['bsw_tracker','bsw_plans','bsw_journal','bsw_reflections','bsw_worship','bsw_gratitude'];
    if (keys.indexOf(e.key) !== -1) { updateDots(); updateStrip(); }
  });

  // ── Devotional tracker ──────────────────────────────────────────────────
  var _today = (function () {
    var d = new Date();
    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
  }());

  function _isToday() { var inp = document.getElementById('devot-date-input'); return inp && inp.value === _today; }

  function _syncDevotUI() {
    var row = document.getElementById('devot-complete-row');
    var markBtn = document.getElementById('devot-mark-btn');
    var doneMsg = document.getElementById('devot-done-msg');
    var body    = document.getElementById('devot-body');
    if (!row || !body) return;
    var todayShowing = _isToday() && !body.hidden;
    row.hidden = !todayShowing;
    if (!todayShowing) return;
    var alreadyDone = isDone('devotional');
    markBtn.hidden = alreadyDone;
    doneMsg.hidden = !alreadyDone;
    if (!alreadyDone) { markDone('devotional'); markBtn.hidden = true; doneMsg.hidden = false; updateDots(); }
  }

  document.getElementById('devot-mark-btn').addEventListener('click', function () {
    markDone('devotional');
    document.getElementById('devot-mark-btn').hidden = true;
    document.getElementById('devot-done-msg').hidden = false;
    updateDots();
  });

  var bodyEl = document.getElementById('devot-body');
  if (bodyEl && typeof MutationObserver !== 'undefined') {
    new MutationObserver(_syncDevotUI).observe(bodyEl, { attributes: true, attributeFilter: ['hidden'] });
  }

  // ── Memory tracker ──────────────────────────────────────────────────────
  var doneEl = document.getElementById('mem-review-done');
  if (doneEl && typeof MutationObserver !== 'undefined') {
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.type === 'attributes' && m.attributeName === 'hidden' && !doneEl.hidden) {
          if (!isDone('memory')) { markDone('memory'); updateDots(); }
        }
      });
    }).observe(doneEl, { attributes: true, attributeFilter: ['hidden'] });
  }
  </script><!-- ════════════════ Tab switching + all content IIFEs ════════════════ --><script is:inline="">
  (function () {
    'use strict';

    /* ── Tab routing ──────────────────────────────────────────────────────── */
    var _inited = {};

    function activateTab(tab, skipHistory) {
      document.querySelectorAll('.disc-panel').forEach(function (p) { p.hidden = true; });
      var panel = document.getElementById('disc-' + tab);
      if (panel) panel.hidden = false;

      // Update tab button active states
      document.querySelectorAll('.disc-tab[data-tab]').forEach(function (btn) {
        var isThis = btn.getAttribute('data-tab') === tab;
        btn.classList.toggle('disc-tab--active', isThis);
        btn.setAttribute('aria-selected', isThis ? 'true' : 'false');
      });

      // Update "More" button label when a More-menu tab is active
      var moreBtn = document.getElementById('disc-more-btn');
      var moreTabs = ['notes', 'progress', 'history'];
      var moreLabels = { notes: '📝 My Notes ▾', progress: '📊 Progress ▾', history: '📅 History ▾' };
      if (moreBtn) {
        if (moreTabs.indexOf(tab) !== -1) {
          moreBtn.textContent = moreLabels[tab] || 'More ▾';
          moreBtn.classList.add('disc-tab--active');
        } else {
          moreBtn.textContent = 'More ▾';
          moreBtn.classList.remove('disc-tab--active');
        }
      }

      // Lazy-load iframe panels
      if (tab === 'notes' || tab === 'progress' || tab === 'history') {
        var iframe = document.getElementById('disc-' + tab + '-iframe');
        if (iframe) {
          iframe.style.display = 'block';
          /* Shared lazy-reveal (defined in main.js); src="" attr is falsy so it sets once. */
          window.bswRevealFrame(iframe);
        }
      }

      if (!skipHistory) {
        var qs = '?tab=' + tab;
        var jtab = new URLSearchParams(location.search).get('jtab');
        if (tab === 'journal' && jtab) qs += '&jtab=' + jtab;
        var wtab = new URLSearchParams(location.search).get('wtab');
        if (tab === 'worship' && wtab) qs += '&wtab=' + wtab;
        history.replaceState(null, '', qs);
        localStorage.setItem('bsw_discipline_tab', tab);
      }

      if (!_inited[tab]) {
        _inited[tab] = true;
        if (tab === 'plans')       initPlans();
        if (tab === 'devotionals') initDevotionals();
        if (tab === 'journal')     initJournal();
        if (tab === 'worship')     initWorship();
        // memory: app.js calls initMemorizePage() automatically via #mem-list
      }
    }

    document.querySelectorAll('.disc-tab[data-tab]').forEach(function (btn) {
      btn.addEventListener('click', function () { activateTab(btn.getAttribute('data-tab')); });
    });

    // ── More ▾ dropdown ─────────────────────────────────────────────────────
    var _moreMenu = document.getElementById('disc-more-menu');
    var _moreBtn  = document.getElementById('disc-more-btn');

    if (_moreBtn && _moreMenu) {
      _moreBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = !_moreMenu.hidden;
        _moreMenu.hidden = open;
        _moreBtn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
      _moreMenu.querySelectorAll('.disc-more-item').forEach(function (item) {
        item.addEventListener('click', function () {
          _moreMenu.hidden = true;
          _moreBtn.setAttribute('aria-expanded', 'false');
          activateTab(item.getAttribute('data-tab'));
        });
      });
      document.addEventListener('click', function (e) {
        if (!e.target.closest('#disc-more-btn, #disc-more-menu')) {
          _moreMenu.hidden = true;
          _moreBtn.setAttribute('aria-expanded', 'false');
        }
      });
      _moreMenu.addEventListener('keydown', function (e) {
        var items = Array.from(_moreMenu.querySelectorAll('.disc-more-item'));
        var idx   = items.indexOf(document.activeElement);
        if (e.key === 'Escape') {
          _moreMenu.hidden = true;
          _moreBtn.setAttribute('aria-expanded', 'false');
          _moreBtn.focus();
          e.preventDefault();
        } else if (e.key === 'ArrowDown') {
          items[(idx + 1) % items.length].focus();
          e.preventDefault();
        } else if (e.key === 'ArrowUp') {
          items[(idx - 1 + items.length) % items.length].focus();
          e.preventDefault();
        } else if (e.key === 'Home') {
          items[0].focus();
          e.preventDefault();
        } else if (e.key === 'End') {
          items[items.length - 1].focus();
          e.preventDefault();
        }
      });
    }

    /* handle URL on load — see deferred activation at the end of the IIFE.
       NOTE: the initial activateTab() call must run AFTER every tab's vars
       (PLAN_IDS, DEVOT_BASE, …) and init functions are defined below, since
       activateTab immediately calls the active tab's init*(). Calling it here
       (before those `var`s are assigned) threw "PLAN_IDS is undefined" and
       aborted the rest of the IIFE, breaking most tabs. */
    var params  = new URLSearchParams(location.search);
    var initTab = params.get('tab') || localStorage.getItem('bsw_discipline_tab') || 'plans';

    /* ══════════════════════════ PLANS ══════════════════════════════════════ */
    var PLANS_KEY  = 'bsw_plans';
    var PLANS_ROOT = '../data/plans';
    var READ_URL   = '../read/';
    var PLAN_IDS   = ['bible-in-a-year','bible-in-a-year-chronological','mcheyne','nt-90-days','psalms-proverbs','gospels-30-days','heidelberg-weekly','wsc-quarterly'];

    function getState()   { try { return JSON.parse(localStorage.getItem(PLANS_KEY)||'{}'); } catch(e) { return {}; } }
    function saveState(s) { localStorage.setItem(PLANS_KEY, JSON.stringify(s)); }
    function todayStr()   { return new Date().toISOString().slice(0,10); }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function dayNum(state) {
      if (!state||!state.startDate) return 1;
      var start=new Date(state.startDate+'T00:00:00'), today=new Date();
      today=new Date(today.getFullYear(),today.getMonth(),today.getDate());
      return Math.floor((today-start)/86400000)+1;
    }
    function passageUrl(p) { return READ_URL+'?ref='+encodeURIComponent(p); }

    function renderAllPlans(planDataList) {
      var state=getState(), listEl=document.getElementById('plans-list');
      listEl.innerHTML='';
      planDataList.forEach(function(plan){ listEl.appendChild(renderPlanCard(plan,state[plan.id])); });
    }

    function renderPlanCard(plan,enrollment) {
      var enrolled=!!(enrollment&&enrollment.startDate);
      var card=document.createElement('div');
      card.className='plan-card'+(enrolled?' plan-card--enrolled':'');
      card.dataset.planId=plan.id;
      var top=document.createElement('div'); top.className='plan-card__top';
      var info=document.createElement('div'); info.className='plan-card__info';
      info.innerHTML='<div class="plan-card__title">'+esc(plan.title)+'</div><div class="plan-card__meta">'+plan.total_days+' days</div><div class="plan-card__desc">'+esc(plan.description)+'</div>';
      var actions=document.createElement('div'); actions.className='plan-card__actions';
      if (!enrolled) {
        var sb=document.createElement('button'); sb.className='plan-btn plan-btn--primary'; sb.textContent='Start Plan';
        sb.addEventListener('click',function(){ enrollPlan(plan); }); actions.appendChild(sb);
      } else {
        var db=document.createElement('button'); db.className='plan-btn plan-btn--danger'; db.textContent='Unenroll';
        db.addEventListener('click',function(){ unenrollPlan(plan.id); }); actions.appendChild(db);
      }
      top.appendChild(info); top.appendChild(actions); card.appendChild(top);
      if (enrolled) card.appendChild(renderTodaySection(plan,enrollment));
      var det=document.createElement('div'); det.className='plan-detail';
      var tog=document.createElement('button'); tog.className='plan-detail-toggle';
      tog.textContent=enrolled?'View full schedule ▾':'Preview schedule ▾';
      var cal=document.createElement('div'); cal.className='plan-calendar';
      tog.addEventListener('click',function(){
        var open=cal.classList.toggle('plan-calendar--open');
        tog.textContent=open?(enrolled?'Hide schedule ▴':'Hide preview ▴'):(enrolled?'View full schedule ▾':'Preview schedule ▾');
        if (open&&!cal.dataset.built){buildCalendar(cal,plan,enrollment);cal.dataset.built='1';}
      });
      det.appendChild(tog); det.appendChild(cal); card.appendChild(det);
      return card;
    }

    function renderTodaySection(plan,enrollment) {
      var div=document.createElement('div'); div.className='plan-today';
      var dn=dayNum(enrollment);
      if (dn<1||dn>plan.total_days){
        div.innerHTML='<div class="plan-today__label">Plan complete!</div><p class="plan-today__complete-msg">You\'ve finished '+esc(plan.title)+'. 🎉</p>';
        return div;
      }
      var day=plan.days[dn-1], done=!!(enrollment.completed&&enrollment.completed[dn]);
      var daysCompleted=Object.keys(enrollment.completed||{}).length;
      var startDt=new Date(enrollment.startDate+'T00:00:00'), finishDt=new Date(startDt.getTime());
      finishDt.setDate(finishDt.getDate()+plan.total_days-1);
      var finishStr=finishDt.toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'});
      div.innerHTML='<div class="plan-today__label">Today\'s Reading — Day '+dn+' of '+plan.total_days+'</div>'+
        '<div class="plan-today__progress">'+progressBar(dn,plan.total_days)+' '+daysCompleted+' of '+plan.total_days+' days done &nbsp;·&nbsp; '+Math.round(dn/plan.total_days*100)+'% &nbsp;·&nbsp; Finish by '+finishStr+'</div>';
      var passDiv=document.createElement('div'); passDiv.className='plan-today__passages';
      if (day.passages&&day.passages.length) {
        day.passages.forEach(function(p){
          var a=document.createElement('a'); a.className='plan-today__passage'; a.href=passageUrl(p); a.textContent=p; passDiv.appendChild(a);
        });
      } else if (day.href) {
        var a=document.createElement('a'); a.className='plan-today__passage'; a.href='../'+day.href; a.textContent=day.label||('Day '+day.day); passDiv.appendChild(a);
        if (day.desc){var ds=document.createElement('span');ds.className='plan-today__desc';ds.textContent=day.desc;passDiv.appendChild(ds);}
      }
      div.appendChild(passDiv);
      var doneDiv=document.createElement('div'); doneDiv.className='plan-today__done';
      var markBtn=document.createElement('button');
      markBtn.className='plan-btn'+(done?' plan-today__mark plan-today__mark--done':' plan-today__mark');
      markBtn.textContent=done?'✓ Marked complete':'Mark day complete';
      markBtn.addEventListener('click',function(){
        var s=getState(); if(!s[plan.id])return; if(!s[plan.id].completed)s[plan.id].completed={};
        if(done){delete s[plan.id].completed[dn];done=false;markBtn.className='plan-today__mark';markBtn.textContent='Mark day complete';
          var oldCta=doneDiv.querySelector('.disc-cta-link');if(oldCta)oldCta.remove();}
        else{s[plan.id].completed[dn]=true;done=true;markBtn.className='plan-today__mark plan-today__mark--done';markBtn.textContent='✓ Marked complete';
          var cta=document.createElement('a');cta.className='disc-cta-link';cta.href='?tab=journal&jtab=reflections';cta.textContent='Write a reflection on today\'s reading →';doneDiv.appendChild(cta);}
        saveState(s);
      });
      doneDiv.appendChild(markBtn); div.appendChild(doneDiv);
      return div;
    }

    function buildCalendar(cal,plan,enrollment) {
      var today=dayNum(enrollment||{}),comp=(enrollment&&enrollment.completed)||{};
      var show=enrollment?plan.days:plan.days.slice(0,14);
      show.forEach(function(day){
        var dn=day.day,isToday=enrollment&&dn===today,isDone=!!comp[dn];
        var row=document.createElement('div');
        row.className='plan-calendar__row'+(isToday?' plan-calendar__row--today':'')+(isDone?' plan-calendar__row--done':'');
        var passText=day.passages?day.passages.join(', '):(day.label||('Day '+dn))+(day.desc?' — '+day.desc:'');
        row.innerHTML='<span class="plan-calendar__check">'+(isDone?'✓':'')+'</span>'+
          '<span class="plan-calendar__day">'+esc(day.label||('Day '+dn))+'</span>'+
          '<span class="plan-calendar__passages">'+esc(passText)+'</span>';
        cal.appendChild(row);
      });
      if (!enrollment&&plan.days.length>14){
        var more=document.createElement('p'); more.style.cssText='font-size:.78rem;color:var(--color-muted);margin-top:.4rem;';
        more.textContent='… and '+(plan.days.length-14)+' more days. Start the plan to see the full schedule.'; cal.appendChild(more);
      }
    }

    function progressBar(cur,total){
      var pct=Math.round(cur/total*100);
      return '<span style="display:inline-block;width:60px;height:6px;background:var(--color-border);border-radius:3px;vertical-align:middle;position:relative;">'+
        '<span style="display:block;height:100%;width:'+pct+'%;background:var(--color-primary);border-radius:3px;"></span></span>';
    }

    function enrollPlan(plan){var s=getState();s[plan.id]={startDate:todayStr(),completed:{}};saveState(s);loadAndRenderPlans();}
    function unenrollPlan(id){if(!confirm('Remove this reading plan and all progress?'))return;var s=getState();delete s[id];saveState(s);loadAndRenderPlans();}

    function loadAndRenderPlans() {
      var listEl=document.getElementById('plans-list');
      if (listEl) listEl.innerHTML='<p class="plans-loading">Loading…</p>';
      Promise.all(PLAN_IDS.map(function(id){
        return fetch(PLANS_ROOT+'/'+id+'.json').then(function(r){return r.ok?r.json():null;}).catch(function(){return null;});
      })).then(function(plans){
        var msg=document.getElementById('plans-list-msg');
        if (msg) msg.setAttribute('hidden','');
        renderAllPlans(plans.filter(Boolean));
      });
    }

    function initPlans() { loadAndRenderPlans(); }

    /* ══════════════════════════ DEVOTIONALS ════════════════════════════════ */
    var DEVOT_BASE = '../data/devotionals/';
    // Per-author/slot files + byline metadata. Mirrors DAILY_DEVOT_SOURCES in daily.js so
    // the Discipline tab and the home-page devotional offer the same sources. To add an
    // author: ship data/devotionals/<slug>.json and add an entry here.
    var DEVOT_AUTHORS = {
      'spurgeon-morning': { file:'spurgeon-morning.json', author:'Charles Spurgeon', work:'Morning by Morning' },
      'spurgeon-evening': { file:'spurgeon-evening.json', author:'Charles Spurgeon', work:'Evening by Evening' },
      'winslow-morning':  { file:'winslow-morning.json',  author:'Octavius Winslow', work:'Morning Thoughts' },
      'winslow-evening':  { file:'winslow-evening.json',  author:'Octavius Winslow', work:'Evening Thoughts' }
    };
    // "Variety" rotates to a different author per day, per slot (matches daily.js).
    var DEVOT_VARIETY = {
      morning: ['winslow-morning', 'spurgeon-morning'],
      evening: ['spurgeon-evening', 'winslow-evening']
    };
    // Dropdown collections. A `variety:true` collection rotates authors; otherwise `slug(p)`
    // maps a period to a DEVOT_AUTHORS key. `periods` drives the period tabs (hidden if <2).
    var DEVOT_COLLECTIONS = [
      { id:'variety',  label:'Variety (rotating authors)', periods:['morning','evening'], variety:true },
      { id:'spurgeon', label:'Spurgeon — Morning & Evening', periods:['morning','evening'],
        slug:function(p){ return 'spurgeon-'+p; } },
      { id:'winslow',  label:'Winslow — Morning & Evening', periods:['morning','evening'],
        slug:function(p){ return 'winslow-'+p; } }
    ];
    var PERIOD_LABELS = { morning:'Morning', evening:'Evening', daily:'Daily' };
    function periodLabel(p){ return PERIOD_LABELS[p] || (p ? p.charAt(0).toUpperCase()+p.slice(1) : ''); }

    var _devotCache={}, _devotDate=new Date(), _devotPeriod='morning', _devotColl='variety', _devotLoadToken=0;
    function currentColl(){
      for (var i=0;i<DEVOT_COLLECTIONS.length;i++) if (DEVOT_COLLECTIONS[i].id===_devotColl) return DEVOT_COLLECTIONS[i];
      return DEVOT_COLLECTIONS[0];
    }
    function dayOfYear(d){
      return Math.floor((d - new Date(d.getFullYear(),0,0)) / 86400000);
    }
    // Fetch one author's entry for a date key → {slug, meta, entry} or null (gap/missing).
    function devotFetchEntry(slug, key){
      var meta=DEVOT_AUTHORS[slug];
      if (!meta) return Promise.resolve(null);
      if (_devotCache[slug]) return Promise.resolve(_devotCache[slug][key] ? {slug:slug,meta:meta,entry:_devotCache[slug][key]} : null);
      return fetch(DEVOT_BASE+meta.file)
        .then(function(r){ return r.ok?r.json():null; })
        .then(function(data){ if(!data) return null; _devotCache[slug]=data; return data[key]?{slug:slug,meta:meta,entry:data[key]}:null; })
        .catch(function(){ return null; });
    }
    // Walk the variety rotation (wrapping) until an author has an entry for the day.
    function devotResolveVariety(period, key, doy){
      var pool=DEVOT_VARIETY[period]||[];
      if (!pool.length) return Promise.resolve(null);
      var start=(doy-1+pool.length)%pool.length, order=[];
      for (var i=0;i<pool.length;i++) order.push(pool[(start+i)%pool.length]);
      var idx=0;
      function tryNext(){ if(idx>=order.length) return null; return devotFetchEntry(order[idx++],key).then(function(r){ return r||tryNext(); }); }
      return Promise.resolve().then(tryNext);
    }

    function pad2(n){return n<10?'0'+n:''+n;}
    function dateToKey(d){return pad2(d.getMonth()+1)+'-'+pad2(d.getDate());}
    function dateToValue(d){return d.getFullYear()+'-'+pad2(d.getMonth()+1)+'-'+pad2(d.getDate());}
    function fmtDevotLabel(d,p){
      var mo=['January','February','March','April','May','June','July','August','September','October','November','December'];
      var dw=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      var base=dw[d.getDay()]+', '+mo[d.getMonth()]+' '+d.getDate();
      // Only append the period when the collection actually has more than one.
      return currentColl().periods.length>1 ? base+' — '+periodLabel(p) : base;
    }

    function devotShowLoading(){
      document.getElementById('devot-loading').hidden=false;
      document.getElementById('devot-body').hidden=true;
      document.getElementById('devot-empty').hidden=true;
    }
    function devotRender(entry,d,p,meta){
      if (!entry){
        document.getElementById('devot-loading').hidden=true;
        document.getElementById('devot-body').hidden=true;
        document.getElementById('devot-empty').hidden=false;
        return;
      }
      document.getElementById('devot-date-label').textContent=fmtDevotLabel(d,p);
      document.getElementById('devot-verse-text').textContent=entry.verse_text||'';
      var cite=document.getElementById('devot-verse-ref');
      cite.innerHTML=entry.verse_ref?'<a class="ref" data-ref="'+entry.verse_ref+'">'+entry.verse_ref+'</a>':'';
      var paras=(entry.body||'').split(/\n+/).filter(function(x){return x.trim();});
      document.getElementById('devot-text').innerHTML=paras.map(function(x){return '<p>'+x.trim()+'</p>';}).join('');
      // Author byline — shown when we know the source (always for variety/multi-author).
      var by=document.getElementById('devot-attribution');
      if (by){
        if (meta && meta.author){
          by.textContent='— '+meta.author+(meta.work?', '+meta.work:'');
          by.hidden=false;
        } else { by.hidden=true; }
      }
      document.getElementById('devot-loading').hidden=true;
      document.getElementById('devot-empty').hidden=true;
      document.getElementById('devot-body').hidden=false;
      if(window._bswWireRefs){window._bswWireRefs(document.getElementById('devot-text'));window._bswWireRefs(cite);}
    }
    function devotLoad(d,p){
      devotShowLoading();
      var coll=currentColl(), key=dateToKey(d);
      // Capture the request so a slow fetch from a previous selection can't overwrite a newer one.
      var token=(_devotLoadToken=(_devotLoadToken||0)+1);
      var resolved = coll.variety
        ? devotResolveVariety(p,key,dayOfYear(d))
        : devotFetchEntry(coll.slug(p),key);
      resolved.then(function(res){
        if (token!==_devotLoadToken) return;             // a newer load superseded this one
        devotRender(res&&res.entry||null, d, p, res&&res.meta);
      }).catch(function(){ if(token===_devotLoadToken) devotRender(null,d,p); });
    }
    function devotSetDate(d){_devotDate=d;document.getElementById('devot-date-input').value=dateToValue(d);devotLoad(_devotDate,_devotPeriod);}
    function devotSetPeriod(p){
      _devotPeriod=p;
      document.querySelectorAll('.devot-period-tab').forEach(function(btn){
        var isThis=btn.getAttribute('data-period')===p;
        btn.classList.toggle('is-active',isThis); btn.setAttribute('aria-selected',isThis?'true':'false');
      });
      devotLoad(_devotDate,_devotPeriod);
    }

    // Rebuild the period tabs to match the active collection; hidden when it has only one period.
    function renderPeriodTabs(){
      var coll=currentColl(), box=document.getElementById('devot-period-tabs');
      box.innerHTML='';
      if (coll.periods.length<2){ box.hidden=true; return; }
      box.hidden=false;
      coll.periods.forEach(function(p){
        var btn=document.createElement('button');
        btn.className='devot-period-tab'+(p===_devotPeriod?' is-active':'');
        btn.id='devot-tab-'+p;
        btn.setAttribute('data-period',p);
        btn.setAttribute('role','tab');
        btn.setAttribute('aria-selected',p===_devotPeriod?'true':'false');
        btn.setAttribute('aria-controls','devot-card');
        btn.textContent=periodLabel(p);
        btn.addEventListener('click',function(){ devotSetPeriod(p); localStorage.setItem('bsw_devot_period',p); });
        box.appendChild(btn);
      });
    }

    function devotSetCollection(id){
      var coll=null;
      for (var i=0;i<DEVOT_COLLECTIONS.length;i++) if (DEVOT_COLLECTIONS[i].id===id) coll=DEVOT_COLLECTIONS[i];
      if (!coll) coll=DEVOT_COLLECTIONS[0];
      _devotColl=coll.id;
      localStorage.setItem('bsw_devot_collection',_devotColl);
      // Keep the current period only if the new collection offers it.
      if (coll.periods.indexOf(_devotPeriod)===-1) _devotPeriod=coll.periods[0];
      renderPeriodTabs();
      devotLoad(_devotDate,_devotPeriod);
    }

    function initDevotionals(){
      document.getElementById('devot-prev').addEventListener('click',function(){var d=new Date(_devotDate);d.setDate(d.getDate()-1);devotSetDate(d);});
      document.getElementById('devot-next').addEventListener('click',function(){var d=new Date(_devotDate);d.setDate(d.getDate()+1);devotSetDate(d);});
      document.getElementById('devot-today').addEventListener('click',function(){devotSetDate(new Date());});
      document.getElementById('devot-date-input').addEventListener('change',function(){
        var parts=this.value.split('-');
        if(parts.length===3) devotSetDate(new Date(+parts[0],+parts[1]-1,+parts[2]));
      });

      // Populate the collection dropdown from the registry and restore the saved choice.
      var sel=document.getElementById('devot-collection');
      DEVOT_COLLECTIONS.forEach(function(c){
        var o=document.createElement('option'); o.value=c.id; o.textContent=c.label; sel.appendChild(o);
      });
      var savedColl=localStorage.getItem('bsw_devot_collection');
      if (savedColl && currentColl){
        for (var i=0;i<DEVOT_COLLECTIONS.length;i++) if (DEVOT_COLLECTIONS[i].id===savedColl) _devotColl=savedColl;
      }
      sel.value=_devotColl;
      sel.addEventListener('change',function(){ devotSetCollection(this.value); });

      // Restore the saved period if the active collection supports it, else default to its first.
      var savedPeriod=localStorage.getItem('bsw_devot_period');
      if (savedPeriod && currentColl().periods.indexOf(savedPeriod)!==-1) _devotPeriod=savedPeriod;
      else if (currentColl().periods.indexOf(_devotPeriod)===-1) _devotPeriod=currentColl().periods[0];

      renderPeriodTabs();
      devotSetDate(new Date());
    }

    /* ══════════════════════════ JOURNAL ════════════════════════════════════ */
    function initJournal() {
      // ── Journal sub-tab switching ──────────────────────────────────────
      var prayersPanel=document.getElementById('journal-prayers-panel');
      var reflPanel=document.getElementById('journal-reflections-panel');
      var gratPanel=document.getElementById('journal-gratitude-panel');
      var _gratInited=false;

      function switchJournalTab(tab) {
        prayersPanel.hidden=(tab!=='prayers');
        reflPanel.hidden=(tab!=='reflections');
        gratPanel.hidden=(tab!=='gratitude');
        document.querySelectorAll('[data-jtab]').forEach(function(btn){
          var isThis=btn.getAttribute('data-jtab')===tab;
          btn.classList.toggle('journal-tab--active',isThis);
          btn.setAttribute('aria-selected',isThis?'true':'false');
        });
        var qs='?tab=journal'; if(tab!=='prayers') qs+='&jtab='+tab;
        history.replaceState(null,'',qs);
        if (tab==='gratitude'&&!_gratInited){_gratInited=true;initGratitude();}
      }
      document.querySelectorAll('[data-jtab]').forEach(function(btn){
        btn.addEventListener('click',function(){switchJournalTab(btn.getAttribute('data-jtab'));});
