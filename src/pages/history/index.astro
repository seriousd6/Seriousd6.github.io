---
import Base from '../../layouts/Base.astro';
---

<Base title={"History — Kingdom Bible Study"} description={"Explore biblical and church history — timeline, church history, maps, and animated historical map."} footer={false}>
<Fragment slot="head-end">
<style is:inline="">
    /* ── History hub tab bar ─────────────────────────────────── */
    .hist-tabbar {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--color-surface);
      border-bottom: 2px solid var(--color-border);
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .hist-tabbar::-webkit-scrollbar { display: none; }

    @media (max-width: 1023px) {
      .hist-tabbar { top: var(--topbar-h, 48px); }
    }

    .hist-tab {
      display: flex;
      align-items: center;
      gap: .38rem;
      padding: .65rem 1.05rem;
      font-family: var(--font-ui);
      font-size: .85rem;
      font-weight: 500;
      color: var(--color-muted);
      border: none;
      background: none;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      white-space: nowrap;
      transition: color .15s;
    }
    .hist-tab:hover { color: var(--color-text); }
    .hist-tab--active {
      color: var(--color-primary);
      border-bottom-color: var(--color-primary);
    }

    /* ── Iframe panel ────────────────────────────────────────── */
    .hist-panel { display: none; }
    .hist-panel.hist-panel--active { display: block; }

    .hist-iframe {
      width: 100%;
      border: none;
      height: calc(100vh - 90px);
      display: block;
    }

    @media (max-width: 1023px) {
      .hist-iframe { height: calc(100vh - var(--topbar-h, 48px) - 48px); }
    }
  </style>
</Fragment>
<!-- ── Sticky tab bar ────────────────────────────────────────────────────── --><div class="hist-tabbar" role="tablist" aria-label="History tabs">
    <button class="hist-tab hist-tab--active" data-tab="timeline" role="tab" aria-selected="true">Biblical Timeline</button>
    <button class="hist-tab" data-tab="church" role="tab" aria-selected="false">Church History</button>
    <button class="hist-tab" data-tab="maps" role="tab" aria-selected="false">Maps</button>
    <button class="hist-tab" data-tab="timelapse" role="tab" aria-selected="false">Animated Map</button>
  </div><!-- ── Panels ────────────────────────────────────────────────────────────── --><div id="hist-timeline" class="hist-panel hist-panel--active">
    <iframe class="hist-iframe" data-src="../timeline/?minimal=1" title="Biblical Timeline"></iframe>
  </div><div id="hist-church" class="hist-panel">
    <iframe class="hist-iframe" data-src="../church-history/?minimal=1" title="Church History Timeline"></iframe>
  </div><div id="hist-maps" class="hist-panel">
    <iframe class="hist-iframe" data-src="../maps/?minimal=1" title="Biblical Maps"></iframe>
  </div><div id="hist-timelapse" class="hist-panel">
    <iframe class="hist-iframe" data-src="../maps/timelapse/?minimal=1" title="Biblical History Time-Lapse"></iframe>
  </div>
<Fragment slot="after-scripts">
<script is:inline="">
    (function () {
      'use strict';

      var _LSKey = 'bsw_history_tab';

      function activateTab(tab, skipUrlUpdate) {
        /* Update tab buttons */
        document.querySelectorAll('.hist-tab').forEach(function (btn) {
          var isThis = btn.getAttribute('data-tab') === tab;
          btn.classList.toggle('hist-tab--active', isThis);
          btn.setAttribute('aria-selected', isThis ? 'true' : 'false');
        });

        /* Show/hide panels; lazy-load iframe src on first activation */
        document.querySelectorAll('.hist-panel').forEach(function (panel) {
          var panelTab = panel.id.replace('hist-', '');
          var isThis   = panelTab === tab;
          panel.classList.toggle('hist-panel--active', isThis);

          if (isThis) {
            var iframe = panel.querySelector('iframe');
            /* Shared lazy-reveal (defined in main.js); true the first time it sets src */
            if (window.bswRevealFrame(iframe)) {
              // INTENT: Show a friendly message if the sub-page can't load (offline, broken URL)
              //   so the user doesn't see a blank frame with no explanation.
              // CHANGE? If panel structure changes from a single iframe to something else,
              //   this fallback must move to the new container element.
              // VERIFY: In DevTools → Network → Offline, click each History tab; each panel
              //   should show "Could not load this view…" rather than a blank white frame.
              iframe.addEventListener('error', function () {
                panel.innerHTML = '<p style="padding:2rem;color:var(--color-muted)">Could not load this view. Check your connection.</p>';
              }, { once: true });
              /* After timelapse loads, dispatch resize so Leaflet sizes correctly */
              if (tab === 'timelapse') {
                iframe.addEventListener('load', function () {
                  try { iframe.contentWindow.dispatchEvent(new Event('resize')); } catch (e) {}
                }, { once: true });
              }
            }
          }
        });

        if (!skipUrlUpdate) {
          history.replaceState(null, '', '?tab=' + tab);
          try { localStorage.setItem(_LSKey, tab); } catch (e) {}
        }
      }

      /* Wire tab clicks */
      document.querySelectorAll('.hist-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
          activateTab(btn.getAttribute('data-tab'));
        });
      });

      /* Restore state: ?tab= param > localStorage > default 'timeline' */
      var params  = new URLSearchParams(location.search);
      var initTab = params.get('tab') || (function () {
        try { return localStorage.getItem(_LSKey); } catch (e) { return null; }
      }()) || 'timeline';

      activateTab(initTab, true);
    }());
  </script>
</Fragment>
</Base>
