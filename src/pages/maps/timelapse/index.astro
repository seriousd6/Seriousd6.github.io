---
import Base from '../../../layouts/Base.astro';
---

<Base title={"Biblical History Time-Lapse — Kingdom Bible Study"} description={"Watch the rise and fall of empires, the journeys of the patriarchs and apostles, and the unfolding of God's redemptive plan across 2,000 years of history."} mainJs={false} appJs={false} footer={false}>
<Fragment slot="head-pre-css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H" crossorigin="">
</Fragment>
<Fragment slot="head-end">
<link rel="stylesheet" href="../../assets/css/timelapse.css?v=2">
</Fragment>
<main class="tl-main">
    <div class="container tl-page">

      <div class="tl-header">
        <div class="tl-header-text">
          <h1 class="tl-page-title">Biblical History Time-Lapse</h1>
          <p class="tl-page-sub">Empires rise and fall · Patriarchs journey · God's plan unfolds</p>
        </div>
        <div style="display:flex;gap:.75rem;align-items:center">
          <a class="hist-back-link" href="../../history/?tab=timelapse" id="hist-back-link" hidden="">← History</a>
          <a class="tl-maps-link" href="../" title="Back to Maps">← All Maps</a>
        </div>
      </div>

      <!-- Main content: event-list | map | info panel -->
      <div class="tl-body">

        <div class="tl-event-col">
          <div class="tl-event-col-header">Events</div>
          <input class="tl-event-search" id="tl-event-search" type="search" placeholder="Filter…" autocomplete="off">
          <div class="tl-event-list" id="tl-event-list"></div>
        </div>

        <div class="tl-map-wrapper">
          <div id="tl-map" class="tl-map-container"></div>
          <button class="tl-events-toggle" id="tl-events-toggle" aria-label="Toggle event list" title="Events">☰ Events</button>
        </div>

        <div class="tl-info-panel">
          <div class="tl-info-year" id="tl-info-year"></div>
          <div id="tl-info-content">
            <div class="tl-info-era" id="tl-info-era"></div>
            <h2 class="tl-info-label" id="tl-info-label"></h2>
            <p class="tl-info-desc" id="tl-info-desc"></p>
            <div class="tl-ref-chips" id="tl-info-refs"></div>
          <a id="tl-map-link" class="tl-map-link" href="#" hidden="">Detailed map →</a>
          </div>

          <div class="tl-figures" id="tl-figures"></div>

          <div class="tl-empire-list" id="tl-empire-list"></div>
        </div>

      </div>

      <!-- Slider controls -->
      <div class="tl-controls">
        <button class="tl-btn-play" id="tl-play" aria-label="Play / Pause" title="Play">▶</button>
        <button class="tl-btn-step tl-btn-step--active" id="tl-step-toggle" title="Step mode: auto-pause at each event" aria-pressed="true">Step</button>
        <button class="tl-btn-continue" id="tl-continue" title="Continue to next event" hidden="">Continue ▶</button>

        <div class="tl-slider-track">
          <input type="range" class="tl-slider" id="tl-slider" min="0" step="1" value="0" aria-label="Timeline position">
          <div class="tl-tick-row" id="tl-ticks"></div>
        </div>

        <select class="tl-speed" id="tl-speed" aria-label="Playback speed">
          <option value="slow">Slow</option>
          <option value="normal" selected="">Normal</option>
          <option value="fast">Fast</option>
        </select>
      </div>

    </div>
  </main><script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH" crossorigin="" is:inline=""></script><script src="../../assets/js/main.js?v=2" is:inline=""></script><script type="module" src="../../assets/js/entries/timelapse.js" is:inline=""></script>
</Base>
