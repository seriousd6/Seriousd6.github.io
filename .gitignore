# OS
.DS_Store
Thumbs.db

# Editor
*.sublime-workspace
.sublime/
*.swp
*~

# Build artifacts
/dist/
/node_modules/
npm-debug.log*

# Python bytecode (one-off generation scripts produce these; never commit them)
__pycache__/
*.pyc

# Local dev
local-notes.md

# Cloud of Witnesses / Catena raw source HTML caches (large, re-downloadable;
# the committed intermediates in data/commentary/cow-sources/ are what cow-merge needs)
working/catena-src/

# ── Build / generation apparatus — NOT part of the deployed site ──────────────
# Excluded so the published site stays lean (HTML/CSS/JS + data/ + assets only) and so the
# copy-to-deployment step can use this file as its exclude-list. These live on disk but are
# untracked. (Inline trailing comments are NOT allowed in .gitignore — keep patterns bare.)
#   working/ = agent prompts, guides, progress trackers, todos, loop-archive
#   scripts/ = build + one-off generation scripts (Python/shell)
#   *.py     = any Python anywhere is build-time tooling, never runtime
# Exception: the data/library/synthesis VALIDATORS are tracked so the CI workflow
#   (.github/workflows/validate.yml) can run them on a fresh checkout (AUD-28).
working/
scripts/*
*.py
!scripts/validate-data.py
!scripts/validate-library-format.py
!scripts/validate-synthesis.py

# Agent workflow files (prompts, guides, progress trackers — not part of the site)
/MKT_*.md
/Z_*.md
/TRANSLATION_AGENT_GUIDE.md

# Extra resources (local reference material, not part of the site)
Z-ExtraResources/

# Claude Code config (local settings, memory, worktrees — not part of the site)
.claude/
memory/

# PowerShell scripts (local utilities, not part of the site)
*.ps1

# Secrets / credentials
.env*
*.pem
*.key
*.p12
*.pfx
secrets.*
credentials.*
*.secret
working/devotionals-raw/
